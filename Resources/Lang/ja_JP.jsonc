  "TMG.Setting.PlayersCanSeeOthersPoints": "プレイヤーは他人のポイントを確認できる",
  "TMG.Setting.SuperPointsToNormalPointsMultiplier": "スーパーポイントの 通常の乗数",
  "TMG.Setting.TimeForEachPickInRound1": "ラウンド 1 で それぞれを選ぶための 時間",
  "TMG.Setting.TimeForEachPickInRound2": "ラウンド 2 で それぞれを選ぶための 時間",
  "TMG.Setting.TimeForEachPickInRound3": "ラウンド 3 で それぞれを選ぶための 時間",
  "TMG.Setting.TimeForItemPurchasingInRound2": "ラウンド 2 で アイテムを購入するための 時間",
  "TMG.Suffix.AuctionValue": "オークション値: {0} スーパーポイント",
  "TMG.Suffix.BuyItemHint": "<size=80%>アイテムを購入するには、「b」 そして それからアイテムの ID を入力しましょう。 例えば、「b0」で 最初のアイテムを購入します。</size>",
  "TMG.Suffix.ChangeBidHint": "<size=80%>入札額を変更するには 消える</size>",
  "TMG.Suffix.ChangePickHint": "<size=80%>選択を変更するには 消える</size>",
