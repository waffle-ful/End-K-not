  // Command Access
  "CommandList": "★ コマンドリスト:",
  "Commands.ChangeSettingHelp": "<b><u>引数:</u></b><size=70%>\\n- map(マップ) (<#66a186>theskeld</color>/<#e84b56>mirahq</color>/<#a167c0>polus</color>/<#66a186>dlekseht</color>/<#ed0007>airship</color>/<#ffa646>thefungle</color>/custom)\\n- <#ff1919>impostors(インポスター数)</color> (数字)\\n- players(プレイヤー数) (数字)\\n- recommended(推奨設定) (on/off)\\n- confirmejects(追放確認) (on/off)\\n- emergencymeetings(緊急会議) (数字)\\n- anonymousvotes(匿名投票) (on/off)\\n- emergencycooldown(緊急会議のクールダウン) (数字)\\n- discussiontime(会議時間) (数字)\\n- votingtime(投票タイム) (数字)\\n- playerspeed(プレイヤーの速度) (float)\\n- <#8cffff>crewmatevision(クルーメイト ビジョン)</color> (float)\\n- <#ff1919>impostorvision(インポスター ビジョン)</color> (float)\\n- killcooldown(キルのクールダウン) (float)\\n- killdistance(キルの可能距離) (short/medium/long/custom)\\n- taskbarupdates(タスクバーのアップデート) (always(いつでも)/meetings(会議毎)/never(しない))\\n- visualtasks(視認タスク) (on/off)\\n- commontasks(通常タスク) (数字)\\n- longtasks(ロングタスク) (数字)\\n- shorttasks(ショートタスク) (数字)\\n- <#8cffff>scientistcount(科学者の数)</color> (数字)\\n- <#8cffff>scientistchance(科学者の確率)</color> (数字)\\n- <#8cffff>vitalsdisplaycooldown(バイタル画面のクールダウン)</color> (float)\\n- <#8cffff>batteryduration(バッテリーの持続時間)</color> (float)\\n- <#8cffff>engineercount(エンジニアの数)</color> (数字)\\n- <#8cffff>engineerchance(エンジニアの確率)</color> (数字)\\n- <#8cffff>ventusecooldown(通気口の使用のクールダウン)</color> (float)\\n- <#8cffff>maxtimeinvents(通気口内の最大時間)</color> (float)\\n- <#8cffff>guardianangelcount(守護天使の数)</color> (数字)\\n- <#8cffff>guardianangelchance(守護天使の確率)</color> (数字)\\n- <#8cffff>protectcooldown(保護のクールダウン)</color> (float)\\n- <#8cffff>protectduration(保護の継続時間)</color> (float)\\n- <#8cffff>protectvisibletoimpostors(保護は <#ff1919>インポスター</color>からも見える)</color> (on/off)\\n- <#ff1919>shapeshiftercount(シェイプシフターの数)</color> (数字)\\n- <#ff1919>shapeshifterchance(シェイプシフターの確率)</color> (数字)\\n- <#ff1919>shapeshiftduration(変身の持続時間)</color> (float)\\n- <#ff1919>shapeshiftcooldown(変身のクールダウン)</color> (float)\\n- <#ff1919>leaveshapeshiftevidence(変身の痕を残す)</color> (on/off)\\n- <#ff1919>phantomcount(亡霊の数)</color> (数字)\\n- <#ff1919>phantomchance(亡霊の確率)</color> (数字)\\n- <#ff1919>inviscooldown(消える クールダウン)</color> (float)\\n- <#ff1919>invisduration(消える 長さ)</color> (float)\\n- <#8cffff>noisemakercount(ノイズメーカーの数)</color> (数字)\\n- <#8cffff>noisemakerchance(ノイズメーカーの確率)</color> (数字)\\n- <#8cffff>noisemakerimpostoralert(<#ff1919>インポスター</color>にも警告する)</color> (on/off)\\n- <#8cffff>noisemakeralertduration(警告の長さ)</color> (数字)\\n- <#8cffff>trackercount(トラッカーの数)</color> (数字)\\n- <#8cffff>trackerchance(トラッカーの確率)</color> (数字)\\n- <#8cffff>trackduration(追跡の持続時間)</color> (float)\\n- <#8cffff>trackcooldown(追跡のクールダウン)</color> (float)\\n- <#8cffff>trackdelay(追跡の遅れ)</color> (float)\\n- ghostdotasks(幽霊のタスク) (on/off)\\n\\n<u><b>注意:</b></u>\\n1. 大文字 と 小文字は 重要\\n2. custom と書いているところは、当然ですが その後に 1つの数字の引数を置きます\\n3. float と書かれているところは 1.7 のような、1つの単精度浮動小数点です\\n4. 「ghostdotasks」を セットすると 問題が発生する。\\n5. 使用例:\\n   - \"/cs map <#a167c0>polus</color>\"\\n   - \"/cs killdistance custom 4\"\\n   - \"/cs <#8cffff>trackdelay</color> 1,7\"\\n   - \"/cs confirmejects on",
  "Commands.NoAccess.Level.Host": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>ホスト</color>による 使用のみできます</color></size>",
  "Commands.NoAccess.Level.HostOrAdmin": "<#ff5555>X <#bb0000>このコマンドは <#ffffff>ホストと管理者のみ実行可能",
  "Commands.NoAccess.Level.HostOrModerator": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>ホスト & モデレーター</color>による 使用のみできます</color></size>",
  "Commands.NoAccess.Level.Modded": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>Mod導入 クライアント</color>による 使用のみできます</color></size>",
  "Commands.NoAccess.Time.AfterDeath": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>死後</color>に 使用のみできます</color></size>",
  "Commands.NoAccess.Time.AfterDeathOrLobby": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>ロビー & 死後で</color> 使用のみできます</color></size>",
  "Commands.NoAccess.Time.InGame": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>ゲームで</color> 使用のみできます</color></size>",
  "Commands.NoAccess.Time.InLobby": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>ロビーで</color> 使用のみできます</color></size>",
  "Commands.NoAccess.Time.InMeeting": "<size=80%><#ff5555>X</color> <#bb0000>このコマンドは <#ffffff>会議で</color> 使用のみできます</color></size>",
  "KickCommandInvalidID": "<size=80%>指定された プレイヤーID は無効です。\\nプレイヤーを追い出すには '/kick [プレイヤーID]' を使用してください。</size>",
  "KickCommandKickHost": "<size=80%>は ホストを追い出す権限がありません。</size>",
