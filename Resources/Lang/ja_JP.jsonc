  "GhostCanSeeOtherVotes": "幽霊は他人の投票色を確認できる",

  /* ==============================
    Task Settings           
  ============================== */
  "GhostIgnoreTasks": "幽霊のタスクを免除する",

  /* ==============================
    Notifications and Messages           
  ============================== */
  "GotGhostRoleNotify": "<#ffff00>幽霊役職が割り当てられた！</color>",

  /* ==============================
    Guess Options         
  ============================== */
  "GuessAbility": "推測者は <color=#ff9ace>ラバーズ</color>を推測できる",
  "GuessAdtRole": "<size=80%>残念ながら、ホストの設定で 属性を 推測することが許可されていません</size>",
  "GuessAnkylosaurus": "<size=80%><#7fe44c>アンキロサウルス</color>を推測できません。</size>",
  "GuessBackstabber": "<size=80%>明かされた <#fcba03>バックスタバー</color>を 推測できません。</size>",
  "GuessBerserker": "うまくいかなかったみたいだ....",
  "GuessCrewRole": "<size=80%>残念ながら、ホストの設定で <#8cffff>クルーメイト</color>が <#8cffff>クルーメイト</color>の役割を 推測することが許可されていません。</size>",
  "GuessDead": "<size=80%>申し訳ありません、ですが 死後の役割の推測は不可能です。</size>",
  "GuessDisabled": "この推測は禁止されている。",
  "GuessDisabledAddonOverride": "<size=80%>申し訳ありませんが、この特定の属性は ホストの設定により 推測ができません。</size>",
  "GuessDoctor": "<size=80%>申し訳ありませんが、明らかになった<#80ffdd>ドクター</color>として 推測することは不公平なのでできません。</size>",
  "GuessDoubleShot": "<size=80%>間違った役割を推測しましたが、<#19fa8d>ダブルショット</color>を持っているので は別のチャンスがあります！</size>",
  "GuessDuringDiscussion": "<size=80%>ホストの設定によると、議論タイム中に 推測ができません。</size>",
  "GuessErased": "<size=80%>消去されたその役割の 1人のプレイヤーを 推測できません。</size>",
  "GuessGM": "<size=80%><#ff5b70>GM</color> はすでに死亡しているため推測できない……そもそもなぜ哀れなホストにそんな仕打ちを？</size>",
  "GuessHelp": "<size=80%>使い方: <b>/bt [プレイヤー ID] [役職名]</b>\n例: /bt 3 <#00f7ff>ベイティング</color>\nプレイヤー ID は各プレイヤーの名前の前に表示されます。\nまたは <b>/id</b> コマンドでプレイヤー ID の一覧を確認できます。</size>",
  "GuessImpRole": "<size=80%>残念ながら、ホストの設定で <#ff1919>インポスター</color>が <#ff1919>インポスター</color>の役割を 推測することが許可されていません。</size>",
  "GuessKill": "<size=90%><b>{0}</b>が 推測された</size>",
  "GuessKnighted": "<size=80%>申し訳ありませんが、<#FFA500>統治者</color>は <#FFA500>騎士</color>を推測できません。</size>",
  "GuessLovers": "<size=80%>申し訳ないですが、ホストの設定で <color=#ff9ace>ラバーズ</color>の推測が許可されていません。</size>",
  "GuessMarkseekerTarget": "<size=80%><#f2a0f1>マークシーカー</color>のターゲットを推測できません</size>",
  "GuessMarshallTask": "<size=80%><#5573aa>マーシャル</color>はタスク完了済みなため推測できません。</size>",
  "GuessMayor": "<size=80%>申し訳ありませんが、明らかになった<#204d42>メイヤー</color>として 推測することは不公平なのでできません。</size>",
  "GuessMonarch": "<size=80%><#FFA500>騎士</color>にされたので、<#FFA500>統治者</color>を推測できません。</size>",
  "GuessNotAllowed": "<size=80%>申し訳ありませんが、役割に推測する極限がありません。</size>",
  "GuessNotifiedBait": "<size=80%><#00f7ff>ベイト</color>だと発表されたから推測できません。\\n簡単だと思ったでしょ？</size>",
  "GuessNull": "<size=80%>役職を推測する生存中のプレイヤーの ID を選択してください</size>",
  "GuessObviousAddon": "<size=80%>申し訳ありませんが、<#424242>忘却</color>の属性 そして 役割を推測することはできません</size>",
  "GuessOnbound": "<size=80%>対象は <#BAAAE9>拘束</color>属性を持つため、推測はキャンセルされました。</size>",
  "GuessPestilence": "<size=80%>ちょうど<#343136>ペスティレンス</color>の推測を試みた！\\n\\n申し訳ありませんが、<#343136>ペスティレンス</color>に殺害されました。</size>",
  "GuessPhantom": "<size=80%><#662962>妖怪</color> は推測できない。推測すると勝利条件を満たさせてしまう！</size>",
  "GuessPresident": "<size=80%>明かされた<#30916f>プレジデント</color>を 推測することはできません。</size>",
  "GuessSameCTAPlayer": "<size=80%>チームにいるプレイヤーの推測を試しました.... あまり賢くないですね？</size>",
  "GuessShielded": "<size=80%>申し訳ありませんが、<#00ff97>メディック</color>に保護されてるプレイヤーを推測できません</size>",
  "GuessSuperStar": "<size=80%><#f6f657>スーパースター</color>を推測することはできません.... \\n簡単だと思いました、よね？</size>",
  "GuessTank": "<size=80%>ホストの設定により、<#176320>タンク</color>を推測することはできません。</size>",
  "GuessTaskDone": "<size=80%>申し訳ありませんが、タスクを終えた誰かを 推測できません。</size>",
  "GuessTeamMate": "仲間を推測することはできない。",
  "GuessVanillaCrewmate": "<size=80%>ホストの設定で 誰かをバニラ<#8cffff>クルーメイト</color>として 推測することが許可されていません</size>",
  "GuessWorkaholic": "<size=80%>申し訳ありませんが、明らかになった<#008b8b>ワーカホリック</color>として 推測することは不公平なのでできません。</size>",
