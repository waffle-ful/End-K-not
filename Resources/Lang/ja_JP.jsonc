  "StopAndGo_LivesRemainingNotify": "<size=2><#ffff00>⚠ 命を失った / 残り <#ffff44>{0}つ</color> ⚠</color></size>",
  "StopAndGo_MiddleCounterGreenMax": "中央カウンターの 最大の<#008000>緑</color>の時間",
  "StopAndGo_MiddleCounterGreenMin": "中央カウンターの 最小の<#008000>緑</color>の時間",
