  "StopAndGo_ExtraGreenTimeOnAirship": "<color=#ed0007>Airship</color>での 追加の<#008000>緑</color>の時間",
  "StopAndGo_ExtraGreenTimeOnFungle": "<color=#ffa646>Fungle</color>での 追加の<#008000>緑</color>の時間",
  "StopAndGo_LeftCounterGreenMax": "左カウンターの 最大の<#008000>緑</color>の時間",
  "StopAndGo_LeftCounterGreenMin": "左カウンターの 最小の<#008000>緑</color>の時間",
  "StopAndGo_LeftCounterRedMax": "左カウンターの 最大の<#ff0000>赤</color>の時間",
