  "KillerNotifyPatrol": "<#ffff00>パトロール圏内にいる！\n<#ffa500>{0}s</color> 以内に外へ移動しないと死亡する！</color>",
  "MinglePlayer": "MINGLE",
  "MinglePlayerInfo": "正しい部屋に居続けて生き残れ",
