  // Free For All - FFA
  "FFA": "フリー フォー オール",
  "ModeFFA": "ゲームモード: FFA",
  "ModeDescribe.FFA": "<size=80%><#00ffff>FFA (Free For All)</color> ゲームモードでは、全員が殺人鬼で そして 全員が 誰もを殺害できます。\\n最後に生きているプレイヤーが 勝利します！\\n\\nいくつかの ランダムイベントが その間に これをさらにもっと楽しませます！</size>",
  "GameModeTutorial.FFA": "<size=90%>現在のゲームモードは <#00ffff>Free For All (FFA)</color>です。</size>\\n<size=80%>全員が 殺害できます。\\n勝利するには 最後 1人で生き残りましょう！\\n誰かを殺害したとき、1つのランダムな バフ または デバフ が得られます。</size>",
  "FFAChatMessageNotify": "[チャット] {0}: <#ffffff>{1}",
  "FFA-Event-GetDecreasedSpeed": "一時的な 増加した速度がある",
  "FFA-Event-GetHighKCD": "増加 キルのクールダウンを得た",
  "FFA-Event-GetIncreasedSpeed": "一時的な 速度ブーストがある！",
  "FFA-Event-GetLowKCD": "低下 キルのクールダウンを得た！",
  "FFA-Event-GetLowVision": "一時的な 低下視力がある",
  "FFA-Event-GetShield": "一時的な シールドがある！",
  "FFA-Event-GetTP": "ランダムな通気口へ テレポートを得た！",
  "FFA-Event-RandomTP": "全員が 誰かと入れ替わった",
  "FFA-NoVentingBecauseKCDIsUP": "キルのクールダウンは起きている、通気口に隠れないでください！",
  "FFA-NoVentingBecauseTwoPlayers": "生存プレイヤーは 2人のみです、通気口に隠れようとするのはやめましょう！",
  "FFA_ChatDuringGame": "ゲーム中のチャット",
  "FFA_DecreasedSpeed": "低下時の速度",
  "FFA_DisableVentingWhenKCDIsUp": "通気口の潜入から プレイヤーの キルのクールダウンが起きてたら 阻止する",
  "FFA_DisableVentingWhenTwoPlayersAlive": "生存しているプレイヤーが 2プレイヤーのみのとき 通気口の潜入を阻止する",
  "FFA_EnableRandomAbilities": "ランダムイベントを有効にする",
  "FFA_EnableRandomTwists": "時々により ランダムスワップを有効にする",
  "FFA_GameTime": "最大の ゲームの長さ",
  "FFA_IncreasedSpeed": "増加時の速度",
  "FFA_KCD": "キルのクールダウン",
  "FFA_LowerVision": "低下時の視力",
  "FFA_ModifiedSpeedDuration": "変化した速度の継続時間",
  "FFA_ModifiedVisionDuration": "低下した視力の継続時間",
  "FFA_ShieldBroken": "<color=#ffff00>誰かが 殺害を試みた、シールドは 今は壊れている！</color>",
  "FFA_ShieldDuration": "シールドの持続時間",
  "FFA_ShieldIsOneTimeUse": "1 殺害攻撃の後 シールドが壊れる",
  "FFA_TargetIsShielded": "<color=#ffff00>殺害の試みをしたプレイヤーは 保護されている！</color>",
  "FFA_TeamMode": "チームモードを有効にする",
  "FFA_TeamNumber": "チームの数",
  // Hide And Seek - HNS
  "HideAndSeek": "かくれんぼ",
  "ModeHideAndSeek": "ゲームモード: Hide And Seek",
  "ModeDescribe.HideAndSeek": "<size=65%><#345eeb>Hide And Seek</color>ゲームモードでは、<#ff1919>シーカー</color>は <#345eeb>ハイダー</color>をすべて殺さなければならなく、その間 <#345eeb>ハイダー</color>は 勝つために 殺されることなく すべてのタスクを完了しなければなりません。\\n制限時間が 0 に到達すると、<#345eeb>ハイダー</color>が勝利する。\\n<#ff1919>シーカー</color>を除く全員が死亡すると、<#ff1919>シーカー</color>が勝利する。\\n\\n役割: <#345eeb>ハイダー</color>、<#ff1919>シーカー</color>、<#00ff00>フォックス</color>、<#ff00ff>トロール</color>、<#ddf542>ジャンパー</color>、<#42ddf5>ディテクター</color>、<#42f54b>ジェット</color>、<#f542b0>ダッシャー</color>、<#f59e42>ロケーター</color>、<#694141>ベンター</color>、<#ff8f8f>エージェント</color>、<#561dd1>タスキネーター</color></size>",
  "GameModeTutorial.HideAndSeek": "<size=90%>現在のゲームモードは <#345eeb>かくれんぼ ハイド アンド シーク (Mod導入)</color>です。</size>\\n<size=80%><#ff1919>シーカ</color>は 勝利するのに すべての<#345eeb>ハイダー</color>を殺害しなければならなく、\\n<#345eeb>ハイダー</color>は タイマーを減らすために タスクをコンプリートしなければなりません。\\n制限時間が終了すると、<#345eeb>ハイダー</color>が勝利する。</size>",
  "HNS.DangerMeter": "(カスタム) 危険メーターを表示",
  "HNS.MaxNeutrals": "<#0000ff>最大</color>の <#ffab1b>ニュートラル</color>の人数",
  "HNS.MinNeutrals": "<#00ffff>最小</color>の <#ffab1b>ニュートラル</color>の人数",
  "HNS.PlayersSeeRoles": "プレイヤーは 各 他の役割を見れる",
  "HNS.TaskCount": "タスク数:",
