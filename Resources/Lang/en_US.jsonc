  // Command Behaviour
  "GameStateCommand.ShowConvertedCount": "Show amount of alive <#ffab1b>Converted</color> Players (excluding <#ff1919>Madmates</color>)",
  "GameStateCommand.ShowCovenCount": "Show amount of alive <#7b3fbb>Coven</color>",
  "GameStateCommand.ShowCrewCount": "Show amount of alive <#8cffff>Crewmates</color>",
  "GameStateCommand.ShowImpCount": "Show amount of alive <#ff1919>Impostors</color>",
  "GameStateCommand.ShowLoversState": "Show <#ff9ace>Lovers</color> pair state",
  "GameStateCommand.ShowMadmateCount": "Show amount of alive <#ff1919>Madmates</color>",
  "GameStateCommand.ShowNKCount": "Show amount of alive <#ffab1b>Neutral</color> <#ff1919>Killers</color>",
  "GameStateCommand.ShowNNKCount": "Show amount of alive <#ffff00>Non-Killing</color> <#ffab1b>Neutrals</color>",
  "GameStateCommand.ShowRomanticState": "Show <#ff1493>Romantic</color> pair state",
  "GameStateCommand.ShowTasks": "Show amount of completed tasks",
  "GNoCommandInfo": "<b>This Command can only be used when in lobby or after you die.</b>\\n\\ntype <b>/gno X</b> to play guess a number. X can be a number between 0 and 99 (both included). \\n\\nYou get maximum of <color=#ff0000>7 tries</color> to guess the number.\\n\\n Example:- <b>/gno 10</b>",
  "HostKillSelfByCommand": "The lobby Host decided to commit suicide",
  "HostMayOmitCmdPrefix": "'cmd' prefix\\ncan be omitted",
  "HostSeesCommandsEnteredByOthers": "Host Sees Commands Entered By Others",
  "MyRoleCommandHelp": "<size=80%><#00ffa5>⇨ Type <#00a5ff>/m</color> in the next meeting for the full description of your role ⇦</color></size>",
  "NoSpamAnymoreUseCmd": "<size=2.5><#ff0000>⚠ <#ffff00>USE THE '/cmd {command name} {arguments}' FORMAT <#ff0000>⚠</size>\\n<#ffa500>Otherwise your messages are exposed!",
  "SpectateCommand.ForcedSpectator": "<#00ff00>✓</color> {0} will spectate for the next game.",
  "SpectateCommand.Removed": "<#ffab1b>-</color> You are no longer spectating.",
  "SpectateCommand.RemovedForcedSpectator": "<#ffab1b>-</color> {0} is no longer a forced spectator.",
  "SpectateCommand.Success": "<#00ff00>✓</color> You are now spectating for the next game.",
  "SpectateCommand.WasSpectatingLastRound": "<#ff0000>X</color> You were spectating last round. You can't spectate again.",
  "TerminateCommand": "Abort Command",
