  "Dad.NormalAlcoholDecreaseValue": "Over time, alcohol decreases by",
  "Dad.Rage.AlcoholDecrease": "Alcohol decrease after Raging",
  "Dad.Rage.AlcoholRequirement": "Required alcohol level to Rage",
  "Dad.Rage.Description": "You kill the next person you see",
  "Dad.SelectedAbilitySuffix": "<size=80%><color=#00ffa5>Selected ability:</color> {0} <color=#888888>(vent to use)</color></size>",
  "Dad.ShopLocation": "<#00ffa5>The shop is at the</color> {0}",
  "Dad.ShopSuffix": "<size=80%><color=#00ffa5>Vent to buy</color> {0} <color=#00ffa5>alcohol from the money you have</color></size>",
  "Dad.ShowWarningWhenAlcoholIsBelow": "Show warning when alcohol level is below",
  "Dad.Sleep.AlcoholDecrease": "Alcohol decrease after Sleeping",
  "Dad.Sleep.AlcoholRequirement": "Required alcohol level to Sleep",
  "Dad.Sleep.Description": "While sleeping, you can't see, move, or use any abilities\\nbut also can't be interacted with and your alcohol level is stable",
  "Dad.Sniffing.AlcoholDecrease": "Alcohol decrease after Sniffing",
  "Dad.Sniffing.AlcoholRequirement": "Required alcohol level to Sniff",
  "Dad.Sniffing.Description": "You get arrows pointing to existing dead bodies; arrows only update when you sniff again",
  "Dad.StartingAlcohol": "Starting alcohol level",
  "Dad.StartingMoney": "Starting money",
  "Dad.SuperVision.AlcoholDecrease": "Alcohol decrease after using Super Vision",
  "Dad.SuperVision.AlcoholRequirement": "Required alcohol level to use Super Vision",
  "Dad.SuperVision.Description": "You will have max vision for some time",
  "Dad.SuperVisionDuration": "Super vision duration",
  "Decryptor": "Decryptor",
  "DecryptorInfo": "Get Letters From Everyone's Roles",
  "DecryptorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to gradually reveal letters from everyone's role names.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Letter Reveal</color></b>\nAfter every X tasks, one more letter from each player's role name becomes visible below their name. Letters are unordered and each appears only once per occurrence in the role name.\n\n<i>The puzzle pieces were there all along.</i></size>",
  "Decryptor.GuessMode": "Can Guess",
  "Decryptor.Suffix": "<size=70%><#00ffa5>Complete</color> <b>{0}</b> <#00ffa5>tasks for the next letters</color></size>",
  "Decryptor.TaskNum": "Number of Tasks to Complete for Each Letter",
  "Demolitionist": "Demolitionist",
  "DemolitionistInfo": "Your killer has a few seconds to vent or they die",
  "DemolitionistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your killer has 5 seconds to vent — or they die with you.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Tripwire</color></b>\nWhen killed, your murderer has 5 seconds to enter and remain in a vent. Jumping out too early doesn't count — they must still be inside when the time expires.\n\n<i>Going down? Not alone.</i></size>",
  "DemolitionistKillerDiesOnMeetingCall": "Killer dies if a meeting gets called before venting",
  "DemolitionistVentTime": "Time to Vent (s)",
  "Deputy": "Officer",
  "DeputyInfo": "Handcuff killers to increase their cooldowns",
  "DeputyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Handcuff a player to spike their kill cooldown.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Handcuff</color></b>\nUse your kill button on a player to reset their kill cooldown to the host-set penalty value. Handcuffing someone without a kill button wastes a use.\n\n<i>Slow them down. Buy your crew time.</i></size>",
  "DeputyHandcuffCDForTarget": "Kill Cooldown for handcuffed player",
  "DeputyHandcuffCooldown": "Handcuff Cooldown",
  "DeputyHandcuffDelay": "Handcuff apply delay",
  "DeputyHandcuffMax": "Maximum Handcuffs",
  "DeputyHandcuffText": "Handcuff",
  "DeputyHandcuffedPlayer": "Handcuffed target",
  "DeputyInvalidTarget": "Target cannot be handcuffed",
  "DetectiveEndKnot": "Detective",
  "DetectiveEndKnotInfo": "Gather Info, Solve Murders",
  "DetectiveEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Gather clues and interrogate suspects to solve murders.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Investigation</color></b>\nWrite notes at crime scenes and question suspects.\n\n<size=70%><color=#ff0000>This role currently does not work due to a basis reset issue.</color></size>\n\n<i>Every scene tells a story — if you know how to read it.</i></size>",
  "Detour": "Detour",
  "DetourInfo": "Pass Kills Onto Nearest Player",
  "DetourInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Redirect any kill button action aimed at you onto the nearest player.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Kill Redirect</color></b>\nAll kill-button actions targeting you are blocked and instead applied to the closest player to you.\n\n<i>It wasn't me — it was them.</i></size>",
  "Dictator": "Dictator",
  "DictatorInfo": "Exile a player based on your own judgment",
  "DictatorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>End a meeting on your terms by forcing an immediate ejection.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Decree</color></b>\nVote for a player to instantly end the meeting and eject them — at the cost of your own life.\n\n<i>One vote. Final answer. No appeals.</i></size>",
  "Dictator.MinTasksToDictate": "Minimum Number of Completed Tasks Required to Dictate Someone",
  "Doctor": "Doctor",
  "DoctorInfo": "Know how each player died",
  "DoctorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Access vitals and determine each player's cause of death.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vitals Access</color></b>\nView player vitals and their cause of death as long as your battery is charged.\n\n<i>The body always tells the truth — you just have to know where to look.</i></size>",
  "DoctorTaskCompletedBatteryCharge": "Battery Duration",
  "DoctorVisibleToEveryone": "Everyone knows who the <color=#80ffdd>Doctor</color> is",
  "DonutDelivery": "Donut Delivery",
  "DonutDeliveryInfo": "Deliver Donuts to Everyone",
  "DonutDeliveryInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Press your kill button to deliver a donut. It does nothing. Enjoy.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Donut Delivery</color></b>\nDeliver a donut to any player. They know they got one. That's it.\n\n<i>Sometimes the mission is just bringing joy.</i></size>",
  "DonutDeliverCD": "Deliver Cooldown",
  "DonutDelivered-0": "\\nSuccess!\\nThey devoured the donut like it was the last task on the ship.",
  "DonutDelivered-1": "\\nDelivered with perfection!\\nTheir happiness level is higher than the emergency meeting button.",
  "DonutDelivered-2": "\\nIt's official:\\nthe donut delivery was more satisfying than completing all tasks!",
  "DonutDelivered-3": "\\nGlowing reviews!\\nThe donut got more compliments than the cafeteria emergency table.",
  "DonutDelivered-4": "\\nPositive vibes only!\\nThey're raving about the donut like it's the 'Best Crewmate' award.",
  "DonutDelivered-5": "\\nDonut delivery rated MVP – Most Valuable Pastry!",
  "DonutDelivered-6": "\\nSweet success!\\nThe donut hit the spot, just like an impostor's target.",
  "DonutDelivered-7": "\\nVictory dance!\\nThe donut delivery was smoother than venting.",
  "DonutDelivered-8": "\\nSweetness level: Maximum.\\nDonut delivery achieved a sweet victory!",
  "DonutDelivered-9": "\\nDelivered!\\nThey loved it more than a victory screen!",
  "DonutDelivered-10": "\\nSuccessful drop-off!\\nThe donut was a hit, not a sus move!",
  "DonutDelivered-11": "\\nDonut delivered without a crumb of suspicion!",
  "DonutDelivered-12": "\\nPositive feedback!\\nThey said the donut was so good it was almost 'impostor-able'!",
  "DonutDelivered-13": "\\nNot a fan of the flavor?\\nMaybe next time, stick to venti lattes...",
  "DonutDelivered-14": "\\nUnpopular opinion:\\nThey didn't like the chocolate. Maybe go for sprinkles next time?",
  "DonutDelivered-15": "\\nThe donut was killer, just like their alibi.",
  "DonutDelivered-16": "\\nOops! Donut delivery failed.\\nThey're probably more into bagels...",
  "DonutDelivered-17": "\\nRejected!\\nTurns out, they're on a diet. Tough crowd!",
  "DonutDelivered-18": "\\nFailed delivery alert.\\nLooks like they prefer impostor snacks.",
  "DonutDeliverSEAmount": "Increase Speed by",
  "DonutDeliverSEDelay": "Speed Boost Delay",
  "DonutDeliverSEDuration": "Speed Boost Duration",
  "DonutDeliverSEEvilsDecreaseAmount": "Decrease Speed by",
  "DonutDeliverSEEvilsGetDecreased": "<#ff1919>Evil</color> Players Get Decreased Speed",
  "DonutDeliverSpeedEffect": "Speed Boost For Players Who Get Donuts",
  "DonutGot-0": "\\nSpecial delivery!\\nYou've been 'dough'nuted' by the Donut Delivery crewmate.\\nEnjoy the sweetness!",
  "DonutGot-1": "\\nCongrats!\\nYou just got 'holey' goodness delivered by the Donut Delivery crewmate.\\nTreat yourself!",
  "DonutGot-2": "\\nDonut Delivery here!\\nYour order of one delicious donut has been successfully dispatched.\\nEnjoy the flavor explosion!",
  "DonutGot-3": "\\nSurprise!\\nYou've been visited by the Donut Delivery crewmate.\\nIt's a killer treat!",
  "DonutGot-4": "\\nDing-dong! A donut delivery is at your door.\\nCourtesy of the Donut Delivery crewmate.\\nSavor the sweetness!",
  "DonutGot-5": "\\nSpecial delivery alert!\\nYou've just received a 'killer' donut from the Donut Delivery crewmate.\\nEnjoy the crime scene... I mean snack!",
  "Doorjammer": "Doorjammer",
  "DoorjammerInfo": "Jam Rooms to Prevent Sabotages",
  "DoorjammerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Jam rooms to prevent enemies from closing doors or sabotaging in them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Room Jam</color></b>\nPet in a room to jam it. No one can close the doors in a jammed room. Depending on settings, all sabotages from jammed rooms may also be blocked.\n\n<i>Lock it down before they can strike.</i></size>",
  "Doorjammer.BlockSabotagesFromJammedRooms": "Block All Sabotages From Jammed Rooms",
  "Doorjammer.MaxRoomsJammedAtOnce": "Max Rooms Jammed At Once",
  "Doorjammer.Suffix": "<b><#00a5ff>{0}/{1}</color> <#00ffa5>Jammed Rooms</color></b>{2}",
  "DoorjammerBlockSabo": "<#bb0000>This room is jammed, you can't sabotage in here</color>",
  "DoubleAgent": "Double Agent",
  "DoubleAgentInfo": "An Impostor Among Impostors",
  "DoubleAgentInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Disguised as an Impostor — expose them from the inside.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Deep Cover</color></b>\nReal Impostors believe you're their partner. You don't know who they are. Use their trust to expose them without blowing your cover.\n\n<i>The best spy is the one they never suspect.</i></size>",
  "Drainer": "Drainer",
  "DrainerInfo": "Drain Vents by Entering Them",
  "DrainerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Enter a vent to kill everyone connected to it.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Drain</color></b>\nWhen you enter a vent, all players inside that vent and all connected vents are instantly killed.\n\n<i>The vents are not safe from the Drainer.</i></size>",
  "Druid": "Druid",
  "DruidInfo": "Place Triggers to Know Where Everyone Is",
  "DruidInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Place triggers in impostor-only spots to detect when someone passes through.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Trigger Placement</color></b>\nVent to place a trigger (with a brief delay). When any player walks near it, you are notified. If pets are enabled, placing is immediate.\n\n<i>The forest remembers who passed through.</i></size>",
  "DruidTimeLeft": "Placing trigger in {0}s",
  "DruidTriggerPlaceDelayOpt": "Trigger Place Delay (when not using pets)",
  "DruidTriggerTriggered": "Trigger {0} was triggered by someone! {1}",
  "Electric": "Electric",
  "ElectricInfo": "Shock Players",
  "ElectricInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your task completions electrify a random killer.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Electric Shock</color></b>\nEvery time you complete a task, a random killer is frozen for a few seconds.\n\n<i>A little static goes a long way.</i></size>",
  "EngineerEndKnot": "Engineer",
  "EngineerEndKnotInfo": "Use the vents to catch the <color=#ff1919>Impostors</color>",
  "EngineerEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Access vents to move faster and gather information.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Access</color></b>\nUse vents freely as long as communications are not sabotaged. Vents are disabled during comms sabotage.\n\n<i>Sometimes the fastest route is underground.</i></size>",
  "Enigma": "Enigma",
  "EnigmaInfo": "Get Clues about Killers",
  "EnigmaInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Earn precise clues about the killer with each completed task.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Murder Clues</color></b>\nEach meeting, receive a random clue about the killer. Completing more tasks makes clues more specific. Reporting a body may be required depending on settings.<size=70%>\n\n<b>Light colors:</b> Red, Pink, Orange, Yellow, White, Cyan, Lime, Rose, Banana, Coral\n<b>Dark colors:</b> Blue, Green, Black, Purple, Brown, Maroon, Gray, Tan</size>\n\n<i>The truth hides in the details.</i></size>",
  "EnigmaClueColor1": "The Killer has a light color!",
  "EnigmaClueColor2": "The Killer has a dark color!",
  "EnigmaClueColor3": "The Killer's color is {0}!",
  "EnigmaClueFriendCode": "The Killer's Friend Code is {0}!",
  "EnigmaClueGetCluesWithoutReporting": "<color=#676798>Enigma</color> can get <color=#676798>Clues</color> without reporting a dead body",
