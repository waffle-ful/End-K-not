  "FFA_ShieldBroken": "<color=#ffff00>Someone tried to kill you, your shield is now broken!</color>",
  "FFA_ShieldDuration": "Shield Duration",
  "FFA_ShieldIsOneTimeUse": "Shields break after 1 kill attempt",
  "FFA_TargetIsShielded": "<color=#ffff00>The player you tried to kill is shielded!</color>",
  "FFA_TeamMode": "Enable Team Mode",
  "FFA_TeamNumber": "Number of Teams",
  // Hide And Seek - HNS
  "HideAndSeek": "HIDE AND SEEK",
  "ModeHideAndSeek": "Gamemode: Hide And Seek",
  "ModeDescribe.HideAndSeek": "In the Hide And Seek gamemode, seekers have to kill all hiders, while hiders have to complete all tasks without being killed in order to win.\\nIf the time limit reaches 0, hiders win.\\nIf everyone apart from the Seekers die, the Seekers win.\\n\\nRoles: Hider, Seeker, Fox, Troll, Jumper, Detector, Jet, Dasher, Locator, Venter, Agent, Taskinator",
  "GameModeTutorial.HideAndSeek": "<size=90%>The current game mode is <#345eeb>Hide And Seek (Modded)</color>.</size>\\n<size=80%>Seekers must kill all hiders to win,\\nhiders must complete tasks to lower the timer.\\nIf the time limit ends, hiders win.</size>",
  "HNS.DangerMeter": "Show (Custom) Danger Meter",
  "HNS.MaxNeutrals": "<#0000ff>Maximum</color> Number of <#ffab1b>Neutrals</color>",
  "HNS.MinNeutrals": "<#00ffff>Minimum</color> Number of <#ffab1b>Neutrals</color>",
