  "Deathrace.Lap": "Lap {0}/{1}",
  "Deathrace.LapsToWinOption": "Number of Laps to Win",
  "Deathrace.PowerUpDisplay.EnergyDrink": "Energy\\nDrink",
  "Deathrace.PowerUpDisplay.Grenade": "Grenade",
  "Deathrace.PowerUpDisplay.Ice": "Ice",
  "Deathrace.PowerUpDisplay.Smoke": "Smoke",
  "Deathrace.PowerUpDisplay.Taser": "Taser",
  "Deathrace.PowerUpEffectDurationOption": "Power-Up Effect Duration",
  "Deathrace.PowerUpEffectRangeOption": "Power-Up Effect Range",
  "Deathrace.PowerUpInfo.EnergyDrink": "<#ffffff>[<#00ffff>VANISH</color>]</color> {0} Energy Drink: Speeds you up",
  "Deathrace.PowerUpInfo.Grenade": "<#ffffff>[<#00ffff>VANISH</color>]</color> {0} Grenade: Blinds everyone nearby (except you)",
  "Deathrace.PowerUpInfo.Ice": "<#ffffff>[<#00ffff>VANISH</color>]</color> {0} Ice: Inverts controls for everyone nearby (except you)",
  "Deathrace.PowerUpInfo.More": "+{0} More Power-Ups Stored",
  "Deathrace.PowerUpInfo.Smoke": "<#ffffff>[<#00ffff>VANISH</color>]</color> {0} Smoke: Slows down everyone nearby (except you)",
