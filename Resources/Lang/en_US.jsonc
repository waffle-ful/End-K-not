  // ── Phase 1 Neutral roles ──────────────────────────────────────────────

  "Banker": "Banker",
  "BankerInfo": "Accumulate coins through tasks or kills to win",
  "BankerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Accumulate coins through tasks or kills to reach the winning threshold.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Task Mode</color></b>\nStart in Task Mode — complete tasks to earn coins. Enter a vent to pay a switching fee and toggle into Kill Mode.\n\n・<b><color=#ffab1b>Kill Mode</color></b>\nEach kill earns coins. Each meeting costs coins. Reach the coin threshold to win as an additional winner.\n\n<i>Money makes the spaceship go round.</i></size>",
  "Banker.InitialCoins": "Starting Coins",
  "Banker.TaskAddCoin": "Coins per Task",
  "Banker.KillAddCoin": "Coins per Kill",
  "Banker.SwitchCoinCost": "Mode Switch Cost",
  "Banker.TurnRemoveCoin": "Coins Lost per Meeting",
  "Banker.AddWinCoin": "Coins Needed to Win",
  "Banker.DieCanWin": "Can Win After Death",
  "Banker.DieRemoveCoin": "Coins Lost on Death",
  "Banker.DieRemoveTurnCoin": "Coins Lost per Meeting (Dead)",
  "Banker.KillCooldown": "Kill Cooldown",
  "Banker.VentButtonText": "Switch Mode",
  "Banker.KillButtonText": "Kill",
  "Banker.ModeTask": "[Task]",
  "Banker.ModeKill": "[Kill]",
  "Banker.SwitchedToTask": "Switched to Task Mode",
  "Banker.SwitchedToKill": "Switched to Kill Mode",

  "Monochromer": "Monochromer",
  "MonochroInfo": "Identify killers among a grey world",
  "MonochromerInfo": "Identify killers among a grey world",
  "MonochromerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Identify killers among the crew — and survive to claim the win.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Killer Sense</color></b>\nImpostors and Neutral Killers appear to you with a ★ marker. If a killer's role color is revealed, the ★ is colored accordingly.\n\n[Win Condition]\n・<b><color=#ffab1b>Survive</color></b>\nSurvive until the end to win alongside the winning team — or steal the win entirely if the game ends by any means other than tasks.\n\n<i>In a grey world, only you see in color.</i></size>",
  "Monochromer.HasImpostorVision": "Has Impostor Vision",
  "Monochromer.CanSeeKillers": "Can See Killer Markers",
  "Monochromer.ShowKillerRoleColor": "Marker Uses Killer Role Color",

  "Turncoat": "Turncoat",
  "TurncoatInfo": "Secretly bet against a random player",
  "TurncoatInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Secretly bet against a random player — if they die and you survive, you win.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Secret Target</color></b>\nA random player is secretly assigned to you at the start (marked with ★ only you can see). If your target dies and you are still alive at the end of the game, you win as an additional winner. Manipulate events to ensure they don't survive.\n\n<i>Loyalty is just a wager on the right person.</i></size>",
  "Turncoat.CanTargetImpostor": "Can Target Impostors",
  "Turncoat.CanTargetNeutral": "Can Target Neutrals",
  "Turncoat.CanTargetMadmate": "Can Target Madmates",
  "Turncoat.KnowTargetRole": "Know Target's Role",
  "TurncoatLowerText": "Target: {0}",

  "Remotekiller": "Remote Killer",
  "RemotekillerInfo": "Mark a target, then vent to kill them from anywhere",
  "RemotekillerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Mark a target with your kill button, then vent from anywhere to execute them remotely.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Remote Mark</color></b>\nUse the kill button to mark a target — they are not killed immediately. Enter any vent to execute the kill from any distance. Your mark clears after each meeting.\n\n[Win Condition]\nEliminate all Impostors and competing Neutral Killers.\n\n<i>Distance is no obstacle for a professional.</i></size>",
  "Remotekiller.KillCooldown": "Mark Cooldown",
  "Remotekiller.HasImpostorVision": "Has Impostor Vision",
  "Remotekiller.CanVent": "Can Vent",
  "Remotekiller.MarkButtonText": "Mark",
  "Remotekiller.VentButtonText": "Execute",
  "Remotekiller.Marked": "Marked: {0}",

  "Strawdoll": "Strawdoll",
  "StrawdollInfo": "Curse a nearby player with Pet; if someone kills you while shapeshifted, the cursed player dies instead",
  "StrawdollInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Curse a nearby player, then shapeshift into your target — letting attackers hit the cursed one instead.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Curse</color></b>\nPress Pet near a player to curse them (marked with †).\n\n・<b><color=#ffab1b>Watch Mode</color></b>\nPress the Ability button to shapeshift into your target and enter watch mode. While shapeshifted, any kill attempt on you is redirected to the cursed target instead. Each successful reprisal increments your counter. Reach the required count to win solo.\n\n<i>The doll takes the blade.</i></size>",
  "StrawdollWinKilledCount": "Reprisal Kills to Win",
  "StrawdollTpToVent": "Teleport to Vent on Activate",
  "StrawdollReprisalDistance": "Self-Destruct Distance (0 = off)",
  "StrawdollStopTime": "Freeze Duration After Reprisal",
  "StrawdollTargetSet": "Cursed: {0}",
  "StrawdollNoTarget": "No nearby player to curse",
  "StrawdollNoTargetSet": "Curse someone with Pet first",
  "StrawdollTargetDead": "Your cursed target is dead",
  "StrawdollAlreadyWatching": "Already in watch mode",
  "StrawdollPetToSetTarget": "Pet to curse a nearby player",
  "StrawdollTargetHUD": "Cursed: {0} (Press Kill to watch)",
  "StrawdollWatchingHUD": "Watching ({0}/{1} reprisals)",

  "CurseMaker": "CurseMaker",
  "CurseMakerInfo": "Stay close to mark a player with Pet; Pet away from everyone to detonate — killing all marked and yourself",
  "CurseMakerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Charge curses onto nearby players, then detonate from a safe distance — killing all cursed targets and yourself.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Curse Charge</color></b>\nPress Pet near a player to begin charging a curse. Stay within range for the full duration to apply it (shown with †). Old curses expire after a set number of meetings.\n\n・<b><color=#ffab1b>Detonation</color></b>\nPress Pet while away from all players to detonate — all cursed players die, and so do you. With Can Win Solo enabled, you win on detonation.\n\n<i>They never see it coming.</i></size>",
  "CurseMakerCurseDistance": "Curse Range",
  "CurseMakerNoroiTime": "Charge Duration",
  "CurseMakerDelTurn": "Curse Expiry (meetings)",
  "CurseMakerCanSoloWin": "Can Win Solo",
  "CurseMakerCharging": "Charging: {0} (stay close)",
  "CurseMakerChargeCanceled": "Charge canceled",
  "CurseMakerAlreadyCursed": "{0} is already cursed",
  "CurseMakerNoTarget": "No nearby player to curse",
  "CurseMakerChargingHUD": "Charging: {0} ({1}%)",
  "CurseMakerCursedHUD": "Cursed: {0} player(s) — Pet away to detonate",
  "CurseMakerPetToMarkHUD": "Pet near a player to curse them",

  "Missioneer": "Missioneer",
  "MissioneerInfo": "Complete missions assigned each meeting to earn points; reach the solo-win threshold to win alone, or the add-win threshold to win alongside whoever wins",
  "MissioneerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Take on missions each meeting to earn points — accumulate enough to win solo or ride any team's victory.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Mission Select</color></b>\nDuring a meeting, vote yourself to view available missions, then vote a player to accept their mission. Complete it before the next meeting to earn points. Kill missions grant a kill button for that round.\n\n[Win Condition]\nReach the Add-Win threshold to win alongside any winning team. Reach the Solo-Win threshold to win the game outright.\n\n<i>Every job is just another contract.</i></size>",
  "Missioneer.MeetingAssignmentCount": "Missions Per Meeting",
  "Missioneer.WinAssignmentPoint": "Solo Win Points",
  "Missioneer.AddWinAssignmentPoint": "Add-Win Points (0 = disabled)",
  "Missioneer.Lv1Point": "Lv 1 Point Bonus",
  "Missioneer.Lv2Point": "Lv 2 Point Bonus",
  "Missioneer.Lv3Point": "Lv 3 Point Bonus",
  "Missioneer.Lv4Point": "Lv 4 Point Bonus",
  "Missioneer.KillPoint": "Kill Mission Base Points",
  "Missioneer.MovePoint": "Move Mission Base Points",
  "Missioneer.TaskPoint": "Task Mission Base Points",
  "Mission.Kill": "Kill someone",
  "Mission.KillToVent": "Kill then vent",
  "Mission.KillRoom": "Kill in target room",
  "Mission.KillPlayer": "Kill target player",
  "Mission.GoRoom": "Enter target room",
  "Mission.GoVent": "Use target vent",
  "Mission.SeePlayer": "Get near target",
  "Mission.MorePlayer": "Crowd with 3+ players",
