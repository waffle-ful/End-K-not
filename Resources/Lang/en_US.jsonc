  "Quiz.EndResults.CorrectAnswerNum": "Correct Answers: ",
  "Quiz.Notify.AllCorrect": "<#00ffa5>Everyone found enough correct answers!</color>",
  "Quiz.Notify.AllDie": "<#ffff00><u>Everyone</u> would die, so no one will die!\\nInstead, we'll redo this round.</color>",
  "Quiz.Notify.AllWrong": "<#ffff00><u>Everyone</u> got this question wrong, so this won't\\ncount as an incorrect answer for anyone.\\nInstead, we'll redo this question.</color>",
  "Quiz.Notify.AllWrongShort": "<#ffff00><u>Everyone</u> was wrong, doesn't count, redo.</color>",
  "Quiz.Notify.CorrectAnswer": "<{0}>The correct answer was:\\n{1} - {2} ({3})",
  "Quiz.Notify.CorrectAnswerNum": "<size=80%>You got {0}/{1} questions correct! The required amount was {2}.</size>",
  "Quiz.Notify.CorrectFFA": "<#00ffff>More than 1 player failed this round!\\nYou get to spectate them fighting in a Free For All (FFA) match to survive!",
  "Quiz.Notify.FFAOngoing": "<size=80%><#ffff00><u>Kill everyone</u> and survive</color>\\nHint: Someone is in {0}\\n<#ffa500>{1}</color></size>",
  "Quiz.Notify.FFASpectating": "<size=80%><#00ffff>Spectate the chaos!</color>\\n<#00a5ff>{1}</color></size>",
  "Quiz.Notify.IncorrectFFA": "<#ff4444>Luckily, you're not alone to failed this round!\\nYou will participate in a Free For All (FFA) event against the others who failed.\\nKill everyone else and be the last one alive to get a second chance!\\nBe sure to do this within the time limit, or all of you will die!</color>",
  "Quiz.Notify.NextRound": "<size=150%><#ffff00>Round {0}</color></size>",
  "Quiz.Notify.NextStage": "--------------------\\nStage {0}\\n--------------------\\n<size=90%>{1} Rounds\\n{2} Questions\\n{3}/{4} Answers Must Be Correct\\n{5}s To Answer Each Question</size>",
  "Quiz.Notify.OneWrong": "<#00a5ff>1 player failed this round. They will simply die.</color>",
  "Quiz.Notify.OnlyYouWrong": "<#ff0000>Only you failed this round. You will die now.</color>",
