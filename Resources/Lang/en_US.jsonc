  "EnigmaClueSkinTitle": "Enigma Skin Clue",
  "Escort": "Escort",
  "EscortInfo": "Role-Block Players to Help the Crew!",
  "EscortInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Role-block killers to buy your crew precious time.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Role-Block</color></b>\nUse your kill button on a player to role-block them for a set duration. Blocked players cannot kill, vent, sabotage, or report.\n\n<i>A moment of stillness can change everything.</i></size>",
  "EscortBlockDuration": "Role-Block Duration",
  "EscortKillButtonText": "Role-Block",
  "EscortTargetHacked": "Target successfully role-blocked",
  "Examiner": "Examiner",
  "ExaminerInfo": "Gather Info, Solve Murders",
  "ExaminerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Grants Detective abilities to investigate crime scenes.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Detective Senses</color></b>\nGains access to Detective-style body examination and investigative abilities for crewmate roles.\n\n<i>No crime scene is without its secrets.</i></size>",
  "Express": "Express",
  "ExpressInfo": "You get a speed boost on completing a task",
  "ExpressInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Completing tasks gives you a temporary speed boost.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Burst</color></b>\nAfter each completed task, gain a short-duration speed increase.\n\n<i>Work faster, move faster.</i></size>",
  "ExpressSpeed": "Increased Speed",
  "ExpressSpeedDur": "Increased Speed Duration",
  "Farmer": "Farmer",
  "FarmerInfo": "Plant Seeds & Sell Them For Buffs",
  "FarmerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Grow seeds from your tasks and harvest them for crew buffs.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Planting</color></b>\nEach completed task gives a seed. Pet to plant it anywhere. After the next meeting, it grows. Pet near a grown seed to harvest and sell it for a buff.<size=75%>\n\n- Wheat: Increased vision (all crewmates)\n- Carrot: Shield (all crewmates)\n- Apple: Invisibility (you)\n- Tomato: Speed boost (you)\n- Potato: Reset all killers' cooldowns\n- Blueberry: Arrows to all dead bodies (you)</size>\n\n<i>Every seed planted is a future victory.</i></size>",
  "Farmer.CompleteTaskToGetSeed": "<size=80%><{0}>Complete a task to get a seed</color></size>",
  "Farmer.HarvestRange": "Harvest Range",
  "Farmer.InvisibilityDuration": "Invisibility Duration",
  "Farmer.MoreSeeds": "<size=80%>{0} more seeds in store</size>",
  "Farmer.Seed.Apple": "Apple",
  "Farmer.Seed.Blueberry": "Blueberry",
  "Farmer.Seed.Carrot": "Carrot",
  "Farmer.Seed.Potato": "Potato",
  "Farmer.Seed.Tomato": "Tomato",
  "Farmer.Seed.Wheat": "Wheat",
  "Farmer.SelectedSeed": "<{0}>Pet</color> to plant {1} seed",
  "Forensic": "Forensic",
  "ForensicInfo": "Gain extra info from your body reports",
  "ForensicInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Report bodies to extract detailed clues about the victim and killer.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Forensic Analysis</color></b>\nAfter reporting a body, receive clues about the victim's role, cause of death, time of death, killer's role, color type, and add-ons — depending on settings.\n\n<i>Every corpse is a witness. You just have to listen.</i></size>",
  "ForensicCanknowAddons": "Can find the dead player's add-ons",
  "ForensicCanknowColorType": "Can find the color type of the killer",
  "ForensicCanknowColorTypeMinBodyAge": "Minimum body age to find color type",
  "ForensicCanknowDeathReason": "Can find the cause of death",
  "ForensicCanknowKillTime": "Can find how long ago the player died",
  "ForensicCanknowKiller": "Can find the killer's role",
  "ForensicNoticeAddons": "\\nThe victim's add-ons are: <b>{0}</b>",
  "ForensicNoticeColorType": "\\nThe killer has a {0} color (<size=70%>{1}</color>)",
  "ForensicNoticeDeathReason": "\\nThe victim's cause of death is <b>{0}</b>",
  "ForensicNoticeKillTime": "\\nThe victim died <b>{0}</b> seconds ago",
  "ForensicNoticeKiller": "\\nThe killer's role is <b>{0}</b>",
  "ForensicNoticeKillerNotFound": "The Forensic couldn't find evidence leading to a murderer, this is most likely suicide.",
  "ForensicNoticeVictim": "According to your investigation,\\nthe victim (<b>{0}</b>) had the role [{1}]",
  "FortuneTeller": "Fortune Teller",
  "FortuneTellerInfo": "Get clues to people's roles",
  "FortuneTellerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote players during meetings to divine cryptic clues about their roles.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Fortune Telling</color></b>\nVoting for a player in a meeting reveals a cryptic clue about their role. Once all tasks are complete, you receive the exact role instead of a clue.\n\n<i>The stars do not lie — but they speak in riddles.</i></size>",
  "FortuneTellerCheck": "According to your fortune...",
  "FortuneTellerCheck.Basic": "<b>{0}</b> seems to not have anything worth noting about them.",
  "FortuneTellerCheck.Blockbuster": "Looks like <b>{0}</b> got big desires to change something.",
  "FortuneTellerCheck.Body": "<b>{0}</b> seems to have an unusual obsession with dead bodies.",
  "FortuneTellerCheck.Careless": "<b>{0}</b> seems to not care about what happens.",
  "FortuneTellerCheck.ChangingCD": "<b>{0}</b> seems to have their ability cooldown changing based on certain conditions.",
  "FortuneTellerCheck.Chaos": "<b>{0}</b> seems to like chaos.",
  "FortuneTellerCheck.Death": "<b>{0}</b> seems to have their goal set towards their death.",
  "FortuneTellerCheck.Disguise": "<b>{0}</b> seems to be focused on concealing their identity.",
  "FortuneTellerCheck.Disturbed": "Looks like <b>{0}</b> is disturbed by something.",
  "FortuneTellerCheck.Enthusiasm": "Looks like <b>{0}</b> speaks with everyone very enthusiastic.",
  "FortuneTellerCheck.Glitch": "TV2gPZ4wUJWYr{0}05gA6T5PKzBG17",
  "FortuneTellerCheck.HelpFromDead": "<b>{0}</b> seems to be getting help from the dead.",
  "FortuneTellerCheck.HideMsg": "Looks like <b>{0}</b> hides secrets.",
  "FortuneTellerCheck.Honest": "Looks like <b>{0}</b> is being honest.",
  "FortuneTellerCheck.Impulse": "Looks like <b>{0}</b> is suppressing some kind of impulse.",
  "FortuneTellerCheck.InRush": "<b>{0}</b> seems to be in a rush do achieve something.",
  "FortuneTellerCheck.Incomprehensible": "Looks like <b>{0}</b> is being misunderstood.",
  "FortuneTellerCheck.IndirectKill": "<b>{0}</b> seems to kill in an abnormal way.",
  "FortuneTellerCheck.Kill": "<b>{0}</b> seems to like killing in plain sight.",
  "FortuneTellerCheck.Love": "♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥",
  "FortuneTellerCheck.Meeting": "<b>{0}</b> seems to be focused on using their ability in meetings.",
  "FortuneTellerCheck.None": "Looks like <b>{0}</b> has just an ordinary life.",
  "FortuneTellerCheck.Power": "<b>{0}</b> seems to be quite powerful in some way.",
  "FortuneTellerCheck.Protect": "<b>{0}</b> seems to be focused on protection in some way.",
  "FortuneTellerCheck.Recruit": "<b>{0}</b> seems to enjoy the idea of growing a team.",
  "FortuneTellerCheck.Reflect": "<b>{0}</b> seems to reflect something back to its target.",
  "FortuneTellerCheck.Reveal": "<b>{0}</b> seems to like revealing the role or team of someone.",
  "FortuneTellerCheck.Sabotage": "<b>{0}</b> seems to be focused on sabotages.",
  "FortuneTellerCheck.SlowGame": "<b>{0}</b> seems to like it if the game is going slow.",
  "FortuneTellerCheck.Special": "<b>{0}</b> seems to have something very special about them.",
  "FortuneTellerCheck.Specific": "<b>{0}</b> seems to be helping or sabotaging someone specific.",
  "FortuneTellerCheck.StackKill": "<b>{0}</b> seems to kill more than 1 player at once.",
  "FortuneTellerCheck.Strong": "Looks like <b>{0}</b> has a strong power but is dim in society.",
  "FortuneTellerCheck.Target": "<b>{0}</b> seems to have their eye on someone specific.",
  "FortuneTellerCheck.Task": "<b>{0}</b> seems to be focused on their tasks.",
  "FortuneTellerCheck.TaskDone": "<b>{0}</b>Role -[{1}]",
  "FortuneTellerCheck.UniqueInfo": "<b>{0}</b> seems to know unique information.",
  "FortuneTellerCheck.UnusualGoal": "<b>{0}</b> seems to have an unusual win condition.",
  "FortuneTellerCheck.Vent": "<b>{0}</b> seems to have an obsession with using vents.",
  "FortuneTellerCheck.Vote": "<b>{0}</b> seems to be focused on voting power in some way.",
  "FortuneTellerCheck.Weirdo": "Looks like <b>{0}</b> is mixed in crowd.",
  "FortuneTellerCheckLimit": "Reminder: You have <b>{0}</b> fortunes left",
  "FortuneTellerCheckReachLimit": "You've run out of fortunes.",
  "FortuneTellerCheckResult": "<b>{0}</b> is one of the following roles:\\n{1}",
  "FortuneTellerCheckSelfMsg": "Wow, you found yourself... All you see is a reflection.",
  "FortuneTellerHideVote": "Hide Fortune Teller's Votes",
  "FortuneTellerSkillLimit": "(Initial) Max number of ability uses",
  "Gardener": "Gardener",
  "GardenerInfo": "Plant Plants to Block Kills",
  "GardenerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Grow defensive plants that block kills in their shadow.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Plant</color></b>\nPet to place a plant. After the next meeting, it grows. No direct kills can occur near a grown plant. Once a plant blocks a kill, it disappears.\n\n<i>Nature's shield is patient — but only strikes once.</i></size>",
  "Gardener.PlantAlreadyExistsNearby": "<#ff0000>Can't place a new plant here, one is already nearby!</color>",
  "Gardener.PlantCreated": "<#00ff00>Plant created!</color>\\nIt will be visible after the next meeting.",
  "Gardener.PlantRange": "Plants' Kill Blocking Range",
  "GardenerPlantNearby": "You cannot kill near plants",
  "Gaulois": "Gaulois",
  "GauloisInfo": "Boost Players' Speed",
  "GauloisInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Give a player a permanent speed boost with your kill button.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Speed Up</color></b>\nUse your kill button on someone to permanently increase their movement speed.\n\n<i>A little push makes all the difference.</i></size>",
  "GauloisKillButtonText": "Speed Up",
  "GauloisSpeedBoost": "Additional Speed",
  "Goose": "Goose",
  "GooseInfo": "Honk at players to annoy them",
  "GooseInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>HONK. Drag players around and disrupt their abilities.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Honk</color></b>\nHonk at players to annoy and drag them around. While being honked at, they cannot use their abilities.\n\n<i>HONK.</i></size>",
  "Grappler": "Grappler",
  "GrapplerInfo": "Prevent kills and pull players towards you",
  "GrapplerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Block the first kill of each round and yank the target to safety.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Intercept</color></b>\nIf you have an ability use remaining from the previous round, the first kill attempt is blocked. The target is teleported to you instead of dying. Does not work during sabotages.\n\n<i>Nobody gets taken out on your watch.</i></size>",
  "Grenadier": "Grenadier",
  "GrenadierInfo": "Reduce <color=#ff1919>Impostors</color>' vision by venting",
  "GrenadierInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Throw a flashbang to cripple the vision of killers.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Flashbang</color></b>\nVent or pet to deploy a flashbang that impairs Impostor vision. Depending on settings, Neutrals may also be affected. A shield animation plays on your body when the effect activates. As a Madmate, the flashbang only affects Crewmates.\n\n<i>When the flash goes off, you're already moving.</i></size>",
  "GrenadierCanAffectNeutral": "Can affect <color=#ffab1b>Neutrals</color>",
  "GrenadierCauseVision": "Lowered vision",
  "GrenadierSkillCooldown": "Grenade Cooldown",
  "GrenadierSkillDuration": "Grenade Duration",
  "GrenadierSkillInUse": "Ability in use",
  "GrenadierSkillMaxOfUsage": "(Initial) Max number of Grenades",
  "GrenadierSkillStop": "Ability expired, {0} uses remain",
  "GrenadierVentButtonText": "Flash",
  "GuardianAngelEndKnot": "Guardian Angel",
  "GuardianAngelEndKnotInfo": "Protect the crewmates from the <color=#ff1919>Impostors</color>",
  "GuardianAngelEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Spawn as a ghost and protect the living crew from beyond.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Guardian Blessing</color></b>\nStart the game as a ghost. Use ghost abilities to shield crewmates from Impostor attacks.\n\n<i>Even in death, the watch continues.</i></size>",
  "Guardian": "Guardian",
  "GuardianInfo": "Complete your tasks to become immortal",
  "GuardianInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete your tasks to become unkillable — though not unguessable.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Immortality</color></b>\nBecome immortal upon completing your tasks. You can still be eliminated by guessing during meetings.\n\n<i>Tasks done. Invincible. For now.</i></size>",
  "GuardianAngel": "Guardian Angel",
  "Hacker": "Hacker",
  "HackerInfo": "Watch Admin Table from anywhere",
  "HackerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Access the admin map from anywhere, in different ways depending on your client.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Remote Admin (Modded Client)</color></b>\nOpening the map (with ability uses remaining) displays the admin view. You may be able to move while viewing.\n\n・<b><color=#8cffff>Remote Admin (Vanilla Client)</color></b>\nVent or pet to receive a text notification showing the player count in each room.\n\n<i>Information is the greatest weapon of all.</i></size>",
  "HackButtonText": "Mimic",
  "HackCooldown": "Hack Cooldown",
  "HackDuration": "Hack Duration",
  "HackLimit": "Ability Use Count",
  "HackerAbilitySecondsLeft": "Ability uses left in seconds",
  "HackerModdedClientAbilityUseSecondsMultiplier": "Modded clients, for 1 ability use, can view Admin map for",
  "HackerModdedClientCanMoveWhileViewingMap": "Modded clients can move while looking at Admin map",
  "HackerVanillaClientSeesInfoFor": "Vanilla clients see admin info notify for",
  "Helper": "Helper",
  "HelperInfo": "Complete Tasks For Others",
  "HelperInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your task completions also complete tasks for others.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Share</color></b>\nEach time you complete a task, a random crewmate also has one of their tasks marked complete.\n\n<i>One for all, all for one.</i></size>",
  "HelperCompletedTaskForYou": "The {0} completed a task for you!",
  "Ignitor": "Ignitor",
  "IgnitorInfo": "Light Candles for High Vision",
  "IgnitorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Light candles via tasks to maintain your vision — and immunity to lights sabotage.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Candle</color></b>\nCompleting a task lights a candle, granting maximum vision. As it burns down, your vision shrinks. Since you use candles, the Lights Sabotage has no effect on you.\n\n<i>Keep the candle burning and you'll never be in the dark.</i></size>",
  "IgnitorCountStartTime": "Time to Start Changing Vision",
  "IgnitorEndVision": "End Vision (Smallest Vision)",
  "IgnitorEndVisionTime": "Time to End Vision",
  "IgnitorStartVision": "Starting Vision (Highest)",
  "IgnitorTasksFinishedVision": "Vision after completing all tasks",
  "IgnitorTimeMoveMeeting": "Time Moves During Meetings",
  "Imitator": "Imitator",
  "ImitatorInfo": "Imitate Roles of Dead Players",
  "ImitatorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Imitate the role of a dead crewmate using a chat command.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Imitation</color></b>\nType <b>/cmd imitate {id}</b> to copy the role of a dead crewmate player next round. Non-host players can use the kick menu instead.\n\n<i>The living can carry the torch of the fallen.</i></size>",
  "Imitator.Success": "<#00ff00>✓ <#00bb00>You will be imitating {0} in the next round!",
  "Imitator.TargetMustBeCrew": "<#ff5555>X <#bb0000>Your target must be a <#8cffff>Crewmate</color>!",
  "Imitator.TargetMustBeDead": "<#ff5555>X <#bb0000>Your target must be dead!",
  "Inquirer": "Inquirer",
  "InquirerInfo": "Check Players' Roles",
  "InquirerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Check if a player has a specific role — with a chance of error.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Role Check</color></b>\nType <b>/cmd check {player id} {role}</b> to check whether a player has that role. There's a chance the result is incorrect.\n\n<i>Even a flawed map is better than no map at all.</i></size>",
  "Inquirer.FailChance": "Chance to Show Incorrect Result",
  "Inquirer.MessageFalse": "<#ff0000><b><u>Incorrect!</u></b></color> That player does not have the role you entered.",
  "Inquirer.MessageTrue": "<#00ff00><b><u>Correct!</u></b></color> That player has the role you entered.",
  "Inquisitor": "Inquisitor",
  "InquisitorInfo": "Check Who Knows Whose Role",
  "InquisitorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player in meetings to see whose roles they know.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Knowledge Probe</color></b>\nVote a player during a meeting to reveal whose roles they are aware of.\n\n<i>What you know can save you — or expose you.</i></size>",
  "Inquisitor.ExcludeDeadPlayers": "Exclude Dead Players' Roles Seen",
  "Inquisitor.KnowExactRolesAfterTasksFinished": "Know Exact Roles After Finishing All Tasks",
  "InquisitorNoInfo": "No one, other than themselves",
  "InquisitorVoteResult": "{0} knows the role of:\\n{1}",
  "Insight": "Insight",
  "InsightInfo": "Know What Roles Spawned",
  "InsightInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to learn a random player's role each time.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Role Glimpse</color></b>\nEach completed task reveals a random player's role from the current game. You won't see the same player twice. Remember what you learn — you can't check it later.\n\n<i>Every task brings another piece of the puzzle.</i></size>",
  "InsightNotify": "<color=#ffffff>Someone in the game is</color> {0}",
  "Inspector": "Lab Tech",
  "InspectorInfo": "Validate the alignments of two players",
  "InspectorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Compare two players to see if they are on the same team.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Team Comparison</color></b>\nType <b>/cmd cmp [id1] [id2]</b> to check if two players are on the same team.<size=70%>\n\nTeam rules:\n- Neutral Killers count as one team\n- Non-Killing Neutrals count as separate teams\n- Trickster counts as Crew\n- Madmates count as Impostor\n- Lawyer/Follower and their target count as same team</size>\n\n<i>To divide the enemy, first understand who stands together.</i></size>",
  "InspectorCheckBaitCountMode": "<color=#00f7ff>Bait</color> count as revealing role if <color=#00f7ff>Bait</color> reveal on first meeting is on",
  "InspectorCheckEgoistickCountMode": "<color=#5600ff>Egoist</color> counts as",
  "InspectorCheckFalse": "<b>{0}</b> and <b>{1}</b> are <color=#ff1919>NOT</color> in the same team!",
  "InspectorCheckHelp": "Instructions: <b>/cmd cmp [Player ID 1] [Player ID 2]</b>\\nExample: <b>/cmd cmp 1 5</b>\\nYou can see the player IDs before everyone's names\\n or use the <b>/cmd id</b> command to list the player IDs",
  "InspectorCheckLimitPerMeeting": "Max inspections per meeting",
  "InspectorCheckMax": "Max inspections per game reached!\\nYou can not use your power anymore.",
  "InspectorCheckNull": "Please select an ID of a living player to check their team",
  "InspectorCheckOtherTargetKnow": "Targets know who they were checked with",
  "InspectorCheckReveal": "HA! You thought it would be this easy. You can not check a role that is revealed",
  "InspectorCheckRevealTarget": "When tasks are done, the target knows the team of the other target",
  "InspectorCheckRound": "Max inspections per round reached!\\nYou can check again in the next round.",
  "InspectorCheckSame": "Bruh, did you seriously just compare a player to themselves?",
  "InspectorCheckSelf": "HA!! You thought it would be this easy. You can not check yourself",
  "InspectorCheckTargetKnow": "Targets know they were checked by <color=#0D57AF>Lab Tech</color>",
  "InspectorCheckTargetMsg": " were checked by Lab Tech.",
  "InspectorCheckTrue": "<b>{0}</b> and <b>{1}</b> are in the same team!",
  "InspectorCopTargetReveal": "Looks like <b>{0}</b> is aligned with team <b>{1}</b>",
  "InspectorDead": "You can not use your power after death",
  "Investigator": "Investigator",
  "InvestigatorInfo": "Reveal roles of other players",
  "InvestigatorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Stand close to a player and reveal their role.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Role Reveal</color></b>\nUse your kill button on a player to begin a reveal. Stay near them for the required time to uncover their role. A 「○」 marks your target.\n\n<i>The truth is close — you just have to get closer.</i></size>",
  "InvestigatorCanBeMadmate": "<color=#BA55D3>Investigator</color> can become <color=#ff1919>Madmate</color>",
  "InvestigatorKillButtonText": "Reveal",
  "InvestigatorRevealCooldown": "<color=#BA55D3>Reveal</color> Cooldown",
  "InvestigatorTime": "<color=#BA55D3>Reveal</color> Time",
  "InvestigatorVision": "<color=#BA55D3>Investigator</color> Vision",
  "Jailor": "Jailor",
  "JailorInfo": "Lock up your target in Jail",
  "JailorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Lock a player in jail to protect them — and interrogate them privately.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Jail</color></b>\nUse your kill button to send a player to jail. Jailed players cannot be guessed or judged, and can only guess you. Communicate privately with jailed players via <b>/cmd jailtalk [message]</b>.\n\n<i>Behind bars, the truth comes out.</i></size>",
  "JailedCanOnlyGuessJailor": "You have been jailed. You can only guess Jailor.",
  "JailedNotifyMsg": "You have been locked up in Jail by the Jailor. No one can guess or judge you and you can only guess Jailor.",
  "JailedSuffix": "JAILED",
  "JailorJailCooldown": "Jail cooldown",
  "JailorTargetAlreadySelected": "You have already selected a target",
  "SuccessfullyJailed": "Target successfully Jailed",
  "notifyJailedOnMeeting": "Notify Jailed player when meeting starts",
  "Journalist": "Journalist",
  "JournalistInfo": "Write Down Notes",
  "JournalistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Write notes during the game — and share them with the crew upon death.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Notes</color></b>\nUse <b>/cmd note {add/remove/clear/view} [value]</b> to manage your notes. When you die, all players see your notes at the next meeting.\n\n<i>A journalist's final publication is their most important one.</i></size>",
  "Journalist.CommandUsage": "Usage: <b>/cmd note {add/remove/clear/view} [value]</b>",
  "JournalistError.ArgumentOutOfRange": "The index you provided is out of range. Use <b>/cmd note view</b> to see the indexes of your notes.",
  "JournalistError.IndexOutOfRange": "You didn't provide enough arguments.",
  "JournalistError.InvalidArgument": "Invalid argument. Use <b>/cmd note {add/remove/clear/view} [value]</b>",
  "JournalistError.Unknown": "An unknown error occurred.",
  "Judge": "Meeting Sheriff",
  "JudgeInfo": "Silence in the courtroom!",
  "JudgeInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Silence in the courtroom.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Role]\n・<b><color=#f8d85a>Meeting Sheriff</color></b>\nDuring meetings, the Meeting Sheriff can put a player on trial and execute the wicked. Trial uses are limited — guess wrong and pay with your life.\n\n＜Trial Effect＞\n・If the target is trialable, they die instantly.\n・If the target is not trialable, the Meeting Sheriff dies instead.\n・Who is trialable depends on host settings.\n\n＜Special Cases＞\n・Trialing yourself counts as suicide.\n・Targets imprisoned by the <color=#aa900d>Jailor</color> cannot be trialed.\n・Targets shielded by the <color=#00ff97>Medic</color> cannot be trialed (configurable to ignore the shield).\n・If the Meeting Sheriff becomes <color=#ff1919>Madmate</color>, every trial succeeds against any target.\n・<color=#343136>Pestilence</color> and <b>Trickster</b> always kill the Meeting Sheriff regardless.\n\n＜Trial Limits＞\n・Three caps apply: per meeting, per game, and total ability uses.\n・Completing tasks can refill ability uses (configurable).\n\n＜Win Condition＞\nSame as <color=#8cffff>Crewmates</color>.\n\n<i>Silence in the courtroom. See the truth — and judge without hesitation.</i>\n\n[Commands]\n・Trial:　<b>/tl [player id]</b>　(or <b>/jj</b>)\n・Check IDs:　<b>/id</b></size>",
  "JudgeCanBeMadmate": "<color=#f8d85a>Meeting Sheriff</color> can become <color=#ff1919>Madmate</color>",
  "JudgeCanTrialContagious": "Can trial <color=#2E8B57>Contagious</color>",
  "JudgeCanTrialConverted": "Can trial <#ffab1b>Converted</color> players",
  "JudgeCanTrialCoven": "Can trial <color=#7b3fbb>Coven</color>",
  "JudgeCanTrialInfected": "Can trial <color=#7B8968>Infected</color>",
  "JudgeCanTrialMadmate": "Can trial <color=#ff1919>Madmates</color>",
  "JudgeCanTrialNeutralB": "Can trial <color=#ffab1b>Neutral</color> <color=#046300>Benign</color>",
  "JudgeCanTrialNeutralE": "Can trial <color=#ffab1b>Neutral</color> <color=#912900>Evil</color>",
  "JudgeCanTrialNeutralK": "Can trial <color=#ffab1b>Neutral</color> <color=#ff1919>Killing</color>",
  "JudgeCanTrialSidekick": "Can trial <color=#00b4eb>Sidekick</color>",
  "JudgeCanTrialnCrewKilling": "Can trial <color=#8cffff>Crewmate</color> <color=#ff1919>Killing</color>",
  "JudgeDead": "Sorry, you can't trial after death.",
  "JudgeTrialMax": "\\nNo more trials left!",
  "LazyGuy": "Lazy Guy",
  "LazyGuyInfo": "You're too lazy",
  "LazyGuyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>One task. Zero effort. Completely immune to Impostor abilities.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Laziness</color></b>\nHas only one task and is immune to all Impostor abilities. No add-ons.\n\n<i>Effort is overrated.</i></size>",
  "Leery": "Leery",
  "LeeryInfo": "Investigate Who Isn't a Crewmate",
  "LeeryInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Stand near someone to sense if they aren't a crewmate.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Suspicion</color></b>\nIf the nearest player stays close to you for the required duration, you'll be notified if they're not a crewmate.\n\n<i>Something about them just doesn't feel right.</i></size>",
  "Leery.Duration": "Time to Stand Near Someone",
  "Leery.Radius": "Maximum Distance to Stand Near Someone",
  "Leery.ShowNearestPlayerName": "Show Nearest Player's Name",
  "Leery.ShowProgress": "Show Progress",
  "LeeryNotify": "<#ffff00>The nearest player is not a crewmate!</color>",
  "LeerySuffix": "<size=80%>Investigating {0}....</size>",
  "Lighter": "Lighter",
  "LighterInfo": "Catch killers with your enhanced vision",
  "LighterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to temporarily boost your vision — including during lights out.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Light Boost</color></b>\nVent or pet to gain improved vision for a set duration. Works even when lights are sabotaged.\n\n<i>No darkness can stop someone who carries their own light.</i></size>",
  "LighterSkillCooldown": "<color=#eee5be>Light</color> Cooldown",
  "LighterSkillDuration": "<color=#eee5be>Light</color> Duration",
  "LighterSkillInUse": "Ability in use",
  "LighterSkillStop": "Ability expired",
  "LighterVentButtonText": "Light",
  "LighterVisionNormal": "Increased Vision",
  "LighterVisionOnLightsOut": "Increased Vision During Lights Out",
  "Lookout": "Lookout",
  "LookoutInfo": "See through shapeshifts",
  "LookoutInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>See every player's ID at all times — pierce through shapeshifts.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>ID Vision</color></b>\nAll players always display their numeric ID. This lets you track players through shapeshifts and camouflages.\n\n<i>You can change your face, but never your number.</i></size>",
  "LovingCrewmate": "Lover",
  "LovingCrewmateInfo": "Stay alive and win together!",
  "LovingCrewmateInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Stay alive and help your lover win — or fall with them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Lover's Bond</color></b>\nYour goal is to survive until the end and help your lover win. If your lover dies, you die with them.\n\n<i>Together or not at all.</i></size>",
  "Luckey": "Luckey",
  "LuckeyInfo": "Dodge attacks",
  "LuckeyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>A chance to dodge any kill — pure luck, no warning.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Lucky Dodge</color></b>\nEach kill attempt on you has a host-set probability of being evaded. The killer sees a shield animation but you remain unaware.\n\n<i>Fortune smiles on the chosen few.</i></size>",
  "LuckeyProbability": "Probability of surviving a kill",
  "Markseeker": "Markseeker",
  "MarkseekerInfo": "Predict Someone's Role",
  "MarkseekerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your first vote marks someone — and your death reveals their role.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Final Mark</color></b>\nYour first vote each game marks that player as your target. When you die, everyone learns your target's role.\n\n<i>The last secret I carry will outlast me.</i></size>",
  "Marshall": "Marshall",
  "MarshallInfo": "Finish your tasks to prove your innocence",
  "MarshallInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete your tasks to reveal your identity and earn the crew's trust.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Self-Reveal</color></b>\nFinishing your tasks reveals you to the rest of the crew. Host settings control which teams can see you.\n\n<i>Trust must be earned — and proven through action.</i></size>",
  "MarshallCanBeGuessedOnTaskCompletion": "Can be Guessed on Task Completion",
  "MarshallCanBeMadmate": "<color=#5573AA>Marshall</color> can become <color=#ff1919>Madmate</color>",
  "Mathematician": "Mathematician",
  "MathematicianInfo": "Ask Math Questions",
  "MathematicianInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Ask math questions in meetings — the first to answer correctly gets a reward.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Math Challenge</color></b>\nType <b>/cmd ask [number] [number]</b> to post a math question. The first player to answer correctly via <b>/answer [answer]</b> gains +1 ability use and a shield for the next round. One question per meeting.\n\n<i>Knowledge protects. Ignorance kills.</i></size>",
  "MathematicianAnsweredString": "<b>{0}</b> has answered correctly! ({1})\nThey got +1 ability use and will be shielded for the next round.",
  "MathematicianProtected": "This player was the first to answer the Mathematician's question correctly,\\ntherefore they're shielded",
  "MathematicianQuestionString": "What is <b>{0} + {1}</b>?\n\nType <b>/answer [answer]</b> to answer.\nFirst to answer correctly gets shielded for the next round!",
  "Mayor": "Mayor",
  "MayorInfo": "Your vote counts multiple times",
  "MayorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your vote carries the weight of many — and you may hold a portable button.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Extra Votes</color></b>\nYour vote counts as multiple votes. Optionally gain more votes by completing tasks.\n\n・<b><color=#8cffff>Mobile Button</color></b>\nDepending on settings, call emergency meetings from anywhere using a portable button.\n\n<i>Leadership means your voice carries further.</i></size>",
  "MayorAdditionalVote": "Additional Votes Count",
  "MayorCanBeMadmate": "<color=#204d42>Mayor</color> can become <color=#ff1919>Madmate</color>",
  "MayorCanGainVotes": "<color=#204d42>Mayor</color> can gain votes by doing tasks",
  "MayorHasPortableButton": "<color=#204d42>Mayor</color> has a Mobile Emergency Button",
  "MayorHideVote": "Hide additional vote(s)",
  "MayorNumOfUseButton": "Max Number of Mobile Emergency Buttons",
  "MayorRevealWhenDoneTasks": "<color=#204d42>Mayor</color> is revealed to everyone on task completion",
  "MayorSeesVoteColorsWhenDoneTasks": "<color=#204d42>Mayor</color> sees vote colors on task completion",
  "MayorTasksPerVoteGain": "Amount of votes gained per task completed",
  "MaxMayorTaskVotes": "Maximum votes Mayor can gain by task",
  "MayorVentButtonText": "Button",
  "Mechanic": "Sabotage Master",
  "MechanicInfo": "Vent and fix sabotages quickly",
  "MechanicInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>A multi-tool utility role — vent freely and fix sabotages with ease.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Access</color></b>\nVent at any time.\n\n・<b><color=#8cffff>Sabotage Mastery</color></b>\nFix Reactors, O2, and Comms from one side. Fix Lights with one switch. Open all doors in a building at once.\n\n<i>Every broken thing is just a job waiting to be done.</i></size>",
  "MechanicCanFixSabotageFromAnywhereWithPet": "Can Fix Sabotages From Anywhere If Pets Are On",
  "MechanicFixesCommunications": "Can Fix Both Comms Alone In <color=#e84b56>MIRA HQ</color>",
  "MechanicFixesDoors": "Can open all doors in the same building",
  "MechanicFixesElectrical": "Can Fix Lights With One Switch",
  "MechanicFixesOxygens": "Can Fix Both O2 Alone",
  "MechanicFixesReactors": "Can Fix Both Reactors Alone",
  "MechanicMaxFixedViaPet": "Max Sabotages Fixed Via Pet",
  "MechanicSkillLimit": "Max use of Abilities (Excluding Doors)",
  "MechanicUsesUsedWhenFixingLightsOrComms": "Uses it takes to fix Lights/Comms",
  "MechanicUsesUsedWhenFixingReactorOrO2": "Uses it takes to fix Reactor/O2",
  "Medic": "Medic",
  "MedicInfo": "Cast a shield onto a player",
  "MedicInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Shield a player from death — at the risk of your own life.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Shield</color></b>\nPress your kill button to place a shield on a player. The shield blocks kill attempts. Settings control: who sees the shield (shown as 「●」 next to the name), whether it breaks on kill attempt, whether it disappears when you die, and whether your kill cooldown resets on attack.\n\n<i>To protect another, you must be willing to fall first.</i></size>",
  "MedicAmountOfShields": "Number of Shields Per Game",
  "MedicKillerTryBrokenShieldTargetForMedic": "Someone tried killing the player you shielded!",
  "MedicKillerTryBrokenShieldTargetForTarget": "Someone tried killing you!",
  "MedicKnowShieldBroken": "Who sees kill attempt",
  "MedicResetCooldown": "On kill attempt, reset murderer's cooldown to",
  "MedicShielDeactivationIsVisible": "Shield deactivation is visible",
  "MedicShieldBreakIsVisible": "Shield Break is Visible",
  "MedicShieldBreaksOnKillAttempt": "<color=#00ff97>Medic</color> Shield Breaks on Kill Attempt",
  "MedicShieldDeactivatesWhenMedicDies": "Shield deactivates when the <color=#00ff97>Medic</color> dies",
  "MedicShieldedCanBeGuessed": "Guessing ignores <color=#00ff97>Medic</color> shield",
  "MedicShieldedCanBeJudged": "Judging ignores <color=#00ff97>Medic</color> shield",
  "MedicWhoCanSeeProtect": "Who can see shield",
  "MedicalerButtonText": "Protect",
  "Medium": "Medium",
  "MediumInfo": "Talk with ghosts",
  "MediumInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Contact the recently departed and ask them a yes-or-no question.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Spirit Contact</color></b>\nAfter a body is reported, contact that player's spirit. They can respond once with yes (<b>/ms yes</b>) or no (<b>/ms no</b>) to your question.\n\n<i>The dead still have things to say — if you know how to ask.</i></size>",
  "MediumContactLimit": "(Initial) Max number of contacts (ability uses)",
  "MediumDone": "You successfully responded to the Medium.",
  "MediumHelp": "<b>/ms yes</b> to agree\\n<b>/ms no</b> to disagree",
  "MediumKnowPlayerDead": "Someone died somewhere",
  "MediumNo": "You thought you heard a quiet voice from another world denying the answer to your question.",
  "MediumNotifySelf": "You established contact with <b>{0}</b>, please ask questions to them and wait for them to respond.\\n\\nRemaining ability uses: {1}",
  "MediumNotifyTarget": "<b>{0}</b>, the Medium, has established contact with you. Before the end of this meeting, you have a chance to respond to their question. Type one of the following commands to answer:\\nConfirm: /ms yes\\nDeny: /ms no",
  "MediumOnlyReceiveMsgFromCrew": "Receive messages only from <color=#8cffff>Crewmates</color> (including <color=#ff1919>Madmates</color> and <color=#cf6acd>Charmed</color> Players)",
  "MediumYes": "You thought you heard a quiet voice from another world affirming the answer to your question.",
  "MeetingManager": "Meeting Manager",
  "MeetingManagerInfo": "Receive Additional Info About Meeting Commands",
  "MeetingManagerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Receive secret information about meeting commands and guesses.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Meeting Intelligence</color></b>\nSee the roles of guessed players. Know when someone misguesses, and observe other hidden meeting commands (swaps, comparisons, judgments, etc.).\n\n<i>In a meeting full of secrets, you know the most.</i></size>",
  "MeetingManagerMessageAboutCommand": "Someone used the <b>{1}</b> command.",
  "MeetingManagerMessageAboutCompare": "The <b>{0}</b> compared <b>{1}</b> and <b>{2}</b>.",
  "MeetingManagerMessageAboutGuessedRole": "Their role was <b>{0}</b>",
  "MeetingManagerMessageAboutJudgeSuicide": "<b>{0}</b> suicided as a <b>{1}</b>.",
  "MeetingManagerMessageAboutMisguess": "<b>{0}</b> misguessed.",
  "MeetingManagerMessageAboutSwap": "The <b>{0}</b> decided to swap the votes of <b>{1}</b> and <b>{2}</b>.",
  "Merchant": "Merchant",
  "MerchantInfo": "Sell Add-ons and bribe killers",
  "MerchantInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Sell add-ons for profit — and bribe killers to stay their hand.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Add-on Selling</color></b>\nEach completed task gives a random add-on to a random player and earns you money.\n\n・<b><color=#8cffff>Bribery</color></b>\nAccumulate enough money to automatically bribe the next killer who targets you. They cannot kill you, but you don't know who it is. Bribe money is consumed.\n\n<i>Everyone has a price. You just need to afford it.</i></size>",
  "MerchantAddonDelivered": "Add-on sold",
  "MerchantAddonSell": "The Merchant sold you a new Add-on",
  "MerchantAddonSellFail": "Could not sell an Add-on",
  "MerchantGivesAllMoneyOnBribe": "<color=#D27D2D>Merchant</color> gives <color=#ff0000>all the money</color> on bribe",
  "MerchantKillAttemptBribed": "An attempted killing was averted by bribery",
  "MerchantMaxSell": "Max number of Add-ons to sell",
  "MerchantMoneyPerSell": "Amount of <color=#D27D2D>money</color> earned for selling an Add-on",
  "MerchantMoneyRequiredToBribe": "Amount of <color=#D27D2D>money</color> required to bribe a killer",
  "MerchantNotifyBribery": "Inform <color=#d27d2d>Merchant</color> when a killer gets bribed",
  "MerchantSellExperimental": "Can sell <color=#76b8e0>experimental</color> Add-ons",
  "MerchantSellHarmful": "Can sell <color=#ff1919>Harmful</color> Add-ons",
  "MerchantSellHarmfulToEvil": "Can sell <color=#ff1919>Harmful</color> Add-ons only to <color=#ff1919>Evil</color>",
  "MerchantSellHelpful": "Can sell <color=#8cffff>Helpful</color> Add-ons",
  "MerchantSellHelpfulToCrew": "Can sell <color=#8cffff>Helpful</color> Add-ons only to <color=#8cffff>Crew</color>",
  "MerchantSellMixed": "Can sell <color=#00ffa5>Mixed</color> Add-ons",
  "MerchantSellNeutral": "Can sell <color=#ffab1b>Neutral</color> Add-ons",
  "MerchantSellOnlyEnabledAddons": "Can Only Sell Enabled Add-ons",
  "MerchantTargetCoven": "Can sell to <color=#7b3fbb>Coven</color>",
  "MerchantTargetCrew": "Can sell to <color=#8cffff>Crewmates</color>",
  "MerchantTargetImpostor": "Can sell to <color=#ff1919>Impostors</color>",
  "MerchantTargetNeutral": "Can sell to <color=#ffab1b>Neutrals</color>",
  "Mole": "Mole",
  "MoleInfo": "TP to Random Vents by Entering One",
  "MoleInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent and emerge at a random location across the map.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Random Teleport</color></b>\nVenting kicks you out and teleports you to a random vent on the map.\n\n<i>Unpredictable even to yourself.</i></size>",
  "Monarch": "Monarch",
  "MonarchInfo": "Give your crew extra voting power!",
  "MonarchInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Knight your allies to give them extra voting power.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Knight</color></b>\nUse your kill button to knight a player, giving them an extra vote. Players already with extra votes cannot be knighted. Knighted players appear with golden names.\n\n<i>Choose your knights wisely.</i></size>",
  "MonarchInvalidTarget": "Target cannot be knighted",
  "MonarchKillButtonText": "Knight",
  "MonarchKnightCooldown": "Knight Cooldown",
  "MonarchKnightMax": "Maximum Knights",
  "MonarchKnightedPlayer": "You successfully knighted a player!",
  "Mortician": "Mortician",
  "MorticianInfo": "Report a body to know who interacted with them last",
  "MorticianInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Report a body to learn who the victim last contacted.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Last Contact</color></b>\nWhen you report a body, you learn the name of the last player the victim was near during their lifetime.\n\n<i>The last person they saw may be the key to everything.</i></size>",
  "MorticianGetInfo": "According to your inspection, the last person <b>{0}</b> came into contact with during their lifetime was <b>{1}</b>.",
  "MorticianGetNoInfo": "According to your inspection, <b>{0}</b> did not seem to have contact with anyone during their lifetime.",
  "Negotiator": "Negotiator",
  "NegotiatorInfo": "Negotiate with Players",
  "NegotiatorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Force your vote target to choose between bad options — or die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Negotiation</color></b>\nVote someone during a meeting to force them into a choice: suicide, a harmful add-on, permanent low vision, or permanent low speed. They use <b>/cmd neg {index}</b> to pick. If they don't respond, they die. You learn their choice after the meeting. One negotiation per meeting.\n\n<i>Every negotiation has a winner and a loser.</i></size>",
  "Negotiator.FinishNotify": "<#00ffa5>Your target chose to</color> {0}",
  "Negotiator.LowSpeed": "Low speed",
  "Negotiator.LowVision": "Low vision",
  "Negotiator.MinVotingTimeLeftToNegotiate": "Minimum Voting Time Left to Negotiate",
  "Negotiator.TargetMessage": "<b><u>The Negotiator forced you to pick one of the following options (use <b>/neg {index}</b>, replacing {index} with the number shown before the option you want, e.g. <b>/neg 1</b>), or you die:</u></b>\\n<size=80%>",
  "Negotiator.TargetPickSuccess": "You've chosen to <b>{0}</b>",
  "Negotiator.Type.HarmfulAddon": "Receive a Harmful Add-on",
  "Negotiator.Type.LowSpeed": "Get Permanent low speed",
  "Negotiator.Type.LowVision": "Get Permanent low vision",
  "Negotiator.Type.Suicide": "Suicide",
  "NiceEraser": "Nice Eraser",
  "NiceEraserInfo": "Erase the roles of <color=#ff1919>evil</color> players",
  "NiceEraserInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player to strip their role away after the meeting.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Role Erasure</color></b>\nVote any player during a meeting. Their role resets to the basis of that role after the meeting ends. Limited uses.\n\n<i>Sometimes the kindest thing is to start over.</i></size>",
  "NiceEraserHideVote": "Hide <color=#00a5ff>Nice Eraser</color>'s Votes",
  "NiceGuesser": "Nice Guesser",
  "NiceGuesserInfo": "Guess <color=#ff1919>evil</color> roles in meetings to kill",
  "NiceGuesserInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Guess an evil player's role during a meeting to eliminate them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Guess</color></b>\nType <b>/cmd bt [player id] [role]</b> during a meeting. A correct guess kills the target. A wrong guess kills you instead.\n\n<i>One guess. One shot. Make it count.</i></size>",
  "Nightmare": "Nightmare",
  "NightmareInfo": "You cannot be killed during lights out",
  "NightmareInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>During lights out, you are untouchable.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Darkness Immunity</color></b>\nCannot be killed during the Lights Sabotage.\n\n<i>The dark is not something to fear — it's home.</i></size>",
  "NoisemakerEndKnot": "Noisemaker",
  "NoisemakerEndKnotInfo": "Alert the crewmates when you die",
  "NoisemakerEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>When you die, every crewmate gets an alert and an arrow to your body.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Death Alert</color></b>\nUpon death, all crewmates are immediately notified and receive an arrow pointing to your body.\n\n<i>Even in death, the alarm sounds.</i></size>",
  "Observer": "Observer",
  "ObserverInfo": "Vote a player to watch; get notified if they die",
  "ObserverInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player to watch them — and get notified if they die.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Watch</color></b>\nVote a player during a meeting to set them as your watch target. If they die, you receive a kill flash and a notification. Limited monitoring uses.\n\n<i>A silent guardian keeps careful watch.</i></size>",
  "ObserverMaxMonitoring": "Max Monitoring Count",
  "ObserverTaskAwakening": "Task Awakening",
  "ObserverAwakeningTaskCount": "Awakening Task Count",
  "ObserverTargetDied": "{0} has died.",
  "Oracle": "Oracle",
  "OracleInfo": "Vote a player to see their alignment",
  "OracleInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player to see their alignment — but the answer might be wrong.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Alignment Read</color></b>\nVote a player in a meeting to see if they are a Crewmate, Neutral, Impostor, or Coven. There's a host-set chance of receiving an incorrect result.\n\n<i>Even oracles can be deceived.</i></size>",
  "OracleCheck": "Target Results:",
  "OracleCheck.Coven": "Appears to be a Coven member",
  "OracleCheck.Crew": "Appears to be a Crewmate",
  "OracleCheck.Imp": "Appears to be an Impostor",
  "OracleCheck.Neut": "Appears to be a Neutral",
  "OracleCheckLimit": "Reminder: You have <b>{0}</b> uses left",
  "OracleCheckReachLimit": "You're out of uses!",
  "OracleCheckSelfMsg": "You can't even trust yourself, huh?",
  "OracleHideVote": "Hide <color=#6666FF>Oracle</color>'s vote",
  "OracleSkillLimit": "Maximum Uses",
  "Oxyman": "Oxyman",
  "OxymanInfo": "Your Oxygen Level Affects Everything",
  "OxymanInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Manage your oxygen level — or suffocate.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Oxygen Level</color></b>\nYour O₂ level decreases over time. Vent to restore it. At 0%, you die. Low O₂ = slow and blind. High O₂ = faster. Very high = invulnerable.\n\n<i>Breathe. Stay sharp. Stay alive.</i></size>",
  "Oxyman.Blind.BelowPercentage": "Blind Below",
  "Oxyman.DecreasementEachSecond": "Every Second, Oxygen Level Decreases by",
  "Oxyman.Fast.AbovePercentage": "Fast Above",
  "Oxyman.IncrementByVenting": "On Venting, Oxygen Level Increases by",
  "Oxyman.Invulnerable.AbovePercentage": "Invulnerable Above",
  "Oxyman.Slow.BelowPercentage": "Slow Below",
  "Pacifist": "Pacifist",
  "PacifistInfo": "Vent/Pet to reset kill cooldowns",
  "PacifistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to reset all kill cooldowns — killers included.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Cooldown Reset</color></b>\nVent or pet to instantly reset the kill cooldowns of all players with a kill button. As a Madmate, this only affects Crewmates.\n\n<i>Peace through neutralization.</i></size>",
  "PacifistCooldown": "Ability Cooldown",
  "PacifistMaxOfUsage": "Max Number of Ability Uses",
  "PacifistMaxUsage": "Ability use limit reached",
  "PacifistOnGuard": "Ability used, {0} uses remain",
  "PacifistSkillNotify": "Pacifist reset your kill cooldown",
  "PacifistVentButtonText": "Reset",
  "Paranoid": "Buttoneer",
  "ParanoidInfo": "You have a portable meeting button",
  "ParanoidInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Carry a portable meeting button for emergencies.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Panic Button</color></b>\nVent or pet to call an emergency meeting from anywhere. The report animation shows a colored body, but you're still alive.\n\n<i>When in doubt, call it out.</i></size>",
  "ParanoidNumOfUseButton": "Max number of portable buttons",
  "ParanoidVentButtonText": "Panic",
  "ParanoidVentCooldown": "Vent Cooldown",
  "Perceiver": "Perceiver",
  "PerceiverInfo": "Check How Many Killers Are Nearby",
  "PerceiverInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to scan nearby for killers.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Killer Scan</color></b>\nVent or pet to receive a count of how many killers are currently within your radius.\n\n<i>You can feel their presence before you see them.</i></size>",
  "PerceiverNotify": "There are {0} killers nearby",
  "PerceiverRadius": "Radius",
  "PortalMaker": "Portal Maker",
  "PortalMakerInfo": "Make Portals & Teleport Between Them",
  "PortalMakerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Place two portals — and let anyone warp between them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Portal Pair</color></b>\nPet to place a portal. Both must be placed to activate. Anyone walking near one is instantly teleported to the other. Portals have a 5-second use cooldown.\n\n<i>Distance is just a setting.</i></size>",
  "PortalMaker.PetToRemovePortals": "Can Pet To Remove Both Portals After Placing Them",
  "President": "President",
  "PresidentInfo": "Control The Game",
  "PresidentInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Six powerful decrees — one per meeting, each used only once.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Decree</color></b>\nType <b>/cmd decree {number}</b> in a meeting to invoke a decree:\n<size=70%>1. Revealing — expose yourself as President; become unguessable, lose half vision permanently\n2. Finishing — end the meeting instantly without counting votes\n3. Declassification — reveal everyone's voting colors at meeting end\n4. Government Support — grant all crewmates +1 ability use\n5. Investigation — learn how many Impostors and Neutral Killers are alive\n6. Government Recruiting — vote a crewmate to assign them a configured role</size>\n\n<i>Power in the right hands changes everything.</i></size>",
  "President.Decree.Declassification": "Declassification Decree",
  "President.Decree.Finish": "Finishing Decree",
  "President.Decree.GovernmentRecruiting": "Government Recruiting Decree",
  "President.Decree.GovernmentSupport": "Government Support Decree",
  "President.Decree.Investigation": "Investigation Decree",
  "President.Decree.Reveal": "Revealing Decree",
  "President.DecreeAlreadyChosenThisMeetingMessage": "You have already chosen a decree this meeting!",
  "President.DecreeAlreadyUsedMessage": "You have already used this decree or it isn't enabled!",
  "President.GovernmentRecruiting.RecruitedRole": "Recruited role",
  "President.Help": "Command: <b>/cmd decree {decree ID}</b>\\nYou can see the decree IDs by typing <b>/cmd decree</b>",
  "President.Recruit.TargetNotifyMessage": "You have been recruited by the <#30916f>President</color>!",
  "President.Reveal.CanBeConvertedAfterRevealing": "Can be <#ffab1b>converted</color> after revealing",
  "President.Reveal.ConvertedPresidentCanReveal": "<#ffab1b>Converted</color> <#30916f>President</color> can reveal",
  "President.UsedDecreeMessage.Everyone": "The <#30916f>President</color> has used the <#ffab1b>{0}</color>!",
  "President.UsedDecreeMessage.RevealMessage": "{0} is the <#30916f>President</color>!",
  "PresidentCanBeMadmate": "<color=#30916f>President</color> can become <color=#ff1919>Madmate</color>",
  "Psychic": "Psychic",
  "PsychicInfo": "One of the red names is <color=#ff1919>evil</color>",
  "PsychicInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Among the red names in meetings — at least one is evil.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Evil Sense</color></b>\nDuring meetings, some players appear with red names. At least one of them is genuinely evil. As a Madmate, all Neutrals and killing Crewmates show red instead.\n\n<i>The guilty glow red — but so do a few innocents.</i></size>",
  "PsychicCanSeeNum": "Max number of red names",
  "PsychicFresh": "New red names every meeting",
  "Rabbit": "Rabbit",
  "RabbitInfo": "Get Clues Toward Impostor Locations",
  "RabbitInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to earn brief arrows toward a random Impostor.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Impostor Arrow</color></b>\nEach task completion points an arrow at a random Impostor for 5 seconds. May require a minimum number of tasks before activating.\n\n<i>Work hard enough and they can't hide.</i></size>",
  "RabbitMinTasks": "Minimum Number of Tasks Completed to Activate Ability",
  "Randomizer": "Randomizer",
  "RandomizerInfo": "stuff's 'boutta get wonky.",
  "RandomizerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Random chaos erupts around you every few seconds — good luck.\n_____________________________________\nDifficulty: ★★★★★\n\n[Skills]\n・<b><color=#8cffff>Random Effect</color></b>\nEvery X seconds, a random event fires — affecting you or everyone. Effects range from super speed and inverted controls to sniper shots, time bombs, and total blindness.\n\n<i>Have fun! — The Dev</i></size>",
  "RandomizerEffectDurMax": "Maximum Effect Duration",
  "RandomizerEffectDurMin": "Minimum Effect Duration",
  "RandomizerEffectFrequency": "Random Effect Frequency",
  "RandomizerNotifyOpt": "Notify When RNG Event Happens (turn off if events are frequent)",
  "Retributionist": "Retributionist",
  "RetributionistInfo": "Find & Kill Your Target's Killer",
  "RetributionistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Camp a target — and avenge their death if you identify the killer.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Retribution</color></b>\nUse your kill button to mark a player and camp them. If they die, you are notified. In the following meeting, use <b>/cmd retribute {id}</b> to execute their killer. A wrong guess does nothing. You can camp a new player each meeting.\n\n<i>Justice delayed is justice still served.</i></size>",
  "Retributionist.Fail": "<#ff0000>X</color> <#bb0000>Wrong!",
  "Retributionist.KillerDead": "<#ffa500>-</color> <#ffab1b>Correct, but the killer is already dead, or they've disconnected.",
  "Retributionist.ResetCampedPlayerAfterEveryMeeting": "Can Camp a New Player After Every Meeting",
  "Retributionist.Success": "<#00ff00>✓</color> Correct!",
  "Retributionist.SuccessOthers": "{0} was killed by a {1}!",
  "Retributionist.TargetDead": "<#ffff00>Your target is dead!</color>\\nYou can use <u>/cmd retribute {id}</u> to kill the player who killed your target in the next meeting.",
  "Rhapsode": "Rhapsode",
  "RhapsodeInfo": "Sing to Distract the Killers",
  "RhapsodeInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Sing to lock out vents and shapeshifts across the ship.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Song</color></b>\nVent or pet to begin singing. While active, no one can vent or shapeshift — they're too distracted. Settings may exclude Crewmates from this restriction.\n\n<i>Your voice is your weapon.</i></size>",
  "Rhapsode.ExcludeCrewmates": "Exclude <#8cffff>Crewmates</color>",
  "Ricochet": "Ricochet",
  "RicochetInfo": "Protect yourself from someone specific",
  "RicochetInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player in a meeting — and they can't kill you next round.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Target Lock</color></b>\nVote a player during a meeting to designate them as your target. In the following round, your target is unable to kill you. Resets each meeting.\n\n<i>You saw it coming before they could act.</i></size>",
  "Safeguard": "Safeguard",
  "SafeguardInfo": "You Get a Temporary Shield by Completing Tasks",
  "SafeguardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to earn a temporary shield against death.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Shield</color></b>\nEach completed task grants a temporary shield that blocks the next kill attempt.\n\n<i>Diligence is its own armor.</i></size>",
  "SafeguardSuffix": "<#00ffa5>You're shielded</color>",
  "SafeguardSuffixTimer": "<#00ffa5>You're shielded for</color> <b>{0}</b>s",
  "Sandbox": "Sandbox",
  "SandboxInfo": "Build walls by placing blocks",
  "SandboxInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Drop solid blocks anywhere — they become walls that bounce anyone who touches them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Place Block</color></b>\nPress Pet to drop a block at your feet. Blocks are roughly two crew wide and act as walls — anyone who steps on them (including you) is ejected to the nearest open spot. There's a cap on how many blocks can exist at once; placing past the cap removes the oldest one. Blocks are cleared during meetings and respawn at the same positions afterward.\n\n<i>The map is yours to redraw.</i></size>",
  "SandboxMaxBlocks": "Maximum Blocks at Once",
  "SandboxPlaceCooldown": "Place Cooldown",
  "SandboxBlockRadius": "Block Hitbox Radius",
  "SandboxBlockPlaced": "<#8cffff>Block placed</color>",
  "SandboxCooldownActive": "<#ff4444>Place cooldown active</color>",
  "Scanner": "Scanner",
  "ScannerInfo": "Scan for Invisible Players and Make them Visible Again",
  "ScannerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vanish and expose invisible players who linger too close.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Reveal Scan</color></b>\nVanish to activate. Any invisible player who remains within your radius for the duration automatically becomes visible again.\n\n<i>No one stays hidden forever.</i></size>",
  "ScannerAbilityRange": "Ability Range",
  "ScannerTimeLimit": "Time Limit for invisible players on range to appear",
  "ScannerWarningInRange": "A <color=#42f5a7>Scanner</color> is near you! If you don't get away in {0}s, you will become visible again!",
  "ScannerNowVisible": "The <color=#42f5a7>Scanner</color> has made you visible again!",
  "ScientistEndKnot": "Scientist",
  "ScientistEndKnotInfo": "Access portable vitals from anywhere",
  "ScientistEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Carry portable vitals — check who's alive from anywhere.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Portable Vitals</color></b>\nYou carry a tablet showing the crew's vital status at all times. Use it to catch self-reports, track body age, or monitor deaths in real time.\n\n<i>Knowledge is the first step to justice.</i></size>",
  "Scout": "Scout",
  "ScoutInfo": "Track other players",
  "ScoutInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player to track their movements with arrows.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Track</color></b>\nVote a player in a meeting to mark them with a directional arrow throughout the round. At the start of each meeting, you may also learn which room they were last seen in.\n\n<i>You always know where they've been.</i></size>",
  "SecurityGuard": "Security Guard",
  "SecurityGuardInfo": "Prevent Impostors from Sabotaging",
  "SecurityGuardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Lock out all sabotages and door closures while on guard.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Lockdown</color></b>\nVent or pet to activate. While active, no one can call any sabotage or close doors — including the doors sabotage and Neutral players.\n\n<i>On your watch, nothing breaks.</i></size>",
  "SecurityGuardSkillCooldown": "Ability Cooldown",
  "SecurityGuardSkillDuration": "Ability Duration",
  "SecurityGuardSkillInUse": "Ability in use",
  "SecurityGuardSkillStop": "Ability expired",
  "SecurityGuardVentButtonText": "<size=0>.</size>",
  "Sensor": "Sensor",
  "SensorInfo": "Get Arrows Towards Sabotage Callers",
  "SensorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Every sabotage call leaves a trail — and you see it.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Sabotage Sense</color></b>\nWhenever any player triggers a sabotage, you receive a temporary arrow pointing toward them.\n\n<i>They think chaos covers their tracks. You know better.</i></size>",
  "Sensor.ArrowDuration": "Arrow Duration",
  "Sentinel": "Sentinel",
  "SentinelInfo": "Scare Killers Away",
  "SentinelInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Patrol a zone to warn, trap, and execute killers within it.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Patrol</color></b>\nVent to begin patrolling your surrounding area. While active, all killers in the zone are warned to leave. Any killer who attempts a kill in your zone is killed instead. When patrolling ends, all remaining killers in the area die. Your vision is reduced while patrolling.\n\n<i>Step inside this perimeter — and you won't step back out.</i></size>",
  "SentinelPatrolDuration": "Patrol Time",
  "SentinelPatrolRadius": "Patrol Radius",
  "Sentry": "Sentry",
  "SentryInfo": "Monitor a Room",
  "SentryInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Monitor a room remotely — and get live alerts from it.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Room Monitor</color></b>\nPet to designate a room for surveillance. Pet again later to receive a report:\n<size=70%>- Who is currently in that room\n- Whether anyone is dead there\n- Alerts for venting or shapeshifting in the room</size>\nSettings may let players know the room is monitored, and Comms Sabotage may block info.\n\n<i>You don't need to be there to know what's happening.</i></size>",
  "Sentry.AdditionalDevicesForInfoView": "Map-Specific Devices Players Can Use to Get Info About Monitored Room",
  "Sentry.CannotSeeInfoDuringComms": "Cannot See Info During Comms Sabotages",
  "Sentry.Notify.Info": "<u>Info about {0}:</u>\\nPlayers: {1}\\nDead players: {2}",
  "Sentry.Notify.Info.NoData": "<#ff0000>none</color>",
  "Sentry.Notify.InvalidRoom": "You are not in a room",
  "Sentry.Notify.Shapeshifted": "{0} shapeshifted into {1} in your monitored room",
  "Sentry.Notify.Vented": "{0} vented in your monitored room",
  "Sentry.PlayersKnowAboutCamera": "Players Know if the Room is Monitored",
  "Sentry.ShowInfoDuration": "Info is Visible for",
  "Sentry.Suffix.MonitoredRoom": "<size=80%>This room is monitored by the {0}</size>",
  "Sentry.Suffix.Self": "<size=70%>Monitoring: <#00ffa5>{0}</color></size>",
  "Sentry.TeamsCanSeeInfo.Coven": "<#7b3fbb>Coven</color> Can See the Info</color>",
  "Sentry.TeamsCanSeeInfo.Crewmate": "<#8cffff>Crewmates</color> Can See the Info</color>",
  "Sentry.TeamsCanSeeInfo.Impostor": "<#ff1919>Impostors</color> Can See the Info</color>",
  "Sentry.TeamsCanSeeInfo.NK": "<#ffab1b>Neutral</color> <#ff1919>Killers</color> Can See the Info</color>",
  "Sentry.TeamsCanSeeInfo.NNK": "<#ffff00>Non-Killing</color> <#ffab1b>Neutrals</color> Can See the Info</color>",
  "Sentry.UsableDevicesForInfoView": "Devices Players Can Use to Get Info About Monitored Room",
  "SentryPetButtonText": "Monitor",
  "Sheriff": "Sheriff",
  "SheriffInfo": "Kill <color=#ff1919>evil</color> players",
  "SheriffInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Hunt down the evil — but shoot the wrong player and you die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Shot</color></b>\nNo tasks — just a gun. Can shoot Impostors (and optionally Neutrals). Shooting a Crewmate causes self-death. As a Madmate, may be able to kill anyone.\n\n<i>One shot. Make it count.</i></size>",
  "SheriffCanBeMadmate": "<color=#ffb347>Sheriff</color> can become <color=#ff1919>Madmate</color>",
  "SheriffCanKill%role%": "Can Kill %role%",
  "SheriffCanKillAll": "<color=#00fefe>All ON</color>",
  "SheriffCanKillAllAlive": "Can Kill when Everyone is Alive",
  "SheriffCanKillCharmed": "Can kill <color=#cf6acd>Charmed</color> players",
  "SheriffCanKillContagious": "Can Kill <color=#2E8B57>Contagious</color> players",
  "SheriffCanKillCoven": "Can Kill <color=#7b3fbb>Coven</color>",
  "SheriffCanKillLovers": "Can Kill <color=#ff9ace>Lovers</color>",
  "SheriffCanKillMadmate": "Can Kill <color=#ff1919>Madmates</color>",
  "SheriffCanKillNeutrals": "Can Kill <color=#ffab1b>Neutrals</color>",
  "SheriffCanKillNeutralsMode": "<color=#ffab1b>Neutral</color> Configuration",
  "SheriffCanKillSeparately": "Individual Settings",
  "SheriffCanKillSidekick": "Can Kill <color=#00b4eb>Sidekicks</color>",
  "SheriffKeepsGameGoing": "Keeps the game going",
  "SheriffKillButtonText": "Shoot",
  "SheriffMadCanKillCrew": "Can kill <color=#8cffff>Crewmates</color>",
  "SheriffMadCanKillImp": "Can kill <color=#ff1919>Impostors</color>",
  "SheriffMadCanKillNeutral": "Can kill <color=#ffab1b>Neutrals</color>",
  "SheriffMisfireKillsTarget": "Misfire Kills Target",
  "SheriffSetMadCanKill": "Non-<color=#8cffff>Crew</color> <color=#f8cd46>Sheriff</color> Configuration",
  "SheriffShotLimit": "Max number of Kills",
  "SheriffShowShotLimit": "Display Shot Limit next to Role Name",
  "Shiftguard": "Shiftguard",
  "ShiftguardInfo": "Know When Someone Shapeshifts",
  "ShiftguardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Every shapeshift and unshift triggers an alert to you.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Shift Alert</color></b>\nWhenever any player shapeshifts or reverts, you are notified.\n\n<i>Disguises don't last long when someone's watching.</i></size>",
  "ShiftguardNotifySS": "Someone just shapeshifted as someone",
  "ShiftguardNotifyUnshift": "Someone just unshifted",
  "Snitch": "Snitch",
  "SnitchInfo": "Finish your tasks to find the <color=#ff1919>Impostors</color>",
  "SnitchInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Finish your tasks to expose Impostor names in meetings.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Exposure</color></b>\nAs tasks are completed, Impostors' names turn red in meetings. When one task remains, both you and the Impostors are marked with a star. As a Madmate, the star turns red.\n\n<i>The closer you get to done, the more danger you're in.</i></size>",
  "SnitchCanBeMadmate": "<color=#b8fb4f>Snitch</color> can become <color=#ff1919>Madmate</color>",
  "SnitchCanBeWorkhorse": "<color=#b8fb4f>Snitch</color> can become <color=#00ffff>Workhorse</color>",
  "SnitchCanFindCoven": "Can Find <color=#7b3fbb>Coven</color>",
  "SnitchCanFindMadmate": "Can Find <color=#ff1919>Madmates</color>",
  "SnitchCanFindNeutralKiller": "Can Find <color=#ffab1b>Neutral Killers</color>",
  "SnitchCanGetArrowColor": "See Colored Arrows based on Team Colors",
  "SnitchDoneTasks": "Call a meeting to find the impostors",
  "SnitchEnableTargetArrow": "See Arrow Towards Target",
  "SnitchRemainingTaskFound": "Remaining tasks to be known",
  "Socialite": "Socialite",
  "SocialiteInfo": "Know Who Interacts With Your Target",
  "SocialiteInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Shield your target — and recruit those who try to harm them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Guest List</color></b>\nUse your kill button each round to mark a target. Kills against your target are blocked, and the attacker is added to your Guest List (they're told). Guest List players' names appear black. Players on the list can kill your target. You can also add players to the list by voting them.\n\n<i>Everyone gets one warning. After that, they're on the list.</i></size>",
  "Socialite.Suffix": "<size=80%>Your target is {0}</size>",
  "SocialiteTarget": "The target of the Socialite cannot be killed\\nYou were added to their Guest List",
  "Soothsayer": "Soothsayer",
  "SoothsayerInfo": "Predict Who Kills You",
  "SoothsayerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Predict your killer — and reveal them to everyone upon death.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Prophecy</color></b>\nVote a player in a meeting to predict them as your killer. If your prediction is correct, when you die everyone is notified of the killer's identity.\n\n<i>Even in death, the truth comes out.</i></size>",
  "SoothsayerDiedNotify": "The Soothsayer predicted that {0} would kill them\\nand they were correct!",
  "SpeedBooster": "Speed Booster",
  "SpeedBoosterInfo": "Boost your speed",
  "SpeedBoosterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Every task you complete speeds up a random player.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Speed Boost</color></b>\nEach task you finish increases a random player's movement speed. Stacks up to a maximum speed limit.\n\n<i>Hard work lifts everyone — whether they asked or not.</i></size>",
  "SpeedBoosterSpeedLimit": "You reached your maximum speed (3x)",
  "SpeedBoosterTaskDone": "Your speed is {0} now",
  "SpeedBoosterTimes": "Max Boosts",
  "SpeedBoosterUpSpeed": "Increase Speed by",
  "Speedrunner": "Speedrunner",
  "SpeedrunnerInfo": "Crew wins if you finish your tasks",
  "SpeedrunnerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Finish all your tasks alive — and the crew wins instantly.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Sprint Finish</color></b>\nComplete all assigned tasks while still alive to trigger an instant Crewmate victory. Stay alive long enough to cross the finish line.\n\n<i>Every second counts. Don't stop.</i></size>",
  "SpeedrunnerHasXTasksLeft": "<size=80%><#ffff44>{0} is the <color=#800080>Speedrunner</color> with <color=#800080>{1}</color> task(s) left!</color></size>",
  "SpeedrunnerNotifyAtXTasksLeft": "Tasks Completed When Notifying",
  "SpeedrunnerNotifyKillers": "Notify Killers When Tasks are Almost Done",
  "SpeedrunnerSpeed": "<color=#800080>Speedrunner</color> Speed",
  "Spiritualist": "Spiritualist",
  "SpiritualistInfo": "You see where a ghost is",
  "SpiritualistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Follow the ghost of the last reported body — and read between the lines.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Spirit Arrow</color></b>\nAfter each meeting, you receive an arrow pointing toward the ghost of the body that was just reported. If the victim was innocent, following it may lead you to a killer. If they were guilty, it may just lead you to a Crewmate.\n\n<i>The dead still have things to say — if you listen.</i></size>",
  "SpiritualistNoticeMessage": "The Spiritualist has an arrow pointing to you!\\nYou can use them to a killer or frame a crewmate",
  "SpiritualistShowGhostArrowEverySeconds": "Ghost arrow interval",
  "SpiritualistShowGhostArrowForSeconds": "Ghost arrow duration",
  "SpiritualistTargetMessage": "<color=#ffff00>The Spiritualist has an arrow pointing toward you</color>",
  "Spy": "Spy",
  "SpyInfo": "You know who interacts with you",
  "SpyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Anyone who targets you with their kill button glows — briefly.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Marked</color></b>\nWhen any player uses their kill button on you, their name briefly appears orange. Note: Crewmates with kill-button abilities also trigger this. Requires at least one ability use remaining to function.\n\n<i>You feel it when someone takes aim.</i></size>",
  "SpyRedNameDur": "Colored Name Duration",
  "SuperStar": "Super Star",
  "SuperStarInfo": "Everyone knows you",
  "SuperStarInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your fame is your shield — no one dares strike in public.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Celebrity Protection</color></b>\nA star appears next to your name. You can only be killed when the killer is completely alone with you. Guessers cannot guess your role.\n\n<i>Fame has its privileges.</i></size>",
  "SuperStarDead": "Shock! Super Star <b>{0}</b> has unfortunately been mercilessly killed in the recent period of time!",
  "Survivor": "Survivor",
  "SurvivorInfo": "With each fallen crew, I get stronger",
  "SurvivorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>The Survivor will get abilities with each set amount of players left in the game.\n\n- 1st Ability: See the number of alive players left in real time.\n- 2nd Ability: Vent/Vanish to give yourself a temporary shield.\n- 3rd Ability: An additional set amount of votes.\n- Last Ability: Finish tasks to gain a Kill button.\n\nNote: All abilities are stackable, separated, and can shuffle their order if wanted, as well as disable them by set the required amount of players needed to 0 or 1.</size>",
  "SurvivorFirstAbility": "Number of players left to get 1st Ability",
  "SurvivorSecondAbility": "Number of players left to get 2nd Ability",
  "SurvivorThirdAbility": "Number of players left to get 3rd Ability",
  "SurvivorLastAbility": "Number of players left to get Last Ability",
  "SurvivorCurrentAlive": "- Alive Players:",
  "SurvivorCantKillYet": "The current number of players is greater than your killing requirement, which means you cannot kill yet.",
  "Swapper": "Swapper",
  "SwapperInfo": "Swap players' votes",
  "SwapperInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Swap the vote tallies between two players — and flip the outcome.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Vote Swap</color></b>\nUse <b>/cmd sw [ID]</b> twice to select 2 players. Their received vote totals are swapped at count. Player IDs are visible next to names. Note: the Host's vote display won't update visually, but the swap still applies.\n\n<i>The numbers say one thing. Your plan says another.</i></size>",
  "Swap1": "First Swap Target Chosen",
  "Swap2": "Second Swap Target Chosen",
  "SwapDead": "You cannot swap votes after you've died.",
  "SwapHelp": "Use <b>/cmd sw [ID]</b> to choose a player to swap votes with.",
  "SwapNull": "No alive player with that ID",
  "SwapTitle": "[★ Swapper ★]",
  "SwapVote": "The votes received by <b>{0}</b> and <b>{1}</b> were swapped!",
  "SwapperCannotCallEmergencyMeeting": "As the <#922348>Nice Swapper</color>, according to the host's settings, you cannot call emergency meetings",
  "SwapperHideMsg": "<color=#00ff00>Hide <color=#922348>Swapper</color>'s commands</color>",
  "SwapperManipulatedEjection": "Thanks to the {0}",
  "SwapperMax": "Initial Number of Swaps",
  "SwapperTrialMax": "Ability use limit reached",
  "Tar": "Tar",
  "TarInfo": "Avoid Kills",
  "TarInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Pet to activate: you freeze and go blind with a black skin for a set time. Any kill attempt during this window is blocked, the attacker is teleported away, and the ability ends instantly.</size>",
  "TaskManager": "Task Manager",
  "TaskManagerInfo": "See the total tasks completed in real-time",
  "TaskManagerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>See the ship's total task count update in real-time.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Count</color></b>\nThe cumulative number of tasks completed by all players is displayed next to your role name, updating live throughout the game.\n\n<i>Progress can't hide from you.</i></size>",
  "Telecommunication": "Telecommunication",
  "TelecommunicationInfo": "Track device usage",
  "TelecommunicationInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Know whenever anyone uses ship devices — cameras, vitals, admin, door logs.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Device Alert</color></b>\nYou are notified whenever any player accesses cameras, vitals, the door log, or admin. Depending on settings, you may also open closed doors by venting or petting.\n\n<i>All signals pass through you first.</i></size>",
  "Telekinetic": "Telekinetic",
  "TelekineticInfo": "Execute Different Actions to Help the Crew",
  "TelekineticInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Wield psychic powers — but every use runs out the clock.\n_____________________________________\nDifficulty: ★★★★★\n\n[Skills]\n・<b><color=#8cffff>Psychic Mode</color></b>\nA timer ticks up constantly. Die if it exceeds 60s. Vent to cycle modes; pet to execute the active one. Only one mode active at a time. Timer resets to 40s after a meeting. Each action adds time:\n<size=70%>・Teleport Target — send nearest player off-map (+40s)\n・Teleport Self — send yourself off-map (+30s)\n・Freeze — freeze nearest player in place (+35s)\n・Kill — instantly eliminate nearest player (+60s)\n・Shield — gain a temporary shield (+45s)\n・Speed — gain temporary speed boost (+30s)\n・Doors — open all closed doors (+35s)</size>\nSome actions freeze you for 5s afterward.\n\n<i>Immense power — with a ticking deadline.</i></size>",
  "Telekinetic.FreezeDuration": "Freeze Duration",
  "Telekinetic.IncreasedSpeed": "Increased Speed",
  "Telekinetic.Mode.Doors": "Doors",
  "Telekinetic.Mode.Freeze": "Freeze",
  "Telekinetic.Mode.Kill": "Kill",
  "Telekinetic.Mode.Shield": "Shield",
  "Telekinetic.Mode.Speed": "Speed",
  "Telekinetic.Mode.TeleportSelf": "Teleport Self",
  "Telekinetic.Mode.TeleportTarget": "Teleport Target",
  "Telekinetic.ShieldDuration": "Shield Duration",
  "Telekinetic.SpeedDuration": "Speed Duration",
  "Telekinetic.Suffix": "<#00ffa5>Mode:</color> <b>{0}</b>",
  "Tether": "Tether",
  "TetherInfo": "Teleport to your target",
  "TetherInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player in a meeting — then teleport to them on demand.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Tether Warp</color></b>\nVote a player during a meeting to designate them as your target. In the next round, vent or pet to instantly teleport to their location. Targets reset each meeting.\n\n<i>Wherever they go, you can follow.</i></size>",
  "TetherNoTarget": "You have no target",
  "TimeManager": "Time Manager",
  "TimeManagerInfo": "Increase meeting time by doing tasks",
  "TimeManagerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Extend meeting time — just by being alive.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Time Extension</color></b>\nWhile alive, meeting discussion time is increased. If you die, meeting time returns to normal. As a Madmate, this inverts — reducing meeting time instead.\n\n<i>The crew needs time to think. You buy it.</i></size>",
  "TimeManagerIncreaseMeetingTime": "Increase voting time by",
  "TimeManagerLimitMeetingTime": "Maximum Length of Meetings",
  "TimeMaster": "Time Master",
  "TimeMasterInfo": "Rewind time to dodge attacks!",
  "TimeMasterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Rewind time itself — send everyone back and undo recent deaths.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Time Rewind</color></b>\nVent or pet to rewind time by a few seconds. All players are teleported back to their positions at that moment. Anyone who died within the rewound window is revived.\n\n<i>Some mistakes deserve a second chance.</i></size>",
  "TimeMasterCanRevive": "Can Revive",
  "TimeMasterCanUseVitals": "Can Use Vitals",
  "TimeMasterKillerAlert": "<#ffff00><size=150%>A player you killed was revived during the rewind!</size></color>",
  "TimeMasterMaxUses": "(Initial) Max Amount of Ability Uses",
  "TimeMasterRewindStart": "The {0} is rewinding time!",
  "TimeMasterRewindTimeLength": "Rewind Time Length",
  "TimeMasterVentButtonText": "Rewind Time",
  "ToiletMaster": "Toilet Master",
  "ToiletMasterInfo": "Place Toilets",
  "ToiletMasterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Place toilets across the map — and let fate decide the effect.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Toilet Placement</color></b>\nPlace toilets around the map. Any player who uses one receives a random effect determined by their poop color.\n\n<i>Nature calls. So does chaos.</i></size>",
  "TM.BluePoopDuration": "Blue Poop Duration",
  "TM.BrownPoopButtonText": "Place Brown Poop",
  "TM.BrownPoopDuration": "Brown Poop Duration",
  "TM.BrownPoopSpeedBoost": "Brown Poop Speed Boost",
  "TM.GetPoopNotify": "You've got {0} Poop",
  "TM.GreenPoop": "There is no killer near you",
  "TM.GreenPoopDuration": "Green Poop Duration",
  "TM.GreenPoopKiller": "There is a killer near you",
  "TM.GreenPoopRadius": "Green Poop Radius",
  "TM.PurplePoopDuration": "Purple Poop Duration",
  "TM.PurplePoopNotifyOnKillAttempt": "Purple Poop Notify On Kill Attempt",
  "TM.RedPoopDuration": "Red Poop Duration",
  "TM.RedPoopRadius": "Red Poop Radius",
  "TM.RedPoopRoleBlockDuration": "Red Poop Role Block Duration",
  "TM.ToiletDuration": "Toilets Disappear After",
  "TM.ToiletMaxUses": "Max Toilet Uses",
  "TM.ToiletUseRadius": "Toilet Use Radius",
  "TM.ToiletUseTime": "Toilet Use Time",
  "TM.ToiletVisibility": "Toilet Visibility Mode For Other Players After Placing",
  "TM.TryKillNotify": "Someone tried to kill you",
  "Tornado": "Tornado",
  "TornadoInfo": "Spawn Tornados",
  "TornadoInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Spawn tornadoes to fling anyone nearby to a random location.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Tornado</color></b>\nPet to spawn a tornado. Any player who walks near it is teleported to a random location on the ship.\n\n<i>Sometimes the best strategy is pure chaos.</i></size>",
  "TornadoCooldown": "Tornado Spawn Cooldown",
  "TornadoDuration": "Tornado Duration",
  "TornadoRange": "Tornado Range",
  "Tracefinder": "Tracefinder",
  "TracefinderInfo": "Locate dead bodies",
  "TracefinderInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Track vital signs and find dead bodies with directional arrows.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vitals + Body Arrows</color></b>\nYou have access to portable vitals like a Scientist. Additionally, you receive arrows pointing toward all unreported dead bodies.\n\n<i>The dead leave traces. You follow them.</i></size>",
  "TrackerEndKnot": "Tracker",
  "TrackerEndKnotInfo": "Track players",
  "TrackerEndKnotInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Tag a player and follow their position with a permanent arrow.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Tracker</color></b>\nUse your track button on a player to place a tracker on them. An arrow persistently points toward their current location.\n\n<i>Tag them once. Know where they are forever.</i></size>",
  "Transmitter": "Transmitter",
  "TransmitterInfo": "TP to nearest player by doing a task",
  "TransmitterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Every completed task snaps you to the nearest player's side.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Teleport</color></b>\nEach time you complete a task, you are instantly teleported to the nearest player's location.\n\n<i>Hard work brings you closer — whether you like it or not.</i></size>",
  "Transporter": "Transporter",
  "TransporterInfo": "Do tasks to swap 2 players' locations",
  "TransporterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Finish tasks — then swap two players' positions on demand.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Location Swap</color></b>\nAfter completing tasks, open the shapeshift menu to select 2 targets. Their positions are instantly swapped.\n\n<i>Confusion is a weapon. Aim it well.</i></size>",
  "TransporterTeleportMax": "Max number of teleports",
  "Tree": "Tree",
  "TreeInfo": "You are a Tree",
  "TreeInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Disguise yourself as a tree — then fall and flatten everyone nearby.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Tree Form</color></b>\nPet to become a tree — anonymous and invisible. After a few seconds, you topple over, killing or stunning all nearby players before becoming visible again.\n\n<i>Even trees have feelings. And roots. And crushes.</i></size>",
  "Tree.FallDelay": "Fall Delay",
  "Tree.FallKillChance": "Fall Kill Chance",
  "Tree.FallRadius": "Falling Effect Radius",
  "Tree.FallStunDuration": "Fall Stun Duration",
  "Tree.TreeSpriteVisible": "Tree Sprite Visible",
  "Tunneler": "Tunneler",
  "TunnelerInfo": "Mark a position and TP back there",
  "TunnelerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Mark a spot — and warp back to it whenever you need.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Tunnel</color></b>\nPet to mark your current position. Pet again at any time to teleport back to that marked spot.\n\n<i>Always have an exit strategy.</i></size>",
  "UndercoverInfo": "Impostors see you as their partner",
  "UndercoverInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Impostors think you're one of them — use it.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>False Alliance</color></b>\nImpostors see you as a teammate and will not target you as an enemy. However, you don't know who the Impostors are — you must figure that out yourself.\n\n<i>You're their friend. They're your leads.</i></size>",
  "Unshifter": "Unshifter",
  "UnshifterInfo": "Unshift Shapeshifted Players",
  "UnshifterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Strip a shapeshifter back to their true form on contact.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Unshift</color></b>\nUse your kill button on a shapeshifted player to force them back to their original appearance. Using it on a non-shifted player does nothing but sends a message. The target may be notified depending on settings.\n<size=50%>Credit: Dechis</size>\n\n<i>No disguise survives your touch.</i></size>",
  "UnshifterCooldown": "Unshift Cooldown",
  "UnshifterUseLimit": "Maximum Unshift Attempts",
  "UnshifterTargetKnows": "Target Knows they're being unshifted",
  "UnshifterTargetNotShifted": "Target is not Shapeshifted.",
  "UnshifterSuccess": "Target was Shapeshifted! Unshift successful!",
  "UnshifterTargetNotify": "You've been unshifted by an <color=#00b4eb>Unshifter</color>!",
  "Vacuum": "Vacuum",
  "VacuumInfo": "Suck In Dead Bodies",
  "VacuumInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Activate your ability and all dead bodies fly to your location.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Body Pull</color></b>\nWhile your ability is active, every dead body on the map is instantly teleported to you — making them easy to report or harder to hide.\n\n<i>Bodies don't run. You come to them.</i></size>",
  "Ventguard": "Ventguard",
  "VentguardInfo": "Block vents by entering them",
  "VentguardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Block vents by entering them — and get alerted when someone tries.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Block</color></b>\nEnter a vent to permanently block it until the next meeting. No one can use a blocked vent (except Crewmates, if settings allow). You are notified whenever someone attempts to enter a vent you've blocked. Blocks reset each meeting.\n\n<i>You turned their escape routes into dead ends.</i></size>",
  "VentguardBlockDoesNotAffectCrew": "<color=#8cffff>Crewmates</color> can use blocked vents",
  "VentguardBlocksResetOnMeeting": "Reset Blocked Vents Every Meeting",
  "VentguardMaxGuards": "Max number of Vent Blocks",
  "VentguardNotify": "Someone tried to use a blocked vent",
  "VentguardNotifyOnBlockedVentUse": "Notify When Someone Tries to Use a Blocked Vent",
  "VentguardVentButtonText": "Block",
  "Veteran": "Squid",
  "VeteranInfo": "Alert to kill anyone who interacts with you",
  "VeteranInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Go on high alert — and execute anyone who attacks you.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Alert</color></b>\nVent or pet to enter an alert state. Any killer who attacks you while you're alerted dies instead. Depending on settings, non-killing interactions may also trigger this.\n\n<i>Come at me. See what happens.</i></size>",
  "VeteranAlertActivatesOnNonKillingInteractions": "Kill Killer on Non-Killing Interactions (e.g., douse, shield, etc.)",
  "VeteranMaxUsage": "The skill use limit has been reached",
  "VeteranOffGuard": "Ability expired, {0} uses remain",
  "VeteranOnGuard": "Ability in use",
  "VeteranSkillCooldown": "Alert Cooldown",
  "VeteranSkillDuration": "Alert Duration",
  "VeteranSkillMaxOfUsage": "(Initial) Max number of Alerts",
  "VeteranVentButtonText": "Alert",
  "Vigilante": "Vigilante",
  "VigilanteInfo": "You can kill 1 player",
  "VigilanteInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>One kill shot — use it wisely or carry the guilt forever.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>One Shot</color></b>\nCan kill any player, but only once. After using your kill, you can still complete tasks normally. Depending on settings, may also be able to vent.\n\n<i>One chance. One choice. Make it count.</i></size>",
  "Whisperer": "Whisperer",
  "WhispererInfo": "Question Souls to Get Info",
  "WhispererInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Question the souls of the dead to piece together the truth.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Soul Questioning</color></b>\nAfter meetings, souls of dead players become visible to you. Pet on a soul and remain close for a few seconds to question them. You receive random clues about the victim or their killer, displayed below your name.\n\n<i>The dead know more than they let on.</i></size>",
  "WhispererCooldown": "Questioning Cooldown",
  "WhispererDuration": "Questioning Duration",
  "WhispererInfo.AloneInRoomAtDeath": "I was alone with the killer when I died",
  "WhispererInfo.Color": "A {0} color killed me\\n(<size=50%>{1}</color>)",
  "WhispererInfo.ColorDark": "<#555555>darker</color>",
  "WhispererInfo.ColorLight": "<#fdffbf>lighter</color>",
  "WhispererInfo.DeathReason": "My death reason is {0}",
  "WhispererInfo.KillerRole": "My killer was {0}",
  "WhispererInfo.NoSabotageAtDeath": "No sabotage was ongoing when I died",
  "WhispererInfo.PlayersInSameRoomAtDeath": "{0} were in the same room as me when I died",
  "WhispererInfo.Role": "I was {0}",
  "WhispererInfo.SabotageAtDeath": "I died during {0}",
  "WhispererInfo.Time": "I died {0} seconds before the meeting started",
  "WhispererQuestioning": "Questioning {0}... {1}%",
  "Witness": "Witness",
  "WitnessInfo": "Find out if someone killed recently",
  "WitnessInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Press your kill button on someone to check if they killed recently.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Examine</color></b>\nUse your kill button on any player to check their recent actions. A yellow exclamation mark means they've killed recently; a green checkmark means they haven't.\n\n<i>Guilt leaves a mark — you just have to look for it.</i></size>",
  "WitnessButtonText": "Examine",
  "WitnessTime": "Max Time after killing where killer appears red",
  "Wizard": "Wizard",
  "WizardInfo": "Change Players' Stats",
  "WizardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Permanently alter any player's speed, vision, or kill cooldown.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Stat Modification</color></b>\nPet to cycle through three stats: Speed, Vision, and Kill Cooldown. Press Vanish to raise the selected value. Use your kill button on a player to apply it permanently. Overriding an existing effect costs another ability use — choose carefully.\n\n<i>A word of warning: <b><u>permanent</u></b> means permanent.</i></size>",
  "Wizard.Buff.KCD": "Kill Cooldown",
  "Wizard.Buff.Speed": "Speed",
  "Wizard.Buff.Vision": "Vision",
  "Wizard.BuffGivenNotify": "<#00ffa5>{0}'s <#ffffff>{1}</color> was set to <#ffffff>{2}</color></color>",
  "Wizard.KCDStep": "Step in which Kill Cooldown is increased",
  "Wizard.MaxKCDValue": "Maximum Kill Cooldown that can be given to players",
  "Wizard.MaxSpeedValue": "Maximum Speed that can be given to players",
  "Wizard.MaxVisionValue": "Maximum Vision that can be given to players",
  "Wizard.MinKCDValue": "Minimum Kill Cooldown that can be given to players",
  "Wizard.MinSpeedValue": "Minimum Speed that can be given to players",
  "Wizard.MinVisionValue": "Minimum Vision that can be given to players",
  "Wizard.SelectedBuff": "<#00ffa5>Selected Buff:</color> <b>{0}</b> {1}{2}",
  "Wizard.SpeedStep": "Step in which Speed is increased",
  "Wizard.Vision": "Vision",
  "Wizard.VisionStep": "Step in which Vision is increased",
  /* ==============================
    Roles (Impostors)           
  ============================== */
  "Abyssbringer": "Abyssbringer",
  "AbyssbringerInfo": "Place Black Holes",
  "AbyssbringerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Place black holes that pull players in — and destroy them on contact.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Black Hole</color></b>\nPlace black holes on the map. They suck in any player that wanders close and kill them on collision.\n\n<i>Gravity is not a force. It's a trap.</i></size>",
  "Abyssbringer.Suffix": "<size=80%><#00ffa5>Number of players consumed by</color> {0} <#00ffa5>active black holes:</color></size><size=70%>\\n{1}",
  "Abyssbringer.Suffix.BlackHole": "<#00ffa5>{0}:</color> {1}",
  "Ambusher": "Ambusher",
  "AmbusherInfo": "Ambush Players to Make Them Fragile",
  "AmbusherInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Turn invisible — shadow a target long enough to leave them fragile.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Ambush</color></b>\nActivate to go invisible. Follow someone within your radius for a few seconds to ambush them, inflicting Fragile effects. Fail to hold position and you become visible when the duration ends with nothing to show for it.\n\n<i>Patience is the sharpest blade.</i></size>",
  "Ambusher.FollowDuration": "Time Needed to Follow Someone For",
  "Ambusher.FollowRadius": "Following Radius",
  "Ambusher.FragileDuration": "Fragile Effect Duration",
  "Ambusher.InProgress": "Ambushing {0}.... {1}s left",
  "Ambusher.InvisDurAfterSuccessfulAmbush": "Extra Invisibility Duration After Successful Ambushes",
  "Ambusher.InvisTimeLeft": "Invisibility expires in {0}s",
  "Ambusher.Success": "<#00ff00>Ambush successful</color>",
  "Anonymous": "Anonymous",
  "AnonymousInfo": "Force a player to report a body",
  "AnonymousInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Hack a player to force them to report the body you just made.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Hack</color></b>\nShapeshift to hack into a target. They will be forced to report the body you last killed — or their own if none exists. Hacking bypasses normal report restrictions. Note: hacking the Lazy Guy is pointless.\n\n<i>Make them look guilty. Then watch.</i></size>",
  "AnonymousBodies": "Anonymous Bodies",
  "AnonymousKillerCount": "Anonymous <#ff1919>Evil</color> Player Count",
  "AnonymousShapeshiftText": "Hack",
  "AntiAdminer": "Anti-Adminer",
  "AntiAdminerInfo": "Track device usage",
  "AntiAdminerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Detect players near ship devices — and punish those who won't move.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Device Proximity</color></b>\nDetect any Crewmate or Neutral near cameras, admin, vitals, or door logs. Note: proximity only — you can't confirm if they're actively using it.\n\n・<b><color=#ff1919>Device Purge</color></b>\n(Settings) Shapeshift to warn all device users to leave immediately. Anyone who doesn't step away in time dies.\n\n<i>Stay off their consoles. Or else.</i></size>",
  "AntiAdminerAD": "<size=1.7><color=#ffff00>⚠ Admin Table ⚠</color></size>",
  "AntiAdminerCA": "<size=1.7><color=#ffff00>⚠ Security Cameras ⚠</color></size>",
  "AntiAdminerDL": "<size=1.7><color=#ffff00>⚠ DoorLog ⚠</color></size>",
  "AntiAdminerVI": "<size=1.7><color=#ffff00>⚠ Vitals Monitor ⚠</color></size>",
  "Arrogance": "Ambitioner",
  "ArroganceInfo": "Your cooldown decreases with each kill you make",
  "ArroganceInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill you make shortens your next kill cooldown.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill Momentum</color></b>\nEach successful kill permanently reduces your kill cooldown — down to a configurable minimum.\n\n<i>The more you kill, the harder you are to stop.</i></size>",
  "ArroganceDefaultKillCooldown": "Starting kill cooldown",
  "ArroganceMinKillCooldown": "Minimum kill cooldown",
  "ArroganceReduceKillCooldown": "Reduce kill cooldown by",
  "ArroganceShowProgressText": "Show kill cooldown reduction below the name",
  "Assumer": "Assumer",
  "AssumerInfo": "Assume Vote Counts",
  "AssumerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Predict exactly how many votes a player will get — and kill those who voted for them.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Vote Assumption</color></b>\nType <b>/cmd assume {id} {number}</b> to predict that a player will receive exactly that many votes. If correct, every player who voted for your target dies. Example: <b>/cmd assume 0 3</b> predicts the host receives 3 votes.\n\n<i>Read the room. Then punish it.</i></size>",
  "Assumer.AssumedMessage": "You're assuming that {0} will receive <b>{1}</b> votes",
  "Assumer.MinPlayersToAssume": "Minimum Alive Players to Make Assumptions",
  "Assumer.VoteReceiverDies": "Vote Receiver Dies on Correct Assumption",
  "Augmenter": "Augmenter",
  "AugmenterInfo": "Choose Who You Want to Kill",
  "AugmenterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift into someone — and redirect your next kill to them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Target Lock</color></b>\nShapeshift into a player to designate them as your target. The next kill you attempt swaps your victim with your marked target — you kill the target instead.\n\n<i>You didn't choose who to kill. You chose who to frame.</i></size>",
  "AugmenterFail": "<#ffff44>Your attempt of murdering your target failed,\\nso you've murdered your original target instead.</color>",
  "Ballooner": "Ballooner",
  "BalloonerInfo": "Inflate while walking and explode on command",
  "BalloonerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Walk to inflate — then detonate and wipe out everyone nearby.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Balloon Bomb</color></b>\nYour balloon inflates as you walk, growing the explosion radius. Use your ability to detonate and kill all players within range. If suicide is disabled, the balloon resets; otherwise you die in the blast too. The balloon deflates slightly after each meeting.\n\n<i>Keep walking. Keep building. Then let go.</i></size>",
  "BalloonerAbilityCooldown": "Ability Cooldown",
  "BalloonerMinBoomDis": "Minimum Explosion Radius",
  "BalloonerMaxBoomDis": "Maximum Explosion Radius",
  "BalloonerChargeWalk": "Walk Distance to Charge One Step",
  "BalloonerChargeStep": "Explosion Radius Charged per Step",
  "BalloonerAfterMeetingRemoveCharge": "Explosion Radius Removed After Each Meeting",
  "BalloonerSuicide": "Ballooner Dies in Their Own Explosion",
  "BalloonerTargetImpostor": "Explosion Can Kill Other Impostors",
  "BalloonerLowerText1": "The balloon is still inflating...",
  "BalloonerLowerText2": "The balloon is ready to explode!",
  "BalloonerAbility": "Explode",
  "Bard": "Bard",
  "BardInfo": "Poem's grace, murder's trace, a rhythmic dance in a dark embrace.",
  "BardInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Replace exile messages with poetry — and gain speed every time it triggers.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Verse</color></b>\nWhile alive, exile confirmation messages are replaced with a random creative sentence. Each time it changes, the Bard's kill cooldown is permanently halved.\n\n<i>Art and murder, perfectly in rhyme.</i></size>",
  "BardChance": "<color=#ff1919>Bard</color> Chance",
  "Blackmailer": "Blackmailer",
  "BlackmailerInfo": "Blackmail Players",
  "BlackmailerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Blackmail players to force their votes to follow yours.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Blackmail</color></b>\nSingle-click your kill button on a player to blackmail them. Their vote in the next meeting is forced to match yours. Double-click to kill normally.\n\n<i>They'll vote your way. They have no choice.</i></size>",
  "Blackmailer.AbilityExpires": "Ability Expires",
  "Blackmailer.MaxBlackmailedPlayersAtOnce": "Max <#ffa500>Blackmailed</color> Players At Once",
  "Blackmailer.MaxBlackmailedPlayersPerMeeting": "Max <#ffa500>Blackmailed</color> Players Per Meeting",
  "Blackmailer.WhoSeesBlackmailedPlayers": "Who Sees <#ffa500>Blackmailed</color> Players",
  "Bomber": "Bomber",
  "BomberInfo": "Shift/Vanish to explode",
  "BomberInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Self-destruct to take out everyone in your blast radius.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Explosion</color></b>\nUse Vanish or pet to trigger a self-explosion, killing all players within the blast radius. The Bomber also dies in the blast. All players see a kill flash when it detonates.\n\n<i>Going out with a bang is still going out on top.</i></size>",
  "BomberCooldownsResetEachOther": "Kill Cooldown & Bomb Cooldown Reset Each Other When Used",
  "BomberDiesInExplosion": "<#ff1919>Bomber</color> dies in their explosion",
  "BomberRadius": "Bomb radius (5x is about half a Cafeteria)",
  "BomberShapeshiftText": "Explode",
  "BountyHunter": "Bounty Hunter",
  "BountyHunterInfo": "Eliminate your target",
  "BountyHunterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Hunt your assigned target for a reward — miss and pay the price.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Bounty</color></b>\nA target is assigned and rotates on a timer. Kill your assigned target for a reduced kill cooldown. Kill anyone else and your cooldown increases. An arrow can optionally point toward your current target.\n\n<i>Wrong kill. Wrong choice. Wrong time.</i></size>",
  "BountyHunterChangeButtonText": "Swap",
  "BountyHunterSwapTimer": "<#00ffa5>New target in</color> <#ffffff>{0}</color>s",
  "BountySuccessKillCooldown": "Kill Cooldown After Killing Bounty",
  "BountyFailureKillCooldown": "Kill Cooldown After Killing Others",
  "BountyShowTargetArrow": "Show arrow pointing towards target",
  "Overkiller": "Overkiller",
  "OverkillerInfo": "Enjoy my beautiful work",
  "OverkillerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Each kill spawns 30 bodies — making deaths impossible to identify.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Dismember</color></b>\nEvery kill drops 30 bodies at the scene, burying the truth in a pile of chaos. Nobody will know who really died at meeting start. If you kill an Avenger, the game instantly ends with 'Everyone died.'\n\n<i>Leave no clean answers behind.</i></size>",
  "OverkillerButtonText": "Dismember",
  "Camouflager": "Camouflager",
  "CamouflagerInfo": "Camouflage everyone for easy kills",
  "CamouflagerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift to make every player look identical — cover becomes total.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Camouflage</color></b>\nShapeshift to make all players appear the same. The effect lasts until you revert. Stacks with Comms Sabotage camouflage for double disguise. If a meeting starts during the ability, it is cancelled.\n\n<i>When everyone looks the same, no one can point a finger.</i></size>",
  "CamouflagerShapeshiftText": "Disguise",
  "Cantankerous": "Cantankerous",
  "CantankerousInfo": "Eject Crewmates to Kill",
  "CantankerousInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Get the crew to eject the innocent — then spend those points to kill.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Point Kill</color></b>\nCan only kill when you have points available. Gain points each time a non-Impostor player is ejected in a meeting. Convince the crew to target their own.\n\n<i>Mob justice is your ammunition.</i></size>",
  "CantankerousPointsGainedPerEjection": "Points Gained Per Non-Impostor Player Ejected",
  "CantankerousStartingPoints": "Starting Points",
  "Capitalist": "Capitalist",
  "CapitalistInfo": "Give more tasks to crewmates",
  "CapitalistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Pile extra tasks onto crewmates — distract them with busywork.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Assign Task</color></b>\nPress your kill button on a player to add a short task to their list. Has no effect on players who have no tasks or have already finished them all.\n\n<i>Keep them working. Keep them away from the truth.</i></size>",
  "CapitalistButtonText": "Add Task",
  "CapitalistSkillCooldown": "Ability Cooldown",
  "Catalyst": "Catalyst",
  "CatalystInfo": "Give Helpful Add-ons to Your Team With Each Kill",
  "CatalystInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill you land buffs your entire Impostor team.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill Catalyst</color></b>\nEach kill grants every Impostor-teamed player a random helpful add-on. Depending on settings, these add-ons may disappear when you die.\n\n<i>Your kills don't just end lives — they strengthen your allies.</i></size>",
  "Catalyst.AddonGivenNotify": "The <#ff1919>Catalyst</color> gave you a new add-on!",
  "Catalyst.GiveAddonsToSelf": "<#ff1919>Catalyst</color> also receives helpful add-ons",
  "Catalyst.GiveOnlyEnabledAddons": "Only give enabled add-ons",
  "Catalyst.RemoveGivenAddonsAfterDeath": "Remove all given add-ons after the <#ff1919>Catalyst</color> dies",
  "Centralizer": "Centralizer",
  "CentralizerInfo": "Centralize Players' Locations",
  "CentralizerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark a spot — then pull a group of players directly to it.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Centralize</color></b>\nMark a position with your ability. Use it again to teleport a set number of players to that spot. You can optionally include yourself in the group.\n\n<i>Gather them. Then act.</i></size>",
  "Centralizer.NumPlayersTeleported": "Number of Players Teleported",
  "Changeling": "Changeling",
  "ChangelingInfo": "Pick Your Impostor Role!",
  "ChangelingInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Cycle through Impostor roles and lock in the one you want to play.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Role Select</color></b>\nVent or pet to cycle through available Impostor roles. Your current selection is shown below your name. Shapeshift to confirm and permanently become that role.\n\n<i>You get to choose your weapon. Choose wisely.</i></size>",
  "ChangelingCurrentRole": "Selected Role: {0}",
  "Chronomancer": "Chronomancer",
  "ChronomancerInfo": "Charge up your kill button and go ham!",
  "ChronomancerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Charge your kill button — then unleash a rapid-fire killing streak.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Charge</color></b>\nOnce your kill cooldown expires, your kill button begins charging (shown as a percentage below your name). Each kill consumes charge and grants a 0-second kill cooldown until the charge depletes. When it runs out, your cooldown resets normally.\n\n<i>Patience charges the storm. Then you let it loose.</i></size>",
  "ChronomancerPercent": "<color=#00ffa5>Charge:</color> <b>{0}</b>%",
  "Cleaner": "Cleaner",
  "CleanerInfo": "Report bodies to make them unreportable",
  "CleanerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Press Report on a body to erase it — make it unreportable forever.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Clean</color></b>\nPress your Report button on a body to destroy it. Requires kill cooldown to be ready. On success, you'll see a shield animation as confirmation (only visible to you). Cleaned bodies — including Bait's — cannot be reported by anyone.\n\n<i>No body, no report, no problem.</i></size>",
  "CleanerCleanBody": "The body has been cleaned",
  "CleanerKCDNotUp": "<#ff4444>Wait for your kill cooldown to be up to clean a body</color>",
  "CleanerKCDNotUpTimer": "<#ff4444>Wait for {0}s to clean a body</color>",
  "CleanerReportButtonText": "Clean",
  "ClockBlocker": "Clock Blocker",
  "ClockBlockerInfo": "Increase Emergency Cooldown by Killing",
  "ClockBlockerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill you land delays when the crew can call meetings.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Cooldown Extension</color></b>\nEach kill permanently extends the emergency meeting cooldown after meetings by a set amount, up to a maximum.\n\n<i>Buy time. Take lives. Repeat.</i></size>",
  "ClockBlocker.CountAddedTimeAfterDeath": "Count Added Time After Death",
  "ClockBlocker.EmergencyCooldownIncreasePerKill": "Increase the Emergency Cooldown by",
  "ClockBlocker.MaxEmergencyCooldown": "Maximum Emergency Cooldown",
  "Commander": "Commander",
  "CommanderInfo": "Command your team",
  "CommanderInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Coordinate your team with six tactical commands.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Command Mode</color></b>\nVent/pet to cycle modes; shapeshift to execute. Shifting into an Impostor targets them specifically:\n<size=70%>・<b>Mark</b> — highlight shapeshift target for your team to kill\n・<b>Whistle</b> — summon all or one Impostor to your location\n・<b>Kill Anyone</b> — tell all or one Impostor to kill now\n・<b>Leave Alive</b> — mark a crewmate as off-limits, or order an Impostor to stand down\n・<b>Don't Sabotage</b> — tell all Impostors to hold sabotages\n・<b>Use Ability</b> — tell all or one Impostor to use their ability</size>\n\n<i>A team without communication is just noise.</i></size>",
  "CommanderDontKill": "<size=1.7>Don't kill this player</size>",
  "CommanderDontKillAnyoneNotify": "Commander wants you to not kill",
  "CommanderDontKillMarkMode": "Mark a Player to Leave Alive",
  "CommanderDontSabotageMode": "Command to Not Sabotage",
  "CommanderDontSabotageNotify": "Commander wants you to not sabotage",
  "CommanderKillAnyoneMode": "Command to Kill Anyone",
  "CommanderKillAnyoneNotify": "Commander wants you to kill anyone",
  "CommanderMarkMode": "Mark Target",
  "CommanderNotify": "The Commander wants you to meet with them",
  "CommanderTarget": "<size=1.7>Commander's target</size>",
  "CommanderUseAbilityMode": "Command to Use Ability",
  "CommanderUseAbilityNotify": "Commander wants you to use your ability",
  "CommanderWhistleMode": "Whistle",
  "CommanderWhistling": "Whistling",
  "Consigliere": "Consigliere",
  "ConsigliereInfo": "Discover the roles of other players",
  "ConsigliereInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Use your kill button to read anyone's role — then decide their fate.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Role Reveal</color></b>\nSingle-click your kill button to reveal a player's role. Double-click to kill normally. When reveal uses are exhausted, your kill button returns to normal function.\n\n<i>Know everyone's secrets. Use them at your discretion.</i></size>",
  "Consort": "Consort",
  "ConsortInfo": "Role-Block and Kill Players",
  "ConsortInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Role-block a player to shut down their abilities — then kill later.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Role-Block</color></b>\nSingle-click your kill button on a player to role-block them — preventing kills, venting, sabotaging, and reporting for a duration. Double-click to kill normally.\n\n<i>Cut their legs out before they can act.</i></size>",
  "Convict": "Convict",
  "ConvictInfo": "Your target died. Now help the Impostors",
  "ConvictInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Your target died. Now your loyalty shifts — work for the Impostors.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Defection</color></b>\nYou are now aligned with the Impostors and work toward their victory.\n\n<i>Loyalty is for those who haven't lost everything yet.</i></size>",
  "Councillor": "Councillor",
  "CouncillorInfo": "Kill crewmates during meetings",
  "CouncillorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Execute players silently during meetings — disguised as a trial.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Trial</color></b>\nUse <b>/cmd tl [player id]</b> during a meeting to secretly kill a player. The kill appears as a Meeting Sheriff trial to other players. Player IDs are shown before names, or use <b>/cmd id</b> to list them.\n\n<i>The meeting is your courtroom. The verdict is always the same.</i></size>",
  "CouncillorCanMurderImpostor": "Can Murder <color=#ff1919>Impostors</color>",
  "CouncillorCanMurderMadmate": "Can Murder <color=#ff1919>Madmates</color>",
  "CouncillorDead": " You can't murder from the dead.",
  "CouncillorMakeEvilJudgeClear": "Show Trial as Councillor Murder",
  "CouncillorMurderMax": "Sorry, you've reached the maximum amount of murders.",
  "CouncillorMurderMaxMeeting": "You cannot murder more players in this meeting. You've reached the limit set by the host.",
  "Crewpostor": "Crewpostor",
  "CrewpostorInfo": "Kill by completing tasks",
  "CrewpostorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Complete tasks — and kill the nearest player each time.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Task Kill</color></b>\nEvery set number of task completions triggers an automatic kill on the nearest player. You appear to be a normal crewmate to everyone else.\n\n<i>Your tasks are your cover. Your kills are the truth.</i></size>",
  "CrewpostorKillAfterTask": "Amount of Task Completions Required to make 1 Kill",
  "CrewpostorKnowsAllies": "Knows <color=#ff1919>Impostors</color>",
  "CrewpostorLungeKill": "Lunge on Kills",
  "CursedWolf": "Cursed Wolf",
  "CursedWolfInfo": "You survive a few kill attempts",
  "CursedWolfInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Survive kill attempts — and curse the attacker to death in return.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Death Curse</color></b>\nWhen someone tries to kill you, the attack is reversed and they die instead. The number of times this can trigger is set by the host.\n\n<i>Kill me if you dare. It won't end well for you.</i></size>",
  "Dazzler": "Dazzler",
  "DazzlerInfo": "Reduce players' vision",
  "DazzlerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift into players to permanently shrink their vision.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Dazzle</color></b>\nShapeshift into a player to permanently reduce their vision. The effect persists until you die or are ejected, at which point their vision returns to normal.\n\n<i>Half the view. Twice the fear.</i></size>",
  "DazzleButtonText": "Dazzle",
  "DazzleCooldown": "Dazzle Cooldown",
  "DazzlerCauseVision": "Reduced vision",
  "DazzlerDazzleLimit": "Max number of players affected by reduced vision",
  "DazzlerDazzled": "You were dazzled by the Dazzler!",
  "DazzlerResetDazzledVisionOnDeath": "Reset vision of dazzled players on death/eject",
  "Deathpact": "Deathpact",
  "DeathpactInfo": "Assign players to a death pact",
  "DeathpactInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark players for a death pact — and force them to find each other or die.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Death Pact</color></b>\nShapeshift into players to mark them. Once enough are marked, they must meet within a set time — or all die. If any marked player dies before the pact resolves, the pact is cancelled.\n\n<i>They think they're safe. They have a deadline.</i></size>",
  "DeathpactActiveDeathpact": "Find <b>{0}</b> in <b>{1}</b> seconds.",
  "DeathpactAverted": "Death Pact was averted.",
  "DeathpactButtonText": "Assign",
  "DeathpactComplete": "Death Pact was concluded.",
  "DeathpactCouldNotAddTarget": "Target can't be added to Death Pact.",
  "DeathPactCooldown": "<color=#ff1919>Death Pact</color> Assign Cooldown",
  "DeathpactDuration": "<color=#ff1919>Death Pact</color> duration",
  "DeathpactExecuted": "Death Pact was executed.",
  "DeathpactKillPlayersInDeathpactOnMeeting": "Kill players in <color=#ff1919>Death Pact</color> on meeting",
  "DeathpactNumberOfPlayersInPact": "Number of players in <color=#ff1919>Death Pact</color>",
  "DeathpactReduceVisionWhileInPact": "Reduce vision for players in <color=#ff1919>Death Pact</color>",
  "DeathpactShowArrowsToOtherPlayersInPact": "Show arrows leading to other players in <color=#ff1919>Death Pact</color>",
  "DeathpactVisionWhileInPact": "Vision for players in <color=#ff1919>Death Pact</color>",
  "Devourer": "Devourer",
  "DevourerInfo": "Consume the skin of the crew",
  "DevourerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Steal a player's appearance permanently — and sharpen with each skin taken.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Devour</color></b>\nShapeshift into a player to permanently overwrite their appearance with a stolen skin. Each appearance change reduces your kill cooldown. If you die or are ejected, all consumed appearances revert.\n\n<i>Their face. Your weapon.</i></size>",
  "DevourerButtonText": "Devour",
  "DevourerEatenSkin": "Target skin eaten",
  "DevourerHideNameConsumed": "Hide the names of consumed players",
  "Disperser": "Disperser",
  "DisperserInfo": "Shift/Vanish to teleport everyone to a random vent",
  "DisperserInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Scatter everyone to random vents across the ship.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Disperse</color></b>\nVanish or pet to teleport all other players to random vents simultaneously. You stay put. Players already inside a vent are not teleported.\n\n<i>Chaos is a strategy when you control the starting positions.</i></size>",
  "DisperserVentButtonText": "Disperse",
  "Duellist": "Duellist",
  "DuellistInfo": "Duel with Players",
  "DuellistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Drag a target outside the map — and settle it one on one.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Duel</color></b>\nShapeshift into a player to teleport both of you off-map. Neither can leave until one of you dies.\n\n<i>No witnesses. No escape. Just the two of you.</i></size>",
  "EarnestWolf": "Earnest Wolf",
  "EarnestWolfInfo": "Switch to extended kill range and stack cooldown on each kill",
  "EarnestWolfInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Toggle OverKill mode for extended reach — at the cost of mounting cooldowns.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>OverKill Mode</color></b>\nToggle with your ability button. In OverKill mode, your kill range extends significantly but your cooldown multiplies with each kill. Limited uses (0 = unlimited). OverKill victims may be made unreportable depending on settings.\n\n<i>More range, more kills — but the price climbs with every body.</i></size>",
  "EarnestWolfOverKillCount": "OverKill Uses (0 = Unlimited)",
  "EarnestWolfOverBairitu": "Kill Cooldown Multiplier per Kill",
  "EarnestWolfNormalKillDistance": "Normal Kill Distance (0=Short 1=Normal 2=Long)",
  "EarnestWolfOverKillDistance": "OverKill Kill Distance (0=Short 1=Normal 2=Long)",
  "EarnestWolfCantReport": "OverKill Victims Cannot Be Reported",
  "EarnestWolfKillButtonNormal": "Normal",
  "EarnestWolfKillButtonOverKill": "OverKill",
  "Echo": "Echo",
  "EchoInfo": "Make Players Die Where You Want",
  "EchoInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Possess a player — then leave them to die where you stood.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Possess</color></b>\nShapeshift into a player to swap positions and appearances with them. While shapeshifted, your target cannot move. When you revert, the swap undoes — and the target dies at your original location. Cannot kill normally.\n\n<i>You never had to go to them. You made them come to their end.</i></size>",
  "Echo.DisableVentingWhileControlling": "Disable Venting While Controlling",
  "EchoShapeshiftButtonText": "Control",
  "Escapist": "Escapist",
  "EscapistInfo": "Shift/Vanish to mark places and warp back to them",
  "EscapistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark an escape point — then warp back to it whenever you need out.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Escape Warp</color></b>\nVanish or pet to mark your current location. Vanish or pet again to instantly teleport back to the marked spot (unshifting does not trigger the warp).\n\n<i>Always have somewhere safe to run to.</i></size>",
  "Escapist.OneMarkPerRound": "One Mark Per Round",
  "EscapistAbilityButtonText": "TP",
  "EvilBomber": "Evil Bomber",
  "EvilBomberInfo": "Plant a delayed bomb on the nearest player",
  "EvilBomberInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Plant a hidden bomb on a player — and let it do the work later.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Bomb Plant</color></b>\nUse your ability button to secretly attach a timed bomb to the nearest player. After a delay, it explodes — killing everyone within blast range of that player. Limited bomb count.\n\n<i>You don't need to be there when it goes off.</i></size>",
  "EvilBomberBombCount": "Number of Bombs",
  "EvilBomberKillDelay": "Bomb Detonation Delay",
  "EvilBomberBlastRange": "Blast Range",
  "EvilBomberAbility": "Plant Bomb",
  "EvilEraser": "Evil Eraser",
  "EvilEraserInfo": "Erase the role of your vote target",
  "EvilEraserInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Vote a crewmate in meetings to strip their role entirely after it ends.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Role Erasure</color></b>\nVote for any crewmate during a meeting to erase their role once it concludes. Erased players are treated as vanilla Crewmates — including on the results screen.\n\n<i>The most dangerous players become ordinary with one vote.</i></size>",
  "EvilEraserHideVote": "Hide <color=#ff1919>Evil Eraser</color>'s Votes",
  "EvilTeller": "Evil Evil Teller",
  "EvilTellerInfo": "Stalk a player to learn their role",
  "EvilTellerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Stalk a player close enough and long enough to learn their role.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Stalk</color></b>\nUse your ability to begin stalking the nearest non-Impostor. Remain within range for the required duration to permanently learn their role. Moving away or the target dying cancels the stalk with a short cooldown. Limited to a set number of successful stalks.\n\n<i>Watch long enough and they'll tell you everything.</i></size>",
  "EvilTellerMaxTellCount": "Max Stalk Count",
  "EvilTellerAbilityCooldown": "Stalk Cooldown",
  "EvilTellerTellTime": "Required Stalk Duration",
  "EvilTellerDistance": "Stalk Range",
  "EvilTellerUseKillCooldownAfterTell": "Reset Kill Cooldown on Successful Stalk",
  "EvilTellerAbility": "Stalk",
  "EvilTellerObservingHint": "Stay close to your target...",
  "EvilGambler": "Evil Gambler",
  "EvilGamblerInfo": "Gamble on your kills for ultra-low or ultra-high cooldown",
  "EvilGamblerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill is a coin flip — jackpot cooldown or brutal penalty.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Gamble</color></b>\nEach kill rolls a random chance. On success, your next kill cooldown is extremely short. On failure, it becomes extremely long. Cooldown resets to the failure value after each meeting.\n\n<i>High risk. High reward. No middle ground.</i></size>",
  "EvilGamblerGambleCollect": "Gamble Success Chance",
  "EvilGamblerCollectkillCooldown": "Kill Cooldown on Success",
  "EvilGamblerNotcollectkillCooldown": "Kill Cooldown on Failure",
  "EvilGuesser": "Evil Guesser",
  "EvilGuesserInfo": "Guess roles in meetings to kill",
  "EvilGuesserInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Guess a player's role in meetings — kill them if right, die if wrong.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Guess</color></b>\nDuring a meeting, use <b>/cmd bt [player id] [role]</b> to guess a player's role. A correct guess kills the target. A wrong guess kills you. Use <b>/cmd id</b> to view player IDs.\n\n<i>One wrong move ends your game. Make sure it's right.</i></size>",
  "EvilJumper": "Evil Jumper",
  "EvilJumperInfo": "Mark a spot, then jump to it killing on the way",
  "EvilJumperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark a destination — then leap across the map, killing on every hop.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Jump</color></b>\nPress your ability once to mark a destination. Press it again to launch across the map in multiple hops. Each hop kills nearby players in a small radius. Cannot kill or vent while jumping.\n\n<i>The journey itself is the weapon.</i></size>",
  "EvilJumperJumpCount": "Number of Jump Hops",
  "EvilJumperJumpRange": "Kill Radius Level Per Hop (1-5)",
  "EvilJumperOneCoolTime": "Ability Cooldown (Set Destination Phase)",
  "EvilJumperJumpCoolTime": "Ability Cooldown (Jump Phase)",
  "EvilJumperJumpInterval": "Seconds Per Hop",
  "EvilJumperSetJumpPos": "Set Jump Destination",
  "EvilJumperJump": "Jump!",
  "EvilMagician": "Evil Magician",
  "EvilMagicianInfo": "Mark nearby players with magic; kill enough targets to eliminate all marked",
  "EvilMagicianInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark targets over time — then make them all disappear at once.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Mark</color></b>\nPress your ability to mark the nearest non-Impostor within range. After accumulating enough kills, all marked targets are simultaneously eliminated. Can mark up to a configurable maximum.\n\n<i>The audience won't see the trick coming. They never do.</i></size>",
  "EvilMagicianCooldown": "Ability Cooldown",
  "EvilMagicianMaximum": "Maximum Marked Targets (0 = Infinite)",
  "EvilMagicianRadius": "Mark Range",
  "EvilMagicianMagicUseKillCount": "Kills Required to Trigger Magic",
  "EvilMagicianShowDeadbody": "Show Dead Body on Kill",
  "EvilMagicianResetKillCount": "Reset Kill Count After Meeting",
  "EvilMagicianResetMagicTarget": "Clear Marked Targets After Meeting",
  "EvilMagicianAbility": "Mark",
  "EvilSatellite": "Evil Satellite",
  "EvilSatelliteInfo": "Vote yourself to reveal a player's movement history",
  "EvilSatelliteInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Vote yourself in meetings to spy on any player's full movement history.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Satellite Mode</color></b>\nVote yourself during a meeting to enter satellite mode. Then vote any player to see their complete room movement history this round. Display order can be randomized. Limited uses per game.\n\n<i>Their route tells you everything about where they've been — and what they've done.</i></size>",
  "EvilSatelliteKillCooldown": "Kill Cooldown",
  "EvilSatelliteRandom": "Randomize Route Display Order",
  "EvilSatelliteMax": "Number of Uses",
  "EvilSatelliteActivate": "Satellite mode activated. Vote a player to see their route.",
  "EvilSatelliteSelfVoteHint": "Vote yourself to activate satellite ability",
  "EvilSatelliteHintActivated": "Satellite active — vote a player to see their route",
  "EvilSatelliteRouteInfo": "\\n{0}'s movement route:",
  "EvilSatelliteRouteInfo2": "\\n(Order is randomized)",
  "EvilSatelliteRouteInfo3": "\\nUses remaining: {0}",
  "EvilSatelliteRouteInfoTitle": "{0}'s Route",
  "Comebacker": "Comebacker",
  "ComebackerInfo": "Enter a vent to register a waypoint; re-enter any vent to teleport back to it",
  "ComebackerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to set a waypoint — re-enter any vent to teleport back to it.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Waypoint</color></b>\nYou have an Engineer-style vent ability. The first vent you enter becomes your registered waypoint. Every subsequent vent entry teleports you to the previous waypoint and registers the new vent for next time.\n\n<i>There's always somewhere safe to come back to.</i></size>",
  "ComebackerLowerText": "Waypoint: {0}",
  "ComebackerAbility": "Register Waypoint",
  "Snowman": "Snowman",
  "SnowmanInfo": "Your vision shrinks as you walk",
  "SnowmanInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Walk less to preserve your vision — stay still or melt away.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Melting</color></b>\nYour vision starts high but shrinks the more you move. Standing still slows the melt. Once all tasks are completed, vision stops decreasing. Depending on settings, electrical sabotage pauses the melting.\n\n<i>The less you move, the more you see.</i></size>",
  "SnowmanFirstVision": "Starting Vision",
  "SnowmanMinVision": "Minimum Vision",
  "SnowmanMeltedSteps": "Steps Until Fully Melted",
  "SnowmanElectricalIgnoreMelt": "Pause Melting During Electrical",
  "Shyboy": "Shyboy",
  "ShyboyInfo": "Die of embarrassment if surrounded by others for too long",
  "ShyboyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Stay away from people — or literally die of embarrassment.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Shyness</color></b>\nIf other players linger near you for too long, you die. After each meeting there is a grace period before the mechanic activates. Your danger level slowly decreases when alone.\n\n<i>Personal space is a matter of survival.</i></size>",
  "ShyboyShytime": "Time Near Others Before Death",
  "ShyboyAfterMeetingNotShytime": "Grace Period After Meeting",
  "Satellite": "Satellite",
  "SatelliteInfo": "Vote yourself in a meeting to reveal a room a player visited",
  "SatelliteInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote yourself in meetings to reveal where players have been.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Satellite Mode</color></b>\nVote yourself during a meeting to enter satellite mode. Then vote any player to see one room they visited this round. Limited uses per game. Optionally requires task completion to unlock.\n\n<i>Overhead always. Nothing passes without notice.</i></size>",
  "SatelliteMaxUses": "Maximum Uses",
  "SatelliteMeetingMaxUses": "Max Uses Per Meeting (0 = Unlimited)",
  "SatelliteTaskCount": "Tasks Required to Unlock Ability",
  "SatelliteActivate": "Satellite mode activated. Vote a player to reveal one of their visited rooms.",
  "SatelliteSelfVoteHint": "Vote yourself to activate satellite ability",
  "SatelliteHintActivated": "Satellite active — vote a player to reveal a room they visited",
  "SatelliteResultTitle": "{0}'s Location",
  "SatelliteResult": "{0} visited {1}.",
  "SatelliteResultAgain": "{0} already scanned — visited {1}.",
  "SatelliteResultNoRooms": "{0} has no recorded movements this round.",
  "SatelliteResultComms": "Satellite signal lost — comms sabotage active.",
  "SatelliteUsesLeft": "\\nUses remaining: {0}",
  "GuardMaster": "Guard Master",
  "GuardMasterInfo": "Complete tasks to earn guard charges",
  "GuardMasterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to earn kill-blocking guard charges.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Guard Charge</color></b>\nCompleting tasks grants guard charges. When a killer attacks you while charges remain, the kill is blocked and one charge is consumed. You see the attacker's name highlighted; they may see yours depending on settings. Optionally requires a task threshold to awaken.\n\n<i>Hard work pays off — literally.</i></size>",
  "GuardMasterAddGuardCount": "Guard Charges Gained Per Task Completion",
  "GuardMasterTaskAwakening": "Require Tasks to Awaken",
  "GuardMasterAwakeningTaskcount": "Tasks Required to Awaken",
  "MadGuardianCanSeeWhoTriedToKill": "Can See Who Tried to Kill You",
  "Gasp": "Gasp",
  "GaspInfo": "Mark your killer on death",
  "GaspInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Die with enough tasks done — and see your killer marked in your final moments.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Last Gasp</color></b>\nWhen killed after completing enough tasks, your killer is marked with a star (★) visible only to you. The mark vanishes permanently when a meeting is called.\n\n<i>Your last sight is the truth. Act before it disappears.</i></size>",
  "GaspTaskTrigger": "Tasks Required to Activate Ability",
  "InSender": "In Sender",
  "InSenderInfo": "Your killer self-reports your body",
  "InSenderInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>When you die, your killer is forced to report your own body.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Force Report</color></b>\nWhen killed, your killer is forced to report your body after a short delay. The delay can be randomized by a configurable amount. Optionally requires task completion to awaken.\n\n<i>Dead? Sure. But they'll be found standing over your body.</i></size>",
  "InSenderCanUseActiveComms": "Ability Works During Comms Sabotage",
  "InSenderReportDelay": "Report Delay",
  "InSenderMaxDelay": "Maximum Additional Random Delay",
  "InSenderTaskAwakening": "Require Tasks to Awaken",
  "InSenderAwakeningTaskcount": "Tasks Required to Awaken",
  "UltraStar": "Ultra Star",
  "UltraStarInfo": "Speed boost with rainbow colors",
  "UltraStarInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Sprint in a rainbow blur — and optionally vaporize anyone who gets too close.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Star Power</color></b>\nYou move faster than everyone else and cycle through all colors in a rainbow pattern. Optionally, players who get too close are automatically killed. Other players can optionally see your role name.\n\n<i>Fast. Flashy. Fabulous.</i></size>",
  "UltraStarAddSpeed": "Speed Bonus",
  "UltraStarCanseeallplayer": "All Players Can See Your Role",
  "UltraStarCankill": "Can Auto-Kill Nearby Players",
  "UltraStarActivate": "Activate Star",
  "UltraStarDeactivate": "Deactivate Star",
  "Balancer": "Balancer",
  "BalancerInfo": "Force two players into a deciding vote",
  "BalancerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Force a decisive showdown between two players — one must go.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Deciding Vote</color></b>\nVote yourself in a meeting to enter selection mode. Vote two players to nominate them. After the meeting ends, a second meeting begins where all votes are locked to those two players. Whoever gets more votes is ejected. One-time use.\n\n<i>Stop the debate. Make the choice simple.</i></size>",
  "BalancerMeetingTime": "Balancer Meeting Duration",
  "BalancerCanUseAllAlive": "Require a Death Before Use",
  "BalancerEnterMode": "Selection mode activated. Vote a player to select the first target.",
  "BalancerCancelMode": "Selection cancelled.",
  "BalancerTargetDead": "That player is dead. Vote again.",
  "BalancerTarget1Selected": "First target selected: {0}. Vote another player to confirm.",
  "BalancerTarget1Cleared": "First target deselected.",
  "BalancerTargetsSelected": "{0} and {1} selected. A deciding meeting will begin after this one.",
  "BalancerMeetingStart": "A deciding vote between {0} and {1} is now starting!",
  "Pathologist": "Pathologist",
  "PathologistInfo": "Examine a player and receive a clue when they die",
  "PathologistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Track a player in meetings — and learn clues about their death if they're killed.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Post-Mortem Examination</color></b>\nVote a player in a meeting to track them. If they die before the next meeting, you receive random death clues — cause of death, killer's color, killer's role, team, time since death, or room. Limited examinations per game.\n\n<i>Every death has a story. You read it after the fact.</i></size>",
  "PathologistMaxUses": "Number of Examinations",
  "PathologistVoteMode": "Ability Vote Mode",
  "PathologistInfoCount": "Info Pieces per Examination",
  "PathologistTaskAwakening": "Require Tasks to Awaken",
  "PathologistAwakeningTaskCount": "Tasks Required to Awaken",
  "PathologistSetRect": "Set Info Chance Weights",
  "PathologistDeathReason": "Death Reason Weight",
  "PathologistKillerColor": "Killer Color Weight",
  "PathologistTargetTeam": "Target Team Weight",
  "PathologistKillerRole": "Killer Role Weight",
  "PathologistDeathTimer": "Time Since Death Weight",
  "PathologistTargetRoom": "Death Room Weight",
  "PathologistEnterMode": "Examination mode activated. Vote a player to track them.",
  "PathologistTargetSet": "Now tracking {0}. You will receive a clue when they die.",
  "PathologistTitle": "Examination Report",
  "PathologistInfoDeathReason": "{0} was killed by: {1}",
  "PathologistInfoColor": "{0}'s killer wore color: {1}",
  "PathologistInfoTeam": "{0}'s team was: {1}",
  "PathologistInfoRole": "{0} was killed by a: {1}",
  "PathologistInfoTimer": "{0} died approximately {1} seconds ago",
  "PathologistInfoRoom": "{0} was killed in: {1}",
  "ShrineMaiden": "Shrine Maiden",
  "ShrineMaidenInfo": "Compare a reported body's team with a living player",
  "ShrineMaidenInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Compare a reported body's team with any living player in the meeting.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Shrine Reading</color></b>\nWhen a body is reported, vote a player during the meeting to compare their team with the victim's. Learn whether they share the same team or belong to different ones. Limited uses per game with an optional per-meeting cap.\n\n<i>The spirits don't lie — they just compare.</i></size>",
  "ShrineMaidenMaxUses": "Number of Uses",
  "ShrineMaidenVoteMode": "Ability Vote Mode",
  "ShrineMaidenTaskAwakening": "Require Tasks to Awaken",
  "ShrineMaidenAwakeningTaskCount": "Tasks Required to Awaken",
  "ShrineMaidenPerMeetingMax": "Max Uses Per Meeting (0 = Unlimited)",
  "ShrineMaidenEnterMode": "Shrine mode activated. Vote a player to compare their team with the body.",
  "ShrineMaidenCancelMode": "Selection cancelled.",
  "ShrineMaidenTitle": "Shrine Reading",
  "ShrineMaidenSameTeam": "{0} and {1} are on the same team.",
  "ShrineMaidenDifferentTeam": "{0} and {1} are on different teams.",
  "ShrineMaidenRemaining": "Remaining uses: {0}",
  "Walker": "Walker",
  "WalkerInfo": "Explore rooms to complete your objective",
  "WalkerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Explore the ship — visit enough unique rooms to complete your objective.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Exploration</color></b>\nYour goal is to visit a set number of unique rooms. Progress is tracked and displayed as (visited/required).\n\n<i>There's more to this ship than meets the eye. Go find it.</i></size>",
  "WalkerWalkTaskCount": "Rooms Required to Visit",
  "Teller": "Teller",
  "TellerInfo": "Divinate a player's role by voting",
  "TellerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote yourself in meetings to divine any player's true role.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Divination</color></b>\nVote yourself to enter divination mode. Then vote any player to reveal their role. Limited uses.\n\n<i>The truth was always there. You just needed to look.</i></size>",
  "TellerMaxUses": "Max Divination Uses",
  "TellerMeetingMaxUses": "Max Uses Per Meeting",
  "TellerVoteMode": "Vote Mode",
  "TellerShowRoleName": "Show Role Above Player Name",
  "TellerShowRole": "Show Role Name (Off = Show Team)",
  "TellerTaskAwakening": "Task Awakening",
  "TellerAwakeningTaskCount": "Awakening Task Count",
  "TellerEnterMode": "Divination mode activated. Vote a player to divine their role.",
  "TellerCancelMode": "Divination cancelled.",
  "TellerTitle": "Divination Result",
  "TellerResult": "{0}: {1}",
  "TellerFin": " →",
  "TellerRemaining": "Remaining uses: {0}",
  "TellerRemainingMeeting": "Remaining uses this meeting: {0}",
  "PonkotuTeller": "Ponkotu Teller",
  "PonkotuTellerInfo": "Divinate with a chance of uncertain results",
  "PonkotuTellerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Divinate roles in meetings — but some results come with a question mark.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Uncertain Divination</color></b>\nVote yourself to enter divination mode, then vote a player to divine their role. There is a set success rate — a confident result is shown normally; an uncertain one appears with a '..?' marker.\n\n<i>Most of the time you're right. Most of the time.</i></size>",
  "PonkotuTellerSuccessRate": "Success Rate",
  "PonkotuTellerMaxUses": "Max Divination Uses",
  "PonkotuTellerMeetingMaxUses": "Max Uses Per Meeting",
  "PonkotuTellerVoteMode": "Vote Mode",
  "PonkotuTellerShowRoleName": "Show Role Above Player Name",
  "PonkotuTellerShowRole": "Show Role Name (Off = Show Team)",
  "PonkotuTellerDontChangeResult": "Keep Same Result on Re-divination",
  "PonkotuTellerTaskAwakening": "Task Awakening",
  "PonkotuTellerAwakeningTaskCount": "Awakening Task Count",
  "PonkotuTellerEnterMode": "Divination mode activated. Vote a player to divine their role.",
  "PonkotuTellerCancelMode": "Divination cancelled.",
  "PonkotuTellerTitle": "Divination Result",
  "AmateurTeller": "Amateur Teller",
  "AmateurTellerInfo": "Mark a player to watch them across rounds",
  "AmateurTellerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vote a player to watch them — and track their role across rounds.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Watch</color></b>\nVote a player in a meeting to set them as your watch target. An arrow guides you toward them. After the meeting, you can see their previous role. The target may receive a mark showing they're being observed.\n\n<i>They move. You watch. You learn.</i></size>",
  "AmateurTellerMaxUses": "Max Uses",
  "AmateurTellerVoteMode": "Vote Mode",
  "AmateurTellerShowRole": "Show Role for Past Targets (Off = Show Team)",
  "AmateurTellerTargetCanSeePlayer": "Target Can See They Are Being Watched",
  "AmateurTellerTargetCanSeeArrow": "Target Can See Arrow to Watcher",
  "AmateurTellerCanUseButton": "Can Use Emergency Button While Watching",
  "AmateurTellerTaskAwakening": "Task Awakening",
  "AmateurTellerAwakeningTaskCount": "Awakening Task Count",
  "AmateurTellerEnterMode": "Target mode activated. Vote a player to mark them.",
  "AmateurTellerCancelMode": "Target cancelled.",
  "AmateurTellerSetTarget": "You are now watching {0}.",
  "WolfBoy": "Wolf Boy",
  "WolfBoyInfo": "Kill players with a shot limit to win",
  "WolfBoyInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Hunt players with a limited kill button — meet your target count to earn a win.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Wolf Hunt</color></b>\nYou have an Impostor-style kill button with a limited number of shots. Kill a required number of players from specified teams to be credited as a winner when Crewmates win.\n\n<i>Not all crewmates play by crewmate rules.</i></size>",
  "WolfBoyShotLimit": "Shot Limit",
  "WolfBoyCanKillAllAlive": "Can Kill Before First Death",
  "WolfBoyWinKillCount": "Required Kills to Win (0 = No Condition)",
  "WolfBoyCountCrew": "Count Crewmate Kills",
  "WolfBoyCountImpostor": "Count Impostor Kills",
  "WolfBoyCountMadmate": "Count Madmate Kills",
  "WolfBoyCountNeutral": "Count Neutral Kills",
  "King": "King",
  "KingInfo": "Force your exile by votes; crewmates perish with you",
  "KingInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Unkillable — but vote you out and crewmates fall with you.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Royal Immunity</color></b>\nImmune to all kills. However, if enough players vote for you in a meeting, you are forcibly exiled — and a number of random crewmates are eliminated alongside you. All crewmates can see your role.\n\n<i>A king's fall brings the court down with them.</i></size>",
  "KingExileVoteCount": "Votes Required to Force Exile",
  "KingInvolvementCount": "Crewmates Eliminated on Exile",
  "KingDeathReason": "Death Reason for Involved Crewmates",
  "EvilTracker": "Evil Tracker",
  "EvilTrackerInfo": "Track players by shifting",
  "EvilTrackerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Track a target with a persistent arrow — and feel it when your teammates kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Track</color></b>\nShapeshift to switch your tracking target (you immediately revert). An arrow below your name always points toward your current target. Receive a kill flash whenever a teammate makes a kill.\n\n<i>You always know where they are. Your team always knows when to strike.</i></size>",
  "EvilTrackerCanSeeKillFlash": "Can See Kill-Flash",
  "EvilTrackerCanSeeLastRoomInMeeting": "Can See Target's Last Room In Meeting",
  "EvilTrackerChangeButtonText": "Track",
  "EvilTrackerResetTargetAfterMeeting": "Can Reset Target After Meeting",
  "EvilTrackerTargetMode": "Can Set Target",
  "EvilTrackerTargetMode.Always": "Any time",
  "EvilTrackerTargetMode.EveryMeeting": "Every Meeting",
  "EvilTrackerTargetMode.Never": "Never",
  "EvilTrackerTargetMode.OnceInGame": "Once in game",
  "Exclusionary": "Exclusionary",
  "ExclusionaryInfo": "Exclude Players From The World",
  "ExclusionaryInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Make a player blind to everyone else on the ship.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Exclusion</color></b>\nSingle-click your kill button to exclude a target after a short delay — all other players vanish from their view. Double-click to kill normally.\n\n<i>Isolated. Helpless. Alone.</i></size>",
  "Exclusionary.CooldownAfterExclusion": "Cooldown After Exclusion",
  "Exclusionary.ExclusionDelay": "Exclusion Delay",
  "Exclusionary.ExclusionDuration": "Exclusion Duration",
  "Fabricator": "Fabricator",
  "FabricatorInfo": "Change Death Reasons",
  "FabricatorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Control the death reason on your next kill — fabricate the evidence.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Fabricate</color></b>\nUse <b>/cmd fabricate {deathreason}</b> to set a custom death reason for your next kill. Choose from any of the mod's available death reasons.\n\n<i>Who decides how they die? You do.</i></size>",
  "Fabricator.InvalidDeathReason": "<#ff5555>X <#bb0000>Invalid death reason '<#ffffff>{0}</color>'!",
  "Fabricator.SetDeathReason": "<#00ff00>✓ <#00bb00>Your next kill will have the death reason: <#ffffff>{0}</color>",
  "Fakeshifter": "Fakeshifter",
  "FakeshifterInfo": "Make a Player Fake-Shapeshift",
  "FakeshifterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Make a player look like someone else — then watch them publicly unshift.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Fake Shift</color></b>\nUse your shapeshift menu to mark a player. They appear as a random player to everyone except themselves. After a delay, they visibly revert with the egg animation — making them look like a shapeshifter to the entire crew.\n\n<i>You didn't frame them. They framed themselves. Sort of.</i></size>",
  "FakeshifterAbilityDuration": "Delay for the target to shapeshift back",
  "Fireworker": "Fireworker",
  "FireworkerInfo": "Go out with a BANG",
  "FireworkerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Plant firework bombs — then detonate them all as the last Impostor.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Firework</color></b>\nVanish or pet to plant up to three firework bombs across the map. When you're the last Impostor alive, vanish or pet again to detonate all bombs simultaneously for area damage. Warning: you can be caught in your own blast. If all surviving players are eliminated, Impostors win.\n\n<i>Save the best for last.</i></size>",
  "FireworkerExplosionButtonText": "Detonate",
  "FireworkerInstallAtionButtonText": "Install",
  "FireworkerMaxCount": "Fireworks Count",
  "FireworkerPutPhase": "{0} Fireworks Left",
  "FireworkerRadius": "Firework Explosion Radius",
  "FireworkerReadyFirePhase": "Fire!",
  "FireworkerWaitPhase": "Wait for it...",
  "Forger": "Forger",
  "ForgerInfo": "Forge Others' Roles",
  "ForgerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Forge a dead player's role — control what the crew sees on the results screen.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Forge</color></b>\nUse <b>/cmd forge {id} {role}</b> to change a player's displayed role after they die. The change is visual only — their actual role is technically unchanged. Manipulate the post-game narrative.\n\n<i>History is written by the ones still standing.</i></size>",
  "Framer": "Framer",
  "FramerInfo": "Frame Other Players",
  "FramerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Make the game think a player is an Impostor — fooling every investigative role.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Frame</color></b>\nSingle-click your kill button on a player to frame them — the game now treats them as Impostor-aligned, fooling investigators. Double-click to kill normally.\n\n<i>Guilt by association. You wrote the association.</i></size>",
  "Framer.TargetFramedNotify": "The game now thinks {0} is an <#ff1919>impostor</color>",
  "Freezer": "Freezer",
  "FreezerInfo": "Freeze Players",
  "FreezerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift into a player to lock them in place.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Freeze</color></b>\nShapeshift into a player to freeze them on the spot. They cannot move for a set duration.\n\n<i>Easy to kill someone who can't run.</i></size>",
  "Gambler": "Gambler",
  "GamblerInfo": "Each Kill gets you an Effect",
  "GamblerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill triggers a random event — good or bad.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Gamble</color></b>\nAfter each kill, a random effect fires. Outcomes range anywhere between a forced self-report and a bonus sniper shot.\n\n<i>You can't control what you get. You can control when you pull the trigger.</i></size>",
  "GamblerBSRDelay": "Self-Report Delay",
  "GamblerFreezeDur": "Freeze Duration",
  "GamblerGet.BSR": "<color=#ffffff><color=#ffa500>Effect:</color> Self-Report (in <color=#ffa500>{0}s</color>)</color>",
  "GamblerGet.DelayedKill": "<color=#ffffff><color=#00ffa5>Effect:</color> Delayed Kill (<color=#00ffa5>{0}s</color>)</color>",
  "GamblerGet.Freeze": "<color=#ffffff><color=#ffa500>Effect:</color> Freeze (for <color=#ffa500>{0}s</color>)</color>",
  "GamblerGet.HighKCD": "<color=#ffffff><color=#ffa500>Effect:</color> Higher Kill Cooldown (<color=#ffa500>{0}s</color>)</color>",
  "GamblerGet.IgnoreDefense": "<color=#ffffff><color=#00ffa5>Effect:</color> Break Through Defense</color>",
  "GamblerGet.LowKCD": "<color=#ffffff><color=#00ffa5>Effect:</color> Lower Kill Cooldown (<color=#00ffa5>{0}s</color>)</color>",
  "GamblerGet.LowVision": "<color=#ffffff><color=#ffa500>Effect:</color> Lower Vision (<color=#ffa500>{1}x</color>, for <color=#ffa500>{0}s</color>)</color>",
  "GamblerGet.NoLunge": "<color=#ffffff><color=#00ffa5>Effect:</color> No Lunge</color>",
  "GamblerGet.Shield": "<color=#ffffff><color=#00ffa5>Effect:</color> Temporary Shield (<color=#00ffa5>{0}s</color>)</color>",
  "GamblerGet.Speedup": "<color=#ffffff><color=#00ffa5>Effect:</color> Higher Speed (<color=#00ffa5>{1}x</color>, for <color=#00ffa5>{0}s</color>)</color>",
  "GamblerGet.Swap": "<color=#ffffff><color=#00ffa5>Effect:</color> Swap Places with Someone</color>",
  "GamblerHighKCD": "Higher Kill Cooldown",
  "GamblerIgnoreCursedWolfAndJinx": "Kill <color=#ff1919>Cursed Wolf</color> and <color=#ed2f91>Jinx</color>",
  "GamblerIgnoreMedicShield": "Ignore <color=#00ff97>Medic</color> <color=#8cffff>Shield</color>",
  "GamblerIgnorePestilence": "Kill <color=#343136>Pestilence</color>",
  "GamblerIgnoreVeteranAlert": "Ignore <color=#a77738>Squid</color> Alert",
  "GamblerKillDelay": "Delayed Kills are delayed by",
  "GamblerLowKCD": "Lower Kill Cooldown",
  "GamblerLowVision": "Lower Vision",
  "GamblerLowVisionDur": "Lower Vision Duration",
  "GamblerPositiveEffectChance": "Positive Effect Chance",
  "GamblerShieldDur": "Shield Duration",
  "GamblerSpeedup": "Increased Speed",
  "GamblerSpeedupDur": "Increased Speed Duration",
  "GamblerTPDelay": "Swap Delay",
  "GamblerWhatToIgnore": "What to Ignore when the Unstoppable effect is applied",
  "Gangster": "Gangster",
  "GangsterInfo": "Convert players to your side",
  "GangsterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Recruit crewmates to your side — or kill those who can't be flipped.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Recruit</color></b>\nPress your kill button on a player to attempt recruitment. On success, they become a Madmate and both see a shield animation as confirmation. If recruitment fails, they are killed normally. Once recruit slots are exhausted, only normal kills remain.\n\n<i>Everyone has a price. Find it fast.</i></size>",
  "GangsterButtonText": "Recruit",
  "GangsterRecruitCooldown": "Recruit cooldown",
  "GangsterRecruitLimit": "Recruit limit",
  "GangsterRecruitmentFailure": "Target cannot be recruited",
  "GangsterSuccessfullyRecruited": "You successfully recruited a player",
  "Generator": "Generator",
  "GeneratorInfo": "Power up the ship",
  "GeneratorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Accumulate charges every second — spend them to kill, vent, shift, or sabotage.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Power Generation</color></b>\nCharges build up over time. Each action (kill, vent, shapeshift, sabotage) costs a set number of charges. Charges also drain while shapeshifted. Running out means standing still.\n\n<i>Patience builds power. Power enables everything.</i></size>",
  "Generator.ChargesGainedEverySecond": "Charges Gained Every Second",
  "Generator.ChargesLostWhileShiftedPerSecond": "Charges Lost While Shifted Per Second",
  "Generator.Kill.Cost": "Charges Needed to Kill",
  "Generator.MaxChargesStored": "Maximum Charges Stored",
  "Generator.Notify.NotEnoughCharges": "You don't have enough charges ({0}) to do that",
  "Generator.Notify.RevertShapeshift": "You ran out of charges, so shapeshifting was reverted",
  "Generator.Sabotage.Cost": "Charges Needed to Sabotage",
  "Generator.Shapeshift.Cost": "Charges Needed to Shapeshift",
  "Generator.StartingCharges": "Starting Charges",
  "Generator.Vent.Cost": "Charges Needed to Vent",
  "Godfather": "Godfather",
  "GodfatherInfo": "Recruit players by voting them",
  "GodfatherInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark a player as your target — whoever kills them joins your side.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Target</color></b>\nVote a player in a meeting to designate them as your target. In the next round, whoever kills that player is converted into a Renegade and fights for the Impostors.\n\n<i>Use the crew's killers against them.</i></size>",
  "Greedy": "Greedy",
  "GreedyInfo": "Your kill cooldown shifts",
  "GreedyInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Your kill cooldown alternates between two values every kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Alternating Cooldown</color></b>\nYour first kill after each meeting sets cooldown to the even-kill value; the second sets it to the odd-kill value. The cycle repeats until the next meeting. A separate post-meeting cooldown also applies.\n\n<i>Odd or even — you always plan for both.</i></size>",
  "Hangman": "Hangman",
  "HangmanInfo": "Killing while shifted ignores shields",
  "HangmanInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Strangle during a shapeshift — no body, no triggers, no trace.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Strangle</color></b>\nKill while shapeshifted to strangle the victim. This ignores all target abilities — no body is left, nothing triggers (Squid, Lucky, Seer, etc. are all bypassed).\n\n<i>Some kills leave no evidence. By design.</i></size>",
  "HangmanKillButtonTextDuringSS": "Strangle",
  "KillCooldownOnStrangle": "Kill Cooldown after Strangling",
  "Hitman": "Hitman",
  "HitmanInfo": "Select your target",
  "HitmanInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark one target — and earn a reduced cooldown when you take them out.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Contract Kill</color></b>\nShapeshift into a player to lock them in as your target. Killing your marked target grants a lower kill cooldown for your next kill. Once chosen, the target is fixed until killed — then you can designate a new one.\n\n<i>One job at a time. Done right.</i></size>",
  "HitmanLowKCD": "Lower Kill Cooldown",
  "Hypnotist": "Hypnotist",
  "HypnotistInfo": "Prevent Body Reports",
  "HypnotistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Use your ability to lock out all body reports across the ship.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Hypnosis</color></b>\nVanish or pet to put everyone into a hypnotic state. While active, no player can report bodies. Depending on settings, reports blocked during hypnosis may be processed once it ends.\n\n<i>Nobody calls a meeting if nobody can report.</i></size>",
  "Hypnotist.DoReportAfterHypnosisEnds": "Process reports that were blocked during hypnosis after the hypnosis expires",
  "HypnosisNoMeeting": "Everyone is in hypnosis, no meeting calls are allowed currently",
  "Hypocrite": "Hypocrite",
  "HypocriteInfo": "Impostors win if you finish your tasks",
  "HypocriteInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Finish all your tasks alive — and win the game for the Impostors.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>False Finish</color></b>\nComplete all assigned tasks while still alive to trigger an instant Impostor victory. You look like a crewmate doing tasks — but you're anything but.\n\n<i>The best deception is the one no one questions.</i></size>",
  "Hypocrite.AlliesKnowHypocrite": "Allies know the <#ff1919>Hypocrite</color>",
  "Hypocrite.KnowsAllies": "Knows their allies",
  "Hypocrite.NonImpGetsNotifyWhenLowTasks": "Non-Impostors get notified when the <#ff1919>Hypocrite</color> has a low number of tasks remaining",
  "Hypocrite.NotifyAtXTasksLeft": "Tasks Remaining When Notifying",
  "HypocriteHasXTasksLeft": "<size=80%><#ffff44>{0} is the <#ff1919>Hypocrite</color> with <#ff1919>{1}</color> task(s) left!</color></size>",
  "ImpostorEndKnot": "Impostor",
  "ImpostorEndKnotInfo": "Kill & Sabotage",
  "ImpostorEndKnotInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill the Crewmates and eliminate the opposition.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill</color></b>\nEliminate Crewmates using your kill button.\n\n・<b><color=#ff1919>Sabotage</color></b>\nTrigger sabotages to create chaos and openings.\n\n・<b><color=#ff1919>Vent</color></b>\nMove secretly through the ship's vent network.\n\n<i>Deceive. Divide. Destroy.</i></size>",
  "Inhibitor": "Inhibitor",
  "InhibitorInfo": "You cannot kill during sabotages",
  "InhibitorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill freely — but only when there's no active critical sabotage.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Conditional Kill</color></b>\nYou can only use your kill button when no critical sabotage (e.g., Lights, Reactor) is currently active. Time your kills around the chaos.\n\n<i>Strike in the calm between the storms.</i></size>",
  "Kamikaze": "Kamikaze",
  "KamikazeInfo": "Mark Players That Die With You",
  "KamikazeInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark your targets — and take them all out when you go down.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Death Mark</color></b>\nSingle-click your kill button on players to mark them. When you die, all marked players die simultaneously. Double-click to kill normally without marking.\n\n<i>They thought they were safe when I was gone. They were wrong.</i></size>",
  "KamikazeMarkCD": "Cooldown After Marking",
  "Kidnapper": "Kidnapper",
  "KidnapperInfo": "TP Players to you by shifting into them",
  "KidnapperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift into a player to teleport them directly to you.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Kidnap</color></b>\nShapeshift into any player to instantly pull them to your location.\n\n<i>You don't go to them. They come to you.</i></size>",
  "KillingMachine": "Killing Machine",
  "KillingMachineInfo": "You can ONLY kill, but low cooldown and bypass shields",
  "KillingMachineInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill with zero downtime — but that's all you can do.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Machine Kill</color></b>\nExtremely short kill cooldown. No venting, no Impostor vision, no sabotages, no reporting, no emergency meetings. Pure killing power — and nothing else.\n\n<i>It doesn't think. It doesn't plan. It just kills.</i></size>",
  "Librarian": "Librarian",
  "LibrarianInfo": "Silence the Reporters Nearby",
  "LibrarianInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Go silent — and execute anyone who dares report a body near you.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Silence</color></b>\nIn silencing mode, any player who reports a body near you is instantly killed instead. After such a kill, 'SSSH!' briefly appears in red under your name for everyone to see.\n\n<i>Shhh. This is a library.</i></size>",
  "LibrarianModeText": "<color=#00ffa5>Mode:</color> <b>{0}</b>",
  "LibrarianNameNotifyDuration": "SSSH! Name Text Duration",
  "LibrarianNameText": "SSSH!",
  "LibrarianNormalMode": "Normal",
  "LibrarianRadius": "Silence Radius",
  "LibrarianShowSSAnimation": "Shapeshift Transformation Animation is Visible",
  "LibrarianSilenceDuration": "Silence Duration",
  "Limiter": "Limiter",
  "LimiterInfo": "Explode when your limit is reached",
  "LimiterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Hit your limits — then become a walking bomb and take everyone down.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Limit Break</color></b>\nYou have kill, turn, and time limits. Once any limit is reached, your kill button becomes an explosion. Press it to kill all nearby players — and yourself. Reporting a body while limited (if meeting option is disabled) causes an instant explosion.\n\n<i>There's a breaking point. You are the breaking point.</i></size>",
  "LimiterLastTurnKillCool": "Kill Cooldown After Limit Reached",
  "LimiterTurnLimit": "Turn Limit (0 = Off)",
  "LimiterTimeLimit": "Time Limit in Seconds (0 = Off)",
  "LimiterKillLimit": "Kill Limit (0 = Off)",
  "LimiterLimitMeeting": "Survive if Limit Reached During Meeting",
  "LimiterBlastRange": "Blast Range",
  "LimiterBom": "💥 BOOM 💥",
  "LimiterExplodeButtonText": "EXPLODE",
  "LibrarianSilenceMode": "<color=#ff1919>Silence</color>",
  "Lightning": "Lightning",
  "LightningInfo": "Convert players to Quantum Ghosts",
  "LightningInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Convert players into quantum ghosts — unstable and doomed to fade.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Evaporate</color></b>\nCannot kill normally. Use your kill button to vaporize a target into a quantum ghost. Any non-ghost who touches a quantum ghost destroys it. Quantum ghosts who survive to a meeting die afterward. Interacting with them has no effect. Depending on settings, killing you may vaporize your killer into a ghost.\n\n<i>They're still here — just barely.</i></size>",
  "LightningButtonText": "Evaporate",
  "LightningConvertTime": "Duration of the transformation to Quantum Ghost",
  "LightningKillCooldown": "Lightning Cooldown",
  "LightningKillerConvertGhost": "Killer can transform into Quantum Ghost",
  "Loner": "Loner",
  "LonerInfo": "Select Your Partner",
  "LonerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Choose your own Impostor partner — and assign their role yourself.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Partner Select</color></b>\nIn a meeting, use the shapeshift menu to assign a partner a random Impostor role, or use <b>/cmd select {id} {role}</b> to pick a specific one. The role change applies after the meeting.\n\n<i>Build the team you want. From scratch.</i></size>",
  "Loner.Picked": "<#00ff00>✓ <#00ffa5>You've picked {0} to be your partner! Their role will be {1}.",
  "LovingImpostor": "Loving Impostor",
  "LovingImpostorInfo": "Stay alive and win together!",
  "LovingImpostorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Survive and protect your lover — you're bound together, for better or worse.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Lover's Bond</color></b>\nStay alive to help your lover win. If your lover dies, you die too. You are still an Impostor and can win through either path — but your lover must survive.\n\n<i>Love makes it complicated. Surviving makes it worth it.</i></size>",
  "LovingImpostorSpawnChance": "<color=#ff9ace>Loving</color> <#ff1919>Impostor</color> Spawn Chance",
  "Lurker": "Lurker",
  "LurkerInfo": "Reduce your kill cooldown by venting",
  "LurkerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Use vents to cut your kill cooldown — then reset after each kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Lurk</color></b>\nEntering a vent reduces your kill cooldown by a set amount. After making a kill, cooldown resets to its original value.\n\n<i>Patience in the dark. Speed when it counts.</i></size>",
  "Mafioso": "Mafioso",
  "MafiosoInfo": "With Each Tier, you're more Powerful",
  "MafiosoInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Earn XP with every action — level up and become unstoppable.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Tier Progression</color></b>\nGain XP by killing, sabotaging, visiting new vents, or seeing non-Impostors ejected. 100 XP = tier up:\n<size=70%>・Tier 0 — standard Impostor, high cooldown, short range\n・Tier 1 — long kill range, normal cooldown\n・Tier 2 — reduced kill cooldown\n・Tier 3 — dual pistols: 2 separate cooldowns, kill if either is ready\n・Tier 4 — normal cooldown on both pistols\n・Tier 5 — kills are delayed</size>\n\n<i>Start small. Become inevitable.</i></size>",
  "MafiosoDelay": "Kill Delay on Tier 5",
  "MafiosoHUDText": "<color=#00ffa5>Tier:</color> {0}\\n<color=#00ffa5>XP:</color> {1}",
  "MafiosoHUDTextWithDualPistols": "<color=#00ffa5>Tier:</color> {0}, <color=#00ffa5>XP:</color> {1}\\n",
  "MafiosoLevelUp": "You've gone up a tier!",
  "MafiosoProgressText": "<color=#00ffa5>Tier:</color> <color=#ffffff>{0}</color>, <color=#00ffa5>XP:</color> <color=#ffffff>{1}</color>",
  "MafiosoRewardForKilling": "XP Gained for Getting a Kill",
  "MafiosoRewardForOtherPlayerEjected": "XP Gained When a Non-Impostor Player Gets Ejected",
  "MafiosoRewardForSabotaging": "XP Gained for Calling a Sabotage",
  "MafiosoRewardForVenting": "XP Gained for Entering a Unique Vent",
  "Mastermind": "Mastermind",
  "MastermindInfo": "Make others kill for you",
  "MastermindInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Manipulate a player into killing for you — or they die.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Manipulation</color></b>\nSingle-click your kill button to manipulate a player. After a delay, they're told they must kill someone within a time limit or die. If time runs out or a meeting is called before they act, they die. Double-click to kill normally.\n\n<i>You didn't kill anyone. You never do.</i></size>",
  "MastermindCD": "Manipulate Cooldown",
  "MastermindDelay": "Manipulation Notify Delay",
  "MastermindTargetSurvived": "<color=#00ff00>You survive</color>",
  "MastermindTimeLimit": "Time Limit to Kill Someone",
  "Mercenary": "Mercenary",
  "MercenaryInfo": "Keep killing, or you suicide",
  "MercenaryInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Low kill cooldown — but the timer never stops. Kill or die.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Mercenary Timer</color></b>\nYour kill cooldown is lower than normal, but a countdown runs constantly. Kill someone to reset it. If it reaches zero, you suicide. The timer appears above your name when it drops below 20 seconds.\n\n<i>There's no resting. There's only the next kill.</i></size>",
  "MercenaryLimit": "Time Until Suicide",
  "MercenarySuicideButtonText": "Suicide Timer",
  "Miner": "Miner",
  "MinerInfo": "Warp to your last used vent by shifting",
  "MinerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Vanish or pet to warp back to the last vent you used.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Warp</color></b>\nVanish or pet to instantly teleport back to the most recent vent you entered.\n\n<i>Every tunnel leads back home.</i></size>",
  "MinerTeleButtonText": "Warp",
  "Morphling": "Morphling",
  "MorphlingInfo": "You can only kill while shapeshifted",
  "MorphlingInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>You can only kill while shapeshifted — no disguise, no kill.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Morphling Kill</color></b>\nYou have a Shapeshifter's toolkit but your kill button only works while shapeshifted. Blend in before you strike.\n\n<i>The kill comes with the costume.</i></size>",
  "Nemesis": "Nemesis",
  "NemesisInfo": "Revenge After Death",
  "NemesisInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Survive until last — then strike from beyond the grave.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Revenge</color></b>\nCannot kill while other Impostors are alive. Once dead, use <b>/rv [player id]</b> to kill a living player from the afterlife. Limited uses.\n\n<i>Death isn't the end. It's the beginning of the revenge.</i></size>",
  "NemesisAliveKill": "Revenge for the Nemesis can only begin after their death.",
  "NemesisCanKillNum": "Max number of revenges",
  "NemesisDeadMsg": "The death of the Nemesis means the beginning of the revenge.\\nPlease use <b>/rv [player ID]</b> to kill the specified player \\nYou can see player IDs in front of their names. \\nOr type /rv to get a list of player IDs",
  "NemesisKillDead": "Choose a living player to take revenge",
  "NemesisKillDisable": "Sorry, but according to Host's settings, Nemesis revenge is prohibited in this game",
  "NemesisKillMax": "You have reached the limit of revenges, you can no longer take revenge",
  "NemesisKillSucceed": "<b>{0}</b> was killed by the Nemesis!",
  "Ninja": "Ninja",
  "NinjaInfo": "Mark a target, then Shift to kill them",
  "NinjaInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark a target — then teleport to them and execute the hit.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Assassination</color></b>\nUse your kill button to mark a target (a shield animation confirms the mark). Then vanish or pet to teleport directly to them and execute the kill. Cannot kill normally by default — though settings may allow normal kills after an assassination.\n\n<i>Strike before they know you're there.</i></size>",
  "NinjaAssassinateCooldown": "Assassinate Cooldown",
  "NinjaCanKillAfterAssassinate": "Can kill after Assassinating",
  "NinjaInvisibilityTimeAfterAssassinate": "Invisibility Time After Assassination",
  "NinjaMarkButtonText": "Mark",
  "NinjaMarkCooldown": "Mark Cooldown",
  "NinjaShapeshiftText": "Kill",
  "Nuker": "Nuker",
  "NukerInfo": "Shift/Vanish to nuke everyone",
  "NukerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Wipe out everyone on the ship in a single detonation.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Nuke</color></b>\nVanish or pet to detonate a nuclear explosion that kills everyone. You die in the blast too. Cannot use your kill button normally.\n\n<i>If everyone dies, that counts as a win.</i></size>",
  "NukerChance": "<color=#ff1919>Nuker</color> Chance",
  "Nullifier": "Nullifier",
  "NullifierInfo": "Remove Ability Uses From Crewmates",
  "NullifierInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Strip ability uses from crewmates — silently sabotage their tools.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Nullify</color></b>\nSingle-click your kill button to remove 1 ability use from the target if they have any. Double-click to kill normally. You won't know if they had uses, but they might notice — be careful.\n\n<i>Their tools are weapons. Take the ammunition.</i></size>",
  "NullifierDelay": "Removal Delay",
  "NullifierUseRemoved": "Ability use removed",
  "Insider": "Insider",
  "InsiderInfo": "See ally roles and your victims' roles",
  "InsiderInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>See ally roles and unmask the roles of everyone you kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Role Insight</color></b>\nYou can see the roles of all Impostors on your team and of every player you kill. After a kill threshold, you may also see ghost roles and Madmate roles depending on settings.\n\n<i>Information wins wars. You're never short of it.</i></size>",
  "InsiderCanSeeAllGhostsRoles": "Can see all ghost roles",
  "InsiderCanSeeImpostorAbilities": "Can see Impostor roles",
  "InsiderCanSeeMadmates": "Can see Madmate roles",
  "InsiderKillCountToSeeMadmates": "Kills needed to see Madmates",
  "Notifier": "Notifier",
  "NotifierInfo": "Flash everyone when you kill",
  "NotifierInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Each kill has a chance to flash every player on the ship.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill Flash</color></b>\nWhenever you kill someone, there is a configurable chance that all players receive a kill flash — disorienting them and creating openings.\n\n<i>The flash is the warning. By then it's too late.</i></size>",
  "NotifierProbability": "Kill Flash Probability",
  "Occultist": "Occultist",
  "OccultistInfo": "Revive Players To Your Team",
  "OccultistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Revive the dead — and convert them to your side.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Revive Mode</color></b>\nToggle between report and revive modes. In revive mode, pressing report on a body brings them back to life as a Renegade or grants them the Madmate add-on (if they weren't an Impostor). Report mode functions normally.\n\n<i>Death is just a recruitment opportunity.</i></size>",
  "Occultist.ArrowsToBodies": "Has arrows toward bodies",
  "Occultist.CanReviveImpostorsAndMadmates": "Can revive <#ff1919>Impostors</color> and <#ff1919>Madmates</color>",
  "Occultist.RPM.Madmate": "Get The <#ff1919>Madmate</color> Add-on",
  "Occultist.RPM.Renegade": "Turn Into <#ff1919>Renegade</color>",
  "Occultist.ReviveTime": "Delay between pressing report and the player being revived",
  "Occultist.RevivedPlayers": "Revived Players",
  "Occultist.RevivedPlayersBodiesCanBeReported": "Revived players' bodies can be reported",
  "OccultistActionSwitchMode.Pet": "Pet",
  "OccultistActionSwitchMode.Vanish": "Vanish",
  "OccultistActionSwitchMode.Vent": "Vent",
  "OccultistMode.Report": "Report",
  "OccultistMode.Revive": "Revive",
  "OccultistRevived": "{0} has been revived!",
  "OccultistReviving": "Reviving {0}....",
  "OccultistSuffix": "<size=80%><#00ffa5>Mode:</color> <b>{0}</b> (<#00a5ff>{1}</color> to switch mode)</size>",
  "Overheat": "Overheat",
  "OverheatInfo": "Hot = Low Kill Cooldown",
  "OverheatInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Wait longer for lower cooldowns — but risk overheating and losing control.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Temperature</color></b>\nYour kill cooldown decreases as your temperature rises. The longer you wait, the lower the cooldown — but the higher the chance of overheating. Shapeshift or pet to cool down and reset your temperature.\n\n<i>The heat is power. Too much heat is a problem.</i></size>",
  "Overheat.ChanceIncrease": "Temperature Increase Rate",
  "Overheat.ChanceIncreaseFrequency": "Temperature Increase Frequency",
  "Overheat.KCDDecreasePerIncreasedTemperature": "Kill Cooldown Decrease per Increased Temperature",
  "Overheat.RollChanceFrequency": "Frequency of Rolling for Overheat",
  "Overheat.Suffix": "<size=80%>Temperature: {0}</size>",
  "Parasite": "Parasite",
  "ParasiteInfo": "Help the Impostors kill the crew",
  "ParasiteInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill, vent, sabotage — you're an Impostor, plain and simple.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Parasite</color></b>\nYou may kill, vent, and sabotage freely. You are aligned with the Impostors.\n\n<i>No frills. No gimmicks. Just the fundamentals.</i></size>",
  "Penguin": "Penguin",
  "PenguinInfo": "Drag your victims",
  "PenguinInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Grab a player and drag them — then finish them at your leisure.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Drag</color></b>\nPress your kill button to grab and drag the nearest player. While dragging, press kill again to finish them, or wait for the drag timer to expire. Double-click for an instant direct kill.\n\n<i>They're going exactly where you want them.</i></size>",
  "PenguinAbductTimerLimit": "Dragging Time",
  "PenguinKillButtonText": "Drag",
  "PenguinMeetingKill": "Kill the target if a meeting starts during dragging.",
  "PenguinSpeedDuringDrag": "Speed During Dragging",
  "PenguinTimerText": "Drag Timer",
  "PenguinVictimCanUseAbilities": "Victim Can Use Their Abilities While Being Dragged",
  "PenguinVictimKill": "As the victim of the Penguin/Goose, you cannot interact with others",
  "Perplexer": "Perplexer",
  "PerplexerInfo": "Invert a player's movement controls",
  "PerplexerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Flip a player's movement controls and watch them stumble.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Perplex</color></b>\nUse your shapeshift menu to target a player. Their movement controls are inverted for a set duration.\n\n<i>Left is right. Up is down. Good luck running.</i></size>",
  "PhantomEndKnot": "Phantom",
  "PhantomEndKnotInfo": "Go invisible temporarily",
  "PhantomEndKnotInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Go invisible — and move through the ship unseen.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Vanish</color></b>\nGo invisible for a short period. While invisible, Crewmates cannot see you.\n\n<i>The best kills start with disappearing.</i></size>",
  "PhantomCooldown": "Invisibility Cooldown",
  "PhantomDuration": "Invisibility Duration",
  "Postponer": "Postponer",
  "PostponerInfo": "Postpone Dead Body Spawning",
  "PostponerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill without leaving an immediate body — it appears after a delay.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Delayed Body</color></b>\nWhen you kill, no body spawns immediately. It appears at the murder location after a configurable delay — giving you time to establish an alibi.\n\n<i>The evidence always comes late. You count on that.</i></size>",
  "Postponer.BodyDelay": "Body Spawn Delay",
  "ProBowler": "Pro Bowler",
  "ProBowlerInfo": "Set a bowl spot with your ability, then kill a player to launch them into it",
  "ProBowlerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Set a bowl spot — then send your next victim rolling toward it.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Bowl</color></b>\nPress your ability button to mark a position as the bowl. Your next kill launches the victim toward it — rolling in steps (Bowling ON) or teleporting directly (Bowling OFF).\n\n<i>You didn't just kill them. You bowled them.</i></size>",
  "ProBowlerMaxUseCount": "Max Bowl Uses",
  "ProBowlerBowling": "Enable Rolling Animation",
  "ProBowlerDeathReasonIsFall": "Death Reason: Fall (instead of Kill)",
  "ProBowlerAbility": "Set Bowl",
  "ProBowlerInfoTextSet": "Press ability to set bowl position",
  "ProBowlerInfoTextKill": "Kill a player to launch them!",
  "TeleportKiller": "Teleport Killer",
  "TeleportKillerInfo": "Shapeshift to teleport to a target — you swap positions and immediately kill them",
  "TeleportKillerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Swap positions with a target — and kill them where you stood.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Teleport Kill</color></b>\nUse your ability to swap positions with a target and kill them shortly after. If the target is unavailable (vent, ladder, etc.), the kill is queued until they're reachable. Certain positions may cause you to die instead.\n\n<i>You swapped places. Only one of you needed to.</i></size>",
  "TeleportKillerMaximum": "Max Uses (0 = Unlimited)",
  "TeleportKillerDuration": "Ability Duration",
  "TeleportKillerFall": "Enable Fall-Based Interactions",
  "TeleportKillerVentgaaa": "Self-Destruct When Target Is In Vent",
  "TeleportKillerPlatformFall": "Allow Kill on Moving Platform (Killer Dies)",
  "TeleportKillerLadderFall": "Allow Kill on Ladder (Killer Dies)",
  "TeleportKillerDokkaaaan": "Self-Destruct When Target Is Already Dead",
  "TeleportKillerKillCooldownReset": "Reset Kill Cooldown After Successful Kill",
  "TeleportKillerChangeDeathReason": "Use Spell Death Reason Instead of Kill",
  "TeleportKillerAbility": "Teleport Kill",
  "ConnectSaver": "Connect Saver",
  "ConnectSaverInfo": "Vote yourself in a meeting to link two players — killing one eliminates the other",
  "ConnectSaverInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Link two players — killing one automatically eliminates the other.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Connection</color></b>\nVote yourself in a meeting to enter connection mode. Vote two players to link them. After the meeting, killing one linked player automatically kills the other. While a connection is active, you can only kill your linked targets.\n\n<i>One pull of the thread. Two lives unravel.</i></size>",
  "ConnectSaverTageKillCooldown": "Kill Cooldown While Connection Is Active",
  "ConnectSaverMinPlayerCount": "Minimum Players to Use Ability",
  "ConnectSaverDeathReason": "Linked Partner Death Reason",
  "ConnectSaverActivate": "Connection mode: vote two players to link them.",
  "ConnectSaverInsufficientPlayers": "Not enough players alive ({0} required) — Connect Saver ability disabled this meeting",
  "ConnectSaverSelfVoteHint": "Vote yourself to enter connection mode",
  "ConnectSaverSelectFirst": "Select first target (vote a player)",
  "ConnectSaverSelectSecond": "Select second target (vote another player)",
  "ConnectSaverTargetSet": "Linked {0}: {1}",
  "ConnectSaverOneTarget": "1 target",
  "ConnectSaverTwoTargets": "2 targets",
  "ConnectSaverConnected": "Connection set! Kill one linked target to eliminate the other.",
  "ProgressKiller": "Progress Killer",
  "ProgressKillerInfo": "See marks on players who have completed their tasks",
  "ProgressKillerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>See which players have finished their tasks — and prioritize accordingly.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Task Sight</color></b>\nPlayers who have completed all their tasks are marked visually. Crewmates are marked with 〇; Madmates with ☆. Use this to identify and eliminate the most task-complete threats first.\n\n<i>Task completion makes them a target. You know who's done.</i></size>",
  "ProgressKillerMadseen": "Show Mark on Task-Complete Madmates",
  "ProgressWorkhorseseen": "Show Mark on Task-Complete Crewmates",
  "AntiReporter": "Anti Reporter",
  "AntiReporterInfo": "Disrupt nearby players so they cannot report or call meetings",
  "AntiReporterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Disrupt a player to block their ability to report or call meetings.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Disrupt</color></b>\nUse your ability to disrupt the nearest player. For a set duration, they cannot report bodies or call emergency meetings. Limited uses.\n\n<i>No report. No meeting. No rescue.</i></size>",
  "AntiReporterMaximum": "Max Ability Uses",
  "AntiReporterResetMeeting": "Reset Disruptions on Meeting",
  "AntiReporterResetse": "Disruption Duration (0 = Permanent)",
  "AntiReporter_Ability": "Disrupt",
  "AntiReporterHudHint": "◆ Aim at nearest target and press ability",
  "CharismaStar": "Charisma Star",
  "CharismaStarInfo": "Mark players then gather them all to a vent",
  "CharismaStarInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark players and pull them all to a vent — then deal with them at once.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Gather</color></b>\nPress your kill button on a player to mark them. Press again on the same player to kill them directly (resetting ability cooldown). Use your ability button to pull all marked players instantly to the nearest vent. Players on ladders or lifts can't be gathered and may be killed instead.\n\n<i>Gather them. Then greet them properly.</i></size>",
  "CharismaStarGatherCooldown": "Gather Cooldown",
  "CharismaStarGatherMaxCount": "Max Gather Uses",
  "CharismaStarNotGatherPlayerKill": "Kill Players Who Can't Be Gathered",
  "CharismaStarCanAllPlayerGather": "Gather All If No Marks",
  "CharismaStarGatherButtonText": "Gather",
  "EvilBlender": "Evil Blender",
  "EvilBlenderInfo": "Assign rooms to all players and kill those who don't arrive in time",
  "EvilBlenderInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Force everyone to race to assigned rooms — or be eliminated.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Blend</color></b>\nUse your ability to trigger a mini-sabotage: all alive players are assigned random rooms and must reach them before time runs out. Anyone who fails is eliminated. Emergency meetings and real sabotages are blocked during the event.\n\n<i>Everyone moves when you say go.</i></size>",
  "EvilBlenderSabotageLimittime": "Sabotage Time Limit",
  "EvilBlender_AbilityButton": "Blend",
  "EvilBlender_SabotageLowerAlive": "Go to: {1} ({0}s left)",
  "EvilBlender_SabotageLower": "Mini-sab active! ({0}s left)",
  "EvilBlenderMiniSabActive": "Cannot call meeting during mini-sabotage!",
  "DummySpawner": "Dummy Spawner",
  "DummySpawnerInfo": "Spawn dummies across the map to confuse crewmates",
  "DummySpawnerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Flood the map with decoys — and let killers waste their time on fakes.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Dummy Spawn</color></b>\nAfter each meeting, random-looking dummies spawn across the map. Killing near a dummy hits it instead of a real player — cooldown still applies. All dummies vanish when you die.\n\n<i>Is that a player? Take your chances.</i></size>",
  "DummySpawnerDummyCount": "Dummies per Meeting",
  "DummySpawnerKillRange": "Dummy Kill Range",
  "Decrescendo": "Decrescendo",
  "DecrescendoInfo": "Weaken yourself with each kill to deceive opponents",
  "DecrescendoInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Kill freely at first — but each death weakens you further.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Weakening</color></b>\nAfter a set number of kills, your cooldown begins multiplying with each subsequent kill. Optionally, your vision also shrinks. At full weakness, you may lose vent access entirely.\n\n<i>Act fast. The clock on your power is already ticking.</i></size>",
  "DecrescendoDecKillCount": "Kills Before Weakening",
  "DecrescendoKillCoolMultiplier": "Kill Cooldown Multiplier",
  "DecrescendoMaxKillCooldown": "Max Kill Cooldown",
  "DecrescendoDecreaseVision": "Decrease Vision When Weakened",
  "DecrescendoVisionMultiplier": "Vision Multiplier Per Kill",
  "DecrescendoMinVision": "Minimum Vision",
  "DecrescendoCantUseVent": "Lose Vent Access When Weakened",
  "Archer": "Archer",
  "ArcherInfo": "Fire an arrow that travels through the map and kills on contact",
  "ArcherInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Nock, aim, release — fire an arrow that kills on contact.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Arrow Shot</color></b>\nPress your ability to nock an arrow. Press again (or wait 5 seconds) to fire — the arrow travels in the direction you last moved and kills the first player it hits. Limited shots. Optionally, you can fly with the arrow.\n\n<i>Aim true. It only takes one.</i></size>",
  "ArcherArrowCount": "Arrow Count (0 = Unlimited)",
  "ArcherLostArrowTimer": "Arrow Flight Duration",
  "ArcherArrowSpeed": "Arrow Speed",
  "ArcherMyArrow": "Player Flies With Arrow",
  "ArcherCanNormalKill": "Can Kill Normally While Arrows Remain",
  "ArcherFriendlyFire": "Arrow Can Kill Impostors",
  "ArcherAbilityButton": "Nock",
  "ArcherLower_Ready": "◆ Press to nock arrow",
  "ArcherLower_SetBow": "◆ Move to aim — press again or wait to fire",
  "ArcherLower_ArrowActive": "◆ Arrow in flight!",
  "ArcherNeedsMovement": "You must move to aim before firing!",
  "EvilMaker": "Evil Maker",
  "EvilMakerInfo": "Convert a nearby crewmate into your Madmate ally",
  "EvilMakerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Convert a nearby crewmate into a Madmate ally — once.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Convert</color></b>\nUse your ability to turn the nearest crewmate within range into a Madmate who fights for the Impostors. One-time use only.\n\n<i>One conversation. One convert. One less enemy.</i></size>",
  "EvilMakerAbilityButton": "Convert",
  "EvilMakerNoTarget": "No valid target in range!",
  "EvilMakerConverted": "Successfully converted a crewmate!",
  "EvilMakerBeConverted": "You have been converted to the impostor side!",
  "EvilMakerUsed": "◆ Ability used",
  "NiceLogger": "Nice Logger",
  "NiceLoggerInfo": "Set a monitoring point near a door and log who passes through it",
  "NiceLoggerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Set a monitoring point near a door and log who passes through.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Log Point</color></b>\nUse your ability at the nearest door to set a monitoring point. Every player who passes through that location is logged. At the next meeting, you receive a private report listing everyone spotted there.\n\n<i>You didn't see them. But you saw that they were there.</i></size>",
  "NiceLoggerCoolTime": "Monitoring Cooldown",
  "NiceLogger_Ability": "Log",
  "NiceLoggerLower": "Enter a vent to set the log point",
  "NiceLoggerTitle": "Monitoring Report",
  "NiceLoggerAbility": "{0} was spotted near {1}\\n",
  "NiceLoggerAbility2": "No one was spotted near {0}",
  "VentMaster": "Vent Master",
  "VentMasterInfo": "Sense when anyone enters a vent",
  "VentMasterInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Get a kill flash every time anyone enters a vent.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Alert</color></b>\nWhenever any player enters a vent, you receive an immediate kill flash notification. Use this to track suspicious movement patterns across the round.\n\n<i>Every vent use leaves a flash in your mind.</i></size>",
  "CanVent": "Can Use Vents",
  "VentOpener": "Vent Opener",
  "VentOpenerInfo": "Enter a vent to expel players hiding inside",
  "VentOpenerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Force players out of vents — expose whoever's hiding inside.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Vent Eject</color></b>\nUse your Engineer-style vent ability to forcibly expel players currently hiding in vents. Configurable by team (Impostors, Madmates, Crewmates). Optionally requires tasks to unlock. Expelled players may be blocked from killing you afterward.\n\n<i>Nowhere to hide when someone can reach in and pull you out.</i></size>",
  "VentOpenerCount": "Max Ejections (0 = Infinite)",
  "VentOpenerFuhatu": "Consume Use On Empty Vent",
  "VentOpenerImp": "Eject Impostors",
  "VentOpenerMad": "Eject Madmates",
  "VentOpenerCrew": "Eject Crewmates",
  "VentOpenerNeutral": "Eject Neutrals",
  "VentOpenerCanTaskcount": "Tasks Required to Unlock",
  "VentOpenerBlockKill": "Block Kills From Ejected Players",
  "VentOpenerAbility": "Eject",
  "ToiletFan": "Toilet Fan",
  "ToiletFanInfo": "Open the bathroom stall doors on Airship",
  "ToiletFanInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Open Airship bathroom stall doors to expose players hiding inside.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Open Stalls</color></b>\nPress your pet button to open the bathroom stall doors on the Airship map. Use this to flush out players hiding inside.\n\n<i>In space, no one can hear you flush.</i></size>",
  "ToiletFanAbility": "Open Stalls",
  "Android": "Android",
  "AndroidInfo": "Use your battery-powered vent ability",
  "AndroidInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Your vent ability runs on a battery that charges as you complete tasks.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Battery Venting</color></b>\nYour battery determines how long you can stay in vents and how fast your cooldown resets. It drains over time, and you are ejected if a sabotage activates or the battery runs out. Complete tasks to recharge it.\n\n<i>Always charge before you go.</i></size>",
  "AndroidInVentTime": "Max Time In Vent (at full battery)",
  "AndroidRemoveBattery": "Battery Drains Over Time",
  "AndroidRemove": "Drain Amount Per Interval",
  "AndroidRemoveTime": "Drain Interval",
  "AndroidAddTaskBattery": "Battery Added Per Task",
  "AndroidVentDrainMultiplier": "In-Vent Drain Multiplier",
  "AndroidAutoRecharge": "Auto-Recharge After All Tasks Done",
  "AndroidAutoRechargeAmount": "Recharge Amount Per Interval",
  "AndroidAutoRechargeInterval": "Recharge Interval",
  "AndroidAutoRechargeStationary": "Only Recharge When Stationary",
  "Amnesia": "Amnesia",
  "AmnesiaInfo": "You have forgotten your role",
  "AmnesiaInfoLong": "(<#a0a0a0>Add-ons</color>):\n<size=80%>You have forgotten your role and cannot use your abilities.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Condition]\n・<b><color=#a0a0a0>Amnesia</color></b>\nYour role abilities are blocked. Complete a set number of tasks or survive enough meetings to gradually recover your memory and regain your role.\n\n<i>A clean slate can be both a curse and a blessing.</i></size>",
  "AmnesiaDontCanUseAbility": "Block Role Ability",
  "AmnesiaCanRealizeDay": "Can Recover Role via Meetings",
  "AmnesiaRealizeDayCount": "Meetings Required to Recover",
  "AmnesiaCanRealizeTask": "Can Recover Role via Tasks",
  "AmnesiaRealizeTaskCount": "Tasks Required to Recover",
  "Psychopath": "Psychopath",
  "PsychopathInfo": "You're Forced to Kill Off Cooldown",
  "PsychopathInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>The moment your kill cooldown ends, you automatically kill anyone in range.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ff1919>Compelled Kill</color></b>\nThe instant your cooldown expires, any player inside your kill range dies automatically. There is also a chance you accidentally stab multiple targets at once.\n\n<i>Control is overrated.</i></size>",
  "Puppeteer": "Puppeteer",
  "PuppeteerInfo": "Make players kill for you",
  "PuppeteerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Use your kill button to manipulate players and make them kill for you.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Manipulate</color></b>\nTarget a player with your kill button. After a short delay, they kill the next player who approaches them.\n\n<size=70%>Settings may vary the mechanics:\n・Double-clicking can allow normal kills.\n・Manipulation may expire after a set time.\n・Lazy Guy and lazy players may be immune.\n・Puppets may kill other Impostors or even you.\n・A maximum puppet count may be enforced.\n・You may die after running out of puppets.\n・Puppeted players may die alongside their victim.</size>\n\n<i>The best killers never get their hands dirty.</i></size>",
  "PuppeteerCD": "Puppet Cooldown",
  "PuppeteerCanKillNormally": "Can Kill Normally",
  "PuppeteerDiesAfterMaxPuppets": "<color=#ff1919>Puppeteer</color> Dies After Running Out Of Puppets",
  "PuppeteerKCD": "Puppeteer Kill Cooldown",
  "PuppeteerManipulationBypassesLazy": "Bypass <color=#a4dffe>Lazy</color>",
  "PuppeteerManipulationBypassesLazyGuy": "Bypass <color=#a4dffe>Lazy Guy</color>",
  "PuppeteerManipulationEndsAfterFixedTime": "Manipulation Ends After a Specific Time",
  "PuppeteerManipulationEndsAfterTime": "Time After The Manipulation Ends",
  "PuppeteerMaxDelay": "Maximum Delay Before The Puppeted Player Can Kill",
  "PuppeteerMaxPuppets": "Maximum Number of Puppets",
  "PuppeteerMinDelay": "Minimum Delay Before The Puppeted Player Can Kill",
  "PuppeteerOperateButtonText": "Manipulate",
  "PuppeteerPuppetCanKillImpostors": "Puppet Can Kill Other <color=#ff1919>Impostors</color>",
  "PuppeteerPuppetCanKillPuppeteer": "Puppet Can Kill The <color=#ff1919>Puppeteer</color>",
  "PuppeteerUsesRemaining": "You have {0} puppets remaining",
  "QuickKiller": "Quick Killer",
  "QuickKillerInfo": "Chain kills rapidly within a time window",
  "QuickKillerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Your first kill opens a brief window of near-instant killing.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill Window</color></b>\nAfter your first kill, your cooldown drops to near-zero for a short time, letting you chain kills rapidly. The window expires after the configured duration and your cooldown returns to normal. Only activates when enough players are alive.\n\n<i>Strike while the iron is hot.</i></size>",
  "QuickKillerTimer": "Quick Kill Window Duration",
  "QuickKillerCanuseplayercount": "Minimum Alive Players to Activate",
  "QuickKillerAbility": "Quick Kill!",
  "QuickShooter": "Quick Shooter",
  "QuickShooterInfo": "Store ammo to offset kill cooldown",
  "QuickShooterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Store bullets when your cooldown is up to instantly offset it after each kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Store Bullet</color></b>\nWhen your kill cooldown expires, shapeshift or pet to reset it and store a bullet — a shield animation confirms storage. After a kill, each stored bullet instantly offsets the cooldown. You can only hold a limited number of bullets between meetings.\n\n<i>Every shell counts.</i></size>",
  "QuickShooterShapeshiftCooldown": "Shapeshift Cooldown",
  "QuickShooterShapeshiftText": "Keep",
  "QuickShooterStoraging": "Bullets stored successfully",
  "MeetingReserved": "Max Bullets reserved for a meeting",
  "Renegade": "Renegade",
  "RenegadeInfo": "Help the Impostors kill off the crew",
  "RenegadeInfoLong": "(<#ff1919>Madmates</color>):\n<size=80%>Help the Impostors eliminate the crew.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Win Condition]\n・<b><color=#ff1919>Impostor Alliance</color></b>\nYou are a crewmate-based ally of the Impostors. Work covertly to support their victory. Your win is tied to theirs.\n\n<i>Loyalty has its own kind of power.</i></size>",
  "RenegadeKillCD": "<color=#ff1919>Renegade</color>'s Kill Cooldown",
  "RenegadeKillImpostor": "Renegades cannot kill Impostors",
  "RiftMaker": "Rift Maker",
  "RiftMakerInfo": "Teleport between 2 places",
  "RiftMakerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark two points on the ship and teleport between them automatically.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Place Rift</color></b>\nShapeshift or pet twice to mark two locations. Once both are set, stepping near either rift instantly teleports you to the other. Venting discards both marks.\n\nYou cannot vent normally.\n\n<i>Distance is just a matter of perspective.</i></size>",
  "Saboteur": "Saboteur",
  "SaboteurInfo": "Kill to call and stack sabotages. You can only kill during a sabotage",
  "SaboteurInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>You can only kill during active sabotages — and each kill triggers another one.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Sabotage Kill</color></b>\nKilling is only possible when a critical sabotage (e.g., Comms or O2) is active. Every kill you land automatically activates another random critical sabotage on top of the ongoing one.\n\n<i>Chaos demands a conductor.</i></size>",
  "Sapper": "Sapper",
  "SapperInfo": "Blow up Everyone with Timed Bombs!",
  "SapperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Plant timed bombs that explode after a delay, killing everyone caught in the blast.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Plant Bomb</color></b>\nPet or vanish to plant a timed explosive. After the configured delay, it detonates and kills everyone nearby — including you if you are in the blast radius.\n\n<i>Patience is the deadliest fuse.</i></size>",
  "SapperCD": "Bomb Place Cooldown",
  "SapperDelay": "Bomb Explode Delay",
  "SapperRadius": "Bomb Explosion Radius",
  "Scavenger": "Scavenger",
  "ScavengerInfo": "Your kills are unreportable",
  "ScavengerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Your kills leave no reportable body — but they require sustained proximity to complete.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Devour</color></b>\nClick your kill button on a target, then stay near them for a few seconds to finish the kill — similar to an Arsonist's douse. No dead body is left behind.\n\n<i>Leave no trace.</i></size>",
  "ScavengerKillDuration": "Time After Kill Completes",
  "ShapeshifterEndKnot": "Shapeshifter",
  "ShapeshifterEndKnotInfo": "Disguise as crewmates to frame them",
  "ShapeshifterEndKnotInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Disguise as crewmates to deceive and frame them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Shapeshift</color></b>\nTransform into another player's appearance to frame them or create confusion. An egg is visible briefly while shifting, and the disguise is temporary.\n\n<i>Anyone could be anyone.</i></size>",
  "Silencer": "Silencer",
  "SilencerInfo": "Shapeshift to Silence Players",
  "SilencerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shapeshift into a player to blackmail and silence them in the next meeting.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Silence</color></b>\nShifting into a player blackmails them, preventing them from speaking in meetings. The silenced player will see their own icon as a warning — speaking anyway triggers the confusion command. A player cap may still allow silenced players to vote.\n\n<i>Words can be more dangerous than weapons.</i></size>",
  "SilencerDead": "<b>{0}</b> has been blackmailed by a <color=#ff1919>Silencer</color>!",
  "MaxPlayersAliveForSilencedToVote": "Max Players Alive for Silenced Players to be able to Vote",
  "SilenceMode": "Silencing Method",
  "Skinwalker": "Skinwalker",
  "SkinwalkerInfo": "Wear a corpse to perfectly impersonate the dead",
  "SkinwalkerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Press Report on a body to wear it — you take on their full appearance, including their level. The body vanishes. Pet to remove the disguise and the body reappears where you stood.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Wear Corpse</color></b>\nPress Report while standing on a body to wear it. Your name, color, cosmetics, name plate, and level all match the victim. You stay disguised through meetings. Press Pet to remove the disguise — the body reappears where you discarded it and can be reported normally again.\n\n<i>The best disguise isn't a mask. It's a skin.</i></size>",
  "SkinwalkerMaxUsage": "Maximum Wear Count",
  "SkinwalkerCopyLevel": "Copy Player Level",
  "SkinwalkerNoUsageLeft": "<#ff4444>You have no wears left</color>",
  "SkinwalkerAlreadyWorn": "<#ff4444>You're already wearing a corpse — discard it first</color>",
  "SkinwalkerWorn": "<#ff1919>Worn:</color> <b>{0}</b>",
  "SkinwalkerUnworn": "<#ff1919>Disguise discarded</color>",
  "Sniper": "Sniper",
  "SniperInfo": "Snipe players from a distance by shifting",
  "SniperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Shoot players from a distance using directional shapeshifts.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Snipe</color></b>\nShapeshift or pet twice to fire a shot. The bullet travels in the direction from your first shift location to your second. It kills the first player in its path. You cannot kill normally while you have ammo remaining.\n\n<i>One shot. One chance. No second guesses.</i></size>",
  "SniperAimAssist": "Aim Assist",
  "SniperAimAssistOneshot": "One shot Assist",
  "SniperBulletCount": "Ammo",
  "SniperCanKill": "<color=#ff1919>Sniper</color> can kill with bullets remaining",
  "SniperPrecisionShooting": "Precise Shooting",
  "SniperSnipeButtonText": "Snipe",
  "SoulCatcher": "Soul Catcher",
  "SoulCatcherInfo": "You swap places with your shift target",
  "SoulCatcherInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Swap positions with your shapeshift target after shifting.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Soul Swap</color></b>\nAfter shapeshifting into a target, you teleport to their location and they teleport to yours. If the target is in an abnormal state (dead, swallowed, venting, etc.), nothing happens.\n\n<i>A body left behind is still a useful tool.</i></size>",
  "SoulCatcherButtonText": "Teleport",
  "Stasis": "Stasis",
  "StasisInfo": "Freeze Time",
  "StasisInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Freeze time — locking all players in place and blinding them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Time Freeze</color></b>\nVanish or pet twice to freeze time. While active, all players are frozen and blinded, unable to act. Depending on settings, other Impostor-team players may be excluded from the effect.\n\n<i>Time stops for everyone else.</i></size>",
  "Stasis.AffectsOtherImpostors": "Time Freezing Affects Other <#ff1919>Impostors</color>",
  "Stasis.TimeFreezeEndNotify": "Time Unfrozen",
  "Stasis.TimeFrozenNotify": "Time Frozen",
  "Stealth": "Stealth",
  "StealthInfo": "Killing Blinds Everyone in the Room",
  "StealthInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Blind nearby players after killing or activating your ability.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Blind (Legacy)</color></b>\nKilling blinds all players in the same room for a short time.\n\n・<b><color=#ff1919>Blind (Modern)</color></b>\nShapeshift, pet, or vanish to blind everyone within a set radius. Impostors may be excluded.\n\n<i>In the dark, every shadow becomes a threat.</i></size>",
  "Stealth.OptionBlindingRadius": "Blinding Radius (If Not Legacy Version)",
  "Stealth.OptionDarkenDuration": "Blinding Duration",
  "Stealth.OptionExcludeImpostors": "Ignore Impostors when Blinding",
  "StealthDarkened": "Darkened: {0}",
  "Swapster": "Swapster",
  "SwapsterInfo": "Swap Players",
  "SwapsterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Select two players to instantly swap their positions.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Position Swap</color></b>\nUse your shapeshift menu to select two players and teleport them to each other's locations.\n\n<i>Location is everything — until it isn't.</i></size>",
  "Swiftclaw": "Swiftclaw",
  "SwiftclawInfo": "Dash to Go Faster",
  "SwiftclawInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Dash forward for a burst of speed.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Dash</color></b>\nPet to dash, temporarily increasing your movement speed for a set duration.\n\n<i>Speed is its own kind of stealth.</i></size>",
  "SwiftclawAbilityButtonText": "Dash",
  "SwiftclawDashCD": "Dash Cooldown",
  "SwiftclawDashDur": "Dash Duration",
  "SwiftclawDashSpeed": "Speed During Dash",
  "Swooper": "Swooper",
  "SwooperInfo": "Turn invisible temporarily",
  "SwooperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Turn temporarily invisible to move and kill unseen.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Swoop</color></b>\nVent or vanish to become invisible for a short time. Unlike vanilla Phantom, you can kill while invisible.\n\n<i>The best predators are the ones you never see.</i></size>",
  "SwooperCanVent": "Vent to turn invisible",
  "SwooperCooldown": "Swoop Cooldown",
  "SwooperDuration": "Swoop Duration",
  "SwooperInvisCooldownRemain": "<color=#00ffa5>Cooldown:</color> <b>{0}</b>s",
  "SwooperInvisInCooldown": "Swoop cooldown isn't up yet, swooping failed",
  "SwooperInvisState": "You're invisible",
  "SwooperInvisStateCountdown": "<color=#00ffa5>Invisibility expires in</color> <b>{0}</b>s",
  "SwooperInvisStateOut": "You're now visible",
  "SwooperRevertVentButtonText": "Expose",
  "SwooperVentButtonText": "Swoop",
  "SwooperVentNormallyOnCooldown": "<color=#ff1919>Swooper</color> vents normally when swooping is on cooldown",
  "TimeThief": "Time Thief",
  "TimeThiefInfo": "Lower meeting time by killing",
  "TimeThiefInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Every kill drains the meeting timer, leaving less time to accuse you.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Time Theft</color></b>\nEach kill reduces total meeting time by a set amount. If the Time Thief dies, stolen time may be restored depending on settings.\n\n<i>Less time to accuse means more time to kill.</i></size>",
  "TimeThiefDecreaseMeetingTime": "Lower Meeting Time by",
  "TimeThiefLowerLimitVotingTime": "Minimum Voting Time",
  "TimeThiefReturnStolenTimeUponDeath": "Return Stolen Time Upon Death",
  "Trapster": "Trapster",
  "TrapsterInfo": "Start a killing chain",
  "TrapsterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Plant fake bodies or traps that kill whoever reports them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Fake Body</color></b>\nVanish or pet to create a fake dead body. Anyone who reports it dies.\n\n・<b><color=#ff1919>Trap (Legacy)</color></b>\nKill a player to trap their body. The next person to report it dies instantly without the body being reported, and they become a Trapster — the chain continues. You die immediately after each kill.\n\n<i>A good trap is bait that looks like treasure.</i></size>",
  "Trickster": "Trickster",
  "TricksterInfo": "Kill and trick the crew",
  "TricksterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>You function as a normal Impostor but appear innocent to investigative roles.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ff1919>Deception Aura</color></b>\nCrewmate investigative roles treat you as a crewmate:\n・The Sheriff cannot kill you.\n・Psychic does not flag you as evil.\n・Snitch cannot find you.\n\n<i>The best lies wear a friendly face.</i></size>",
  "Twister": "Twister",
  "TwisterInfo": "Swap all players' positions",
  "TwisterInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Randomly shuffle all players' positions across the map.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Twist</color></b>\nVanish or pet to randomly teleport every player to a different location. The Twister itself is never moved, and players inside vents cannot be teleported.\n\n<i>Chaos is just an unscheduled teleport.</i></size>",
  "TwisterButtonText": "Twist",
  "TwisterCooldown": "Twist Cooldown",
  "Undertaker": "Undertaker",
  "UndertakerInfo": "Take bodies wherever you want to",
  "UndertakerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Mark a target, then kill them remotely — their body appears at your location.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Mark</color></b>\nUse your kill button to mark a target.\n\n・<b><color=#ff1919>Assassinate</color></b>\nVanish or pet to kill the marked target. Their body teleports to your current location instead of theirs — ideal for hiding evidence.\n\n<i>Where you fall is where I choose.</i></size>",
  "UndertakerAssassinateCooldown": "Assassinate Cooldown",
  "UndertakerCanKillAfterAssassinate": "Can kill after Assassinating",
  "UndertakerMarkButtonText": "Mark",
  "UndertakerMarkCooldown": "Mark Cooldown",
  "UndertakerShapeshiftText": "Kill",
  "Vampire": "Vampire",
  "VampireInfo": "Your kills are delayed",
  "VampireInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Bite players to delay their death until the next meeting begins.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Bite</color></b>\nBiting a player delays their death — they die when the next meeting starts. Biting a Bait triggers a normal kill and self-report instead.\n\n<i>The meeting will handle it.</i></size>",
  "VampireBiteButtonText": "Bite",
  "VampireKillCooldown": "Bite Cooldown",
  "VampireKillDelay": "Bite Kill Delay",
  "VampireSpeedDown": "Slow Down Bitten Targets",
  "VampireSpeedDownStartTime": "Slow Down Start Delay",
  "VampireTargetDead": "Target died",
  "Venerer": "Venerer",
  "VenererInfo": "Stack Abilites By Killing",
  "VenererInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Stack up to three passive abilities by making kills.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Ability Stack</color></b>\nEach kill grants a new ability activated by shapeshift, vanish, or pet. All active abilities trigger simultaneously for the same duration.\n\n<size=70%>・1st Kill: Camouflage — turn gray\n・2nd Kill: Dash — move faster\n・3rd Kill: Freeze — slow down nearby players</size>\n\n<i>Every kill makes you more dangerous.</i></size>",
  "Venerer.FreezeRadius": "Freeze Ability Radius",
  "Venom": "Venom",
  "VenomInfo": "Kill to Dissolve Bodies",
  "VenomInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Grants the Viper's body-dissolving ability to another Impostor role.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Passive]\n・<b><color=#ff1919>Viper Ability</color></b>\nBodies you leave behind slowly dissolve and become unreportable, as if you were a Viper.\n\n<i>No body, no problem.</i></size>",
  "Ventriloquist": "Ventriloquist",
  "VentriloquistInfo": "Make Others Say What You Want",
  "VentriloquistInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Force other players to say whatever you want in chat.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Ventriloquize</color></b>\nType <b>/cmd target {id}</b> to select a player, then <b>/cmd chat {message}</b> to make them say your message in chat.\n\n<i>Everyone has something to say — if you know how to make them.</i></size>",
  "Vindicator": "Vindicator",
  "VindicatorInfo": "Use your extra votes to kill everyone",
  "VindicatorInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Wield extra votes to swing every election in your favor.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Extra Votes</color></b>\nYou have additional votes in every meeting, similar to the Mayor. Use this leverage to eliminate crewmates through the vote.\n\n<i>Democracy is a tool like any other.</i></size>",
  "ViperEndKnot": "Viper",
  "ViperEndKnotInfo": "Kill to Dissolve Bodies",
  "ViperEndKnotInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Your kills slowly dissolve into acid, leaving no reportable body.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ff1919>Acid Dissolution</color></b>\nBodies you create gradually dissolve and become unreportable. <size=70%>Note: Some roles (e.g., Sheriff) may still see dissolved bodies from their own perspective due to desync.</size>\n\n<i>Even death leaves a residue — unless you're the Viper.</i></size>",
  "Visionary": "Visionary",
  "VisionaryInfo": "You see the alignments of the living",
  "VisionaryInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Reveal players' team alignments by selecting them as your shift target.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Reveal</color></b>\nSelect a player as your shapeshift target (with at least one charge: use left) to reveal their alignment. Their name color shows their team: <#8cffff>Crewmate</color> / <#ff1919>Impostor</color> / <#ffab1b>Neutral</color> / <#7b3fbb>Coven</color>.\n\nEach kill earns one ability charge.\n\n<i>Knowledge is the sharpest blade.</i></size>",
  "Warlock": "Warlock",
  "WarlockInfo": "Curse crewmates & Shift to make them kill",
  "WarlockInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Curse a player, then cast a spell to make the closest person kill them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Curse</color></b>\nWhile not shapeshifted, use your kill button to curse a player.\n\n・<b><color=#ff1919>Spell</color></b>\nVanish or pet after cursing to trigger the kill — the closest player to the cursed target dies, regardless of distance. You may also double-click your kill button for a direct kill. Killing via curse may briefly freeze you.\n\n<i>The hand that curses need not be the one that kills.</i></size>",
  "WarlockControlKill": "Target died",
  "WarlockCurseButtonText": "Curse",
  "WarlockNoTarget": "Manipulation failed due to no target",
  "WarlockShapeshiftButtonText": "Spell",
  "Wasp": "Wasp",
  "WaspInfo": "Sting Players",
  "WaspInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Sting players to kill them after a meeting, and evade attacks to enter swarm mode.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ff1919>Sting</color></b>\nUse your kill button on a target. Players with a kill button die after a few seconds; others display a ◀ marker and die after the next meeting if the Wasp isn't ejected.\n\n・<b><color=#ff1919>Evade</color></b>\nWhen attacked, you may evade the kill, triggering one of two effects:\n<size=70%>・<b>Swarm Mode:</b> No kill cooldown for a short time.\n・<b>Pest Control:</b> You are dazed — reduced vision, speed, and sting ability.\nNote: Evading a kill prevents future evasion, sabotage use, and venting for that round.</size>\n\n<i>Even insects can be apex predators.</i></size>",
  "Wasp.EvadeKills": "Evade Kills",
  "Wasp.KillDelay": "Sting Kill Delay",
  "Wasp.PestControlDuration": "Pest Control Duration",
  "Wasp.PestControlSpeed": "Speed During Pest Control",
  "Wasp.PestControlVision": "Vision During Pest Control",
  "Wasp.StingCooldown": "Sting Cooldown",
  "Wasp.SwarmModeDuration": "Swarm Mode Duration",
  "Wasp.SwarmModeSuffix": "<#ffff00>You've been attacked and entered swarm mode for {0} seconds!</color>",
  "Wasp.WaspDiesAfterSwarmEnd": "Suicide After Swarm Mode Ends",
  "WaspStungPlayersMessage": "<b>{0}</b> has/have been stung!\\nThey will die after the meeting if the {1} isn't dead or ejected by then!",
  "WaveCannon": "Wave Cannon",
  "WaveCannonInfo": "Charge and fire a beam that kills on contact",
  "WaveCannonInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Charge up and fire a beam that kills anyone caught in its path.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Wave Cannon</color></b>\nPress the pet button to begin charging. You are frozen in place while charging. After charging, a warning beam appears along your firing line, then the beam fires, killing anyone in its path. The beam grows thicker over time, widening the danger zone.\n\n<i>Charging is just aimed waiting.</i></size>",
  "WaveCannon.AbilityCooldown": "Wave Cannon Cooldown",
  "WaveCannon.DirectionDetectDuration": "Aim Window",
  "WaveCannon.ChargeDuration": "Charge Duration",
  "WaveCannon.WarningDuration": "Warning Duration",
  "WaveCannon.FiringDuration": "Firing Duration",
  "WaveCannon.MaxThicknessStages": "Max Beam Thickness Stages",
  "WaveCannon.FriendlyFire": "Friendly Fire",
  "WaveCannon.ButtonText": "FIRE",
  "WaveCannon.DirectionDetect": "Move briefly in your firing direction. Beam charges right after.",

  /* --- Riptide --- */
  "Riptide": "Riptide",
  "RiptideInfo": "Send waves across the map to slow and drown players",
  "RiptideInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>After each meeting, waves sweep across the map from the edges. Anyone caught in a wave is slowed down, and those who stay inside too long will drown.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#0073ff>Waves</color></b>\nAfter every meeting (except the first), one or more waves spawn from the map edges and travel across. Players inside a wave are slowed. Stay inside long enough and you drown — even other Impostors aren't safe.\nThe number of waves and their speed increase as the game goes on.\n\n・<b><color=#0073ff>Kill</color></b> (optional)\nYou can also kill players directly with the standard kill button.\n\n<i>The tide is rising. Get out while you can.</i></size>",
  "Riptide.BaseWaveSpeed": "Wave Speed",
  "Riptide.EnableAcceleration": "Waves Accelerate Each Round",
  "Riptide.AccelerationRate": "Acceleration Rate Per Round",
  "Riptide.SlowMultiplier": "Speed Multiplier While in Wave",
  "Riptide.DeathStaySeconds": "Time in Wave Before Death",
  "Riptide.MaxConcurrentDirections": "Max Waves per Round",
  "Riptide.CanKillManually": "Can Kill Normally",
  "Riptide.KillCooldown": "Kill Cooldown",
  "Riptide.WaveBandThickness": "Wave Hit Depth",
  "Riptide.WaveLateralExtent": "Wave Hit Width",
  "Riptide.ShowPredictiveGhost": "Show Wave Preview",

  "Wildling": "Wildling",
  "WildlingInfo": "Killing gives you a temporary shield",
  "WildlingInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Killing temporarily makes you immune to attacks.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ff1919>Kill Shield</color></b>\nYou can shapeshift but cannot vent. After each kill, you are temporarily immune to being killed.\n\n<i>The hunter becomes untouchable.</i></size>",
  "Wiper": "Wiper",
  "WiperInfo": "Wipe Out Rooms",
  "WiperInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Wipe out entire rooms — killing everyone inside in one sweep.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Room Wipe</color></b>\nPet or vanish to instantly kill everyone in your current room. Depending on settings, this may include other Impostors. Normal kills are not available, and the ability is disabled during active sabotages.\n\n<i>Sometimes the entire room has to go.</i></size>",
  "Wiper.CannotUseAbilityDuringSabotage": "You cannot use your ability during sabotages",
  "Wiper.CurrentRoom": "<#00ffa5>Current Room:</color> <b>{0}</b>",
  "Wiper.KillOtherImpostors": "Wiping Out a Room Kills Other <#ff1919>Impostors</color>",
  "Wiper.MustBeInRoomToUseAbility": "You must be in a room to use your ability\\n<size=80%>Not in the spawn area</size>",
  "Witch": "Witch",
  "WitchInfo": "Spell crewmates to kill them in meetings",
  "WitchInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Spell players to kill them at the end of the next meeting.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Spell</color></b>\nTap your kill button (once or twice, depending on mode) to cast a spell. Spelled players display a 「†」 mark in the next meeting and die when it ends — if the Witch survives.\n\nDirect kills are also available.\n\n<i>Let the meeting do the killing.</i></size>",
  "WitchCurrentMode": "Current Mode",
  "WitchCursedPlayersMessage": "<b>{0}</b> has/have been cursed!\\nThey will die after the meeting if the {1} isn't dead or ejected by then!",
  "WitchMaxSpellsPerRound": "Max Spells Per Round",
  "WitchModeDouble": "Double Click = Kill, Single Click = Spell",
  "WitchModeKill": "Kill",
  "WitchModeSpell": "Spell",
  "WitchModeSwitchAction": "Switch Action via",
  "WitchModeVanish": "Vanish next to someone to Spell them",
  "WitchSpellButtonText": "Spell",
  "WitchSpellCooldown": "Spell Cooldown",
  "YinYanger": "Yin Yanger",
  "YinYangerInfo": "Make 2 players meet each other to kill them!",
  "YinYangerInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Yin Yang two players — they both die the moment they come close to each other.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ff1919>Yin Yang</color></b>\nAfter each meeting, mark two players. When those players come within kill distance of each other, they both die simultaneously. Normal kills remain available while Yin Yang is active.\n\n<i>Balance is deadly when you set the scales.</i></size>",
  "YinYangCD": "Yin Yang Cooldown",
  "YinYangMode": "Yin Yang",
  "YinYangModeNormal": "Kill",
  "Zombie": "Zombie",
  "ZombieInfo": "You're very slow, but can't be ejected",
  "ZombieInfoLong": "(<#ff1919>Impostors</color>):\n<size=80%>Short kill cooldown, nearly blind and very slow — but virtually unkillable in meetings.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ff1919>Undying</color></b>\nYou cannot be voted out except by the Dictator. Your movement speed gradually slows with each kill or over time. You have very low vision but a very short kill cooldown.\n\n<i>Slow, unstoppable, inevitable.</i></size>",
  "ZombieInitialSpeed": "Initial Speed",
  "ZombieMinimumSpeed": "Minimum Speed",
  "ZombieSpeedReduce": "After a certain time, decrease the speed of <color=#ff1919>Zombie</color> by",
  "ZombieSpeedReduceInterval": "Speed Reduction Interval",
  /* ==============================
    Roles (Neutrals)
  ============================== */
  "Accumulator": "Accumulator",
  "AccumulatorInfo": "Do Tasks For Low Kill Cooldown",
  "AccumulatorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Complete tasks to lower your kill cooldown, then transform into a killer when ready.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Accumulate</color></b>\nStart as a crewmate and complete tasks. Each task reduces your eventual kill cooldown. Pet or finish all tasks to transform into a killing neutral with the accumulated cooldown. Eliminate everyone to win.\n\n<i>Patience sharpens every blade.</i></size>",
  "Accumulator.CanVentAfterKilling": "Can Vent After Killing",
  "Accumulator.CanVentBeforeKilling": "Can Vent Before Killing",
  "Accumulator.ImpostorVisionAfterKilling": "Has Impostor Vision After Killing",
  "Accumulator.ImpostorVisionBeforeKilling": "Has Impostor Vision Before Killing",
  "Accumulator.KillCooldownDecrementWithEachTask": "Kill Cooldown Decrement With Each Task",
  "Agitator": "Agitator",
  "AgitatorInfo": "Pass a Bomb onto others",
  "AgitatorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Pass a bomb to another player — whoever holds it when a meeting is called dies.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Pass Bomb</color></b>\nUse your kill button to give the bomb to a player (once per round). The recipient is notified and must pass it on by walking near someone. When a meeting starts, the current bomb holder dies.\n\nAttempting to pass to Pestilence or an alerted Squid kills the current carrier instead. Optionally, the Agitator cannot receive the bomb back.\n\n<i>Nobody wants to be the last one holding it.</i></size>",
  "AgitatorAutoReportBait": "<color=#F4A460>Agitator</color> Auto Report Bait",
  "AgitatorBombCooldown": "<color=#F4A460>Agitator</color> bomb cooldown",
  "AgitatorCanGetBombed": "<color=#F4A460>Agitator</color> can get the bomb",
  "AgitatorPassCooldown": "Bomb pass cooldown",
  "AgitatorPassNotify": "Bomb successfully passed",
  "AgitatorTargetNotify": "<size=110%><#ffff00>YOU HAVE THE BOMB!!</color>\\n<#ffa500>Pass it to someone else or die!</color></size>",
  "Amnesiac": "Amnesiac",
  "AmnesiacInfo": "Copy someone's role",
  "AmnesiacInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Copy another player's role by interacting with them or their body.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Remember</color></b>\nUse your kill or report button (depending on host settings) on a player or their body to copy their role. Settings may alter the role you receive in specific scenarios.\n\n<i>Identity is borrowed until it isn't.</i></size>",
  "AmnesiacInvalidTarget": "Remember failed",
  "AmnesiacRM.ByKillButton": "By Kill Button",
  "AmnesiacRM.ByReportingBody": "By Report",
  "AmnesiacRemembered": "An Amnesiac remembered your role!",
  "AmnesiacRoleBasis": "Role Basis",
  "CanRememberCrewPower": "Can Remember <#8cffff>Crewmate</color> <#fbff00>Power</color> Roles",
  "RememberAddons": "Also Remember Add-ons",
  "RememberButtonText": "Remember",
  "RememberCooldown": "Remember Cooldown",
  "RememberMode": "Role Remembering Mode",
  "RememberedAmnesiac": "You failed to remember your role.",
  "RememberedCoven": "You remembered you were a Coven member!",
  "RememberedCrewmate": "You remembered you were a Crewmate!",
  "RememberedFollower": "You remembered you were a Follower!",
  "RememberedImpostor": "You remembered you were an Impostor!",
  "RememberedLover": "You remembered you were a Lover!",
  "RememberedMaverick": "You remembered you were a Maverick!",
  "RememberedNeutralKiller": "You remembered you were a neutral killer!",
  "RememberedPursuer": "You remembered you were a Pursuer!",
  "HasArrowsToDeadBodies": "Sees Arrows to Dead Bodies (If Remembering by Reporting)",
  "ReportBodyAfterRemember": "After remembering a role by reporting, report the body",
  "Amogus": "Amogus",
  "AmogusInfo": "You're the sussy baka",
  "AmogusInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Transform into Amogus form to gain escalating powers and kill everyone.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Toggle Form</color></b>\nPet or vanish to switch between regular and Amogus form. You can only kill in Amogus form. Each kill upgrades your level.\n\n<size=70%>・<b>Amogus:</b> Basic white bean.\n・<b>Sugoma:</b> Faster movement, but controls are inverted.\n・<b>Sumogus:</b> Retains speed; controls restored; players cannot interact with you.\n・<b>Suspicious Sus:</b> All above + arrows pointing to every player.\n・<b>Ultimate Sus:</b> All prior abilities + 50% reduced kill cooldown + extra votes per kill. Appears as a red bean.</size>\n\n<i>Among us, one of us is sus.</i></size>",
  "Amogus.Levels.Amogus": "Amogus",
  "Amogus.Levels.Sugoma": "Sugoma",
  "Amogus.Levels.Sumogus": "Sumogus",
  "Amogus.Levels.SuspiciousSus": "Suspicious Sus",
  "Amogus.Levels.UltimateSus": "Ultimate Sus",
  "Amogus.StartingLevel": "Starting Level",
  "Amogus.Suffix": "<#00ffa5>Current level:</color> <b>{0}</b>",
  "Amogus.SugomaSpeed": "Speed at Sugoma level",
  "Amogus.SuspiciousSusArrowsToBodies": "At Suspicious Sus level, when someone dies, the arrow points at the dead body instead of disappearing",
  "Amogus.UltimateSusVotesPerKill": "Number of Extra Votes gained for every kill, when the level is Ultimate Sus",
  "Arsonist": "Arsonist",
  "ArsonistInfo": "Douse everyone and ignite",
  "ArsonistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Douse every living player, then ignite them all for a solo victory.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Douse</color></b>\nClick your kill button on a player and follow them for a few seconds to douse them. 「△」 = being doused; 「▲」 = fully doused.\n\n・<b><color=#ffab1b>Ignite</color></b>\nOnce all living players are doused, vent or pet to ignite and win alone. If 'Can Ignite Anytime' is on, click your kill button on a fully doused player to ignite — only doused players die.\n\n<i>Patience. Every fire starts the same way.</i></size>",
  "ArsonistCanIgniteAnytime": "Can Ignite Anytime",
  "ArsonistDouseButtonText": "Douse",
  "ArsonistDouseTime": "Douse Duration",
  "ArsonistKeepsGameGoing": "Arsonist keeps the game going",
  "ArsonistMaxPlayersToIgnite": "Maximum Amount of Doused Players at once",
  "ArsonistMinPlayersToIgnite": "Minimum Doused Players required to Ignite",
  "ArsonistVentButtonText": "Ignite",
  "Auditor": "Auditor",
  "AuditorInfo": "Check Players",
  "AuditorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Check players to steal their abilities or blind them — and win when crewmates lose.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Check</color></b>\nUse your kill button on a player to reveal their role, then apply your current mode:\n\n・<b><color=#ffab1b>Auditing Mode</color></b>\nSteal 1 or all ability uses from the target.\n\n・<b><color=#ffab1b>Smokebomb Mode</color></b>\nTemporarily lower the target's vision.\n\nYou win if crewmates lose.\n\n<i>Oversight is its own kind of power.</i></size>",
  "Auditor.AuditCooldown": "Audit Cooldown",
  "Auditor.LoweredVision": "Lowered Vision",
  "Auditor.LoweredVisionDuration": "Lowered Vision Duration",
  "Auditor.SmokebombCooldown": "Smokebomb Cooldown",
  "Auditor.StealAllChargesInsteadOfOne": "Steal All Charges Instead Of 1",
  "Auditor.Suffix.Auditing": "<size=80%><#00ffa5>Mode:</color> <b>Auditing</b> (<#00a5ff>{0}</color> to switch mode)</size>",
  "Auditor.Suffix.Smokebombing": "<size=80%><#00ffa5>Mode:</color> <b>Smokebombing</b> (<#00a5ff>{0}</color> to switch mode)</size>",
  "Backstabber": "Backstabber",
  "BackstabberInfo": "Stab a Team in the Back",
  "BackstabberInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your kill choice determines which team you win with.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Calculated Betrayal</color></b>\nYou may kill one player during the game.\n・Kill no one → win with Crewmates.\n・Kill an Impostor or Madmate → win with the winning Neutral Killer.\n・Kill anyone else → win with the Impostors.\n\n<i>Choose your betrayal wisely.</i></size>",
  "Backstabber.MurderNotify": "Your kill target was {0}\\nThis means, you'll win with {1}",
  "Backstabber.RevealAfterKilling": "Revealed after killing",
  "BackstabberTeam.Imp": "the <#ff1919>Impostors</color>",
  "BackstabberTeam.NK": "a <#ffab1b>Neutral Killer</color>",
  "Bandit": "Bandit",
  "BanditInfo": "Rob Add-ons",
  "BanditInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Single-click to steal add-ons from players; double-click to kill normally.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Rob</color></b>\nSingle-click your kill button to steal an add-on from the target (if they have stealable ones). Double-click to kill normally.\n\nWhen ability uses run out, all clicks kill normally. Add-ons may be stolen on meeting start rather than immediately. Eliminate everyone to win.\n\n<i>Take what they've earned.</i></size>",
  "BanditCanStealBetrayalAddon": "Can Steal Betrayal Addons",
  "BanditCanStealImpOnlyAddon": "Can Steal <color=#ff1919>Impostor</color> Only Addons",
  "BanditMaxSteals": "Maximum Steals",
  "BanditStealMode": "Steal happens",
  "BanditStealMode.Instantly": "Instantly",
  "BanditStealMode.OnMeeting": "On Meeting",
  "Bargainer": "Bargainer",
  "BargainerInfo": "Gain Money & Buy Power-Ups",
  "BargainerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Earn money by killing and sabotaging, then spend it at map shops for power-ups.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Shop</color></b>\nAll map devices act as shops. Walk near one to browse items; step away to purchase. Sabotage cycles between available items.\n\n<size=70%>Available items:\n・Energy Drink — lowers kill cooldown for that round\n・Lens of Truth — reveals a random player's role briefly\n・Band Aid — grants a temporary shield</size>\n\nEarn money by killing, sabotaging, and surviving meetings.\n\n<i>Everything has a price — even survival.</i></size>",
  "Bargainer.BandAid": "Band Aid",
  "Bargainer.BandAid.Cost": "Band Aid Cost",
  "Bargainer.BandAid.Duration": "Band Aid Duration",
  "Bargainer.BandAid.DurationSwitch": "Band Aid Lasts",
  "Bargainer.BandAid.Enabled": "Band Aid Enabled",
  "Bargainer.EnergyDrink": "Energy Drink",
  "Bargainer.EnergyDrink.Cost": "Energy Drink Cost",
  "Bargainer.EnergyDrink.Enabled": "Energy Drink Enabled",
  "Bargainer.EnergyDrink.ReducedKCD": "Energy Drink Reduced Kill Cooldown",
  "Bargainer.Kill.Amount": "Money Gained for Killing",
  "Bargainer.Kill.Enabled": "Gain Money for Killing",
  "Bargainer.LensOfTruth": "Lens Of Truth",
  "Bargainer.LensOfTruth.Cost": "Lens Of Truth Cost",
  "Bargainer.LensOfTruth.Duration": "Lens Of Truth Duration",
  "Bargainer.LensOfTruth.DurationSwitch": "Lens Of Truth Lasts",
  "Bargainer.LensOfTruth.Enabled": "Lens Of Truth Enabled",
  "Bargainer.None": "No Item",
  "Bargainer.Notify.PurchasedItem": "You have purchased a(n) {0}",
  "Bargainer.Sabotage.Amount": "Money Gained for Sabotaging",
  "Bargainer.Sabotage.Enabled": "Gain Money for Sabotaging",
  "Bargainer.StartingMoney": "Starting Money",
  "Bargainer.Suffix.InShop": "<size=80%>[<#00ffa5>Shop</color>] Selected: {0} ({1})</size>",
  "Bargainer.SurviveMeeting.Amount": "Money Gained for Surviving Meetings",
  "Bargainer.SurviveMeeting.Enabled": "Gain Money for Surviving Meetings",
  "Beehive": "Beehive",
  "BeehiveInfo": "Sting Players",
  "BeehiveInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Sting players — they must flee your bees within a time limit or die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Sting</color></b>\nSingle-click your kill button to sting a player. They must walk a set distance away from you within the time limit or they die. Double-click to kill normally. Eliminate everyone to win.\n\n<i>Run fast enough and you might survive.</i></size>",
  "Beehive.Distance": "Distance to Walk",
  "Beehive.Notify": "<#ffff00>You were stung by the Beehive!\\nWalk {0} units away from the Beehive in {1}s or you die!</color>",
  "Beehive.StingCooldown": "Sting Cooldown",
  "Beehive.StungPlayersDieOnMeeting": "Stung Players Die on Meeting Start",
  "Beehive.Time": "Time to Walk the Distance",
  "Berserker": "Berserker",
  "BerserkerInfo": "Go Berserk If Others Kill More Than You",
  "BerserkerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Grow stronger each time someone else kills — but lose power when you kill.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Passive]\n・<b><color=#ffab1b>Berserk Stack</color></b>\nEach time another player kills, you gain a level. Each kill you make reduces your level by one.\n\n<size=70%>・Level 1: Extended kill range\n・Level 2: Reduced kill cooldown\n・Level 3: Impostor vision\n・Level 4: Kill immunity\n・Level 5: Suicide</size>\n\nEliminate everyone to win.\n\n<i>The longer you wait, the stronger you become.</i></size>",
  "Berserker.LowerKillCooldown": "Lower Kill Cooldown",
  "BloodKnight": "Blood Knight",
  "BloodKnightInfo": "Killing gives you a temporary shield",
  "BloodKnightInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Gain a temporary shield after every kill and outlast all other killing roles.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Last Killer Standing</color></b>\nYou win if you are the last killing role alive and crewmates are equal to or fewer than you. Each kill grants a brief period of complete kill immunity.\n\n<i>Only the last one standing truly wins.</i></size>",
  "Bubble": "Bubble",
  "BubbleInfo": "Encase Players in Explosive Bombs",
  "BubbleInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Encase players in explosive bubbles that detonate after a delay.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Encase</color></b>\nUse your kill button on a player to encase them. They explode after the configured delay, killing everyone nearby. Depending on settings, encased players may be revealed with a pink name after a time.\n\n<i>Everything beautiful is dangerous if you shake it enough.</i></size>",
  "BubbleCD": "Encase Cooldown",
  "BubbleDiesIfInRange": "Bubble Dies If In Range Of Explosion",
  "BubbleExplosionDelay": "Explosion Delay",
  "BubbleExplosionRadius": "Explosion Radius",
  "BubbleTargetNotifyDelay": "Notify Delay",
  "Chemist": "Chemist",
  "ChemistInfo": "Mix Chemicals",
  "ChemistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Craft overpowered chemicals in map factories and deploy them as devastating weapons.\n_____________________________________\nDifficulty: ★★★★★\n\n[Skills]\n・<b><color=#ffab1b>Factory System</color></b>\nEach room is a different factory. Vent to gather basic ingredients. Pet to process ingredients. Sabotage to cycle between factory processes.\n\n<size=70%>End products:\n・Sulfuric Acid: Mark a player — they spread acid to everyone nearby. All acid players die after a time.\n・Methylamine Gas: Vent to blind all other players.\n・Explosive: Applied to your next dead body — anyone who reports it dies.\n・Grenade: Apply via kill button to a player — they explode shortly, killing all nearby.</size>\n\nSingle-click to use an end product; double-click to kill normally.\n\n<i>By far the most complex role in Among Us history. Good luck! (- The Dev)</i></size>",
  "Chemist.AcidPlayersDie": "Acid Players Die",
  "Chemist.AcidPlayersDieAfterTime": "Time",
  "Chemist.AirGainedPerSecond": "Amount of Air Gained Every Second",
  "Chemist.BlindDuration": "Blinding Duration",
  "Chemist.CoalGainedPerVent": "Amount of Coal Gained With Venting",
  "Chemist.GrenadeExplodeDelay": "Grenade Explosion Delay",
  "Chemist.GrenadeExplodeRadius": "Grenade Explosion Radius",
  "Chemist.IronOreGainedPerVent": "Amount of Iron Ore Gained With Venting",
  "Chemist.Item.Air": "Air",
  "Chemist.Item.BaseMineralOil": "Base Mineral Oil",
  "Chemist.Item.Coal": "Coal",
  "Chemist.Item.Explosive": "Explosive",
  "Chemist.Item.Explosive.Usage": "Amount of Explosives Lost When Using",
  "Chemist.Item.Grenade": "Grenade",
  "Chemist.Item.Grenade.Usage": "Amount of Grenades Lost When Using",
  "Chemist.Item.IronIngot": "Iron Ingot",
  "Chemist.Item.IronOre": "Iron Ore",
  "Chemist.Item.IronPlate": "Iron Plate",
  "Chemist.Item.MethylamineGas.Usage": "Amount of Methylamine Gas Lost When Using",
  "Chemist.Item.MoltenIron": "Molten Iron",
  "Chemist.Item.Naphtha": "Naphtha",
  "Chemist.Item.Steam": "Steam",
  "Chemist.Item.SulfuricAcid.Usage": "Amount of Sulfuric Acid Lost When Using",
  "Chemist.Item.ThermalWater": "Thermal Water",
  "Chemist.Item.Water": "Water",
  "Chemist.WaterGainedPerSecond": "Amount of Water Gained Every Second",
  "Cherokious": "Cherokious",
  "CherokiousInfo": "Do tasks to get Bullets to Kill",
  "CherokiousInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Complete tasks to earn bullets, then use them to kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Bullet Kill</color></b>\nComplete tasks to gain bullets. Pet near a player to spend a bullet and kill them. You can only kill if you have bullets remaining.\n\n<i>Every task is a loaded chamber.</i></size>",
  "Clerk": "Clerk",
  "ClerkInfo": "Check Players' Taxes",
  "ClerkInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Vote players in meetings to audit their taxes — death awaits those who shirked their tasks.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Tax Audit</color></b>\nVote for a player in a meeting to audit them. If they completed a task last round (or have finished all tasks, or have none), they receive a refund: bonus speed and vision next round. Otherwise, they die.\n\nYou win if crewmates lose, or if the game ends with everyone completing their tasks.\n\n<i>The only certainties in life are death and taxes.</i></size>",
  "Clerk.CanUseAbilityOnFirstMeeting": "Can Use Ability on First Meeting",
  "Clerk.DidTax": "{0} did their taxes. They got a refund!",
  "Clerk.Killed": "{0} was caught not doing their taxes (tasks). They were killed!",
  "Collector": "Collector",
  "CollectorInfo": "Collect votes from players",
  "CollectorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Collect votes cast on your targets to reach a quota and win.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Collect Votes</color></b>\nGather all votes cast for your target in each meeting. Once you accumulate the required total, you win — even over ejected players.\n\n<i>Votes have power when you know how to count them.</i></size>",
  "CollectorCollectAmount": "Required number of votes",
  "Cultist": "Succubus",
  "CultistInfo": "Charm everyone",
  "CultistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Charm players into your thrall and outnumber the crewmates to win.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Charm</color></b>\nPress your kill button on a non-neutral player to recruit them into the Succubus team with new win conditions.\n\nThe Succubus team wins when they outnumber the Crewmates and only those two teams remain.\n\n<i>Lure them in. They won't even notice they've already chosen your side.</i></size>",
  "CultistCanCharmNeutral": "Neutral Roles can be <color=#cf6acd>Charmed</color>",
  "CultistCharmCooldown": "Charm Cooldown",
  "CultistCharmCooldownIncrease": "Increases Charm Cooldown For Each Charm",
  "CultistCharmMax": "Maximum Number Of Charm",
  "CultistCharmedPlayer": "You successfully charmed a player",
  "CultistInvalidTarget": "Target cannot be charmed",
  "CultistKillButtonText": "Charm",
  "CultistKnowTargetRole": "Know <color=#cf6acd>Charmed</color> Player's Role",
  "CultistTargetKnowOtherTarget": "<color=#cf6acd>Charmed</color> players know each other",
  "Curser": "Curser",
  "CurserInfo": "Make Others' Life Worse",
  "CurserInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Reveal alignments or curse players with permanent debuffs — win when crewmates lose.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Inspect</color></b>\nSingle-click your kill button to reveal a player's alignment.\n\n・<b><color=#ffab1b>Curse</color></b>\nDouble-click to apply one of the following effects:\n<size=70%>・Remove 1 ability use\n・Add 1 harmful add-on\n・Permanent low vision\n・Permanent low speed</size>\n\nYou win if crewmates lose.\n\n<i>A curse unseen is a curse that lingers.</i></size>",
  "Curser.LowerSpeed": "Permanent Lower Speed",
  "Curser.LowerVision": "Permanent Lower Vision",
  "Curser.Notify.0": "You've removed an ability use from your target",
  "Curser.Notify.1": "You gave your target a harmful add-on",
  "Curser.Notify.2": "You gave your target permanent low vision",
  "Curser.Notify.3": "You gave your target permanent low speed",
  "Dealer": "Dealer",
  "DealerInfo": "Give Players Add-ons",
  "DealerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Hand out add-ons to players — distribute enough to satisfy your win condition.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Deal Add-on</color></b>\nUse your kill button to give a player a random add-on. Once you have given out the required number, your win condition is met and you win with the winning team at the end.\n\n<i>The hand that gives holds all the power.</i></size>",
  "Dealer.AAO.After5s": "After 5 seconds",
  "Dealer.AAO.Instantly": "Instantly",
  "Dealer.AAO.OnMeeting": "On The Next Meeting",
  "Dealer.AddonAppears": "Add-ons Assign Target Sees the Add-on",
  "Dealer.AssignNeedToWin": "Number of Add-ons Needed to Give to Win",
  "Deathknight": "Deathknight",
  "DeathknightInfo": "Help the Necromancer Recruit",
  "DeathknightInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Aid the Necromancer in converting players to the Undead faction.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Recruit</color></b>\nPet near a player that the Necromancer has targeted to convert them to the Undead.\n\nOnly one Deathknight exists at a time. If the Necromancer dies, the Deathknight becomes the new Necromancer.\n\n<i>Death is not an ending — it is a recruitment.</i></size>",
  "DeathknightRecruitedPlayer": "Successfully recruited player to the Undead faction!",
  "DKCD": "<#361d12>Deathknight</color> Recruit Cooldown",
  "Demon": "Demon",
  "DemonInfo": "Consume blood volumes",
  "DemonInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Drain players' health with repeated attacks until they die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Attack</color></b>\nDeals damage to a player's health over multiple hits. A player dies when their health is fully drained. If an attack consumes health but doesn't kill, the attacker sees a shield animation. Attacks also deal self-damage.\n\n<i>Every blow drains something — from both of us.</i></size>",
  "DemonButtonText": "Attack",
  "DemonDamage": "Damage ",
  "DemonHealthMax": "Player max health",
  "DemonKillCooldown": "Attack Cooldown",
  "DemonSelfDamage": "Demon damage received",
  "DemonSelfHealthMax": "Demon max health",
  "Doomsayer": "Doomsayer",
  "DoomsayerInfo": "Successfully guess players to win",
  "DoomsayerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Guess players' roles in meetings to reach your win quota.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Guess</color></b>\nDuring a meeting, use <b>/cmd bt [player id] [role]</b> to guess a player's role. Guess enough correctly (set by host) to win.\n\nUse <b>/cmd id</b> to view all player IDs.\n\n<i>To name the truth is to hold power over it.</i></size>",
  "DoomsayerAdvancedSettings": "Advanced Settings",
  "DoomsayerAmountOfGuessesToWin": "Amount of Guesses to win",
  "DoomsayerCantGuess": "Sorry, you can only guess the roles in the next meeting.",
  "DoomsayerCorrectlyGuessRole": "You guessed the role correctly!\\nBut the player didn't die because the Host settings don't allow them to die",
  "DoomsayerDoesNotSuicideWhenMisguessing": "<color=#14f786>Doomsayer</color> does not suicide when misguessing",
  "DoomsayerGuessCountMsg": "You correctly guessed {0} roles",
  "DoomsayerGuessSameRoleAgainMsg": "You tried to guess the same role or add-on that you guessed before",
  "DoomsayerKillCorrectlyGuessedPlayers": "Kill correctly guessed players",
  "DoomsayerMaxNumberOfGuessesPerMeeting": "Max number of guesses per meeting",
  "DoomsayerMisguessRolePrevGuessRoleUntilNextMeeting": "Misguessing role prevents guessing roles until next meeting",
  "DoomsayerNotCorrectlyGuessRole": "You didn't correctly guess the role!\\nBut you didn't die because the Host's settings don't allow you to die",
  "Doppelganger": "Doppelganger",
  "DoppelgangerInfo": "Steal The Identity of Your Target",
  "DoppelgangerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Steal a player's identity before killing them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Identity Theft</color></b>\nUse your kill button on a player to steal their name and skin, then kill them. Eliminate everyone to win.\n\nNote: Cannot steal identity while Camouflage is active.\n\n<i>The best disguise is someone else's face.</i></size>",
  "DoppelgangerWarning": "<#ffff00>The Doppelganger swapped skins with you!</color>",
  "DoppelMaxSteals": "Maximum Steals",
  "Duality": "Duality",
  "DualityInfo": "Kill, Task, Repeat",
  "DualityInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Alternate between killing and completing a task on a timer — fail either and you die.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Duality Cycle</color></b>\nA timer is always visible. Kill within the time limit, then immediately switch to completing a task within the same limit. Failure causes suicide. The cycle repeats until the game ends. Eliminate everyone to win.\n\n<i>Kill. Work. Repeat. Never stop.</i></size>",
  "Duality.MustDoTask": "<#ffff00>Must complete a task within </color>{0}s",
  "Duality.MustKill": "<#ffff00>Must kill within </color>{0}s",
  "Duality.Time": "Time to do a task or kill",
  "Eclipse": "Eclipse",
  "EclipseInfo": "Your vision increases with each kill you get",
  "EclipseInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill everyone to win — your vision grows with each kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Growing Sight</color></b>\nStart with very low vision. Each kill gradually increases it. Be the last one standing to win.\n\n<i>The darkness retreats the more you embrace it.</i></size>",
  "EclipseMaxVision": "Maximum Vision",
  "EclipseStartVision": "Starting Vision",
  "EclipseVisionIncrease": "Increase Vision per each kill by",
  "Enderman": "Enderman",
  "EndermanInfo": "Teleport Back And Forth",
  "EndermanInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Mark your position and teleport back to it after a set delay.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Mark Position</color></b>\nSabotage or pet to mark your current location. After the configured delay, you automatically teleport back to the marked position.\n\n<i>Distance means nothing when you can return.</i></size>",
  "EndermanSecondsBeforeTP": "Seconds Before Teleporting",
  "Evolver": "Evolver",
  "EvolverInfo": "Select an Upgrade After Each Meeting",
  "EvolverInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Choose an upgrade after each meeting to steadily grow more powerful.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Evolve</color></b>\nAfter each meeting, pet to cycle between available upgrades. When the selection timer expires, the chosen upgrade is applied. The same upgrade may appear multiple times.\n\n<size=70%>Available upgrades:\n・Decrease Kill Cooldown (−2.5s)\n・Impostor Vision (unaffected by lights)\n・Increase Vision (+0.4x)\n・Increase Speed (+0.25x)\n・Higher Kill Distance (Short→Medium→Long)\n・Gain Venting (+1 use)\n・More Vent Uses (+3)\n・Gain Sabotage (+1 use)\n・More Sabotage Uses (+2)\n・Shield (cannot be killed this round)</size>\n\nVent uses display as <b>(V: 1)</b>; sabotage uses as <b>(S: 2)</b> next to your role name.\n\n<i>Adaptation is its own form of survival.</i></size>",
  "EvolverProgress.Sabotage": " (S: {0})",
  "EvolverProgress.Vent": " (V: {0})",
  "EvolverSuffix": "<size=85%>Selected upgrade will be applied in <#00ffa5>{0}s</color>\\nSelected upgrade: <#00ffa5>{1}</color> (Pet to cycle)\\n<size=70%>Available upgrades: <#00ffa5>{2}</color></size></size>",
  "EvolverUpgrade.DecreaseKillCooldown": "Lower Kill Cooldown",
  "EvolverUpgrade.GainImpostorVision": "Impostor Vision",
  "EvolverUpgrade.GainSabotage": "Ability to Sabotage",
  "EvolverUpgrade.GainShield": "Shield for Current Round",
  "EvolverUpgrade.GainVent": "Ability to Vent",
  "EvolverUpgrade.IncreaseKillDistance": "Higher Kill Distance",
  "EvolverUpgrade.IncreaseSabotageUseLimit": "More Sabotage Uses",
  "EvolverUpgrade.IncreaseSpeed": "Higher Speed",
  "EvolverUpgrade.IncreaseVentUseLimit": "More Vent Uses",
  "EvolverUpgrade.IncreaseVision": "Higher Vision",
  "Executioner": "Executioner",
  "ExecutionerInfo": "Get your target voted out",
  "ExecutionerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Get your marked target voted out to win.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Execute</color></b>\nYour target is marked with a diamond symbol. Get them voted out to win. If the target dies by other means, you may become a Crewmate, Jester, or Opportunist.\n\n<i>Justice is just vengeance with better paperwork.</i></size>",
  "ExecutionerCanTargetImpostor": "Can Target <color=#ff1919>Impostors</color>",
  "ExecutionerCanTargetNeutralKiller": "Can Target <color=#ffab1b>Neutral</color> <color=#ff1919>Killing</color>",
  "ExecutionerChangeRolesAfterTargetKilled": "When Target Dies, <color=#c0c0c0>Executioner</color> becomes",
  "ExecutionerRoleChanged": "Your target died",
  "Explosivist": "Explosivist",
  "ExplosivistInfo": "Explode Time Bombs",
  "ExplosivistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Carry a bomb that detonates nearby enemies — while you teleport to safety.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Bomb Carry</color></b>\nPet or vanish to start carrying a bomb. Others see only the bomb at your original position. After a few seconds, the bomb explodes killing everyone nearby, and you teleport back to where you started. Normal kills are unavailable. Eliminate everyone to win.\n\n<i>The best bomber is the one who walks away.</i></size>",
  "Explosivist.ExplosionDelay": "Explosion Delay",
  "Explosivist.ExplosionRadius": "Explosion Radius",
  "ExplosivistSuffix": "<size=80%>Carrying the bomb</size>\\n<#ffff00>Explodes in </color>{0}s",
  "Follower": "Follower",
  "FollowerInfo": "Follow a player and help them",
  "FollowerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Bet on a player — if they win, you win too.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Follow</color></b>\nUse your kill button to start following a player. Use it again to switch targets. If your current target wins, you win — even if you are already dead.\n\n<i>Back the right horse and victory is assured.</i></size>",
  "FollowerBetCooldown": "Follow Cooldown",
  "FollowerBetCooldownIncrese": "Increase Cooldown per 1 follow by",
  "FollowerBetOnYou": "The Follower is now following you",
  "FollowerBetPlayer": "You're now following your target",
  "FollowerBetTargetKnowFollower": "Follower target knows who the Follower is",
  "FollowerKillButtonText": "Follow",
  "FollowerKnowTargetRole": "Follower knows their target's role",
  "FollowerMaxBetCooldown": "Maximum Follow Cooldown",
  "FollowerMaxBetTimes": "Maximum Number of Follows",
  "Gaslighter": "Gaslighter",
  "GaslighterInfo": "Make others doubt their own memory",
  "GaslighterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your kill button action changes every round in a repeating cycle.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Cycling Ability</color></b>\nEach round, your kill button does something different:\n・Round 1: Kill normally\n・Round 2: Knight players\n・Round 3: Curse players (like Witch)\n・Round 4: Shield players\n\nThe cycle may repeat or stay on killing permanently, depending on settings. Win condition is set by the host.\n\n<i>Nobody can predict what you'll do next — not even you.</i></size>",
  "Gaslighter.Curse": "In this round, you <#ff00ff>curse players</color>",
  "Gaslighter.CycleRepeats": "Kill Button Actions Cycle Repeats",
  "Gaslighter.Kill": "In this round, you <#ff1919>kill normally</color>",
  "Gaslighter.Knight": "In this round, you <#ffa500>knight players</color>",
  "Gaslighter.Shield": "In this round, you <#00ff97>shield players</color>",
  "Gaslighter.WinCondition": "Win Condition",
  "GaslighterWinCondition.CrewLoses": "<#8cffff>Crewmates</color> <#ff0000>lose</color>",
  "GaslighterWinCondition.IfAlive": "<#00ff00>Alive</color> at the end",
  "GaslighterWinCondition.LastStanding": "<#ffab1b>Last one standing</color>",
  "Glitch": "The Glitch",
  "GlitchInfo": "Hack and kill everyone",
  "GlitchInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Hack players to suppress their abilities, then pick them off.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Hack</color></b>\nPrevent a player from killing, venting, sabotaging, and reporting for a limited time.\n\n・<b><color=#ffab1b>Disguise</color></b>\nDisguise as a random player for a limited time.\n\nCooldowns decrease while inside vents. Kill everyone to win.\n\n<i>The system has an error — and the error is you.</i></size>",
  "GlitchCanVote": "Can vote",
  "God": "God",
  "GodInfo": "Everything is under your control",
  "GodInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Know every player's role from the start — and win alone if you survive to the end.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Omniscience</color></b>\nYou know every player's role from the very beginning. Survive until the game ends to win alone. God cannot be assigned as a Lover.\n\n<i>With knowledge comes responsibility — and absolute power.</i></size>",
  "God.KnowInfo": "God knows players'",
  "GodMode": "God Mode",
  "GodNoticeAlive": "During the meeting, each player felt a revelation from heaven, and it turned out that God is still alive!",
  "Hater": "Hater",
  "HaterInfo": "Kill <color=#ff9ace>Lovers</color> and <color=#ffab1b>Converted</color> players",
  "HaterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill Lovers and recruited players with no cooldown — targeting anyone else kills you.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Hatred</color></b>\nNo kill cooldown and Impostor vision. You can only kill Lovers, recruited players, and recruiting roles — killing anyone else results in your own death. Win by killing at least one player.\n\n<i>Some hatred is so pure it becomes a principle.</i></size>",
  "HaterButtonText": "Hatred",
  "HaterCanKillCharmed": "Can Kill <color=#cf6acd>Charmed</color> Players",
  "HaterCanKillContagious": "Can Kill <color=#2e8b57>Contagious</color> Players",
  "HaterCanKillEgoist": "Can Kill <color=#5600ff>Egoist</color>",
  "HaterCanKillLovers": "Can Kill <color=#ff9ace>Lovers</color>",
  "HaterCanKillMadmate": "Can Kill <color=#ff1919>Madmates</color>",
  "HaterCanKillSidekick": "Can Kill <color=#00b4eb>Sidekicks</color>",
  "HaterCanKillUndead": "Can Kill <color=#ed9abd>Undead</color> Players",
  "HaterChooseConverted": "Can Kill Converted Players",
  "HaterMisFireKillTarget": "Misfire Kills Target",
  "HeadHunter": "Head Hunter",
  "HeadHunterInfo": "Kill your target for low cooldown",
  "HeadHunterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill your assigned targets for cooldown reductions — missing costs you dearly.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Bounty Target</color></b>\nYou have 3 targets each round (shown with black names) that reset after each meeting. Killing a target permanently decreases your kill cooldown. Killing anyone else permanently increases it.\n\n<i>Every hit either sharpens or dulls the blade.</i></size>",
  "HHFailureKCDIncrease": "Kill Cooldown Increase on killing others",
  "HHMinKCD": "Minimum Kill Cooldown",
  "HHMaxKCD": "Maximum Kill Cooldown",
  "HHSuccessKCDDecrease": "Kill Cooldown Decrease on killing target",
  "HexMaster": "Hex Master",
  "HexMasterInfo": "Hex players to kill them in meetings",
  "HexMasterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Hex players to kill them at the end of the next meeting — just like a Witch.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Hex</color></b>\nHex a player to mark them for death at the end of the next meeting, or kill them directly. Hexing works identically to a Witch's spell.\n\n<i>The curse finds its mark long after it's cast.</i></size>",
  "HexButtonText": "Hex",
  "HexMasterModeDouble": "Double Click = Kill, Single Click = Hex",
  "HexMasterModeHex": "Hex",
  "HexMasterModeKill": "Kill",
  "Hookshot": "Hookshot",
  "HookshotInfo": "Pull Players or TP to them",
  "HookshotInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Pull targets to you or teleport to them — then finish the job.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Mark</color></b>\nSingle-click your kill button to mark a target. Double-click to kill normally.\n\n・<b><color=#ffab1b>Execute</color></b>\nVent to switch between two modes: Pull Target to You, or Teleport to Target. Sabotage or pet to execute the selected action on the marked target.\n\n<i>No matter where they run, the hook finds them.</i></size>",
  "HookshotPullTarget": "Pull Target",
  "HookshotTpToTarget": "TP to Target",
  "Infection": "Infection",
  "InfectionInfo": "Spread the infection!",
  "InfectionInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Infect one player, then let the disease spread to everyone around them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Infect</color></b>\nChoose one player to initially infect. Anyone who spends enough time near an infected player becomes infected too. Infection progress is cumulative and does not reset with distance or after meetings. Win when all living players are infected.\n\n<i>One carrier is all it takes.</i></size>",
  "InfectionCanInfectSelf": "Can Infect Self",
  "InfectionCanInfectVent": "Can Infect While In Vent",
  "InfectionInfectDistance": "Infect Distance",
  "InfectionInfectInactiveTime": "Meeting Infection Onset Delay",
  "InfectionInfectLimit": "Infect Limit",
  "InfectionInfectTime": "Infect Time",
  "InfectionInfectWhenKilled": "Infect Killer When Killed",
  "InfectionSpreads": "Infection Spreads",
  "Impartial": "Impartial",
  "ImpartialInfo": "Kill Specified Number of Players in Each Team",
  "ImpartialInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill the required number of players from each team to win.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Equal Opportunity Killer</color></b>\nKill a specified number of players from each team. Your progress is shown next to your role name. Win by meeting the kill quota for every team.\n\n<i>Fairness is just another word for efficiency.</i></size>",
  "ImpartialCanWinWhenKillingMore": "Can Win Even When Killing More of a Team than the Maximum",
  "ImpartialCovenmax": "Maximum Number of <#7b3fbb>Coven</color> to Kill",
  "ImpartialCovenmin": "Minimum Number of <#7b3fbb>Coven</color> to Kill",
  "ImpartialCrewmax": "Maximum Number of <#8cffff>Crewmates</color> to Kill",
  "ImpartialCrewmin": "Minimum Number of <#8cffff>Crewmates</color> to Kill",
  "ImpartialImpmax": "Maximum Number of <#ff1919>Impostors</color> to Kill",
  "ImpartialImpmin": "Minimum Number of <#ff1919>Impostors</color> to Kill",
  "ImpartialNeutralmax": "Maximum Number of <#ffab1b>Neutrals</color> to Kill",
  "ImpartialNeutralmin": "Minimum Number of <#ffab1b>Neutrals</color> to Kill",
  "Innocent": "Innocent",
  "InnocentInfo": "Get someone ejected by making them kill you",
  "InnocentInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Frame someone to make them kill you — then get them voted out.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Frame</color></b>\nUse your kill button to plant a player, causing them to kill you immediately. If that player is voted out in the next meeting, you win. The Jester, Executioner, and Innocent can all win together.\n\n<i>The best victim is the one who set the trap.</i></size>",
  "InnocentButtonText": "Frame",
  "InnocentCanWinByImp": "If their target was an <color=#ff1919>Impostor</color> then they win with them",
  "Investor": "Investor",
  "InvestorInfo": "Invest in Players",
  "InvestorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Mark players and win with the winning team if enough of your investments succeed.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Invest</color></b>\nUse your kill button to mark players. At the end, you win with the winning team if at least the set percentage of your marked players also won.\n\n<i>Choose your investments wisely.</i></size>",
  "Investor.PercentNeed": "Minimum Percentage of Winning Marked Players Needed to Win",
  "Jackal": "Jackal",
  "JackalInfo": "Convert & Murder Everyone",
  "JackalInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Convert players and achieve majority while eliminating all other evil teams.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Convert</color></b>\nUse your kill button to recruit a player as a Sidekick. If you die, the Sidekick becomes the new Jackal.\n\nWin once you achieve majority and no other evil teams remain.\n\n<i>An empire begins with one loyal follower.</i></size>",
  "JackalCanKillSidekick": "<color=#00b4eb>Jackal</color> can kill <color=#00b4eb>Sidekick</color>",
  "JackalCanRecruitImpostors": "Can recruit <color=#ff1919>Impostors</color>",
  "JackalCanRecruitMadmates": "Can recruit <color=#ff1919>Madmates</color>",
  "JackalCanRecruitSidekick": "Can recruit <color=#00b4eb>Sidekick</color>",
  "JackalSidekick": "This Jackal-Sidekick interaction is not allowed",
  "Jester": "Jester",
  "JesterInfo": "Get voted out",
  "JesterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Get voted out to win — survive to the end and you lose.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>The Joke's on Them</color></b>\nWin alone if voted out. Lose if still alive when the game ends. The Jester, Executioner, and Innocent can all win together.\n\n<i>The fool who controls the crowd holds all the power.</i></size>",
  "JesterCanUseButton": "Can call emergency meetings",
  "JesterCannotCallEmergencyMeeting": "As the <#ec62a5>Jester</color>, according to the host's settings, you cannot call emergency meetings",
  "JesterVision": "<color=#ec62a5>Jester</color> Vision",
  "Jinx": "Jinx",
  "JinxInfo": "Reflect attacks onto your attackers",
  "JinxInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Reflect attacks back onto your attackers — with limited uses.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Jinx</color></b>\nWhenever you are attacked, the attacker is jinxed and dies instead. This ability has limited uses. Eliminate everyone to win.\n\n<i>Touch me and the curse comes home.</i></size>",
  "JinxSpellTimes": "Amount of Jinx Spells",
  "Juggernaut": "Juggernaut",
  "JuggernautInfo": "Your cooldown decreases with each kill you get",
  "JuggernautInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your kill cooldown decreases with every kill — become unstoppable.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Momentum</color></b>\nEach kill permanently reduces your kill cooldown. Eliminate everyone to win.\n\n<i>Once you start, you can't stop.</i></size>",
  "Lawyer": "Lawyer",
  "LawyerInfo": "Help your target win!",
  "LawyerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Defend your client — their victory is yours, their defeat is yours too.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Defend</color></b>\nYour target is marked with a diamond 「♦」. If your target wins, you win. If they lose, you lose. If your target dies, your role may change.\n\n<i>Every client deserves a defender — regardless of guilt.</i></size>",
  "LawyerCanTargetCoven": "Can target <color=#7b3fbb>Coven</color>",
  "LawyerCanTargetCrewmate": "Can Target <color=#8cffff>Crewmates</color>",
  "LawyerCanTargetImpostor": "Can Target <color=#ff1919>Impostors</color>",
  "LawyerCanTargetJester": "Can Target <color=#ec62a5>Jester</color>",
  "LawyerCanTargetNeutralKiller": "Can Target <color=#ffab1b>Neutral Killers</color>",
  "LawyerChangeRole": "Your client is dead",
  "LawyerChangeRolesAfterTargetKilled": "When Target Dies, <color=#008080>Lawyer</color> becomes",
  "LawyerVision": "<color=#008080>Lawyer</color> Vision",
  "Magician": "Magician",
  "MagicianInfo": "Play your cards to win",
  "MagicianInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Earn random ability cards through kills and deploy them at will.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Draw Card</color></b>\nEach kill grants a random card. A notification shows the card's effect when drawn.\n\n・<b><color=#ffab1b>Play Card</color></b>\nCall any sabotage (not doors) to play your current card — the sabotage itself won't trigger. Pet can also be used if enabled.\n\n<size=70%>Possible cards: Slowness Potion, Flash Bomb, Sniper Rifle, Overclocking Device, Energy Drink, Teleporting Machine, Portal Gun, Grenade, Time Bomb, Button Barry, Admin Device</size>\n\n<i>Every kill deals you a new hand.</i></size>",
  "Magician-GetIdToDesc-1": "Slows down everyone nearby for some time.",
  "Magician-GetIdToDesc-2": "Offsets your kill cooldown.",
  "Magician-GetIdToDesc-3": "Teleports you to a random vent.",
  "Magician-GetIdToDesc-4": "Use twice to mark 2 positions. Going near a marked position teleports you to the other.",
  "Magician-GetIdToDesc-5": "Sniper shot.",
  "Magician-GetIdToDesc-6": "Blinds everyone nearby for some time.",
  "Magician-GetIdToDesc-7": "Place a time bomb. When it explodes, it kills everyone nearby.",
  "Magician-GetIdToDesc-8": "Increases your speed for some time.",
  "Magician-GetIdToDesc-9": "Call a meeting.",
  "Magician-GetIdToDesc-10": "See how many players are in each room.",
  "Magician-GetIdToName-1": "Slowness Potion",
  "Magician-GetIdToName-2": "Overclocking Device",
  "Magician-GetIdToName-3": "Teleporting Machine",
  "Magician-GetIdToName-4": "Portal Gun",
  "Magician-GetIdToName-5": "Sniper Rifle",
  "Magician-GetIdToName-6": "Flash Bomb",
  "Magician-GetIdToName-7": "Grenade",
  "Magician-GetIdToName-8": "Energy Drink",
  "Magician-GetIdToName-9": "Button Barry",
  "Magician-GetIdToName-10": "Admin Device",
  "MagicianBlindDur": "Blinding Card Duration",
  "MagicianBlindRadius": "Blinding Card Radius",
  "MagicianBombDelay": "Bomb Delay",
  "MagicianBombExlodesIn": "Bomb explodes in {0}s",
  "MagicianBombExploded": "Time bomb exploded",
  "MagicianBombRadius": "Bomb Radius",
  "MagicianCardUsed": "Card used",
  "MagicianClearPortalAfterMeeting": "Clear Portals after meetings",
  "MagicianLowKCD": "Kill Cooldown when using Overlocking Device",
  "MagicianSlownessDur": "Slowness Duration",
  "MagicianSlownessRadius": "Slowness Card Radius",
  "MagicianSlownessValue": "Speed caused by Slowness Card",
  "MagicianSpeedup": "Increased Speed",
  "MagicianSpeedupDur": "Increased Speed Duration",
  "Magistrate": "Magistrate",
  "MagistrateInfo": "Call Court to Coordinate With Evils",
  "MagistrateInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Call court once to orchestrate an anonymous decisive meeting.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Call Court</color></b>\nOnce per game, trigger a special meeting: everyone turns gray, you appear as COURT with extra votes, and others appear as JURY.\n\nYou win if crewmates lose.\n\n<i>In court, the loudest voice wins.</i></size>",
  "Magistrate.CourtName": "COURT",
  "Magistrate.ExtraVotes": "Extra Votes",
  "Magistrate.JuryName": "JURY",
  "Maverick": "Maverick",
  "MaverickInfo": "Kill & Survive until the end to win",
  "MaverickInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill freely and survive to the end — win with whatever team wins.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Survivor's Gamble</color></b>\nKill freely like a Serial Killer. Win with whatever team is victorious — as long as you are alive when the game ends. Die and you lose.\n\n<i>Survival is its own kind of allegiance.</i></size>",
  "Medusa": "Medusa",
  "MedusaInfo": "Stone bodies by reporting them",
  "MedusaInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Stone dead bodies to make them permanently unreportable.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Stone</color></b>\nWhen your kill cooldown is up, report a dead body to stone it instead. Stoned bodies cannot be reported by anyone. Eliminate everyone to win.\n\n<i>Legends say she turned kings to stone.</i></size>",
  "MedusaReportButtonText": "Stone",
  "MedusaStoneBody": "Body stoned",
  "Mycologist": "Mycologist",
  "MycologistInfo": "Spread Spores and Kill Infected Players",
  "MycologistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Spread spores to infect players nearby — then kill only the infected.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Spread Spores</color></b>\nVent, sabotage, or pet to infect players around you.\n\n・<b><color=#ffab1b>Harvest</color></b>\nYou can only use your kill button on players who have been infected.\n\n<i>Fungi grow in the dark — so does danger.</i></size>",
  "MycologistAction": "Action To Infect",
  "MycologistNotify": "Spores spread successfully",
  "NecroGuesser": "Necro-Guesser",
  "NecroGuesserInfo": "Guess Dead Players' Roles",
  "NecroGuesserInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Guess the roles of dead players to earn a win with the winning team.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Guess</color></b>\nUse <b>/cmd bt {id} {role}</b> to guess a dead player's role. Use <b>/cmd id</b> to view player IDs. Guess enough correctly to win with the winning team at the end.\n\n<i>The dead still have secrets — if you know how to ask.</i></size>",
  "NecroGuesser.GuessCorrect": "Your guess was <#00ff00>correct</color>!",
  "NecroGuesser.GuessIncorrect": "Your guess was <#ff0000>incorrect</color>!",
  "NecroGuesser.NumGuessesToWin": "Number of Guesses Required to Win",
  "Necromancer": "Necromancer",
  "NecromancerInfo": "Recruit Everyone to the Undead",
  "NecromancerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Recruit a Deathknight and convert others to build the Undead faction.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Partial Recruit</color></b>\nYour first kill creates a Deathknight. Work together to convert other players to the Undead. If you die, the Deathknight becomes the new Necromancer.\n\n<i>Even death serves those who command it.</i></size>",
  "NecromancerCD": "Partial Recruit Cooldown",
  "NecromancerKnowTargetRole": "Know Recruited Players' Roles",
  "NecromancerRecruitedPlayer": "Successfully recruited player partially",
  "Nonplus": "Nonplus",
  "NonplusInfo": "Blind Others",
  "NonplusInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Blind all other players by venting or petting.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Blind</color></b>\nVent or pet to blind all other players, removing their vision for a set duration. Kill everyone to win.\n\n<i>No one can accuse what they cannot see.</i></size>",
  "Nonplus.BlindCooldown": "Blind Cooldown",
  "Nonplus.BlindDuration": "Blind Duration",
  "NoteKiller": "Note Killer",
  "NoteKillerInfo": "Find Players' Real Names to Kill Them in Meetings",
  "NoteKillerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Discover players' real names and kill them remotely by naming them.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Reveal</color></b>\nPet or vanish to briefly show fragments of every player's real name.\n\n・<b><color=#ffab1b>Death Note</color></b>\nOnce you know someone's full real name, use <b>/cmd dn {realname}</b> to kill them instantly from anywhere. Everyone knows a Note Killer is in the game. Everyone can see their own real name.\n\n<i>The name is the weapon.</i></size>",
  "NoteKiller.ClueShowDuration": "Clue Show Duration",
  "NoteKiller.MaxLettersRevealed": "Maximum Number of Letters Revealed From Each Name",
  "NoteKiller.MinLettersRevealed": "Minimum Number of Letters Revealed From Each Name",
  "NoteKiller.NumPlayersToKill": "Number of Players to Kill (X =)",
  "NoteKiller.OthersSelfSuffix": "<size=70%>There's a {0} in the game. Your real name is <#00ffa5>{1}</color></size>",
  "NoteKiller.OthersSelfSuffixShort": "<size=70%>Real Name: <#00ffa5>{0}</color></size>",
  "NoteKiller.WinCondition": "Win Condition",
  "DeathCommand": "<#ffffff>You were killed by </color>{0}<#ffffff>\\nTheir role is </color>{1}",
  "DeathCommandFail": "<#ff0000>The game could not determine your real killer.</color>\\nYour death reason is <#00ffa5>{0}</color>.",
  "DeathNoteCommand.CanNotGuess": "You've already tried to guess someone's real name and failed, so you can't guess again until the next meeting.",
  "DeathNoteCommand.PlayerNotFoundOrDead": "The player with this name was not found or is already dead.",
  "DeathNoteCommand.Success": "Success! {0} was killed.",
  "DeathNoteCommand.SuccessForOthers": "{0} was killed by the Note Killer.",
  "DeathNoteCommand.WrongName": "You've entered the wrong name.",
  "Opportunist": "Opportunist",
  "OpportunistInfo": "Stay alive until the end",
  "OpportunistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Stay alive until the end — and win with whoever wins.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Opportunism</color></b>\nIf still alive when the game ends, win with the winning team.\n\n<i>Survival is the most flexible form of victory.</i></size>",
  "ImmuneToAttacksWhenTasksDone": "Immune to attacks on task completion",
  "Patroller": "Patroller",
  "PatrollerInfo": "Have Different Boosts in Each Room",
  "PatrollerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Each room grants you a randomly assigned boost — and you can vent freely once per round.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Room Boosts</color></b>\nAt the start of the game, each room is assigned a random boost. Pet to view your current room's boost (if enabled). Vent freely from any room once per round.\n\n<size=70%>Possible boosts:\n・Increased Speed\n・Shorter Kill Cooldown\n・Larger Kill Range\n・Increased Vision\n・Ability to Vent\n・Ability to Sabotage</size>\n\nKill everyone to win.\n\n<i>Know every room. Own every room.</i></size>",
  "PatrollerBoost.Cooldown": "you have <color=#00ffa5>lower kill cooldown</color>",
  "PatrollerBoost.Range": "you have <color=#00ffa5>higher kill range</color>",
  "PatrollerBoost.Sabotage": "<color=#00ffa5>you can sabotage</color>",
  "PatrollerBoost.Speed": "you have <color=#00ffa5>higher speed</color>",
  "PatrollerBoost.Vent": "<color=#00ffa5>you can vent</color>",
  "PatrollerBoost.Vision": "you have <color=#00ffa5>higher vision</color>",
  "PatrollerNotify": "You are now in <color=#00ffa5>{0}</color>\\nIn this room, {1}",
  "PatrollerNotifyNoBoost": "You are now in <color=#00ffa5>{0}</color>\\nIn this room, you have <#ff0000>no boosts</color>",
  "Pawn": "Pawn",
  "PawnInfo": "Complete Tasks Then Pick Your Role",
  "PawnInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Complete all tasks, then choose your own role.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Choose Role</color></b>\nFinish all tasks, then use <b>/cmd choose {role}</b> to pick any enabled role. The command can be entered early — it applies once tasks are done.\n\nIf the game ends while you still have this role, you lose.\n\n<i>Finish the work. Then decide who you are.</i></size>",
  "Pawn.KeepsGameGoing": "Keeps The Game Going",
  "PawnChooseFail": "<#ff5555>X <#bb0000>Please enter a valid role that is enabled.",
  "PawnChosenRole": "<#00ff00>✓ <#00bb00>Your role will become {0} after the meeting if your tasks are done.",
  "Pelican": "Pelican",
  "PelicanInfo": "Eat all players",
  "PelicanInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Swallow players alive and keep them trapped outside the map.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Eat</color></b>\nUse your kill button to swallow a player — they are teleported outside the map and cannot interact with the game. Swallowed players die instantly when a meeting is called. Role defenses (Bodyguard, Squid) are ineffective against this. If you die or disconnect, all swallowed players return to your location.\n\n<i>Out of sight, out of mind — indefinitely.</i></size>",
  "PelicanButtonText": "Eat",
  "PelicanKillCooldown": "Eat Cooldown",
  "Pestilence": "Pestilence",
  "PestilenceInfo": "You're unstoppable",
  "PestilenceInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Reflect all attacks back at attackers — nearly unkillable.\n_____________________________________\nDifficulty: ★★★★★\n\n[Passive]\n・<b><color=#ffab1b>Immortal Reflection</color></b>\nAny direct attack against you is reflected back at the attacker. Indirect kills and suicide triggers have no effect. When you transform, all lethal add-ons are removed.\n\nThe only ways to eliminate Pestilence are by vote or misguessing. May optionally be announced in the next meeting after transforming.\n\n<i>You cannot stop what you cannot touch.</i></size>",
  "PestilenceCD": "<color=#343136>Pestilence</color> Kill cooldown",
  "PestilenceCanVent": "<color=#343136>Pestilence</color> Can Vent",
  "PestilenceHasImpostorVision": "<color=#343136>Pestilence</color> Has <color=#ff1919>Impostor</color> Vision",
  "PestilenceImmune": "You can't kill Pestilence.",
  "Pickpocket": "Pickpocket",
  "PickpocketInfo": "Steal votes from your kills",
  "PickpocketInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Steal votes from every player you kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Vote Theft</color></b>\nEach kill steals votes from the target and adds them to your vote count in meetings. Kill everyone to win.\n\n<i>Take their voice as well as their life.</i></size>",
  "PickpocketGetVote": "You've got +{0} votes",
  "PlagueBearer": "Plaguebearer",
  "PlagueBearerInfo": "Plague everyone to turn into <color=#343136>Pestilence</color>",
  "PlagueBearerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Plague every living player to transform into the unstoppable Pestilence.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Plague</color></b>\nUse your kill button to plague each player. Once every living player is plagued, you transform into Pestilence — gaining near-immortality, kill ability, and attack reflection.\n\nYou can only win by transforming into Pestilence.\n\n<i>Patience. Every plague begins with one touch.</i></size>",
  "PlagueBearerAlreadyPlagued": "Player has already been plagued",
  "PlagueBearerCD": "Plague cooldown",
  "PlagueBearerToPestilence": "You have turned into Pestilence!!",
  "Poisoner": "Poisoner",
  "PoisonerInfo": "Your kills are delayed",
  "PoisonerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your kills are delayed — but just as lethal.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Poison</color></b>\nPoison a player with your kill button. They die after the configured delay. Kill everyone to win.\n\n<i>The slowest poison is the most terrifying.</i></size>",
  "PoisonerKillButtonText": "Poison",
  "PoisonerKillDelay": "Poison Kill Delay",
  "PoisonerPoisonButtonText": "Poison",
  "PoisonerTargetDead": "Target died",
  "Postman": "Postman",
  "PostmanInfo": "Deliver Mail to Everyone!",
  "PostmanInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Deliver mail to every player — click the wrong person and you die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Deliver</color></b>\nYou always have a current target. Use your kill button on that exact target to deliver mail. Clicking the wrong player kills you. Deliver to everyone to satisfy your win condition — you then win with whatever team wins.\n\n<i>The mail always gets through. One way or another.</i></size>",
  "PostmanCorrectDeliver": "<color=#00ff00>Deliver successful.</color>",
  "PostmanDiesWhenTargetDies": "<color=#00b893>Postman</color> dies when the current target dies",
  "PostmanDone": "<color=#00ff00>You're done delivering messages!\\nYou'll win with the winning team at the end.</color>",
  "PostmanGetNewTarget": "Your new target is {0}.",
  "PostmanHasArrowsToTargets": "<color=#00b893>Postman</color> has an arrow pointing towards their current target",
  "PostmanKillButtonText": "Deliver",
  "PostmanTarget": "<color=#00ffa5>Target:</color> <b>{0}</b>",
  "PostmanTargetDied": "<color=#ffff00>Your target died.</color>",
  "Predator": "Predator",
  "PredatorInfo": "Eliminate Specific Roles",
  "PredatorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill one player with a listed role to win — wrong target kills you.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Predator's Mark</color></b>\nKill one player who has a role listed below your name. On success, you win with the winning team at the end. Killing anyone else kills you instead.\n\n<i>Study your prey. Strike once.</i></size>",
  "PredatorCorrectKill": "Successful kill! They were {0}.",
  "PredatorDone": "You've done your job.\\nYou'll win with the winning team at the end.",
  "Provocateur": "Provocateur",
  "ProvocateurInfo": "Win if your target loses",
  "ProvocateurInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Greet a target — and win with the winning team if they lose.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Greet</color></b>\nUse your kill button to greet a target. If that player loses at the end of the game, you win with the winning team.\n\n<i>Victory tastes better when it comes from another's defeat.</i></size>",
  "ProvocateurButtonText": "Greet",
  "Pulse": "Pulse",
  "PulseInfo": "Your kill cooldown shifts",
  "PulseInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your kill cooldown alternates between two values with each kill.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Passive]\n・<b><color=#ffab1b>Pulsing Cooldown</color></b>\nAfter each meeting, your first kill uses the Even-Numbered Kill Cooldown; your second uses the Odd-Numbered cooldown. The pattern repeats. A separate cooldown applies right after meetings.\n\n<i>Rhythm is its own kind of strategy.</i></size>",
  "Pursuer": "Pursuer",
  "PursuerInfo": "Protect yourself and live to the end!",
  "PursuerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Protect yourself with blank shots — and survive to the end to win.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Trick</color></b>\nUse your ability on a player to make their next kill attempt fire a blank — resetting their cooldown without harming you.\n\nSurvive until the game ends to win.\n\n<i>Let them waste their shot.</i></size>",
  "PursuerButtonText": "Trick",
  "PursuerSkillCooldown": "Ability cooldown",
  "PursuerSkillLimitTimes": "Max number of uses",
  "Pyromaniac": "Pyromaniac",
  "PyromaniacInfo": "Douse and Kill Everyone",
  "PyromaniacInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Douse players for near-instant kills when you finish them off.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Douse</color></b>\nDouse players to mark them. Killing a doused player resets your cooldown to near-zero. Eliminate everyone to be the last one standing.\n\n<i>Everything burns brighter when you're the one holding the match.</i></size>",
  "PyroBurnCooldown": "Kill Cooldown after killing a Doused Player",
  "PyroDouseCooldown": "Douse Cooldown",
  "Quarry": "Quarry",
  "QuarryInfo": "Hide From Players",
  "QuarryInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Swap places with a target — they must hunt you down or die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Swap</color></b>\nShapeshift to select a target and swap positions with them. They must find and kill you within the time limit or they die instead. Normal kills are also available. Eliminate everyone to win.\n\n<i>The hunter and the hunted are always switching places.</i></size>",
  "Quarry.CanVentDuringSeekTime": "Can Vent During Seek Time",
  "Quarry.SeekTime": "Seek Time",
  "Quarry.TargetDiesOnMeetingCall": "Target Dies on Meeting Call",
  "Quarry.TargetHasArrowToQuarry": "Target has an arrow to the <#c1fb2b>Quarry</color>",
  "Quarry.TargetSeekBeginNotify": "<#ff0000>You were swapped with the {0}! They have a black name!",
  "Quarry.TimeLeftSuffix": "<#ffff00>You have <#ffffff>{0}s</color> to kill the {1} <#ffa500>or you die!",
  "QuarryTarget": "As the <#c1fb2b>Quarry</color>'s target, you cannot start meetings",
  "QuizMaster": "Quiz Master",
  "QuizMasterInfo": "Ask Questions to Players",
  "QuizMasterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Ask players questions in meetings — answer wrong and die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Mark</color></b>\nSingle-click your kill button to mark a player as your question target for the next meeting. Double-click to kill them normally.\n\n・<b><color=#ffab1b>Quiz</color></b>\nYour marked target receives a question in the next meeting. An incorrect answer kills them. You receive a copy of the question sent. Kill everyone to win.\n\n<i>Knowledge is power — and ignorance is death.</i></size>",
  "QuizMaster.Question.1": "What was the color of the body that was last reported?",
  "QuizMaster.Question.2": "Who was the last person that pressed the button?",
  "QuizMaster.Question.3": "What was the last sabotage that was called?",
  "QuizMaster.Question.4": "What was the most recently ejected player's role?",
  "QuizMaster.Question.5": "Who reported the body in the last meeting?",
  "QuizMaster.Question.6": "How many players voted last meeting (excluding hidden/extra votes)?",
  "QuizMaster.Question.7": "How many meetings did we have so far?",
  "QuizMaster.Question.8": "Whose body was reported first in the game?",
  "QuizMaster.Question.9": "How many people pressed the emergency button so far <size=80%>(including this meeting if it's a button)</size>?",
  "QuizMaster.Question.10": "How many players died in this round?",
  "QuizMaster.Question.11": "How many players died in the first round?",
  "QuizMaster.Question.12": "How many sabotages were called so far?",
  "QuizMaster.Question.13": "How many tasks are currently completed?",
  "QuizMaster.Question.14": "What base does {0} have?",
  "QuizMaster.Question.ABC.1": "What faction killed the last victim that got reported?",
  "QuizMaster.Question.ABC.2": "How did the last victim that got reported die?",
  "QuizMaster.Question.ABC.3": "Which Among Us mod has the most amount of roles?",
  "QuizMaster.Question.ABC.4": "Who is the main developer of End K not?",
  "QuizMaster.Question.ABC.5": "What alignment/team is {0} in?",
  "QuizMaster.Question.ABC.6": "What is {0}?",
  "QuizMaster.AnswerCorrect": "Correct! You may live.",
  "QuizMaster.AnswerCorrect.Self": "Your target answered the question correctly. ({0})",
  "QuizMaster.AnswerIncorrect": "Incorrect! You died.\\nThe answer was <b>{0}</b>.",
  "QuizMaster.AnswerIncorrect.Self": "Your target answered incorrectly. They chose {0}, while the correct option was {1}.",
  "QuizMaster.CustomQuestionChance": "Chance of Custom Question",
  "QuizMaster.EnableCustomQuestions": "Enable Custom Questions",
  "QuizMaster.MarkCooldown": "Player Marking Cooldown",
  "QuizMaster.QuestionSample": "{0}\\n{1}\\n\\n<size=80%>To answer, type /qa (A/B/C) (ex.: '/qa C')\\nTo see this question again, type /qs\\nIf you don't answer or answer incorrectly, you die",
  "QuizMaster.QuestionSample.Title": "Quiz Master Questioned You",
  "QuizMaster.QuestionSample.Title.Self": "Sent Question:",
  "QuizMaster.Title": "Quiz Master Question",
  "Reckless": "Reckless",
  "RecklessInfo": "Avoid Meetings at all costs",
  "RecklessInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Each kill reduces your cooldown — but it resets every meeting.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Reckless Momentum</color></b>\nYour kill cooldown decreases with each kill, but resets to its default value at every meeting. Avoid calling meetings to maintain your advantage.\n\n<i>Momentum is everything. Meetings are your enemy.</i></size>",
  "Revolutionist": "Revolutionist",
  "RevolutionistInfo": "Recruit players to win with you",
  "RevolutionistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Recruit players and trigger a group vent to win together.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Recruit</color></b>\nUse your kill button on a player and follow them for a few seconds to recruit them. Recruited players may be immediately eliminated at a host-set probability. Win if the required number of players vent within the countdown — otherwise, the recruited player dies. You die if killed during a countdown or at a meeting. Players who died after recruitment can still win with you.\n\n<i>Revolution doesn't wait for everyone to be ready.</i></size>",
  "RevolutionistCooldown": "Tag Cooldown",
  "RevolutionistDrawButtonText": "Win Over",
  "RevolutionistDrawCount": "Amount of Players needed to Tag",
  "RevolutionistDrawTime": "Tag Duration",
  "RevolutionistKillProbability": "Tagged player sacrifice probability",
  "RevolutionistVentButtonText": "Revolution",
  "RevolutionistVentCountDown": "Time to Vent",
  "Ritualist": "Ritualist",
  "RitualistInfo": "Kill and reveal the roles of your enemies",
  "RitualistInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Reveal players' roles with single-clicks — or kill with double-clicks.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Reveal</color></b>\nSingle-click your kill button to reveal a player's role.\n\n・<b><color=#ffab1b>Kill</color></b>\nDouble-click to kill normally.\n\nWhen reveal uses run out, the kill button functions normally.\n\n<i>Knowledge precedes the kill.</i></size>",
  "Rogue": "Rogue",
  "RogueInfo": "Complete Objectives, Get Rewards",
  "RogueInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Complete optional objectives each round to earn powerful rewards.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Objective</color></b>\nEach round you receive an optional objective with a reward. Completing it grants one of many possible benefits:\n\n<size=70%>Halved kill cooldown, disabled devices, helpful add-on, Impostor vision, speed boost, long kill range, morph ability, sabotage ability, or invincibility for the round.</size>\n\n<i>Risk is its own kind of reward.</i></size>",
  "Rogue.AllTasksCompleted": "<#00ff00>All Objectives Completed</color>",
  "Rogue.Objective.CallEmergencyMeeting": "Call an emergency meeting",
  "Rogue.Objective.DontStopWalking": "Don't stop walking",
  "Rogue.Objective.FixSabotage": "Fix a sabotage",
  "Rogue.Objective.KillInSpecificRoom": "Kill someone in {0}",
  "Rogue.Objective.KillSpecificPlayer": "Kill {0}",
  "Rogue.Objective.KillXTimes": "Kill {0} times",
  "Rogue.Objective.VentXTimes": "Vent {0} times",
  "Rogue.Reward.DecreasedKillCooldown": "Kill cooldown cut in half",
  "Rogue.Reward.DisableDevices": "Disable all devices for the rest of the game",
  "Rogue.Reward.HelpfulAddon": "Get a random helpful add-on",
  "Rogue.Reward.ImpostorVision": "Impostor vision for the rest of the game",
  "Rogue.Reward.IncreasedSpeed": "Increased speed by 0.5x for the rest of the game",
  "Rogue.Reward.LongReach": "Longest kill range for the rest of the game",
  "Rogue.Reward.Morph": "Ability to turn into a random crewmate (by sab/pet) for 15s",
  "Rogue.Reward.Sabotage": "Ability to sabotage for the rest of the game",
  "Rogue.Reward.Shield": "Invincibility for the rest of the game",
  "Rogue.RewardEnabled.DecreasedKillCooldown": "Enable Decreased Kill Cooldown Reward",
  "Rogue.RewardEnabled.DisableDevices": "Enable Disable Devices Reward",
  "Rogue.RewardEnabled.HelpfulAddon": "Enable Helpful Add-on Reward",
  "Rogue.RewardEnabled.ImpostorVision": "Enable Impostor Vision Reward",
  "Rogue.RewardEnabled.IncreasedSpeed": "Enable Increased Speed Reward",
  "Rogue.RewardEnabled.LongReach": "Enable Long Reach Reward",
  "Rogue.RewardEnabled.Morph": "Enable Morph Reward",
  "Rogue.RewardEnabled.Sabotage": "Enable Sabotage Reward",
  "Rogue.RewardEnabled.Shield": "Enable Shield Reward",
  "Rogue.Task": "Objective: <#ffff00>{0}</color>\nReward: <#00ffa5>{1}</color>",
  "Rogue.TaskCompleted": "<#00ff00>Objective Completed</color>",
  "RogueKnowEachOther": "<color=#696969>Rogues</color> know each other",
  "RogueKnowEachOtherRoles": "<color=#696969>Rogues</color> know the roles of each other",
  "Romantic": "Romantic",
  "RomanticInfo": "Select your partner and win with them",
  "RomanticInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Choose a partner and protect them — your fate is entirely tied to theirs.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Pick Partner</color></b>\nUse your kill button to select a partner. While both of you are alive, using your kill button gives your partner a temporary shield. If your partner wins, you win too.\n\n・<b><color=#ffab1b>Partner Died</color></b>\n<size=70%>If partner had a kill button: you take on their exact role.\nIf partner was a non-killing Neutral or died without a player killer: you become Ruthless Romantic (kill everyone to win).\nIf partner was an Impostor: you become Renegade.\nOtherwise: you become Vengeful Romantic — kill only your partner's murderer to win. Killing anyone else kills you.</size>\n\n<i>Love is the most dangerous weapon of all.</i></size>",
  "Romantic.PickPartnerText": "PICK PARTNER",
  "RomanticArrows": "<color=#ff1493>Romantic</color> has arrows pointing to their Partner",
  "RomanticBetCooldown": "Pick Partner Cooldown",
  "RomanticBetOnYou": "The Romantic chose you as their Partner!",
  "RomanticBetPlayer": "You picked your partner",
  "RomanticBetTargetKnowRomantic": "Target knows who the <color=#ff1493>Romantic</color> is",
  "RomanticGetsPartnerConvertedAddons": "<color=#ff1493>Romantic</color> gets the converted add-ons of their partner",
  "RomanticIsProtectingYou": "The <color=#FF1493>Romantic</color> is protecting you",
  "RomanticKillButtonText": "Romance",
  "RomanticKnowTargetRole": "<color=#ff1493>Romantic</color> knows their target's role",
  "RomanticPartnerHasArrows": "Partner has arrows pointing to the <color=#FF1493>Romantic</color>",
  "RomanticProtectCooldown": "Protect Cooldown",
  "RomanticProtectDuration": "Protect Duration",
  "RomanticProtectPartner": "Your partner is under protection",
  "RomanticDesignationMethod": "Partner Designation Method",
  "RomanticDesignation.Kill": "Kill",
  "RomanticDesignation.SelfVote": "Self-Vote",
  "RomanticDesignation.Both": "Both",
  "RomanticLoverDeathTransformRole": "Transform Into When Partner Dies",
  "RomanticSelfVoteActivate": "Confession mode activated. Vote your target to confess your love.",
  "RomanticConfessionCanceled": "Confession canceled.",
  "RoomRusher": "Room Rusher",
  "RoomRusherInfo": "You're Playing Room Rush",
  "RoomRusherInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Race to specified rooms within time limits — miss the deadline and you die.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Room Rush</color></b>\nReach the specified room within the time limit or die. Venting is allowed a limited number of times (host-set). Successfully reach the target room the required number of times to satisfy your win condition — you then win with the winning team.\n\n<i>Speed is the only currency that matters here.</i></size>",
  "RoomRusher.MaxVents": "Max Number of Vent Uses",
  "RoomRusher.RoomsToWin": "Number of rooms to get to for the win condition to satisfy",
  "RouleteGrandeur": "Roulette Grandeur",
  "RouleteGrandeurInfo": "Play Russian Roulette",
  "RouleteGrandeurInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Play Russian Roulette to permanently reduce your kill cooldown.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Roulette</color></b>\nVent to cycle the number of bullets loaded (risk level). Sabotage or pet to spin. There are 5 slots — landing on a bullet kills you. Surviving permanently reduces your kill cooldown by the set amount, <i>multiplied by the number of bullets you risked</i>.\n\n<i>Fortune favors the bold — and the reckless.</i></size>",
  "KCDReduction": "Kill Cooldown Reduction (multiplied by the amount of bullets put in)",
  "RG.Hit": "<#ffff00>The hit landed on one of your bullets!\\nBetter luck next time!</color>",
  "RG.NoHit": "<#00ffa5>You survived, despite putting in <#8cffff>{0}</color> bullets.\\nYour kill cooldown was reduced by <#8cffff>{1}s</color>!</color>",
  "RG.Suffix": "<#00ffa5>Bullets:</color> <b>{0}</b>",
  "RuthlessRomantic": "Ruthless Romantic",
  "RuthlessRomanticInfo": "Kill everyone to win",
  "RuthlessRomanticInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your partner is gone — now you kill everyone to honor their memory.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Ruthless Killer</color></b>\nYou transformed from Romantic after your partner died without a player killer (or as a non-killing Neutral). Kill everyone to win. Your dead partner wins with you.\n\n<i>Grief has no patience for mercy.</i></size>",
  "RuthlessCanVent": "<color=#D2691E>Ruthless Romantic</color> Can Vent",
  "RuthlessKCD": "<color=#D2691E>Ruthless Romantic</color> Kill Cooldown",
  "RuthlessHasImpVision": "<color=#D2691E>Ruthless Romantic</color> Has <#ff1919>Impostor</color> Vision",
  "Samurai": "Samurai",
  "SamuraiInfo": "Kill Players in Unique Ways",
  "SamuraiInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Stay near your target after marking them for a bonus — or lunge immediately.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Precision Strike</color></b>\nClick your kill button to mark a target (kill doesn't trigger immediately). Stay near them for a few seconds — like an Arsonist douse — to trigger a delayed kill with a reduced cooldown bonus. Breaking proximity causes a normal lunge kill instead.\n\n<i>Patience is the sharpest blade.</i></size>",
  "Samurai.KillDelay": "Kill Delay",
  "Samurai.NearbyDuration": "Time to Stay Near Target",
  "Samurai.SuccessKCD": "Kill Cooldown for Delayed Kills",
  "SchrodingersCat": "Schrödinger's Cat",
  "SchrodingersCatInfo": "Get Attacked to Get a Role",
  "SchrodingersCatInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Getting attacked gives you the same role as your killer.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Quantum State</color></b>\nIf attacked, you transform into the same role as your killer. If never attacked when the game ends, you lose — or win with crewmates, depending on settings.\n\n<i>You don't know what you are until someone tries to kill you.</i></size>",
  "SchrodingersCat.Notify.KillerRecruited": "You have recruited the {1}! {0} now has the same role as you.",
  "SchrodingersCat.Notify.RecruitedByKiller": "You have been recruited by the {1}! You now have the same role as {0}.",
  "SchrodingersCat.StealsExactImpostorRole": "Steals the exact impostor role instead of <#ff1919>Renegade</color>",
  "SchrodingersCat.WinsWithCrewIfNotAttacked": "Wins with crewmates if not attacked",
  "SchrodingersCat.KillBackKiller": "Kill back the attacker after a delay (BakeCat-style)",
  "SchrodingersCat.KillBackDelay": "Kill-back Delay",
  "Seamstress": "Seamstress",
  "SeamstressInfo": "Sew Players Together",
  "SeamstressInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Sew two players together so that anything that happens to one happens to both.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Sew</color></b>\nUse your shapeshift menu to link two players. Any interaction affecting one (kills, effects) also applies to the other. Sewed players know they are linked but not to whom. The sew breaks on death, disconnect, or meeting.\n\nYou win if crewmates lose.\n\n<i>Bound together, they fall together.</i></size>",
  "SerialKiller": "Serial Killer",
  "SerialKillerInfo": "Kill everyone to win!",
  "SerialKillerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill everyone to win — no tricks, just survival of the deadliest.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Serial Killing</color></b>\nYour only goal is to eliminate every other player. You may have a kill-or-die timer depending on settings.\n\n<i>Simple objectives. Brutal execution.</i></size>",
  "SerialKillerTimeLeft": "<#ffff00>Must kill within <#ffa500>{0}</color>s</color>",
  "Sharpshooter": "Sharpshooter",
  "SharpshooterInfo": "Kill Blindly and Accurately",
  "SharpshooterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Go blind and super fast — the first player you touch dies, then you teleport back.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Sharpshoot</color></b>\nActivate your ability to turn blind and move at extreme speed while appearing frozen to others. The first player you come near dies, and you teleport back to your starting position. Failing to kill within the time limit causes a misfire (suicide). Eliminate everyone to win.\n\n<i>Close your eyes. Trust the instinct.</i></size>",
  "Sharpshooter.SpeedIncreasement": "Speed Increasement",
  "Shifter": "Shifter",
  "ShifterInfo": "Steal Someone's Role",
  "ShifterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Steal another player's role by getting near them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Shift Role</color></b>\nUse your kill button near a player to steal their role. Depending on settings, you may also steal their role progress and ability uses.\n\nIf the game ends while you still have this role, you lose.\n\n<i>Take what they've built for themselves.</i></size>",
  "Shifter.CanBeKilled": "<#777777>Shifter</color> Can Be Killed",
  "Shifter.CanBeVoted": "<#777777>Shifter</color> Can Be Voted",
  "ShifterKillButtonText": "Shift Role",
  "Sidekick": "Sidekick",
  "SidekickInfo": "Help the Jackal win",
  "SidekickInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Help your Jackal win — and take their place if they fall.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Jackal Ally</color></b>\nHelp your Jackal achieve majority and eliminate all other evil teams. If the Jackal dies, you become the new Jackal and gain the ability to convert players with your kill button. All Jackals and Sidekicks win together.\n\n<i>A good second is worth more than a weak leader.</i></size>",
  "SKCanKill": "<color=#00b4eb>Sidekick</color> can kill",
  "SidekickCanKillJackal": "<color=#00b4eb>Sidekick</color> can kill <color=#00b4eb>Jackal</color>",
  "SidekickCanKillSidekick": "<color=#00b4eb>Sidekicks</color> can kill other <color=#00b4eb>Sidekicks</color>",
  "SidekickCountMode": "<color=#00b4eb>Sidekicks</color> count as",
  "SidekickCountMode.Jackal": "<color=#00b4eb>Jackal</color>",
  "SidekickCountMode.None": "Nothing",
  "SidekickCountMode.Original": "Original Team",
  "SidekickKnowOtherSidekick": "<color=#00b4eb>Sidekicks</color> know each other",
  "SidekickSettings": "Show Sidekick Settings",
  "SidekickSheriffCanGoBerserk": "<color=#00b4eb>Recruited</color> <color=#f8cd46>Sheriff</color> Can Go Nuts",
  "Simon": "Simon",
  "SimonInfo": "Give Instructions to Players",
  "SimonInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Give instructions to players — those who disobey by the next meeting die.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Mark</color></b>\nSingle-click your kill button to mark players. Double-click to kill normally.\n\n・<b><color=#ffab1b>Give Instruction</color></b>\nVent to send instructions to all marked players. Kill-button players are told to kill; crewmates are told to complete a task. Disobeying by the next meeting kills them. Sabotage or pet to swap to the opposite instruction.\n\n<i>Simon says: follow the rules.</i></size>",
  "SimonDoMode": "<#00ffa5>Mode:</color> Do instruction",
  "SimonDoShort": "<#ff0000>Must do instruction</color>",
  "SimonDontKill": "Simon says: <#ffff00>You must NOT use your kill button until the next meeting</color>",
  "SimonDontMode": "<#00ffa5>Mode:</color> Do NOT do instruction",
  "SimonDontShort": "<#ffa500>Must not do instruction</color>",
  "SimonDontTask": "Simon says: <#ffff00>You must NOT complete a task until the next meeting</color>",
  "SimonKill": "Simon says: <#ffff00>You must use your kill button before the next meeting</color>",
  "SimonTask": "Simon says: <#ffff00>You must complete a task before the next meeting</color>",
  "Slenderman": "Slenderman",
  "SlendermanInfo": "Everyone Gets Blinded Near You",
  "SlendermanInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Blind anyone who strays too close — a deadly presence without lifting a finger.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Proximity Blind</color></b>\nWhenever someone gets close to you, they are blinded until they move away. The effect is constant and passive.\n\n<i>Some monsters don't need to chase you.</i></size>",
  "Slenderman.AfterMeetingBlindCooldown": "Blinding Cooldown After Meetings",
  "Slenderman.BlindRange": "Blinding Range",
  "Slenderman.AffectsPlayersInVents": "Blinding Affects Players Inside Vents",
  "SoulCollector": "Soul Collector",
  "SoulCollectorInfo": "You Kill Without Any Notice",
  "SoulCollectorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill silently — victims appear alive to the crew until a meeting is called.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Ghost Kill</color></b>\nWhen you kill someone, everyone except you and your target sees them as still alive. Your targets fully die when a meeting is called.\n\n<i>Death can wait — right up until the moment it can't.</i></size>",
  "SoulHunter": "Soul Hunter",
  "SoulHunterInfo": "Hunt Souls To Win",
  "SoulHunterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Mark a target, then race the clock to collect their soul.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Mark</color></b>\nSingle-click your kill button to mark a target. After the next meeting, you are frozen for a set time while the target is notified — they cannot vent, call meetings, or kill you during this time.\n\n・<b><color=#ffab1b>Hunt</color></b>\nKill your marked target within a time limit to gain a soul. Fail and you lose one. Collect enough souls to satisfy your win condition and win with the winning team.\n\n<i>The hunt begins the moment the meeting ends.</i></size>",
  "SoulHunterFreezeTimeAfterMeeting": "Waiting Time After Meeting",
  "SoulHunterGetSoulForSuicide": "Gain Soul When Target Dies By Other Means",
  "SoulHunterNotify": "You have <color=#00ffa5>{0}s</color> to kill <color=#3f2c61>{1}</color>",
  "SoulHunterNotifyFreeze": "You can begin hunting <color=#3f2c61>{0}</color> in <color=#00ffa5>{1}s</color>",
  "SoulHunterNotifySuccess": "<color=#00ff00>Success!</color>",
  "SoulHunterNumOfSoulsToWin": "Number of Souls Required to Win",
  "SoulHunterTargetNotify": "The <color=#3f2c61>Soul Hunter</color>, <color=#00ffa5>{0}</color> is hunting you. Hide!",
  "SoulHunterTargetNotifyNoKill": "<color=#ffff00>You cannot kill the <color=#3f2c61>Soul Hunter</color> while being hunted</color>",
  "SoulHunterTargetNotifyNoMeeting": "<color=#ffff00>You cannot call emergency meetings while being hunted</color>",
  "SoulHunterTargetNotifyNoVent": "<color=#ffff00>You cannot vent while being hunted</color>",
  "SoulHunterTargetNotifySurvived": "<color=#00ff00>You survived!</color>",
  "SoulHunterTimeToKillTarget": "Time to Kill Target",
  "Specter": "Specter",
  "SpecterInfo": "Get killed and finish your tasks to win!",
  "SpecterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Complete your tasks, then get killed — death is the path to victory.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Martyr's Path</color></b>\nComplete all your tasks while alive, then get killed. Win with the winning team at the end. Cannot win while still alive.\n\n<i>The finishing line is on the other side of death.</i></size>",
  "Spider": "Spider",
  "SpiderInfo": "Trap players in your webs then eat them",
  "SpiderInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Lay webs, wait for victims, then devour the trapped.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Web</color></b>\nVanish/pet/shapeshift to place a web. Players who walk into it are frozen with reduced vision, and you are notified. Webs break if a player stays too long. You can only kill players currently trapped in a web.\n\n<i>Patience is its own kind of predator.</i></size>",
  "Spider.LowerVisionBy": "Lower Vision By",
  "Spider.TrappedDuration": "Trapped Duration (after which the web breaks)",
  "Spider.WebTrapRange": "Web Trap Range",
  "Spirit": "Spirit",
  "SpiritInfo": "Place Candles to Swap Interactions",
  "SpiritInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Swap the fates of two players — what happens to one, happens to the other.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Candle Swap</color></b>\nUse the shapeshift menu to link two players with candles. Any interaction between either player — including kills — redirects to the other. If one dies or disconnects, the swap breaks and the candle is returned. Swapped players know they are linked, but not with whom.\n\nWin if crewmates lose.\n\n<i>Destiny is just a matter of rearrangement.</i></size>",
  "SpiritTarget": "<#ffff44>You were swapped with someone by the {0}!</color>",
  "SpiritTargetBoth": "<#00ff00>2/2 targets set</color>\\n<size=80%>Interactions between {0} and {1} are swapped</size>",
  "SpiritTargetNone": "0/2 targets set\\n<size=80%>Use your shapeshift menu to set targets</size>",
  "SpiritTargetOne": "<#ffff44>1/2</color> targets set ({0})\\n<size=80%>Use your shapeshift menu to set the second target</size>",
  "Spiritcaller": "Spiritcaller",
  "SpiritcallerInfo": "Turn Players into Evil Spirits",
  "SpiritcallerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your victims become spirits that fight for you from beyond the grave.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Evil Spirits</color></b>\nPlayers you kill become Evil Spirits. Spirits can freeze other players, block their vision, or grant you a shield that briefly protects against an incoming kill.\n\n<i>Death is not the end — it is a new form of service.</i></size>",
  "SpiritcallerCauseVision": "<color=#003366>Evil Spirit</color> ability caused vision",
  "SpiritcallerCauseVisionTime": "<color=#003366>Evil Spirit</color> ability caused vision time",
  "SpiritcallerFreezeTime": "<color=#003366>Evil Spirit</color> ability freeze time",
  "SpiritcallerNoticeMessage": "The Spiritcaller has killed you and turned you into an Evil Spirit. Your task now is to help the Spiritcaller to victory by using your spook button to hinder other players or to protect the Spiritcaller. Use /m for more information.",
  "SpiritcallerProtectTime": "<color=#003366>Evil Spirit</color> ability protect time",
  "SpiritcallerSpiritAbilityCooldown": "<color=#003366>Evil Spirit</color> ability cooldown",
  "SpiritcallerSpiritMax": "Maximum number of <color=#003366>Evil Spirits</color>",
  "Sprayer": "Sprayer",
  "SprayerInfo": "Place Traps",
  "SprayerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Lay chemical traps and let the crew poison themselves to death.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Trap</color></b>\nSabotage or pet to place a trap. Players who walk into it suffer reduced speed and vision for a time. Walk into a trap too many times and they die.\n\n<i>The most effective traps are the ones people keep walking into.</i></size>",
  "SprayerMaxTrappedTimes": "Times a Player Has to Walk Into a Trap to Die",
  "SprayerNotify": "Trap placed",
  "Stalker": "Stalker",
  "StalkerInfo": "Your kills cause power outages",
  "StalkerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Every kill plunges the ship into darkness.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Blackout Kill</color></b>\nEach kill triggers the electricity sabotage. Cannot vent. Depending on host settings, may win alone if alive when the Crewmate or Impostor team wins.\n\n<i>The lights go out, and the screaming begins.</i></size>",
  "Starspawn": "Starspawn",
  "StarspawnInfo": "Isolate Players & Call Daybreak",
  "StarspawnInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Isolate the crew from help, then call daybreak to silence all resistance.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Isolate</color></b>\nUse your kill button to isolate a player. Only evil players can interact with isolated players.\n\n・<b><color=#ffab1b>Daybreak</color></b>\nOnce per game, type <b>/cmd daybreak</b> in chat during a meeting to prevent ALL meeting abilities — guessing, judging, and other role-specific abilities — for that meeting.\n\nWin if crewmates lose.\n\n<i>When daybreak comes, there is nowhere left to hide.</i></size>",
  "StarspawnUsedDayBreak": "<#ff0000>⚠</color> <#ffff00>Daybreak has been called by the {0}!</color> <#ff0000>⚠</color>\\nThis means that NO meeting abilities can be used in this meeting anymore.",
  "Sunnyboy": "Sunnyboy",
  "SunnyboyInfo": "Shine, shine my sunshine!",
  "SunnyboyInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Your presence alone prevents a premature game-over — die at the end to win.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Passive]\n・<b><color=#ffab1b>Life Panel</color></b>\nCheck the life status of other players through the life panel.\n\n・<b><color=#ffab1b>Sunlight</color></b>\nWhile alive, the game cannot end due to numerical advantage (e.g., Impostors outnumber crew). Die at the end of the game to win with the winning team.\n\n<i>Even the sun must set to end the day.</i></size>",
  "SunnyboyChance": "<color=#ff9902>Sunnyboy</color> Chance",
  "Tank": "Tank",
  "TankInfo": "Vent in Every Vent",
  "TankInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Crawl through every vent on the map — slow and steady wins the game.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Vent Explorer</color></b>\nVent in every single vent on the map before the game ends to win with the winning team. Move at significantly reduced speed. An arrow points to a random unvisited vent.\n\n<i>Every corner of this ship will know your name.</i></size>",
  "Tank.CanBeGuessed": "Can be Guessed",
  "Tank.CanBeKilled": "Can be Killed",
  "Tank.Speed": "Movement Speed",
  "Tank.Suffix": "<size=80%><#00ffa5>A random vent you haven't entered yet:</color> {0}</size>",
  "Technician": "Technician",
  "TechnicianInfo": "Fix sabotages",
  "TechnicianInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Earn your victory by fixing what others break.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Repair</color></b>\nFix a set number of sabotages to win. Different sabotage types may award different point values. Depending on host settings, you may vent and may win alone or with the winning team.\n\n<i>When everyone else panics, you fix.</i></size>",
  "Technician.PointGain.Comms": "Points gained for fixing Comms",
  "Technician.PointGain.Electrical": "Points gained for fixing Lights",
  "Technician.PointGain.LifeSupp": "Points gained for fixing O2",
  "Technician.PointGain.Reactor": "Points gained for fixing Reactor",
  "Technician.RequiredPoints": "Required Points to Win",
  "Technician.WinsAlone": "Wins Alone",
  "Terrorist": "Terrorist",
  "TerroristInfo": "Finish your tasks, THEN die",
  "TerroristInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Finish your tasks, then go out with a bang.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Final Act</color></b>\nComplete all your tasks and then die to win the game alone.\n\n<i>A mission accomplished in the most dramatic way possible.</i></size>",
  "Thanos": "Thanos",
  "ThanosInfo": "Collect Infinity Stones",
  "ThanosInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Collect all six Infinity Stones — or just kill everyone. Either works.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#ffab1b>Infinity Stones</color></b>\nRandom players hold Infinity Stones — kill them to claim the stones. Shift/Vanish/Pet to use the selected stone.\n\n<size=70%>・Space Stone: Next kill leaves no body and ignores all shields\n・Mind Stone: Permanent immunity to controlling abilities\n・Reality Stone: Grants a shield\n・Power Stone: Kill cooldown drastically reduced after the next kill\n・Time Stone: Slows everyone except you\n・Soul Stone: Arrow pointing to a player holding a stone</size>\n\n<i>The hardest choices require the strongest will.</i></size>",
  "Thanos.ActiveStone": "<size=80%><#00ffa5>Active Stone:</color> <b>{0}</b></size>",
  "Thanos.CanWinAfterCollectingAllStones": "Can Win After Collecting All Infinity Stones",
  "Thanos.FirstKillAlwaysSoulStone": "The First Infinity Stone is Always The Soul Stone",
  "Thanos.MindStoneUsed": "<size=80%><#00ff00>Mind Stone Active</color>",
  "Thanos.PowerStoneKillsIgnoreShields": "Kills With The Power Stone Ignore Shields",
  "Thanos.PowerStoneReducesKillCooldownBy": "Power Stone Kill Cooldown Reduction",
  "Thanos.Stone.Mind": "Mind",
  "Thanos.Stone.Power": "Power",
  "Thanos.Stone.Reality": "Reality",
  "Thanos.Stone.Soul": "Soul",
  "Thanos.Stone.Space": "Space",
  "Thanos.Stone.Time": "Time",
  "Thanos.StoneWaitingForUse": "<#00a5ff>{0}</color> to activate/switch to the <#00ffff>{1} Stone</color>",
  "Thanos.TimeStoneReducesSpeedBy": "Time Stone Reduces Speed By",
  "Thief": "Thief",
  "ThiefInfo": "Steal a Killing Role",
  "ThiefInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill to steal — become the role of whoever you murder.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Role Theft</color></b>\nKill someone to steal their role:\n\n<size=70%>・Impostor / Neutral Killing roles → become the same role\n・Trickster → become Double Agent\n・Maverick → become Serial Killer\n・Madmate roles → become Renegade\n・Coven roles (if enabled) → become Coven Member</size>\n\nKilling any other role causes you to suicide.\n\n<i>Identity is just one kill away.</i></size>",
  "Thief.CanKillRound1": "Can Kill on the First Round",
  "Thief.CanStealCovenRoles": "Can Steal <#7b3fbb>Coven</color> Roles",
  "Tiger": "Tiger",
  "TigerInfo": "Enrage to Kill Additional Players",
  "TigerInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Enrage to turn every kill into a double kill.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Enrage</color></b>\nSabotage or pet to become enraged. While enraged, killing someone also kills the closest player within a radius.\n\n<i>When the Tiger strikes, collateral damage is the point.</i></size>",
  "EnrageCooldown": "Enrage Cooldown",
  "EnrageDuration": "Enrage Duration",
  "TigerRadius": "Enrage Radius",
  "Traitor": "Traitor",
  "TraitorInfo": "Eliminate the <color=#ff1919>Impostors</color>, then win",
  "TraitorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>You know the Impostors — and you've already turned on them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Inside Knowledge</color></b>\nYou were an Impostor who switched sides. You know who the Impostors are, but they don't know you. They can kill you, but you cannot kill them.\n\nEliminate the Impostors by other means, then kill everyone else to win.\n\n<i>Betrayal runs in both directions.</i></size>",
  "TraitorKillImpostor": "As the Traitor, you cannot kill Impostors",
  "Tremor": "Tremor",
  "TremorInfo": "When Doom Happens, Everyone is Doomed",
  "TremorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill to delay doom — once it triggers, destroy everything in range or die trying.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Doom Timer</color></b>\nA countdown appears below your name. Each kill reduces the timer. When doom triggers, you kill everyone who comes near you. Kill everyone within the allotted time — or you suicide.\n\n<i>The countdown was always going to hit zero.</i></size>",
  "Tremor.DoomNotify": "Doom started! The Tremor now kills everyone that comes near them!",
  "Tremor.DoomTime": "Doom Time (= Time to Kill Everyone)",
  "Tremor.TimerDecrease": "When Killing, Timer Decreases by",
  "Tremor.TimerStart": "Time Until Doom Happens",
  "Tremor.SpeedDuringDoom": "<#e942f5>Tremor</color>'s Speed During Doom",
  "Tremor.VisionDuringDoom": "<#e942f5>Tremor</color>'s Vision During Doom",
  "Vector": "Vector",
  "VectorInfo": "Jump in, jump out, win!",
  "VectorInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Vent enough times to claim a solo victory.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Vent Rush</color></b>\nVent a set number of times (different per map) to win alone.\n\n<i>The vents are not a hiding place — they are the finish line.</i></size>",
  "Vector.NumVentsToWinOn.Airship": "Number of Vents to Win on <#ed0007>Airship</color>",
  "Vector.NumVentsToWinOn.Dleks": "Number of Vents to Win on <#66a186>dlekS ehT</color>",
  "Vector.NumVentsToWinOn.Fungle": "Number of Vents to Win on <#ffa646>The Fungle</color>",
  "Vector.NumVentsToWinOn.MiraHQ": "Number of Vents to Win on <#e84b56>MIRA HQ</color>",
  "Vector.NumVentsToWinOn.Polus": "Number of Vents to Win on <#a167c0>Polus</color>",
  "Vector.NumVentsToWinOn.Skeld": "Number of Vents to Win on <#66a186>The Skeld</color>",
  "VectorVentButtonText": "Hop",
  "Vengeance": "Vengeance",
  "VengeanceInfo": "Kill your killer to live",
  "VengeanceInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Survive every attempt on your life — and punish whoever dared to try.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Counter</color></b>\nWhen someone tries to kill you, the kill is blocked and you are teleported to a random vent. You have a limited time to kill your attacker. Succeed and you survive; fail and you die permanently. Killing anyone other than your attacker also kills you.\n\n[Win Condition]\n・<b><color=#ffab1b>Last Stand</color></b>\nBe the last one standing to win.\n\n<i>Every attack is a gift — if you're fast enough.</i></size>",
  "VengeanceRevenge": "You have {0}s to kill your killer",
  "VengeanceRevengeTime": "Time to Revenge",
  "VengeanceSuccess": "<color=#00ff00>Revenge successful! You live!</color>",
  "VengefulRomantic": "Vengeful Romantic",
  "VengefulRomanticInfo": "Kill the killer of your Partner",
  "VengefulRomanticInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>One shot, one target — avenge your partner or lose everything.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Avenge</color></b>\nKill your partner's killer. You have only one attempt. Kill the wrong player and you misfire. Kill the right target to win with the winning team alongside your Romantic Partner.\n\n<i>Love is the most dangerous motive.</i></size>",
  "VengefulRomanticKillButtonText": "Avenge",
  "Virus": "Virus",
  "VirusInfo": "Kill and infect everyone",
  "VirusInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Spread infection through the dead — build a team from the bodies.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Infection</color></b>\nWhen you kill a crewmate, their body is infected. The crewmate who reports the body joins the Virus team — or dies if the Virus is voted out. The Virus team wins by outnumbering the Crewmates.\n\n<i>The real threat was the teammates we infected along the way.</i></size>",
  "VirusCanVent": "Can Vent",
  "VirusInfectMax": "Maximum Number Of <color=#2E8B57>Spreads</color>",
  "VirusKillCooldown": "Kill Cooldown",
  "VirusKillInfectedPlayerAfterMeeting": "<color=#2E8B57>Contagious</color> player dies after meeting",
  "VirusKnowTargetRole": "Know <color=#2E8B57>Contagious</color> Player's Role",
  "VirusNoticeMessage": "The body you reported was infected by the Virus! You are now part of Team Virus. Help the Virus win the game.",
  "VirusNoticeMessage2": "The body you reported was infected by the Virus! Vote the Virus out this meeting or you will die.",
  "VirusTargetKnowOtherTarget": "<color=#2E8B57>Contagious</color> players know each other",
  "Vortex": "Vortex",
  "VortexInfo": "Your victims' bodies teleport to a random vent",
  "VortexInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Kill and watch the bodies vanish into the vents.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Vortex Kill</color></b>\nWhen you kill someone, their body teleports to a random vent where it can be reported.\n\n<i>Out of sight, but never quite out of mind.</i></size>",
  "Vortex.IfTargetCannotBeTeleported": "If the target cannot be teleported to a random vent",
  "Vortex.NoTPMode.Block": "Cancel Kill",
  "Vortex.NoTPMode.DoWithoutTP": "Kill Without TP",
  "Vulture": "Vulture",
  "VultureInfo": "Eat bodies by reporting to win",
  "VultureInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Report and consume corpses to pick your path to victory.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Consume</color></b>\nReport a body to eat it (making it unreportable) if the eat cooldown is up. If the cooldown is still active or the round limit is reached, report the body normally. Eat enough bodies to win.\n\n<i>Nothing goes to waste on a dead ship.</i></size>",
  "VultureArrowsPointingToDeadBody": "Arrows pointing to dead bodies",
  "VultureBodyReported": "Body eaten!",
  "VultureChangeRole": "Role to change to",
  "VultureChangeRoleWhenCantWin": "Change role when winning is impossible",
  "VultureEatButtonText": "Consume",
  "VultureMaxEatenInOneRound": "Maximum eaten bodies possible per round",
  "VultureNumberOfReportsToWin": "Bodies needed to win",
  "VultureReportCooldown": "Eat Cooldown",
  "WeaponMaster": "Weapon Master",
  "WeaponMasterInfo": "Use your weapons to kill everyone",
  "WeaponMasterInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Cycle between four weapons — each with a distinct killing style.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Weapon Cycle</color></b>\nPet or call a sabotage to switch weapons:\n\n<size=70%>・Sword: Standard kill\n・Axe: Kill hits everyone in a radius; higher cooldown\n・Lance: Maximum kill range, no lunge; cannot vent\n・Shield: Survive one attack; cannot kill while shielded</size>\n\n<i>A true master needs no favorite weapon.</i></size>",
  "Weatherman": "Weatherman",
  "WeathermanInfo": "Spawn Natural Disasters",
  "WeathermanInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Summon natural disasters and let chaos do the killing.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#ffab1b>Disaster</color></b>\nPet or vanish to spawn a random natural disaster (same pool as the Natural Disasters game mode). Use them to eliminate everyone.\n\n<i>When nature itself is your weapon, no one is safe.</i></size>",
  "Werewolf": "Werewolf",
  "WerewolfInfo": "Vent to Rampage to kill quickly",
  "WerewolfInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Vent to rampage — a brief window of brutal killing before the cooldown resets.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Rampage</color></b>\nEnter a vent to begin rampaging. While rampaging, kill cooldown is drastically reduced. Cannot kill outside of rampage. Rampaging has its own cooldown and limited duration.\n\n<i>The beast within can only be restrained for so long.</i></size>",
  "WWCD": "<color=#00ffa5>Cooldown:</color> <b>{0}</b>s",
  "WWCO.IfFinishedTasks": "If Finished Tasks",
  "WWCanRampage": "Vent to begin Rampaging",
  "WWCanRampageVanish": "Press Vanish to begin Rampaging",
  "WWRampageCD": "Rampage Cooldown",
  "WWRampageCDAfterNoKillRampage": "Rampage Cooldown After Rampaging Without Killing",
  "WWRampageCountdown": "<color=#00ffa5>Rampage ends in</color> <b>{0}</b>s",
  "WWRampageDur": "Rampage Duration",
  "WWRampageOut": "You're no longer Rampaging",
  "WWRampaging": "Rampaging",
  "Workaholic": "Workaholic",
  "WorkaholicInfo": "Finish all tasks to solo win!",
  "WorkaholicInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Finish your task list and claim a solo victory — no alliances required.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Win Condition]\n・<b><color=#ffab1b>Task Completion</color></b>\nComplete all your tasks to win alone. Depending on host settings, you may also win while dead.\n\n<i>Hard work is its own reward — especially when it wins the game.</i></size>",
  "WorkaholicAdviceAlive": "It's not recommended to kill or vote <b>{0}</b> out. Doing so will help them finish their tasks quicker.",
  "WorkaholicAliveTitle": "★[ Message about Workaholic ]★",
  "WorkaholicCannotWinAtDeath": "Can't win after they died",
  "WorkaholicGiveAdviceAlive": "Advice at first meeting if alive, can win after death, ghost tasks ON",
  "WorkaholicSpeed": "<color=#008b8b>Workaholic</color> Speed",
  "WorkaholicVisibleToEveryone": "Everyone knows who the <color=#008b8b>Workaholic</color> is",
  "Wraith": "Wraith",
  "WraithInfo": "Vent/Vanish to go invisible temporarily",
  "WraithInfoLong": "(<#ffab1b>Neutrals</color>):\n<size=80%>Turn invisible and strike from the shadows.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#ffab1b>Vanish</color></b>\nVent or press Vanish to become temporarily invisible. Kills are still possible while invisible.\n\n<i>The deadliest attacks come from nothing.</i></size>",
  "WraithCanVent": "Vent to turn invisible",
  "WraithCooldown": "Vanish Cooldown",
  "WraithDuration": "Vanish Duration",
  "WraithInvisCooldownRemain": "<color=#00ffa5>Cooldown:</color> <b>{0}</b>s",
  "WraithInvisInCooldown": "Ability still on cooldown, vanish failed",
  "WraithInvisState": "You are invisible",
  "WraithInvisStateCountdown": "<color=#00ffa5>Invisibility expires in</color> <b>{0}</b>s",
  "WraithInvisStateOut": "You are visible again",
  "WraithRevertVentButtonText": "Expose",
  "WraithVentButtonText": "Vanish",
  "WraithVentNormallyOnCooldown": "<color=#4b0082>Wraith</color> vents normally when invis is on cooldown",
  /* ==============================
    Roles (Coven)           
  ============================== */
  "Augur": "Augur",
  "AugurInfo": "Guess roles",
  "AugurInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Guess roles in meetings — misses don't kill you, just delay you.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Role Guess</color></b>\nGuess players' roles during meetings. A wrong guess doesn't kill you, but you cannot guess again until the next meeting. Cannot gain the Necronomicon.\n\n<i>The Augur reads what others cannot see.</i></size>",
  "Augur.IncorrectGuess": "<#ff0000>Incorrect!</color> You can't guess in this meeting anymore.",
  "Augur.MaxGuessesPerGame": "Max number of guesses per game",
  "Augur.MaxGuessesPerMeeting": "Max number of guesses per meeting",
  "Banshee": "Banshee",
  "BansheeInfo": "Deafen or kill with screech",
  "BansheeInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Screech to deafen the crew — and kill when empowered.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Screech</color></b>\nUse the vanish button to screech, deafening nearby players. Deafened players cannot hear or see the chat during the next meeting. With the Necronomicon, the screech becomes lethal.\n\n<i>The wail that ends in silence.</i></size>",
  "Banshee.Radius": "Screech Radius",
  "CovenLeader": "Coven Leader",
  "CovenLeaderInfo": "Lead the Coven & Kill",
  "CovenLeaderInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Lead the Coven — the only member who can kill, and the first to wield the Necronomicon.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Coven Kill</color></b>\nThe only Coven member who can directly kill. Always spawns when the Coven is enabled.\n\n・<b><color=#7b3fbb>Necronomicon</color></b>\nGain the Necronomicon first. When enhanced, kill cooldown is halved and kill distance is greatly extended.\n\n<i>Where the Coven Leader points, death follows.</i></size>",
  "CovenLeaderKillCooldown": "<color=#7b3fbb>Coven Leader</color>'s Kill Cooldown",
  "CovenMember": "Coven Member",
  "CovenMemberInfo": "Win with the Coven",
  "CovenMemberInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Your role is gone — but your loyalty to the Coven remains.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Passive]\n・<b><color=#7b3fbb>Loyal Member</color></b>\nYour original Coven role was lost. You win with the Coven but have no abilities, cannot kill, and cannot hold the Necronomicon. If the Coven Leader dies, you become the new Leader.\n\n<i>Even without power, the Coven stands together.</i></size>",
  "Death": "Death",
  "DeathInfo": "Kill with low cooldown",
  "DeathInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Unkillable, relentless, and always on cooldown.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Passive]\n・<b><color=#7b3fbb>Immortal</color></b>\nCannot be killed normally. Possesses a very short kill cooldown. Cannot receive Necronomicon enhancements.\n\n<i>Death cannot die.</i></size>",
  "Dreamweaver": "Dreamweaver",
  "DreamweaverInfo": "Drive players insane with weaving",
  "DreamweaverInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Weave madness into players — turn their own abilities against them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Weave</color></b>\nWeave a player; they become insane after the next meeting. Insane players automatically use their ability on anyone nearby if their cooldown is up. All insane players are freed upon your death. With the Necronomicon, insane players suicide on contact with another player.\n\n<i>The worst chains are the ones the mind forges itself.</i></size>",
  "Empress": "Empress",
  "EmpressInfo": "Empower the Necronomicon & Cast Spells",
  "EmpressInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Empower the Necronomicon and cast devastating spells on the crew.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#7b3fbb>Empower</color></b>\nVote yourself in a meeting to empower the Necronomicon. Next round, holders can kill twice before cooldown resets, but cooldown is doubled. Cannot empower 2 consecutive rounds.\n\n・<b><color=#7b3fbb>Spells</color></b>\nSingle-click kill button to cast the selected spell (double-click to kill normally after gaining the Necronomicon):\n\n<size=70%>・Frost Gaze: Freezes the target; if not interacted with in time, they die instantly\n・Encourage: A Coven member gains 1.25× speed and 25% reduced ability cooldown for the round</size>\n\nVanish to switch spells. Pet to briefly conceal yourself and nearby Coven members.\n\n<i>An Empress does not simply rule — she reshapes the battlefield.</i></size>",
  "Empress.CoverageDelay": "Coverage Delay",
  "Empress.CoverageDuration": "Coverage Duration",
  "Empress.CoverageRange": "Coverage Range",
  "Empress.EmpowerFailWeakenedMessage": "<#ff5555>X <#bb0000>The <#7b3fbb>Necronomicon</color> cannot be empowered in 2 consecutive rounds!</color>",
  "Empress.EmpowerSuccessMessage": "<#00ff00>✓ <#00ffa5>Successfully empowered the <#7b3fbb>Necronomicon</color>!</color>",
  "Empress.FrostGazeDelay": "Frost Gaze Delay",
  "Empress.FrostGazeDuration": "Frost Gaze Duration",
  "Enchanter": "Enchanter",
  "EnchanterInfo": "Alter investigations; kill with Necronomicon",
  "EnchanterInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Corrupt investigations — make your targets look like Coven to the crew.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Enchant</color></b>\nEnchant a player to make them appear as a Coven member to investigating crewmates. Enchanted players who die show a random death cause. With the Necronomicon, double-click the kill button to kill directly.\n\n<i>Suspicion is a weapon — if you choose its direction.</i></size>",
  "Goddess": "Goddess",
  "Goddess.Suffix": "<{1}>Stone Gazing</color> <#888888>-</color> <b>{0}</b>",
  "GoddessInfo": "Stone gaze kills and stuns",
  "GoddessInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Turn attackers to stone — bodies that cannot be reported.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Stone Gaze</color></b>\nUse the vanish button to activate stone gaze. Anyone who interacts with you dies and their body is stoned — unreportable. With the Necronomicon, kill directly; victims are still stoned.\n\n<i>To meet the Goddess's gaze is to become part of the scenery.</i></size>",
  "Illusionist": "Illusionist",
  "IllusionistInfo": "Morph players, kill sampled targets",
  "IllusionistInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Sample one player, then disguise another as them to sow confusion.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Morph</color></b>\nSample a player, then shapeshift into another to morph them into the sampled player's appearance. With the Necronomicon, double-click the kill button on the sampled player to eliminate them.\n\n<i>Confusion is the most effective disguise.</i></size>",
  "Illusionist.ShapeshiftAnimation": "Show Shapeshift Animation",
  "Illusionist.UnmorphPrevious": "Unmorph previous target if a new one is chosen",
  "MoonDancer": "Moon Dancer",
  "MoonDancerInfo": "Give and Steal Add-ons",
  "MoonDancerInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Distribute and steal add-ons to manipulate every player's power.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#7b3fbb>Self-Assign</color></b>\nVanish to grant yourself a random add-on.\n\n・<b><color=#7b3fbb>Give / Steal</color></b>\nSingle-click kill button: give an add-on (helpful for Coven, harmful for others — takes effect after the next meeting). Double-click: steal all add-ons from the target (if settings allow).\n\nWith the Necronomicon, double-clicking kills and steals all add-ons simultaneously.\n\n<i>Every gift is a trap; every theft is a gift.</i></size>",
  "MoonDancer.CanStealAddonsWithoutNecronomicon": "Can Steal Add-ons Without Necronomicon",
  "MoonDancer.OthersAssignAddonCooldown": "Cooldown for Assigning Add-ons to Others",
  "MoonDancer.SelfAssignAddonCooldown": "Self-Assign Add-on Cooldown",
  "MoonDancer.StealAddonCooldown": "Add-on Stealing Cooldown",
  "MoonDancer.StealAllAddonsOnKill": "Steal All Add-ons On Kill",
  "Poache": "Poache",
  "PoacheInfo": "Poison kills with delay or disables votes",
  "PoacheInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Poison silently — block votes or escalate to a lethal dose.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Poison</color></b>\nPoison a player; they cannot vote in the next meeting and are unaware they have been poisoned. With the Necronomicon, poisoned players die after a configurable delay.\n\n<i>The most elegant toxins are the ones never tasted.</i></size>",
  "Poache.KillDelay": "Poison Kill Delay",
  "PotionMaster": "Potion Master",
  "PotionMasterInfo": "Use potions to support the Coven",
  "PotionMasterInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Shield allies and expose enemies — or kill them outright.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Potion</color></b>\nApply a potion: shields Coven members with a medic shield; reveals non-Coven members' roles to all Coven. With the Necronomicon, potions kill non-Coven members instead of revealing them.\n\n<i>The right potion for the right patient.</i></size>",
  "PotionMaster.ShieldDuration": "Shield Duration",
  "PotionMaster.Suffix": "<{1}>Shielded</color> <#888888>-</color> <b>{0}</b>",
  "Reaper": "Reaper",
  "ReaperInfo": "Curse, collect souls, become Death",
  "ReaperInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Collect souls from cursed players to transform into Death itself.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Curse</color></b>\nCurse a player; when they die, you gain a soul. Reach the required number of souls (or be the last killer alive) to transform into Death. Cannot receive Necronomicon enhancements.\n\n<i>Every death is a deposit.</i></size>",
  "Reaper.SoulsRequired": "Number of Souls required to transform into Death",
  "Siren": "Siren",
  "SirenInfo": "Sing to convert with stages",
  "SirenInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Sing to progressively enchant players — convert them to the Coven with three hearings.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#7b3fbb>Sing</color></b>\nUse the Vanish button to sing. Each hearing advances nearby players through three stages:\n\n<size=70%>・Stage 1: Blinded and slowed briefly\n・Stage 2: Blinded, slowed, and cannot report bodies temporarily\n・Stage 3 (Entranced): Converted to the Coven</size>\n\nWith the Necronomicon, you can kill normally and singing is boosted two stages (0 hearings → treated as 2; 1 hearing → Entranced). A tracker near each player's name shows their current stage.\n\n<i>Every song has a final verse.</i></size>",
  "Siren.CovenCanKillEntranced": "<#7b3fbb>Coven</color> Members can kill <#7b3fbb>Entranced</color> players",
  "Siren.CovenKnowEntranced": "Who sees <#7b3fbb>Entranced</color> players",
  "Siren.EntrancedCanKillCoven": "<#7b3fbb>Entranced</color> players can kill <#7b3fbb>Coven</color> Members",
  "Siren.EntrancedCountMode": "<#7b3fbb>Entranced</color> players count as",
  "Siren.EntrancedKnowCoven": "<#7b3fbb>Entranced</color> players see",
  "Siren.EntrancedKnowEntranced": "<#7b3fbb>Entranced</color> players know each other",
  "Siren.ReducedSpeed": "Reduced Speed",
  "Siren.ReducedVision": "Reduced Vision",
  "Siren.SingRange": "Sing Affect Range",
  "Siren.Stage1EffectsLength": "Length of Stage 1 Effects",
  "Siren.Stage2EffectsLength": "Length of Stage 2 Effects",
  "SpellCaster": "Spellcaster",
  "SpellCasterInfo": "Hex all players to win",
  "SpellCasterInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Hex every last player to trigger a Coven victory.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Win Condition]\n・<b><color=#7b3fbb>Hex</color></b>\nHex players one by one. When all are hexed, the Coven wins after the next meeting if any Spellcasters survive. Other players are warned when more than half the living are hexed — you appear hexed too. With the Necronomicon, hexed players are also spelled (like the Witch).\n\n<i>Every name on the list will be crossed off.</i></size>",
  "SpellCaster.WinConditionMet": "The Coven will win after this meeting if the {0} is still alive.",
  "Summoner": "Summoner",
  "SummonerInfo": "Summon Players to Kill For You",
  "SummonerInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Resurrect the dead to kill for you — a killer on a timer.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#7b3fbb>Summon</color></b>\nType <b>/cmd summon {ID}</b> or use the kick menu to revive a dead player after the meeting. They have limited time to kill for you. Success lets them win alongside you and their original team; failure returns them to death.\n\nWith the Necronomicon, you also gain a direct kill button.\n\n<size=70%>Use <b>/cmd id</b> to see player IDs, or check the meeting screen. Example: <b>/cmd summon 5</b></size>\n\n<i>The dead make such obedient soldiers.</i></size>",
  "Summoner.SummonedTimeToKill": "Time To Kill For Summoned Players",
  "Summoner.SummonDelayAfterMeeting": "Summon Delay After Meetings",
  "Summoner.SummonedKillCooldown": "Summoned Player's Kill Cooldown",
  "Summoner.SummonedKnowsCoven": "Summoned Players Know Coven Members",
  "Summoner.PlayersSeeSummonedPlayerWarning": "Players See Who The Summoned Player Is",
  "Summoner.AllowSummoningTheSamePlayerTwice": "Allow Summoning The Same Player Twice",
  "Summoner.ReSummonTakesAbilityUse": "Re-Summoning Takes Ability Use",
  "Summoner.SummonedKillsCountForSummoner": "Players who were killed by Summoned Players have the <#7b3fbb>Summoner</color> as their Real Killer",
  "Summoner.BlockMeetingsWhileSummonedPlayerAlive": "Block Meetings While a Summoned Player Is Alive",
  "Summoner.SomeoneWillBeRevivedMessage": "Someone from the dead has been chosen to kill for the Coven.",
  "Summoner.SelfSuffix": "<size=80%>{0} has {1}s to kill</size>",
  "Summoner.SummonedPlayerSuffix": "<size=120%><#ffff00>{0}, the {1} summoned you to kill for them!\\nYou have</color> {2}s</size>",
  "Summoner.SummonedWarningSuffix": "Summoned to kill for the Coven",
  "Summoner.SummonSuccessMessage": "<#00ff00>✓ <#00bb00>{0} will be summoned after the meeting to kill for you",
  "Summoner.CantSummonSamePlayerTwice": "<#ff5555>X <#bb0000>The same player cannot be summoned twice",
  "SummonerCantKillCoven": "As a summoned player, you kill for the Coven, meaning you can't kill Coven members",
  "SummonedPlayerAlive": "Meetings can't be started while a summoned player is alive",
  "Timelord": "Timelord",
  "TimelordInfo": "Refresh or reset cooldowns; kill",
  "TimelordInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Control cooldowns — accelerate allies and sabotage enemies.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Time Control</color></b>\nUse your ability on a Coven member to instantly refresh their cooldown. Use on a non-Coven member to reset (maximize) theirs. With the Necronomicon, also gain a kill button and reduce meeting time with each kill.\n\n<i>Time is the only currency that matters.</i></size>",
  "Timelord.TimeStolenWithEachKill": "Time stolen with each kill",
  "VoodooMaster": "Voodoo Master",
  "VoodooMasterInfo": "Redirect abilities, kill with Necronomicon",
  "VoodooMasterInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Force players to use their own abilities against themselves.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#7b3fbb>Voodoo</color></b>\nForce a player to use their own ability on themselves or generally (e.g., Tornado, Camouflager). With the Necronomicon, also kill the target.\n\n<i>The cruelest trick is making someone their own worst enemy.</i></size>",
  "Wyrd": "Wyrd",
  "WyrdInfo": "Mark players; doom triggers on action.",
  "WyrdInfoLong": "(<#7b3fbb>Coven</color>):\n<size=80%>Mark players with a shared countdown — doom them with their own actions.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#7b3fbb>Fate Mark</color></b>\nShapeshift into a player to mark them with Fate's Countdown. All marked players share a hidden countdown that starts on the first mark. When it expires, any marked player who completes a task, reports a body, or presses the meeting button dies instantly.\n\nUp to a set number of players can be marked at once. Two or more marked players can see the countdown. A small bonus is added to the countdown per additional mark. The countdown pauses during meetings.\n\nWith the Necronomicon, kill directly with the kill button.\n\n<i>They never know which action will be their last.</i></size>",
  "Wyrd.BlockMeetingOnDeath": "Block Meeting If The Marked Player Died due to the above settings",
  "Wyrd.CountdownTime": "Countdown Time",
  "Wyrd.MarkedDiesOnButton": "Button Pressing Causes Death",
  "Wyrd.MarkedDiesOnReport": "Body Reporting Causes Death",
  "Wyrd.MarkedDiesOnTask": "Task Completion Causes Death",
  "Wyrd.MaxMarkedPlayersAtOnce": "Max Marked Players At Once",
  "Wyrd.Suffix.FateCountdown": "Fate Countdown: {0}s",
  "Wyrd.Suffix.SuicideWarningOnAction.Button": "Calling an emergency meeting",
  "Wyrd.Suffix.SuicideWarningOnAction.Report": "Reporting a dead body",
  "Wyrd.Suffix.SuicideWarningOnAction.Task": "Completing a task",
  "Wyrd.Suffix.SuicideWarnings": "<#ffff00><size=80%>⚠ The following actions will cause you to suicide: ⚠\\n{0}</size></color>",
  "Wyrd.TimeAdditionOnMoreMark": "Time Addition On More Marks",
  /* ==============================
    Roles (Add-ons)
  ============================== */
  "Absorber": "Absorber",
  "AbsorberInfo": "Report bodies to absorb Ability Uses",
  "AbsorberInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Report a dead body to absorb up to 1 ability use from the deceased.</size>",
  "Aide": "Aide",
  "AideInfo": "You Can't Sabotage",
  "AideInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot sabotage.</size>",
  "Allergic": "Allergic",
  "AllergicInfo": "You're Allergic to Someone",
  "AllergicInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=75%>As an Allergic, you are allergic to a random player in the game.\nWhen you go near that player, your allergy level starts to rise.\nIf it reaches 100%, you die.\nYou must always stay away from the player you're allergic to.</size>",
  "Allergic.Range": "Maximum distance from the target that is considered nearby",
  "Allergic.Suffix": "<#ffff44><size=80%>Allergy Level:</color> {0}%</size>",
  "Allergic.Time": "Time in which the allergy level goes from 0% to 100%",
  "Amanojaku": "Amanojaku",
  "AmanojakuInfo": "Conditional add-win after a chosen day",
  "AmanojakuInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>From the chosen day onward, you also win when one of the selected non-Crewmate teams wins. Crewmate victories never grant you a win.</size>",
  "AmanojakuActivationDay": "Activation Day",
  "AmanojakuMustSurvive": "Must Be Alive To Win",
  "AmanojakuWinIfImpostor": "Win With <color=#ff1919>Impostors</color>",
  "AmanojakuWinIfNeutral": "Win With <color=#ffab1b>Neutrals</color>",
  "AmanojakuWinIfCoven": "Win With <color=#7b3fbb>Coven</color>",
  "Anchor": "Anchor",
  "AnchorInfo": "You Can't Get Ghost Roles",
  "AnchorInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot be assigned any ghost roles.</size>",
  "AntiTP": "Anti-TP",
  "AntiTPInfo": "You can't be teleported",
  "AntiTPInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot be teleported.</size>",
  "Antidote": "Antidote",
  "AntidoteInfo": "Decrease your killer's cooldown",
  "AntidoteInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When someone tries to use the kill button on you, their cooldown is decreased by a configurable amount.</size>",
  "AntidoteCDOpt": "Decrease the cooldown by",
  "AntidoteCDReset": "Cooldown returns to normal after a meeting",
  "Asthmatic": "Signal",
  "AsthmaticInfo": "You're Playing Stop And Go",
  "AsthmaticInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=75%>You're forced into a <#00ffa5>Stop and Go</color> pattern.\nA symbol with a <#ff0000>red</color> or <#008000>green</color> timer is always shown below your name.\nWhile the signal is <#ff0000>red</color>, you cannot move.\nThe timer counts down to the next color change.</size>",
  "AsthmaticMaxGreenTime": "Maximum Green Time",
  "AsthmaticMaxRedTime": "Maximum Red Time",
  "AsthmaticMinGreenTime": "Minimum Green Time",
  "AsthmaticMinRedTime": "Minimum Red Time",
  "Autopsy": "Autopsy",
  "AutopsyInfo": "You see how others died",
  "AutopsyInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You can see how other players died.\n_____________________________________\nCannot be assigned to Doctor, Tracefinder, Scientist, or Sunnyboy.</size>",
  "Avenger": "Avenger",
  "AvengerInfo": "You take someone with you upon death",
  "AvengerInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you die, a random player is also killed as revenge.</size>",
  "Bait": "Baiting",
  "BaitInfo": "Your killer self-reports your body",
  "BaitInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When a Baiting is killed, the murderer must self-report the body, except when killed by a <#ff1919>Scavenger</color> or <#ff1919>Cleaner</color>.\nThe report can be delayed based on the host's settings.</size>",
  "BaitAdviceAlive": "<b>{0}</b> is the Bait. Whoever kills the Bait will commit self report.",
  "BaitDelayMax": "Maximum Report Delay",
  "BaitDelayMin": "Minimum Report Delay",
  "BaitDelayNotify": "<color=#ffff00>Warn the killer about the upcoming self-report</color>",
  "BaitNotification": "Reveal <color=#00f7ff>Bait</color> at the first meeting",
  "BananaMan": "Bananie",
  "BananaManInfo": "You're the Banana Man",
  "BananaManInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>As a Bananie, you are a banana.</size>",
  "Beartrap": "Beartrap",
  "BeartrapInfo": "Freeze your killer for a few seconds",
  "BeartrapInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When a Beartrap is killed, the murderer is immobilized for a configurable amount of time.</size>",
  "BeartrapBlockMoveTime": "Freeze time",
  "Bewilder": "VisionLeak",
  "BewilderInfo": "Your killer gets your vision",
  "BewilderInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you are killed, your (reduced) vision is transferred to your killer for the rest of the game.</size>",
  "BewilderVision": "<color=#c894f5>VisionLeak</color> Vision",
  "Blessed": "Blessed",
  "BlessedInfo": "Shielded Temporarily After Meetings",
  "BlessedInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>After every meeting and at the start of the game, you receive a temporary shield for a set number of seconds.</size>",
  "Blessed.MinLivingPlayersToActivateShield": "Minimum Living Players for the Shield to Activate",
  "Blind": "Blind",
  "BlindInfo": "You Can't See Arrows",
  "BlindInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot see any arrows pointing to dead bodies or players.</size>",
  "BlindTime": "Blind Time",
  "Blocked": "Blocked",
  "BlockedInfo": "You Can't Move Between Vents",
  "BlockedInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot move between vents.\nYou can still enter and exit the same vent.</size>",
  "Bloodlust": "Bloodlust",
  "BloodlustInfo": "You can kill",
  "BloodlustInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>You gain the ability to kill while keeping your original role's abilities. Single-click the kill button to use your role ability; double-click to kill normally.</size>",
  "Busy": "Busy",
  "BusyInfo": "You have more tasks",
  "BusyInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You have more tasks than usual.</size>",
  "BusyLongTasks": "Amount of Extra Long Tasks",
  "BusyShortTasks": "Amount of Extra Short Tasks",
  "Charmed": "Charmed",
  "CharmedInfo": "You've been Charmed by the Succubus",
  "CharmedInfoLong": "(<#ff1919>Betrayal</color> <#ff9ace>Add-on</color>):\n<size=80%>You were charmed by the Succubus and are now on their team, no longer on your original team.</size>",
  "Charmed-": "Charmed ",
  "CharmedByCultist": "You have been charmed by the Succubus",
  "CharmedCountMode": "<color=#cf6acd>Charmed</color> players count as",
  "CharmedCountMode.Cultist": "<color=#cf6acd>Succubus</color>",
  "CharmedCountMode.None": "Nothing",
  "CharmedCountMode.Original": "Original Team",
  "CharmedDiesOnCultistDeath": "<color=#cf6acd>Charmed</color> Players Die When <#cf6acd>Succubus</color> Dies",
  "Circumvent": "Circumvent",
  "CircumventInfo": "You can't vent",
  "CircumventInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You cannot use vents, or can only use them a limited number of times per game or round.</size>",
  "Cleansed": "Cleansed",
  "Cleansed-": "Cleansed ",
  "CleansedInfo": "Your add-ons were cleansed",
  "CleansedInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>All your add-ons were erased by the Cleanser. Depending on settings, you may not be able to obtain new add-ons in the future.</size>",
  "CleansedCanGetAddon": "Cleansed player can get Add-on",
  "Clumsy": "Klutz",
  "ClumsyInfo": "You trip while walking",
  "ClumsyInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>While walking, there is a small chance you trip and freeze for a few seconds.</size>",
  "Commited": "Commited",
  "CommitedInfo": "Vote Equivalently for Low Cooldown",
  "CommitedInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>At the start of every meeting you receive a random target, marked with ⌆ next to their name. Vote the same player as your target to reduce your kill cooldown. Skips may be ignored based on settings.</size>",
  "Commited.IgnoreSkips": "Ignore Skips",
  "Commited.PermanentReduction": "Cooldown Reduction is Permanent",
  "Commited.Reduction": "Cooldown is Reduced by",
  "Compelled": "Compelled",
  "CompelledInfo": "Must Vote Or Suicide",
  "CompelledInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You must vote in every meeting, or you suicide.</size>",
  "Composter": "Composter",
  "ComposterInfo": "You Gain More Ability Uses",
  "ComposterInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Gain bonus ability uses — multiplied per task completed, kill made, or upon finishing all tasks.</size>",
  "Composter.AbilityUseGainMultiplier": "Ability Use Gain Multiplier",
  "Concealer": "Concealer",
  "ConcealerInfo": "Your Kills are Anonymous",
  "ConcealerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Each body you create is camouflaged — your kills are anonymous.</size>",
  "Connecting": "Connecting",
  "ConnectingInfo": "Recognize fellow Connecting players",
  "ConnectingInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You can see each other's roles and a Ψ mark next to fellow Connecting players. Dead players also see them.</size>",
  "Constricted": "Constricted",
  "ConstrictedInfo": "You have a shorter kill range",
  "ConstrictedInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Killer-only add-on. Your kill range is set to the shortest possible in the game.</size>",
  "Contagious": "Contagious",
  "ContagiousInfo": " You've been Infected by the Virus",
  "ContagiousInfoLong": "(<#ff1919>Betrayal</color> <#ff9ace>Add-on</color>):\n<size=80%>You were infected by the Virus and are now on the Virus team. Whether you die after a meeting depends on the host's Virus settings.</size>",
  "Contagious-": "Contagious ",
  "ContagiousCountMode": "<color=#2E8B57>Contagious</color> players count as",
  "ContagiousCountMode.None": "Nothing",
  "ContagiousCountMode.Original": "Original Team",
  "ContagiousCountMode.Virus": "<color=#2E8B57>Virus</color>",
  "ContagiousPlayers": "Contagious players cannot kill each other",
  "ContagiousPlayersCanKillEachOther": "<color=#2E8B57>Contagious</color> players can kill each other",
  "Damocles": "Damocles",
  "DamoclesInfo": "Impostor lifespan countdown",
  "DamoclesInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. A countdown runs next to your role name. If it expires, you die. The timer pauses during meetings.\n_____________________________________\n<size=75%>[<color=#00ff00><b>+</b></color>] You or an ally kills · Enter a new vent this round · Survive a meeting · Non-ally ejected\n[<color=#ff0000><b>-</b></color>] Fix a sabotage · Ally dies · Report a body or call a meeting · Ally ejected</size></size>",
  "DamoclesExtraTimeAfterKill": "Time Gained For Killing",
  "DamoclesExtraTimeAfterMeeting": "Time Gained After Each Meeting",
  "DamoclesStartingTime": "Starting Time",
  "DamoclesTimeLeft": "<color=#00ffa5>Time:</color> <color=#ffffff><b>{0}</b>s</color>",
  "Deadlined": "Deadline",
  "DeadlinedInfo": "Must do a task or use the kill button each round",
  "DeadlinedInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=75%>As a Deadline, you must complete a task or use your kill button (not necessarily for direct killing) on someone each round.\nIf you fail to do so, you will die.\nIf a meeting is called too soon after the previous one ends (timing set by the host), you won't die.\nThis doesn't apply on the first round.</size>",
  "Deadlined.InactiveTime": "Safe Time After Meetings",
  "Deadlined.MustDoTask": "<size=80%><#ffa500>You must complete a task or kill before the next meeting</color></size>",
  "Deadlined.SafeTime": "<size=80%><#00ffa5>Safe time:</color> <b>{0}</b>s</size>",
  "DeadlyQuota": "Deadly Quota",
  "DeadlyQuotaInfo": "You don't win if you didn't kill enough",
  "DeadlyQuotaInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You must reach a specified kill quota to be eligible to win. Even if your win condition triggers, you lose if the quota isn't met.</size>",
  "Disco": "Disco",
  "DiscoInfo": "You continuously change colors",
  "DiscoInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Your skin color changes every few seconds.</size>",
  "DiscoChangeInterval": "Disco Change Color Interval",
  "Diseased": "Diseased",
  "DiseasedInfo": "Increase your killer's cooldown",
  "DiseasedInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When someone tries to use the kill button on you, their cooldown is increased by a configurable amount.</size>",
  "DiseasedCDOpt": "Increase the cooldown by",
  "DiseasedCDReset": "Cooldown returns to normal after a meeting",
  "Disregarded": "Disregarded",
  "DisregardedInfo": "Your body can't be reported",
  "DisregardedInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your corpse cannot be reported by anyone.</size>",
  "DoubleShot": "Double Shot",
  "DoubleShotInfo": "You have an extra life when guessing",
  "DoubleShotInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>When you misguess in a meeting, you get a second chance. A second wrong guess causes you to suicide.</size>",
  "DoubleShot.MaxTries": "Maximum Number of Incorrect Guesses",
  "Dynamo": "Dynamo",
  "DynamoInfo": "You get faster by walking",
  "DynamoInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You move faster the longer you walk continuously. Stopping resets your speed.</size>",
  "DynamoSuffix": "Dynamo: {0}% Charge",
  "Egoist": "Egoist",
  "EgoistInfo": "Win on your own",
  "EgoistInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You must eject all other Impostors and stay alive to win. If the Impostor team wins while any non-Egoist Impostor is still alive, you lose.</size>",
  "EgoistCountMode.Neutral": "Neutral",
  "EgoistCountMode.Original": "Original",
  "Elector": "Elector",
  "ElectorInfo": "Cannot skip vote",
  "ElectorInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You are forced to vote for someone in every meeting. Skip-vote is rejected.</size>",
  "ElectorCancelMessage": "Electors cannot skip the vote.",
  "Energetic": "Adept",
  "EnergeticInfo": "Your Ability Cooldown is Lower",
  "EnergeticInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your ability cooldown is reduced by 25%.</size>",
  "Entranced": "Entranced",
  "EntrancedInfo": "You're on the Coven team",
  "EntrancedInfoLong": "(<#7b3fbb>Betrayal</color> <#ff9ace>Add-on</color>):\n<size=80%>You were entranced by the Siren and are now on the Coven team. Win with them at the end.</size>",
  "Entranced-": "Entranced ",
  "EntrancedKillCoven": "As an Entranced player, you cannot kill Coven members",
  "EvilSpirit": "Evil Spirit",
  "EvilSpiritInfo": "You are an evil Spirit",
  "EvilSpiritInfoLong": "(<#ffab1b>Evil Spirit</color> <#ff9ace>Add-on</color>):\n<size=80%>You were killed by the Spiritcaller and became an Evil Spirit. Use your Haunt button to freeze players and reduce their vision, or to grant the Spiritcaller a temporary shield against a kill attempt.</size>",
  "Faction": "Faction",
  "FactionInfo": "Neutral allies who win together",
  "FactionInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Neutrals-only add-on. Faction members see each other and a δ mark, and they ride along with each other's wins.</size>",
  "Finder": "Finder",
  "FinderInfo": "Grants Access to Tracking Players",
  "FinderInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Grants crewmate roles the ability to track other players.</size>",
  "Flash": "Sprinter",
  "FlashInfo": "You're faster",
  "FlashInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>As a Sprinter, you move faster than usual.</size>",
  "FlashSpeed": "<color=#ff8400>Sprinter</color> Speed",
  "Fool": "Clumsy",
  "FoolInfo": "You can't fix lights & comms",
  "FoolInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot fix Lights or Comms sabotages.\n_____________________________________\nThe <#ff1919>Technician</color> role is never assigned this add-on.</size>",
  "Fragile": "Fragile",
  "FragileInfo": "Everything Kills You",
  "FragileInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>If anyone presses their kill button on you, you die — even when the ability isn't meant to be lethal.</size>",
  "Giant": "Sluggish",
  "GiantInfo": "You're slower",
  "GiantInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>As a Sluggish, you move slower than usual.</size>",
  "GiantSpeed": "<color=#32a852>Sluggish</color> Speed",
  "Glow": "Glow",
  "GlowInfo": "You glow in the dark",
  "GlowInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>During a lights sabotage, your name is colored — making you visible in the dark.</size>",
  "GlowVision": "<color=#E2F147>Glow</color> Vision",
  "Gravestone": "Gravestone",
  "GravestoneInfo": "Your role is revealed when you die",
  "GravestoneInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you die, your role is revealed to everyone.</size>",
  "Guesser": "Guesser",
  "GuesserInfo": "Guess roles of players in meetings to kill",
  "GuesserInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Guess a player's role in meetings to kill them. Guessing wrong kills you instead.\n_____________________________________\nCommand: <b>/cmd bt [player id] [role]</b>\nUse <b>/cmd id</b> to see all player IDs.</size>",
  "GuesserCanGuessTimes": "Maximum number of guesses",
  "GuesserDoesntDieOnMisguess": "Guesser Doesn't Die on Misguess",
  "GuesserMaxKillsPerGame": "Max Kills Per Game",
  "GuesserMaxKillsPerMeeting": "Max Kills Per Meeting",
  "GuesserMode": "Guesser Mode",
  "GuesserNumRestrictions": "Restrict the Number of Guessers on Each Team",
  "GuesserSuicides": "Guessers Suicide When Trying to Guess Players With <#BAAAE9>Bound</color>",
  "GuessersKeepTheGameGoing": "Crewmate Guessers Keep The Game Going",
  "Haste": "Haste",
  "HasteInfo": "Your kill cooldown progresses while in vents",
  "HasteInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your kill cooldown ticks down at all times — even while in vents or standing still.</size>",
  "Hidden": "Hidden",
  "HiddenInfo": "Your Body Is Anonymous",
  "HiddenInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Your body is anonymous when reported — no name shown.</size>",
  "InfoPoor": "Info Poor",
  "InfoPoorInfo": "Cannot use info devices",
  "InfoPoorInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot use Admin, Cameras, Vitals, or DoorLog. Note: only takes effect for the host player due to the host-only architecture.</size>",
  "Insane": "Insane",
  "InsaneInfo": "You're insane",
  "InsaneInfoLong": "(<#7b3fbb>Coven Member</color> <#ff9ace>Add-on</color>):\n<size=75%>Insane players were woven by the <#7b3fbb>Dreamweaver</color>.\nWhen your cooldown ends, you are forced to use your ability on any player you touch.\nIf the <#7b3fbb>Dreamweaver</color> dies, you lose this add-on.</size>",
  "Introvert": "Introvert",
  "IntrovertInfo": "You Don't Like Being Near Players",
  "IntrovertInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>As an Introvert, if you stay near other players for too long, you teleport away to a random vent.</size>",
  "Introvert.Radius": "Radius in which players are considered nearby",
  "Introvert.Suffix": "<size=70%><#888888>Teleporting away in </color>{0}s</size>",
  "Introvert.Time": "Time to be near players before teleporting",
  "Knighted": "Knighted",
  "KnightedInfo": "You have an extra vote (from the Monarch)",
  "KnightedInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Granted by the Monarch. You receive an extra vote in meetings.</size>",
  "KnightedByMonarch": "You have been knighted by a Monarch!",
  "LastImpostor": "Last Impostor",
  "LastImpostorInfo": "Lower kill cooldown",
  "LastImpostorInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your kill cooldown is reduced.</size>",
  "LastNeutral": "Last Neutral",
  "LastNeutralInfo": "Granted to the last surviving Neutral",
  "LastNeutralInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When only one Neutral remains alive, they receive this add-on. Their kill cooldown is overridden and, optionally, they win as long as they're alive (Opportunist-style).</size>",
  "LastNeutralKillCooldown": "Kill Cooldown",
  "LastNeutralGiveOpportunist": "Wins If Alive At Game End",
  "Lazy": "Lazy",
  "LazyInfo": "You're too lazy",
  "LazyInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When a meeting is called, you stay exactly where you ended the previous round instead of walking to the table. Also immune to Warlocks, Puppeteers, and Gangsters.</size>",
  "Listener": "Listener",
  "ListenerInfo": "Listen to Whispers",
  "ListenerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You have a chance to eavesdrop on whispered messages. You may hear the full message, or just learn who whispered to whom.</size>",
  "Listener.FromTo": "{0}\\n{1} whispers to {2}",
  "Listener.FullMessage": "{0}\\n{1} whispers to {2}:\\n{3}",
  "Listener.FullMessageHearChance": "Full Message Hear Chance",
  "Listener.WhisperHearChance": "Whisper Hear Chance",
  "Looter": "Looter",
  "LooterInfo": "Loot Players' Add-ons",
  "LooterInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you report a body, you steal all add-ons from the deceased.</size>",
  "Lovers": "Lovers",
  "LoversInfo": "Stay alive and win together",
  "LoversInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Lovers win together and may die together. A ♥ appears next to each other's name. If one wins at the end, the other wins too. If one is exiled or killed, the other may follow based on settings.</size>",
  "LoverDieConsequence": "Consequence for Second <color=#ff9ace>Lover</color>, When First One Dies",
  "LoverKnowRoles": "<color=#ff9ace>Lovers</color> know the roles of each other",
  "LoverSpawnChances": "Spawn Chance of <color=#ff9ace>Lovers</color>",
  "LoverSuicideTime": "Suicide When",
  "LoversChatCannotTalkMsg": "This is a chat for <color=#ff9ace>Lovers</color> only!",
  "LoversChatCannotTalkTitle": "<#ffff00>⚠ ➡</color> <#ff0000>YOU CANNOT TALK HERE</color> <#ffff00>⬅ ⚠</color>",
  "Loyal": "Loyal",
  "LoyalInfo": "You cannot be recruited",
  "LoyalInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot be recruited by roles such as Jackal or Succubus.\n_____________________________________\nCannot be assigned to Neutrals.</size>",
  "Lucky": "Lucky",
  "LuckyInfo": "Dodge attackers",
  "LuckyInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>A configurable chance to evade a kill attempt. When triggered, the killer sees a shield animation but you receive no notification.</size>",
  "LuckyProbability": "Probability of surviving a kill",
  "MagicHand": "Magic Hand",
  "MagicHandInfo": "Fixed kill distance",
  "MagicHandInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Killer-only add-on. Your kill distance is locked to a configured value, ignoring the host's normal setting.</size>",
  "MagicHandKillDistance": "Kill Distance",
  "Magnet": "Magnet",
  "MagnetInfo": "Pull your victims to you",
  "MagnetInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>When you kill, the victim lunges toward you rather than the other way around.</size>",
  "Mare": "Mare",
  "MareInfo": "Kill in the dark",
  "MareInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You can only kill during lights sabotage, but your kill cooldown is very low then. Your name turns red during lights out. Cannot be guessed.</size>",
  "MareAddSpeedInLightsOut": "Additional Speed During Lights Out",
  "MareHasIncreasedSpeed": "Increased Speed During Lights Sabotage",
  "MareKillCooldownInLightsOut": "Kill Cooldown During Lights Out",
  "MareSpeedDuringLightsOut": "Speed During Lights Sabotage",
  "Messenger": "Messenger",
  "MessengerInfo": "Send a Message to Players After Death",
  "MessengerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>After you die, type <b>/hm {number}</b> in a meeting to send one informational message to all alive players:\n\n<size=70%><b>1.</b> The player that killed me was last in [room]\n<b>2.</b> The killer's role is [role]\n<b>3.</b> I was a(n) [Crewmate/Impostor/Neutral]</size>\n\nExample: <b>/hm 1</b></size>",
  "MessengerMessage.1": "The player that killed me was last in {0}",
  "MessengerMessage.2": "The killer's role is {0}",
  "MessengerMessage.3": "I was a(n) {0}",
  "Mimic": "Mimic",
  "MimicInfo": "You see dead players' roles",
  "MimicInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. When you die, other Impostors receive a message in the next meeting revealing the roles of players you killed. You can also see the roles of dead players.</size>",
  "MimicCD": "<color=#ffff00>Mimic Cooldown:</color> <color=#ffffff><b>{0}</b>s</color>",
  "MimicCanSeeDeadRoles": "<color=#ff1919>Mimic</color> can see the roles of dead players",
  "MimicCooldown": "Mimic Cooldown",
  "MimicDeadMsg": "Mimic's hint: ",
  "MimicDur": "<color=#ffff00>Mimic Duration:</color> <color=#ffffff><b>{0}</b>s</color>",
  "MimicDuration": "Mimic Duration",
  "Mischievous": "Vandal",
  "MischievousInfo": "You can Sabotage",
  "MischievousInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You can sabotage.</size>",
  "Moon": "Moon",
  "MoonInfo": "Sees through electrical sabotage",
  "MoonInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your vision is unaffected by electrical sabotage. You see normally even when the lights are out.</size>",
  "Necroview": "Necroview",
  "NecroviewInfo": "See the team of the dead",
  "NecroviewInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>In meetings, dead players' names show their team affiliation by color:\n_____________________________________\n<#ff1919>Red</color> = Impostor · <#8cffff>Cyan</color> = Crewmate · <#ffab1b>Orange</color> = Neutral</size>",
  "News": "News",
  "NewsInfo": "Your role is broadcast at meetings",
  "NewsInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Once the trigger conditions are met, every meeting begins with a broadcast naming the role of every alive player who has this add-on.</size>",
  "NewsTriggerDay": "Trigger Day (0 = off)",
  "NewsTriggerEveryDayAfter": "Repeat Every Day After Trigger",
  "NewsTriggerAliveCount": "Trigger Alive Count (0 = off)",
  "NewsTriggerEveryAliveCountBelow": "Repeat When Alive Count Stays Below",
  "News.BroadcastTitle": "<#88ddff>News</color>",
  "News.Broadcast.0": "Today's spotlight: {0}",
  "News.Broadcast.1": "Latest scoop — among us walks {0}",
  "News.Broadcast.2": "Big news! {0} are out there",
  "Nimble": "Nimble",
  "NimbleInfo": "Grants Vent Access",
  "NimbleInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Grants crewmate roles the ability to use vents.</size>",
  "Noisy": "Noisy",
  "NoisyInfo": "Grants Noisemaker Ability",
  "NoisyInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Grants crewmate roles the Noisemaker ability.</size>",
  "NonReport": "Non-Report",
  "NonReportInfo": "Cannot report bodies or call meetings",
  "NonReportInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Depending on the Mode, you cannot use the emergency button, cannot report bodies, or both.</size>",
  "NonReportMode": "Mode",
  "NonReportMode.NotButton": "Block Emergency Button Only",
  "NonReportMode.NotReport": "Block Body Report Only",
  "NonReportMode.Both": "Block Both",
  "NonReportCannotUseButton": "<#7b7c7d>Non-Report</color> cannot use the emergency button.",
  "NonReportCannotReport": "<#7b7c7d>Non-Report</color> cannot report bodies.",
  "Notvoter": "Notvoter",
  "NotvoterInfo": "Your vote counts as zero",
  "NotvoterInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You may still vote in meetings, but your vote contributes 0 to the tally.</size>",
  "Oblivious": "NonReport",
  "ObliviousInfo": "You can't report bodies",
  "ObliviousInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot report dead bodies.\n_____________________________________\nBait killed by a NonReport is still auto-reported. Forensics and Cleaners are never assigned this add-on.</size>",
  "ObliviousBaitImmune": "Immune to <color=#00f7ff>Bait</color>",
  "Onbound": "Bound",
  "OnboundInfo": "You can't be guessed",
  "OnboundInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot be guessed in meetings.</size>",
  "OneWolf": "One Wolf",
  "OneWolfInfo": "Other Impostors appear as Crewmates",
  "OneWolfInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. Other Impostors look like Crewmates to you (and you to them) — you cannot easily identify your teammates.</size>",
  "Opener": "Opener",
  "OpenerInfo": "Door open propagates to entire room",
  "OpenerInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you open a door, every other door in the same room opens with it. Effective on Polus, Airship, and The Fungle.</size>",
  "Physicist": "Physicist",
  "PhysicistInfo": "Grants Portable Vitals Access",
  "PhysicistInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Grants crewmate roles access to a portable vitals panel.</size>",
  "Rascal": "Rascal",
  "RascalInfo": "You appear evil in some cases",
  "RascalInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Crewmate-only add-on. The Sheriff can kill you, and Snitch can identify you if Snitch can find Madmates.\n_____________________________________\nCannot be assigned by the Merchant.</size>",
  "RascalAppearAsMadmate": "Appear As <color=#ff1919>Madmate</color> On Ejection",
  "Reach": "Reach",
  "ReachInfo": "You have a longer kill range",
  "ReachInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Killer-only add-on. Your kill range is set to the maximum possible in the game.</size>",
  "Rookie": "Rookie",
  "RookieInfo": "You Can't Kill on the First Round",
  "RookieInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot kill on the first round.</size>",
  "RookieKillRoundOne": "As a Rookie, you cannot kill in the first round",
  "Schizophrenic": "DoubleCount",
  "SchizophrenicInfo": "You count as two players",
  "SchizophrenicInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Neutrals and Madmates cannot receive this add-on. You count as two players — the game won't end from numerical imbalance while you're alive if you're the only non-Impostor remaining.</size>",
  "Seer": "Seer",
  "SeerInfo": "You see when players die",
  "SeerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>When a player is killed, you see a red flash accompanied by a Reactor alarm sound.</size>",
  "Serial": "Serial",
  "SerialInfo": "Reduced kill cooldown",
  "SerialInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Killer-only add-on. Your kill cooldown is reduced to a configured value.</size>",
  "SerialKillCooldown": "Kill Cooldown",
  "Shy": "Shy",
  "ShyInfo": "You don't hear whispers",
  "ShyInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot hear whispered messages. You can still send them.</size>",
  "Sleep": "Sleep",
  "SleepInfo": "You Sleep During Lights Out",
  "SleepInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>During lights sabotage, you fall asleep — unable to see or move. You wake when the lights come back on. If a player with the Glow add-on comes near you, you fully wake and lose this add-on.</size>",
  "Sleuth": "Sleuth",
  "SleuthInfo": "Know the roles of the bodies you report",
  "SleuthInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>When you report a body, you learn the deceased's role.</size>",
  "SleuthMsg": "{0}'s role is: {1}",
  "SlowStarter": "Slow Starter",
  "SlowStarterInfo": "Cannot kill until conditions are met",
  "SlowStarterInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You cannot kill until either the alive Impostor count drops to the threshold, or the activation day is reached.</size>",
  "SlowStarterAliveImpThreshold": "Alive Impostor Threshold",
  "SlowStarterActivationDay": "Activation Day (0 = day-trigger off)",
  "SlowStarterCannotKill": "<#ffaa66>Slow Starter</color> cannot kill yet.",
  "Sonar": "Sonar",
  "SonarInfo": "You have an arrow pointing to the nearest player",
  "SonarInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You see an arrow pointing to the nearest player.</size>",
  "Spurt": "Spurt",
  "SpurtInfo": "Boosts Movement",
  "SpurtInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>When you start walking, you burst with high speed that quickly fades. Standing still for a moment recharges your speed.</size>",
  "Stack": "Stack",
  "StackInfo": "Bundles selected add-ons",
  "StackInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>At game start, every Stack player also receives every add-on toggled on below. Use this to combine effects on the same player.</size>",
  "StackAssign.Water": "Add <color=#3399ff>Water</color>",
  "StackAssign.Notvoter": "Add <color=#6c848d>Notvoter</color>",
  "StackAssign.Elector": "Add <color=#544a47>Elector</color>",
  "StackAssign.Transparent": "Add <color=#7b7c7d>Transparent</color>",
  "StackAssign.Moon": "Add <color=#ffff33>Moon</color>",
  "StackAssign.MagicHand": "Add <color=#dea785>Magic Hand</color>",
  "StackAssign.Serial": "Add <color=#ff1919>Serial</color>",
  "StackAssign.Opener": "Add <color=#007bbb>Opener</color>",
  "StackAssign.NonReport": "Add <color=#006666>Non-Report</color>",
  "StackAssign.InfoPoor": "Add <color=#555647>Info Poor</color>",
  "StackAssign.News": "Add <color=#88ddff>News</color>",
  "StackAssign.SlowStarter": "Add <color=#ffaa66>Slow Starter</color>",
  "StackAssign.Connecting": "Add <color=#96514d>Connecting</color>",
  "SpurtMaxSpeed": "Max Speed",
  "SpurtMinSpeed": "Min Speed",
  "SpurtModule": "Speed Modulator",
  "SpurtSuffix": "\\n« <color=#c9e8f5>Spurt</color>: {0}% »",
  "Stained": "Stained",
  "StainedInfo": "Your killer gets a violet name for 3s",
  "StainedInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>When you are killed, your killer's name turns violet for 3 seconds — briefly marking them to others.</size>",
  "Stealer": "Stealer",
  "StealerInfo": "Gain votes with kills",
  "StealerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Each time you kill someone, you gain additional votes in the next meeting.</size>",
  "StealerGetVote": "You've got +{0} votes",
  "Stressed": "Stressed",
  "StressedInfo": "Crewmate lifespan countdown",
  "StressedInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Crewmate-only add-on (requires tasks). A countdown runs next to your role name. If it expires, you die. The timer pauses during meetings.\n_____________________________________\n<size=75%>[<color=#00ff00><b>+</b></color>] Complete a task · Non-crewmate dies · Survive a meeting · Non-crewmate ejected · Fix a sabotage · Report a body or call a meeting\n[<color=#ff0000><b>-</b></color>] A crewmate gets ejected</size></size>",
  "StressedExtraTimeAfterFixingSabotage": "Time Gained For Fixing a Sabotage",
  "StressedExtraTimeAfterImpostorDeath": "Time Gained When a Non-Crewmate Player Dies",
  "StressedExtraTimeAfterImpostorEjected": "Time Gained When a Non-Crewmate Player Gets Ejected",
  "StressedExtraTimeAfterReporting": "Time Gained For Reporting a Dead Body",
  "StressedExtraTimeAfterTask": "Time Gained After Completing a Task",
  "StressedTimePenaltyAfterCrewmateEjected": "Time Penalty When a Crewmate Gets Ejected",
  "Sunglasses": "Sunglasses",
  "SunglassesInfo": "You have reduced vision",
  "SunglassesInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your vision is reduced.</size>",
  "SunglassesVision": "<color=#E7C12B>Sunglasses</color> Vision",
  "Swift": "Swift",
  "SwiftInfo": "Your kills don't cause a lunge",
  "SwiftInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Your kills do not cause you to lunge toward the target.</size>",
  "Talkative": "Talkative",
  "TalkativeInfo": "Talkative",
  "TalkativeInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>If you send more chat messages in a meeting than the host-set limit, you suicide.</size>",
  "Talkative.MaxMessagesPerMeeting": "Max Messages Per Meeting",
  "Talkative.Died": "{0} talked too much and died.",
  "Urgent": "Urgent",
  "UrgentInfo": "You Have +1 Emergency Meeting",
  "UrgentInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You have one extra emergency meeting button use.</size>",
  "TaskMaster": "Task Master",
  "TaskMasterInfo": "Auto-Completes 1 Task After Every Meeting",
  "TaskMasterInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You automatically complete 1 task after every meeting.</size>",
  "Taskcounter": "Taskcounter",
  "TaskcounterInfo": "You see the total tasks completed in real-time",
  "TaskcounterInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You see the total number of tasks completed by all players in real time, displayed next to your role name.</size>",
  "Tiebreaker": "Tiebreaker",
  "TiebreakerInfo": "Break tied votes",
  "TiebreakerInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>In the event of a tied vote, the player you voted for is ejected. If multiple Tiebreakers vote for different players, the ability cancels out.</size>",
  "Tired": "Tired",
  "TiredInfo": "Too Tired to Kill",
  "TiredInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Impostor-only add-on. You can only kill a limited number of players each round.</size>",
  "TiredMaxKillsPerRound": "Max Kills Per Round",
  "TiredReachedMaxKillsPerRound": "You're too tired to kill more this round",
  "Torch": "Torch",
  "TorchInfo": "You have a higher vision!",
  "TorchInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>Crewmate-only add-on. You have increased vision and may be immune to Lights Sabotage.</size>",
  "TorchAffectedByLights": "<color=#eee5be>Torch</color>'s vision is affected by Lights Sabotage",
  "TorchVision": "<color=#eee5be>Torch</color> Vision",
  "Trainee": "Trainee",
  "TraineeInfo": "You Can't Vent/Sabotage/SS/Pet/Vanish Round 1",
  "TraineeInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>On the first round, you cannot vent, sabotage, shapeshift, or pet.</size>",
  "TraineeNotify": "<#ffff00>As the <#4287f5>Trainee</color>, you can't vent, sabotage, shapeshift, or pet on the first round!</color>",
  "Transparent": "Transparent",
  "TransparentInfo": "Your body cannot be reported",
  "TransparentInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>When you die, no one can report your body. The emergency meeting button is unaffected.</size>",
  "Truant": "Truant",
  "TruantInfo": "You freeze after meetings for some time",
  "TruantInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>After each meeting, you are frozen in place for a set number of seconds.</size>",
  "TruantWaitingTime": "Waiting Time After Meetings",
  "Twins": "Twins",
  "TwinsInfo": "Paired with another Twin",
  "TwinsInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Paired with another Twin player. You see each other's role and a ♊ mark. If your partner wins, you also win.</size>",
  "TwinsAddWin": "Both Twins Win Together",
  "Unbound": "Unbound",
  "UnboundInfo": "You're Always Correctly Guessed",
  "UnboundInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>When someone tries to guess you — even with the wrong role — the guess succeeds anyway.</size>",
  "Undead": "Undead",
  "UndeadInfo": "You're on the Undead faction",
  "UndeadInfoLong": "(<#ff1919>Betrayal</color> <#ff9ace>Add-on</color>):\n<size=80%>You were recruited by the Necromancer or Deathknight and are now part of the Undead faction.</size>",
  "Undead-": "Undead ",
  "UndeadCountMode": "<#ed9abd>Undead</color> Players count as",
  "UndeadCountMode.Necromancer": "<#f7adcf>Necromancer</color>",
  "UndeadCountMode.None": "None",
  "UndeadCountMode.Original": "Original Team",
  "Underdog": "Underdog",
  "UnderdogInfo": "Start killing on a low player count",
  "UnderdogInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>Your kill cooldown is longer while many players are alive. Once the count drops below the threshold, your cooldown becomes shorter.</size>",
  "UnderdogKillCooldownWithMorePlayersAlive": "Kill Cooldown when more players are alive",
  "UnderdogMaximumPlayersNeededToKill": "Maximum players needed for low cooldown",
  "Unlucky": "Unlucky",
  "UnluckyInfo": "Everything has a chance to kill you",
  "UnluckyInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>Routine actions each have a configurable chance to kill you — including completing tasks, killing, venting, reporting bodies, shapeshifting, and opening doors.</size>",
  "UnluckyKillSuicideChance": "Chance to suicide from killing",
  "UnluckyReportSuicideChance": "Chance to suicide from reporting bodies",
  "UnluckySabotageSuicideChance": "Chance to suicide from opening a door",
  "UnluckyShapeshiftSuicideChance": "Chance to suicide from shapeshifting",
  "UnluckyTaskSuicideChance": "Chance to suicide from doing tasks",
  "UnluckyVentSuicideChance": "Chance to suicide from venting",
  "Watcher": "Watcher",
  "WatcherInfo": "You see vote colors",
  "WatcherInfoLong": "(<#8cffff>Helpful</color> <#ff9ace>Add-on</color>):\n<size=80%>You can see vote colors even when Anonymous Voting is enabled.</size>",
  "Water": "Water",
  "WaterInfo": "Cannot fix electrical sabotage",
  "WaterInfoLong": "(<#ffab1b>Harmful</color> <#ff9ace>Add-on</color>):\n<size=80%>You cannot operate the electrical repair panel. Other crewmates must repair the lights for you.</size>",
  "Workhorse": "Workhorse",
  "WorkhorseInfo": "Be the first to complete all tasks and get more",
  "WorkhorseInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>This add-on is hidden until you complete all your tasks. Upon finishing, it becomes visible and you gain an additional set of tasks.</size>",
  "WorkhorseNumLongTasks": "Additional Long Tasks",
  "WorkhorseNumShortTasks": "Additional Short Tasks",
  "WorkhorseSpawnChance": "<color=#00ffff>Workhorse</color> Spawn Chance",
  "Youtuber": "YouTuber",
  "YoutuberInfo": "Get killed first to win",
  "YoutuberInfoLong": "(<#00ffa5>Mixed</color> <#ff9ace>Add-on</color>):\n<size=80%>If you are the first player killed in the game, you win. If not, your win condition follows the Crewmates'.\n_____________________________________\nIndirect kill methods do not count.</size>",
  /* ==============================
    Roles (Ghosts)           
  ============================== */
  "Bloodmoon": "Bloodmoon",
  "BloodmoonInfo": "Help the Impostors Kill!",
  "BloodmoonInfoLong": "(<#ff1919>Impostor Ghost</color>):\n<size=80%>Use your protect button on a player to mark them for death — they die after a set amount of time and are aware of it.</size>",
  "Bloodmoon.CDCIncreasePerUse": "Cooldown Increase Per Use",
  "Bloodmoon.DieOnMeetingCall": "Targets Die on Meeting Call",
  "Bloodmoon.Duration": "Time After Target Dies",
  "Bloodmoon.Speed": "<#ff1919>Bloodmoon</color> Speed",
  "Bloodmoon.Suffix": "<{1}>You will die in <{2}>{0}s</color></color>",
  "BloodmoonNearYou": "<size=70%>The {0} is near you! Stay away to avoid death!</size>",
  "Facilitator": "Facilitator",
  "FacilitatorInfo": "Give Necronomicon",
  "FacilitatorInfoLong": "(<#7b3fbb>Coven Ghost</color>):\n<size=80%>Protect a Coven member to transfer the Necronomicon to them. Has no effect on non-Coven members or those who already hold the Necronomicon.</size>",
  "GA": "Ghost Angel",
  "GAInfo": "Protect Crewmates",
  "GAInfoLong": "(<#8cffff>Crewmate Ghost</color>):\n<size=80%>Protect a player to save them from being killed. This is the vanilla Guardian Angel role, re-packaged as a ghost add-on.</size>",
  "GAGuarded": "This player is shielded by the Guardian Angel",
  "Haunter": "Haunter",
  "HaunterInfo": "You're the Impostors' Worst Nightmare",
  "HaunterInfoLong": "(<#8cffff>Crewmate/Neutral Ghost</color>):\n<size=80%>Complete all your tasks to reveal a random living Impostor's name in red to everyone in meetings. When you have 1 task left, all Impostors receive an arrow pointing to you — if any come close, you lose this role.</size>",
  "Haunter.CanWinWithCrewmates": "Can Win With <#8cffff>Crewmates</color>",
  "Haunter.NumberOfReveals": "Number of Players Revealed on Task Completion",
  "Haunter.RevealCovenMembers": "Can Reveal <#7b3fbb>Coven</color>",
  "Haunter.RevealMadmates": "Can Reveal <#ff1919>Madmates</color>",
  "Haunter.RevealNeutralKillers": "Can Reveal <#ffab1b>Neutral Killers</color>",
  "Haunter.TasksBeforeBeingKnown": "Reveal Haunter When They've Completed This Many Tasks",
  "Haunter1TaskLeft": "<#ffff00>The Haunter has almost finished their tasks!\\nGo near them or you might be revealed!</color>",
  "HaunterFinishedTasks": "The Haunter completed all tasks, an impostor was revealed! (But it wasn't you)",
  "HaunterRevealedYou": "You have been revealed by the Haunter!",
  "HaunterStopped": "<#00ff00>The Haunter was successfully stopped!</color>",
  "HaunterStoppedSelf": "<#ff1313>An impostor came too close to you, your role was removed.</color>",
  "Minion": "Minion",
  "MinionInfo": "Help the Impostors",
  "MinionInfoLong": "(<#ff1919>Impostor/Neutral Ghost</color>):\n<size=80%>Protect a player to blind them for a few seconds.</size>",
  "MinionBlindDuration": "Blind Duration",
  "Phantasm": "Phantasm",
  "PhantasmInfo": "Finish Tasks to Win!",
  "PhantasmInfoLong": "(<#ffab1b>Neutral Ghost</color>):\n<size=80%>Complete all your tasks to win. Depending on settings, you may also end the game and win alone upon completing them.</size>",
  "Shade": "Shade",
  "ShadeInfo": "Protect Everyone to Win",
  "ShadeInfoLong": "(<#ffab1b>Neutral Ghost</color>):\n<size=80%>Use your protect button to mark every living player. Mark everyone before the game ends to win with the winning team. This is an additional win condition — it does not override your original one.</size>",
  "Warden": "Warden",
  "WardenInfo": "Boost the Crewmates",
  "WardenInfoLong": "(<#8cffff>Crewmate Ghost</color>):\n<size=80%>Protect a player to warn them of danger and grant them a temporary speed boost.</size>",
  "WardenAdditionalSpeed": "Additional Speed",
  "WardenNotify": "The Warden warns you that you're in danger!",
  "WardenNotifyTarget": "Notify Target About Danger",
