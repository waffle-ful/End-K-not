  "EnigmaClueVisor2": "The Killer does not wear a Visor!",
  "EnigmaClueVisor3": "The Killer wears {0} as a Visor!",
  "EnigmaCluePetTitle": "Enigma Pet Clue",
  "EnigmaClueNameTitle": "Enigma Name Clue",
  "EnigmaClueNameLengthTitle": "Enigma Name Length Clue",
  "EnigmaClueColorTitle": "Enigma Skin Color Clue",
  "EnigmaClueLocationTitle": "Enigma Location Clue",
  "EnigmaClueStatusTitle": "Enigma Status Clue",
