  "Quiz.Settings.TimeLimit.Hard": "Time Limit to Answer Each Question in Hard Rounds",
  "Quiz.Settings.TimeLimit.Medium": "Time Limit to Answer Each Question in Medium Rounds",
  "Quiz.Suffix.Invisible": "You cannot see where other people go\\nOther people cannot see where you go",
  "Quiz.TaskBarText": "---- GAME DATA ----\\n\\nDifficulty: {0}\\nRound: {1}\\nQuestion: {2}\\n\\nNumber of correct answers\\nfrom everyone so far:\\n\\n{3}",
  // Room Rush - RR
  "RoomRush": "ROOM RUSH",
  "ModeRoomRush": "Gamemode: Room Rush",
  "ModeDescribe.RoomRush": "In the Room Rush gamemode, everyone has to get to a specific room as fast as possible. The last player to get there dies. The last player alive wins!\\nOh yeah, and there's also a time limit. Everyone who doesn't get to the room in the specified time dies. Seems easy, right? Well.... When the first 2 players enter the correct room, the time limit gets set to a lower amount, like a few seconds! Good luck!\\n\\nYou can see the room you have to get to below your name.\\nDepending on the settings, everyone may be able to vent limited times.",
  "RR_Tutorial_Basics": "The current game mode is <#ffab1b>Room Rush</color>.\\n<size=90%>The goal is to get to the specified rooms as fast as possible.</size>",
  "RR_Tutorial_DontMoveOutOfRoom": "<size=90%>After you get to the correct room, don't move out of it!</size>",
  "RR_Tutorial_LastDeath": "<size=90%>If you are last to get to the correct room, you die.</size>",
  "RR_Tutorial_LowerTimeWhenTwoPlayersEnterRoom": "<size=90%>When 2 players enter the correct room,\\nthe time limit is set to <#ffff44>{0}</color> seconds.</size>",
  "RR_Tutorial_PointsSystem": "<size=90%>When you get to the correct room, you get points.\\nThe sooner you get there, the more points you get.</size>",
  "RR_Tutorial_PointsToWin": "<size=90%>The first player to reach <#ffff44>{0}</color> points wins.</size>",
  "RR_Tutorial_RoomIndication_ArrowAndName": "<size=90%>Both the name of the room and an arrow\\npointing to it are displayed below your name.</size>",
  "RR_Tutorial_RoomIndication_ArrowOnly": "<size=90%>An arrow pointing to the room is displayed below your name.</size>",
  "RR_Tutorial_RoomIndication_NameOnly": "<size=90%>The name of the room is displayed below your name.</size>",
  "RR_Tutorial_TimeLimitDeath": "<size=90%>If you don't get to the correct room within the time limit, you die.</size>",
  "RR_Tutorial_TimeLimitLastPoints": "<size=90%>If you are last to or don't get to the correct\\nroom within the time limit, you get teleported\\nto a player who did and don't get any points.</size>",
  "RR_Tutorial_Venting": "<size=90%>Every player can vent <#ffff44>{0}</color> times.</size>",
  "RR_DisplayArrowToRoom": "Display an Arrow to the Room to Get to",
  "RR_DisplayRoomName": "Display the Name of the Room to Get to",
  "RR_DontKillLastPlayer": "Don't Kill The Last Player to Enter the Correct Room",
  "RR_DontKillPlayersOutsideRoomWhenTimeRunsOut": "Don't Kill Players Outside the Room When the Time Runs Out",
  "RR_DontLowerTimeLimitWhenTwoPlayersEnterCorrectRoom": "Don't Lower Time Limit When the First Two Players Enter the Correct Room",
  "RR_FirstPoints": "1st place: {0} with {1} points",
  "RR_GlobalTimeMultiplier": "Global Time Multiplier (for adjusting the difficulty)",
  "RR_Points": "Points: {0}/{1}",
  "RR_PointsToWin": "Points to Win - Multiplied by how many players are in the game",
  "RR_ReadyQM": "Ready?\\nStarting in <#ffff44>{0}</color>",
  "RR_Tie": "<size=80%><#00a5ff>In tie with {0}\\nWaiting for the tie to break....</color></size>",
  "RR_TimeWhenTwoPlayersEntersRoom": "When the first two players enter the correct room, the time limit is set to",
  "RR_VentTimes": "Times each player can vent",
  "RR_VentsRemaining": "<size=80%>Remaining vent uses: {0}</size>",
  "RR_WinByPointsInsteadOfDeaths": "Instead of deaths, count the places each time in points and the first player to get a certain amount of points wins",
  "RR_YouAreFirst": "You are in the 1st place",
  "RR_YouWereLast": "<#ff1919>You were the last to get to the room</color>",
  // Snowdown
  "Snowdown": "SNOWDOWN",
  "ModeSnowdown": "Gamemode: Snowdown",
  "ModeDescribe.Snowdown": "In the Snowdown gamemode, the player that successfully throws the most snowballs at other players wins! You get 1 coin for every hit. You can spend coins on powerups in the shop, or turn pet to turn 20 coins into 1 point. Highest <u>points</u> (not coins) wins! Triggers:\\n- Vanish: Throw a snowball in your movement direction / Cycle between powerups while in shop\\n- Calling a Critical Sabotage: Enter/Exit shop\\n- Pet: Turn 20 coins into 1 point / Buy selected powerup in shop\\n- Kill: Give the target one of your snowballs",
  "GameModeTutorial.Snowdown": "<size=90%>The current game mode is <#e4fdff>Snowdown</color>.</size>\\n<size=80%>Vanish to throw a snowball in your movement direction.\\nIf it hits someone, you get a coin. Pet to turn 20 coins into 1 point.\\nCall a critical sabotage to enter/exit the shop. Highest points wins!</size>",
  "Snowdown.GameEndTimeOption": "Game Ends After",
  "Snowdown.GameEndsAfterTimeOption": "Game Ends After a Certain Time",
  "Snowdown.GameEndsWhenPointsReachedOption": "Game Ends When Someone Reached a Specific Number of Points",
  "Snowdown.MaxCoinsInHandOption": "Max Coins Everyone Can Hold Initially",
  "Snowdown.MaxSnowballsInHandOption": "Max Snowballs Everyone Can Hold Initially",
  "Snowdown.PointsToReachOption": "Points to Reach to Win",
  "Snowdown.PowerUp.FasterPickup": "Pickup Boost",
  "Snowdown.PowerUp.FasterPickup.Description": "Increases your rate of getting snowballs",
  "Snowdown.PowerUp.FillUp": "Fill-Up",
  "Snowdown.PowerUp.FillUp.Description": "Sets your snowball counter to its max",
  "Snowdown.PowerUp.IncreaseCapacity": "Capacity Increment",
  "Snowdown.PowerUp.IncreaseCapacity.Description": "Increases how many snowballs and coins you can hold",
  "Snowdown.PowerUpPriceOption": "{powerup} Powerup Price (Coins)",
  "Snowdown.ShopHelp": "Vanish: Cycle between powerups | Pet: Buy selected powerup | Sabotage: Exit shop",
  "Snowdown.SnowballGainFrequencyOption": "Initial Snowball Gaining Frequency",
  "Snowdown.SnowballThrowSpeedOption": "Snowball Throwing Speed",
  "SnowdownButtonText": "THROW",
  // SoloPVP
  "SoloPVP": "SOLO PVP",
  "ModeSoloPVP": "Gamemode: Solo PVP",
  "ModeDescribe.SoloPVP": "In the Solo PVP game mode, everyone has HP and can use their kill button to cause damage on other players. When a player's health reaches 0, they 'die' and respawn after a few seconds. The player(s) with the highest number of kills win(s) at the end of the game.",
  "GameModeTutorial.SoloPVP": "<size=90%>The current game mode is <#f55252>Solo PVP</color>.</size>\\n<size=80%>Use your kill button to damage others. If someone's HP goes below 0,\\nthey get teleported outside the map for some time, then respawn.\\nWhen you kill someone, you get a small buff and 1 point.\\nThe person with the most points at the end of the time limit wins!</size>",
  "PVP.ATK": "Attack",
  "PVP.DF": "Defend",
  "PVP.RCO": "Recover",
  "SoloPVP.Summary": "Rank: {0} | Kills: {1}",
  "SoloPVP.WinnersKillCount": "They got <color=#ffffff>{0}</color> kills!",
  "SoloPVP_ATK": "Default Attack",
  "SoloPVP_ATKCooldown": "Attack Cooldown",
  "SoloPVP_BackCountDown": "<#ff0000>DEAD</color>\\n<#ffffff>Respawning in <#ffff00>{0}</color>s</color>\\n\\n",
  "SoloPVP_Buff_ATK": "Gain: Attack +{0}",
  "SoloPVP_Buff_DF": "Gain: Defense +{0}",
  "SoloPVP_Buff_HPMax": "Gain: HP Max +{0}",
  "SoloPVP_Buff_HPReco": "Gain: Recover HP Per Second +{0}",
  "SoloPVP_CanVent": "Players Can Vent",
  "SoloPVP_GameTime": "Game duration",
  "SoloPVP_HPMax": "Default HP",
  "SoloPVP_KillBonusMultiplier": "Kill bonus multiplier",
  "SoloPVP_RecoverAfterSecond": "Recover Cooldown",
  "SoloPVP_RecoverPerSecond": "Recover Per Second",
  "SoloPVP_ResurrectionWaitingTime": "Resurrection waiting time",
  // Speedrun
  "Speedrun": "SPEEDRUN",
  "ModeSpeedrun": "Gamemode: Speedrun",
  "ModeDescribe.Speedrun": "In the Speedrun gamemode, everything is about speed. Everyone has to complete all tasks as fast as possible, then kill everyone else as fast as possible!\\n\\nWhen someone finishes all their tasks, they become a killer and can kill everyone else. The last player alive wins!\\nBut to make this a bit harder, you have a time limit to complete a task or kill someone! The timer resets when you do so. If your time runs out, you die!\\n\\nThis gamemode is a hybrid of the Stop And Go and Free For All gamemodes.",
  "GameModeTutorial.Speedrun": "<size=90%>The current game mode is <#800080>Speedrun</color>.</size>\\n<size=80%>Complete all tasks to gain the kill button, then kill everyone to win.\\nYou must do a task or kill within your time limit, else you suicide.</size>",
  "Speedrun_CanKillSuffixInfo": "<#00ffa5>Time:</color> <#ffffff>{3}s</color>\\n<size=80%><#ffff00>Living players: <#ffab1b>{0}</color>/{1}</color>\\n<#ff1919>Kill everyone to win</color>\\n<size=70%><#888888>Apart from you, <#ffffff>{2}</color> players can kill</color></size></size>",
  "Speedrun_CompletedTasks": "<#00ff00>You're done with tasks!</color>",
  "Speedrun_DoTasksSuffixInfo": "<#00ffa5>Time:</color> <#ffffff>{4}s</color>\\n<size=70%><#888888>Living players: <#ffffff>{1}</color>/{2}</color>\\n<size=80%><#00ffa5>Finish your <#ffff00>{0}</color> remaining tasks</color>\\n<size=70%><#ffab1b><#ffffff>{3}</color> players can kill</color></size></size></size>",
  "Speedrun_KillersCanKillTaskingPlayers": "Killing Players Can Kill Players Who Didn't Finish Their Tasks Yet",
  "Speedrun_KillingPlayer": "<#ff1919>KILLING</color>",
  "Speedrun_TaskFinishWins": "First to Finish Tasks Wins Immediately (skips killing phase)",
  "Speedrun_TimeLimit": "Time Limit to Do a Task or Kill",
  "Speedrun_TimeStacksUp": "Time Remainder Adds to Next Time Limit (time stacks up)",
  // Stop And Go
  "StopAndGo": "STOP AND GO",
  "ModeStopAndGo": "Gamemode: Stop And Go",
  "ModeDescribe.StopAndGo": "In Stop And Go, everyone has 3 timers with symbols for movement directions: ← (left) 17s, → (right) 5s, ⇅ (up/down) 9s. Each symbol is red or green. When a timer reaches 0, its color swaps.\\nConcept: You can't move in directions with a red symbol, or you die. Everyone is a crewmate. First to finish all tasks wins!",
  "StopAndGo_Tutorial": "<size=80%><#ffffff><size=100%>Stop on red lights</size>\\nOnly move in directions where you see a green arrow\\nThe timers indicate when the color changes\\nYellow means the light will turn red, so stop moving\\nOrange means the light will turn green, but do not move yet\\nFinish your tasks to win</color></size>",
  "StartingKillCooldown": "Starting Kill Cooldown",
  "StopAndGo_EnableTutorial": "Enable Tutorial",
