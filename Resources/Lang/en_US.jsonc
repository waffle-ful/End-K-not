  "StopAndGo_PlayerLives": "Player Lives",
  "StopAndGo_RightCounterGreenMax": "Right Counter Maximum Green Time",
  "StopAndGo_RightCounterGreenMin": "Right Counter Minimum Green Time",
  "StopAndGo_RightCounterRedMax": "Right Counter Maximum Red Time",
  "StopAndGo_RightCounterRedMin": "Right Counter Minimum Red Time",
  // The Mind Game - TMG
  "TheMindGame": "THE MIND GAME",
  "ModeTheMindGame": "Gamemode: The Mind Game",
  "ModeDescribe.TheMindGame": "The Mind Game is a 4-round elimination game focused on strategy, bluffing, and item use. Players compete for points across rounds, with only one emerging victorious.\\nRound 1: Demand Points - Pick a number. If someone else picks the same, both get nothing. Reach the point goal first to advance. Lowest scorers in each group are eliminated.\\nRound 2: Super Point Auctions - Bid normal points in hidden auctions for super points. Highest bidders win. Lowest super point holders are eliminated.\\nRound 2.5: Merchant Intermission - Spend super points on powerful items. Items can blind, block, steal, or enhance. Use commands to buy and activate them.\\nRound 3: Demand + Items - Same as Round 1, but items are active. Everyone plays together. Lowest scorers are eliminated until only a few remain.\\nRound 4: The Briefcase Game - One player holds the winning briefcase. Get ejected while holding it to lock in placement. Briefcases shuffle after each ejection. If only 2 remain, the briefcase holder loses. Use Lasso to steal.\\nFinal Scoring: Total score = points from rounds + super points bonus + placement bonus. Highest total wins.",
  "TMG.Tutorial.Basics": "The Mind Game has 4 rounds.\\nEach round's goal will be explained as it begins.\\nGet as many points as possible - highest score wins!",
  "TMG.Tutorial.Round1": "Pick a number 1-3 by clicking the Vanish button\\nYour number appears below your name and cycles with each click.\\nYou have {0} seconds to lock in your choice.\\nThis is how many points you demand.\\nIf another player picks the same number, <u>neither</u> of you get points.\\nThe round repeats until someone reaches {1} points.\\nThe {2} lowest scorers are eliminated.",
  "TMG.Tutorial.Round2": "3 hidden-bid auctions are held for super points.\\nBid using your normal points with the Vanish button (same as Round 1).\\nHighest bidder(s) win(s) the super points, others still lose their bid.\\nSuper points are used to buy items in the next round and count toward your final score (1 super point = {0} normal points).\\nAfter all auctions, players with the lowest super points are eliminated.",
  "TMG.Tutorial.Round3": "Same rules as Round 1, but now you can use your items.\\nNo groups, everyone plays together.\\nPick a number from 1 to {0} using the Vanish button.\\nLowest scorers are eliminated until only {1} players remain for Round 4.",
  "TMG.Tutorial.Round4": "One player gets the winning briefcase, others get empty ones.\\nGoal: Get ejected while holding the winning briefcase!\\n\\nIf ejected with the winning briefcase: you lock in your placement.\\nIf ejected with an empty one: you're ranked from the bottom.\\n\\nAfter each ejection, a meeting is triggered and the briefcase is shuffled.\\nWhen only 2 players remain, the one holding the winning briefcase automatically loses.\\n\\nBriefcases can be stolen using Lasso.\\nIf yours is stolen, you'll be notified.\\nUse `s {id}` to guess who took it and try to steal it back.",
  "TMG.EjectionText.HadEmptyBriefcase": "{0} had an empty briefcase.",
  "TMG.EjectionText.HadWinningBriefcase": "{0} had the <#00ff00>winning</color> briefcase!\\nThey are ranked {1}.",
  "TMG.EndScreen.Points": "Points: {0}",
  "TMG.Item.BlindingGas": "Blinding Gas",
  "TMG.Item.DoubleModifier": "2x Modifier",
  "TMG.Item.Fool": "Fool",
  "TMG.Item.Lasso": "Lasso",
  "TMG.Item.MerchantDise": "Merchant-Dise",
  "TMG.Item.MindDetective": "Mind Detective",
  "TMG.ItemDescription.BlindingGas": "Temporarily hides a player's normal point total from them and blocks feedback from point demanding.",
  "TMG.ItemDescription.DoubleModifier": "Doubles point gain from point demanding.",
  "TMG.ItemDescription.Fool": "Instantly causes a target player to lose {0} normal points.",
  "TMG.ItemDescription.Lasso": "Used in Round 4 to steal a player's briefcase.",
  "TMG.ItemDescription.MerchantDise": "Prevents one player from buying items during this phase.",
  "TMG.ItemDescription.MindDetective": "Reveals the target's point demand. Has a chance to be inaccurate.",
  "TMG.Message.CannotPurchase": "Someone used the Merchant-Dise on you!\\nYou cannot buy items.",
  "TMG.Message.ItemPurchased": "You bought <b>{0}</b> for <b>{1}</b> super points!\\n<size=80%>You have <b>{2}</b> super points left.</size>",
  "TMG.Message.ItemUsed": "{0} successfully used!",
  "TMG.Message.LassoOnlyInRound4": "You can only use the Lasso in Round 4!",
  "TMG.Message.LassoedEmptyBriefcase": "You stole an empty briefcase from {0}.",
  "TMG.Message.LassoedWinningBriefcase": "Your briefcase was stolen! You can try to get it back by guessing who took it.\\n<size=80%>Use `s {id}` to guess the ID of the player who stole it.</size>",
  "TMG.Message.LassoedWinningBriefcaseSelf": "You stole the <#00ff00>winning</color> briefcase from {0}!",
  "TMG.Message.MindDetective": "Currently, {0} is picking <b>{1}</b>.",
  "TMG.Message.NotEnoughSuperPoints": "<b>{0}</b> costs <b>{1}</b> super points, but you only have <b>{2}</b>!",
  "TMG.Message.StealBackEmptyBriefcase": "{0} had an empty briefcase.",
  "TMG.Message.StealBackNotLastHolder": "You are not the previous holder of the briefcase, or you were the one who stole it!\\nYou cannot steal it back.",
  "TMG.Message.StealBackWinningBriefcase": "{0} guessed correctly!\\nThey stole back the winning briefcase from you!",
  "TMG.Message.StealBackWinningBriefcaseSelf": "Correct! You stole back the <#00ff00>winning</color> briefcase from {0}!",
  "TMG.Message.TimeLeft": "Proceeding in {0}s",
  "TMG.Message.TimeLeftTitle": "<#ffff00>⚠ Time Is Ticking ⚠</color>",
  "TMG.Message.YouHoldAnEmptyBriefcase": "You hold an empty briefcase.\\n<size=80%>Don't get ejected.\\nIf you have Lasso, you can steal someone's briefcase.</size>",
  "TMG.Message.YouHoldTheWinningBriefcase": "<#00ff00>You hold the winning briefcase!</color>\\n<size=80%>Get ejected to lock in your placement.\\n<#ffff00>Be careful, briefcases can be stolen!</color></size>",
  "TMG.Notify.AuctionEnd": "The highest bid was {0} by {1}!\\n<size=80%>They won {2} super points!</size>",
  "TMG.Notify.ItemPurchasingBegins": "Now you have {0}s to buy items with your super points!\\nPress Vanish to signal that you're done.\\nThe items can be used right away!",
  "TMG.Notify.ItemPurchasingEnd": "The item purchasing phase is over!\\n<size=80%>The remaining super points will contribute to your final score.</size>",
