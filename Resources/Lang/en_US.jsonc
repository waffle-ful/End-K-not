  /* ==============================
    ROLES (Crewmates)           
  ============================== */
  "Addict": "Vent Addict",
  "AddictInfo": "Vent to become invulnerable, or you'll die",
  "AddictInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to survive — or watch the timer hit zero.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Addiction Timer</color></b>\nA vent-cooldown timer counts down constantly. Venting resets it and grants temporary immortality. After immunity ends, you are briefly frozen and cannot report bodies.\n\n<i>One hit to live. One miss to die.</i></size>",
  "AddictFreezeTimeAfterInvulnerbility": "Time the <color=#008000>Vent Addict</color> gets frozen in place after <color=#008000>Invulnerbility</color>",
  "AddictInvulnerbilityTimeAfterVent": "<color=#008000>Invulnerbility</color> Time",
  "AddictSpeedWhileInvulnerble": "Movement speed while <color=#008000>Invulnerble</color>",
  "AddictVentButtonText": "Get Fix",
  "AddictWarning": "<#ffff00>You must vent soon or you'll suicide!</color>",
  "Adrenaline": "Adrenaline",
  "AdrenalineInfo": "Be Fast Enough to Avoid Kills",
  "AdrenalineInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Survive an attack — if a meeting starts in time.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Adrenaline Rush</color></b>\nWhen attacked, the kill is blocked and a countdown begins. If a meeting is called before the timer expires, you live. If not, you die when it runs out. Whether you can call emergency meetings during the timer is host-controlled.\n\n<i>The clock is ticking. Move fast.</i></size>",
  "Adrenaline.CanCallMeetingDuringTimer": "Can Call Emergency Meetings During the Timer",
  "Adrenaline.MaxSurvives": "Maximum Survives",
  "Adrenaline.MinTasksRequired": "Minimum Tasks Required to Survive an Attack",
  "Adrenaline.SpeedDuringTimer": "Speed During the Timer",
  "Adrenaline.Suffix": "<size=80%><#ffff00>You were attacked!\\nIf a meeting doesn't start before <#ffffff>{0}s</color>, you die!</color></size>",
  "Adrenaline.Time": "Time for a Meeting to Start",
  "AdrenalineCannotCallEmergencyMeeting": "As the <#ffff00>Adrenaline</color>, you cannot call emergency meetings currently",
  "Adventurer": "Adventurer",
  "AdventurerInfo": "Collect Resources to Perform Actions",
  "AdventurerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Gather resources and craft weapons to shape the outcome.\n_____________________________________\nDifficulty: ★★★★☆\n\n[Skills]\n・<b><color=#8cffff>Crafting</color></b>\nCollect scattered resources and combine them into weapons. Pet to use the currently selected weapon.<size=70%>\n\n<u><b>Resources (and how to obtain them):</b></u>\n- ❖ (Complete a Task)\n- Θ (Players Leave This Behind*)\n- ♳ (Dead Bodies*)\n- ⁂ (Shapeshift Skins*)\n- ☀ (Fix Lights)\n- ○ (Found in Groups*)\n* Arrow points to available resource locations.\n\n<u><b>Weapons (and their ingredients):</b></u>\n- Gun (1 ♳ + 1 ❖) Kill nearest player\n- Shield (3 ❖) Give nearest player a 1-use shield\n- Lantern (1 ☀ + 1 ❖) Boost crewmates' vision\n- Portal (2 Θ) Swap you with a random player\n- Wrench (1 ☀ + 2 ❖) Fix current sabotage\n- Proxy (2 ○ + 1 ❖) +1 vote next meeting\n- Prediction (1 ♳ + 2 ⁂ + 1 ❖) Reveal nearest role\n- RNG (2 Θ + 2 ❖) Make a random weapon</size>\n\n<i>Fortune favors the prepared.</i></size>",
  "AdventurerFound": "Found Resource: {0}",
  "AdventurerGun.Gun": "Gun",
  "AdventurerGun.Lantern": "Lantern",
  "AdventurerGun.Portal": "Portal",
  "AdventurerGun.Prediction": "Prediction",
  "AdventurerGun.Proxy": "Proxy",
  "AdventurerGun.RNG": "RNG",
  "AdventurerGun.Shield": "Shield",
  "AdventurerGun.Wrench": "Wrench",
  "AdventurerIncreasedVisionDuration": "Increased Vision Duration",
  "AdventurerIngredientsDisplay": "{0}: {1}\\nVent to craft this weapon / Pet to cycle to next weapon",
  "AdventurerVentToEnterCrafting": "Vent to Enter Crafting Menu",
  "AdventurerWeaponCrafted": "Crafted Weapon: {0}",
  "AdventurerWeaponDescription.Gun": "Kill the next player you go near",
  "AdventurerWeaponDescription.Lantern": "Increases crewmates' vision for some time",
  "AdventurerWeaponDescription.Portal": "Swaps you with a random player",
  "AdventurerWeaponDescription.Prediction": "Reveals the nearest player's role",
  "AdventurerWeaponDescription.Proxy": "Gives you +1 vote in the next meeting",
  "AdventurerWeaponDescription.RNG": "Makes a random weapon",
  "AdventurerWeaponDescription.Shield": "Gives someone a 1-time shield",
  "AdventurerWeaponDescription.Wrench": "Clears the current sabotage",
  "AdventurerWeaponEnabled.Gun": "Gun Enabled",
  "AdventurerWeaponEnabled.Lantern": "Lantern Enabled",
  "AdventurerWeaponEnabled.Portal": "Portal Enabled",
  "AdventurerWeaponEnabled.Prediction": "Prediction Enabled",
  "AdventurerWeaponEnabled.Proxy": "Proxy Enabled",
  "AdventurerWeaponEnabled.RNG": "RNG Enabled",
  "AdventurerWeaponEnabled.Shield": "Healthy Dose Enabled",
  "AdventurerWeaponEnabled.Wrench": "Wrench Enabled",
  "Akazukin": "Akazukin",
  "AkazukinInfo": "Survive your own murder until your killer is judged",
  "AkazukinInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Death is staged. Justice is what brings you back.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Pseudo-Death</color></b>\nWhen killed, you don't actually die. A body in your color is left at the scene, and you are whisked off the map — silenced, immobile, invisible to your killer's victory check. Your killer believes the deed is done.\n・<b><color=#8cffff>Justice's Return</color></b>\nIf your killer is voted out, slain, or leaves the game, you return to where you fell. If the grace period expires before justice arrives, you truly die.\n\n<i>What is buried may yet rise.</i></size>",
  "Akazukin_RevivalGracePeriod": "Revival Grace Period",
  "Akazukin_DisplayDeathReasonInName": "Display Death Reason in Name",
  "Akazukin_CanReviveAfterMeeting": "Revive When Killer is Voted Out",
  "Akazukin_ReviveAtOriginalPosition": "Revive at the Place You Fell",
  "Akazukin_CannotVotePseudoDead": "You cannot vote while pseudo-dead. Await the judgement's return.",
  "Aid": "Aid",
  "AidInfo": "Protect players temporarily",
  "AidInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Mark a target, then vent to shield them before it's too late.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Protective Shield</color></b>\nUse your kill button to mark a target, then vent to activate their shield. The shield blocks direct attacks. Neither you nor your target will know if an attack was attempted.\n\n<i>Protection is most powerful when it goes unnoticed.</i></size>",
  "AidCD": "Shield Cooldown",
  "AidCounterSelf": "<#00ffa5>You're shielded for </color>{0}s",
  "AidCounterTarget": "{0} <#00ffa5>is shielded for </color>{1}s",
  "AidDur": "Shield Duration",
  "AidTargetKnowsAboutShield": "Targets Know They're Shielded",
  "Alchemist": "Alchemist",
  "AlchemistInfo": "Make potions by completing tasks",
  "AlchemistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Complete tasks to brew random potions with unique effects.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Potion Brewing</color></b>\nEach completed task creates a potion. 7 possible potions include: invisibility, speed boost, vision boost, shield, teleport, quick-fix sabotage, and a dangerous awkward potion. Vent or pet to drink the current potion.\n\n<i>Every task is an experiment. Some results are... unexpected.</i></size>",
  "AlchemistAbilityCooldown": "Ability Cooldown",
  "AlchemistGotInvisPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#01c834>Invisibility Potion</color>\\n<color=#e6d798>Description: </color>Turns you temporarily invisible\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistGotQFPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#3333ff>Quick Fix Potion</color>\\n<color=#e6d798>Description: </color>You can fix the next critical sabotage alone\\nActivates <color=#e6d798>automatically</color></size></color>",
  "AlchemistGotShieldPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#00ff97>Shield Potion</color>\\n<color=#e6d798>Description: </color>Grants a temporary shield\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistGotSightPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#eee5be>Sight Potion</color>\\n<color=#e6d798>Description: </color>Increases your vision temporarily\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistGotSpeedPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#ff8400>Speed Potion</color>\\n<color=#e6d798>Description: </color>Increases your speed temporarily\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistGotSuicidePotion": "<color=#ffffff><size=1.7><color=#ffff00>Awkward Potion</color>\\nLooks like you've mixed the wrong ingredients!\\n<color=#ff1919>Drinking this potion will kill you!</color>\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistGotTPPotion": "<color=#ffffff><size=1.7><color=#e6d798>Potion Name: </color><color=#42d1ff>Teleport Potion</color>\\n<color=#e6d798>Description: </color>Teleports you to a random player\\nActivate by <color=#e6d798>Venting/Petting</color></size></color>",
  "AlchemistHasSpeed": "Speed Potion active",
  "AlchemistHasVision": "Sight Potion active",
  "AlchemistInvisDur": "Invisibility Potion Duration",
  "AlchemistNoPotion": "You don't have any potions ready to drink",
  "AlchemistShieldDur": "Shield Potion Duration",
  "AlchemistShieldOut": "Shield Potion effect expired",
  "AlchemistShielded": "Shield Potion active",
  "AlchemistSpeed": "Speed During Speed Potion",
  "AlchemistSpeedDur": "Speed Potion Duration",
  "AlchemistSpeedOut": "Speed Potion effect expired",
  "AlchemistVentButtonText": "Drink",
  "AlchemistVision": "Vision During Sight Potion",
  "AlchemistVisionDur": "Sight Potion Duration",
  "AlchemistVisionOnLightsOut": "Vision During Lights Out During Sight Potion",
  "AlchemistVisionOut": "Vision Potion effect expired",
  "Altruist": "Altruist",
  "AltruistInfo": "Revive Dead Players",
  "AltruistInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Give your life so another may return to the living.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Revive</color></b>\nReport a dead body to revive that player instead. The revived player resumes playing as if they never died — but you die in their place. Vent or pet to switch between Revive and Report modes.\n\n<i>True courage is giving all you have for someone else.</i></size>",
  "Altruist.ReviveTargetCanReportTheirOwnBody": "Revived players can report their own dead body",
  "Altruist.ReviveTargetsKillerGetsAlert": "The killer of the revived player gets an alert about the revival",
  "Altruist.ReviveTargetsKillerGetsArrow": "The killer also gets an arrow towards the revived player",
  "Altruist.ReviveTime": "Revive Time",
  "AltruistKillerAlert": "<#ffff00><size=150%>A player you killed was revived by the <color=#300000>Altruist</color>!</size></color>",
  "AltruistReportMode": "Report",
  "AltruistReviveMode": "Revive",
  "AltruistSuffix": "<#00ffa5>Mode:</color> <b>{0}</b>",
  "AltruistSuffixRevive": "<#00ffa5>Target is revived in </color>{0}s",
  "Analyst": "Analyst",
  "AnalystInfo": "Analyze Players to Get Information",
  "AnalystInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Stand close and analyze a player to reveal their hidden statistics.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Analysis</color></b>\nUse your kill button on a target and stand near them for a few seconds. On success, you see how many kills they've made, how many times they've vented, and their role basis. Note: results depend on host settings, and these factors alone don't determine guilt.\n\n<i>The numbers never lie — but they don't tell the whole story either.</i></size>",
  "Ankylosaurus": "Ankylosaurus",
  "AnkylosaurusInfo": "You're an Ankylosaurus.... I guess",
  "AnkylosaurusInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Slow but unyielding — an armored dinosaur that cannot be guessed.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Dinosaur Armor</color></b>\nCannot be guessed. Slower movement and lower vision, but possesses multiple lives and is hard to kill.\n\n<i>Even a slow stride can carry you to survival.</i></size>",
  "Ankylosaurus.Lives": "Maximum Lives",
  "Ankylosaurus.Speed": "<#7fe44c>Ankylosaurus</color> Speed",
  "Astral": "Busker",
  "AstralInfo": "Become a Ghost Temporarily",
  "AstralInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Briefly become a ghost, then return to the world of the living.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Temporary Ghosting</color></b>\nVent or pet to become a ghost for a short time. After the duration ends, you automatically revive.\n\n<i>A traveler between the realms of life and death.</i></size>",
  "AstralSuffix": "<#ffff00>Revival in </color><#ffa500>{0}s</color>",
  "Autocrat": "Autocrat",
  "AutocratInfo": "TP nearest player to you by doing a task",
  "AutocratInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Completing tasks teleports the nearest player to your side.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Summon</color></b>\nEvery time you complete a task, the nearest player is teleported to your location.\n\n<i>Work done right brings everyone together.</i></size>",
  "Bane": "Bane",
  "BaneInfo": "Erase your killer's role",
  "BaneInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Whoever kills me shall lose their power.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Cursed Retribution</color></b>\nWhen killed, the murderer loses their role and reverts to a basic one. Impostors become regular Impostors; Neutrals become Amnesiac.\n\n<i>My death shall bring about their undoing.</i></size>",
  "Battery": "Battery",
  "BatteryInfo": "Prevent Lights Sabotages",
  "BatteryInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Prevent lights sabotages just by being alive with ability uses.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Power Reserve</color></b>\nAs long as you have at least 1 ability use when lights are sabotaged, the sabotage is instantly fixed.\n\n<i>Some heroes power up from behind the scenes.</i></size>",
  "BatteryNotify": "<#ffa500>The lights sabotage cannot be called\\nbecause there's a {0} alive</color>",
  "Beacon": "Beacon",
  "BeaconInfo": "Increase Nearby Players' Vision During Lights",
  "BeaconInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>A beacon of light for those around you during sabotage.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Vision Boost</color></b>\nDuring the lights sabotage, nearby players gain improved vision while close to you.\n\n<i>Stay close to the light.</i></size>",
  "BeaconVisionIncrease": "Increased Vision for Affected Players During Lights Sabotage",
  "Benefactor": "Benefactor",
  "BenefactorInfo": "Mark Tasks as a Source of a Shield",
  "BenefactorInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Mark tasks to shield whoever completes them.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Task Marking</color></b>\nComplete a task to mark it. The next player to complete that marked task receives a temporary shield.\n\n<i>Hard work pays off — in more ways than one.</i></size>",
  "BenefactorTargetGotShieldNotify": "You got a temporary shield as the task\\nyou completed was marked by the Benefactor!",
  "BenefactorTaskMarked": "Task marked",
  "TaskMarkPerRound": "Maximum Number of Tasks Marked Each Round",
  "Bestower": "Bestower",
  "BestowerInfo": "Give Ability Uses",
  "BestowerInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Grant your allies extra ability uses when they need it most.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Ability Grant</color></b>\nUse your kill button on a player to give them additional ability uses.\n\n<i>Generosity is a power of its own.</i></size>",
  "Bestower.GivenUses": "Given Uses (to other players)",
  "Bodyguard": "Bodyguard",
  "BodyguardInfo": "Prevent nearby kills",
  "BodyguardInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Become a shield so that your allies may live.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Self-Sacrifice</color></b>\nWhen a nearby player is about to be killed, sacrifice yourself to prevent it. Depending on settings, you may also kill the murderer in return.\n\n<i>As long as there is someone to protect, I will not fall.</i></size>",
  "BodyguardKillsKiller": "Bodyguard kills murderer",
  "BodyguardProtectRadius": "Protect Radius",
  "BodyguardProtected": "The Bodyguard protected your target and died for them",
  "CameraMan": "Camera Man",
  "CameraManInfo": "View Cameras anytime",
  "CameraManInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Vent to access security cameras from anywhere on the map.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Remote Surveillance</color></b>\nVent or pet to instantly teleport to the security room and access the camera feed.\n\n<i>Eyes everywhere.</i></size>",
  "Captain": "Captain",
  "CaptainInfo": "Track Players' Movements",
  "CaptainInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Always know who's nearby — and track your vote target's movements.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Presence Detection</color></b>\nSee the names of every player in the same room as you at all times.\n\n・<b><color=#8cffff>Movement Tracking</color></b>\nYour vote target is tracked. The next meeting reveals every room they visited that round, in order.\n\n<i>A good captain always knows where their crew has been.</i></size>",
  "Captain.Suffix": "<size=80%>Players in the same room as you:\\n{0}</size>",
  "Captain.TargetInfo": "{0} entered the following rooms this round, in this order:\\n{1}",
  "Car": "Car",
  "CarInfo": "Drive around the map",
  "CarInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>You are a car. This role has no purpose. Just have fun.\n_____________________________________\nDifficulty: ★☆☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Propulsion</color></b>\nEveryone sees you as a car. When you drive into someone, they are launched far in the direction you were moving.\n\n<i>Vroom.</i></size>",
  "Car.PropelDistance": "Propel Distance",
  "Carrier": "Carrier",
  "CarrierInfo": "Carry Players to Locations",
  "CarrierInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Mark a location, then teleport an ally there on command.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Quick Transport</color></b>\nPet to mark your current location. Then use your shapeshift menu to teleport another player to that marked spot.\n\n<i>Right place, right time.</i></size>",
  "Carrier.TargetNotify": "You were carried to a new location!",
  "Catcher": "Catcher",
  "CatcherInfo": "Catch Players' Roles",
  "CatcherInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Place traps to record roles of anyone who walks through them.\n_____________________________________\nDifficulty: ★★★☆☆\n\n[Skills]\n・<b><color=#8cffff>Trap Placement</color></b>\nVent or pet to place traps. Anyone who walks over a trap has their role recorded. At the next meeting, receive a list of all roles caught — but not who has which role. Multiple traps can be placed.\n\n<i>The trap was set long before anyone suspected.</i></size>",
  "Catcher.CatchRange": "Trap Catch Range",
  "Catcher.CaughtRoles": "Roles caught in your traps:\\n",
  "Catcher.MinPlayersTrappedToShowInfo": "Minimum Number of Players Trapped to Show Info",
  "Catcher.NotEnoughCaughtRoles": "Not enough players have stepped on your traps to show the roles.",
  "Catcher.Suffix": "<#00ffa5>Placing trap in</color> {0}s",
  "Catcher.TrapPlaceDelay": "Trap Placement Delay (after venting) (if not using pets)",
  "Catcher.TrapPlaced": "Trap placed",
  "Chameleon": "Chameleon",
  "ChameleonInfo": "Vent/Pet to disguise into your surroundings",
  "ChameleonInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Blend into your surroundings and become untouchable.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Disguise</color></b>\nVent to turn invisible. While invisible, no one can interact with you. Vent again to reveal yourself.\n\n<i>The best defense is not being seen at all.</i></size>",
  "ChameleonCanVent": "Vent to disguise",
  "ChameleonCooldown": "Disguise Cooldown",
  "ChameleonDisguise": "Disguise",
  "ChameleonDuration": "Disguise Duration",
  "ChameleonInvisCooldownRemain": "<color=#00ffa5>Cooldown:</color> <b>{0}</b>s",
  "ChameleonInvisInCooldown": "Ability still on cooldown, disguise failed",
  "ChameleonInvisState": "You are disguising!",
  "ChameleonInvisStateCountdown": "<color=#00ffa5>Invisibility expires in</color> <b>{0}</b>s",
  "ChameleonInvisStateOut": "Your disguise ended",
  "ChameleonRevertDisguise": "Expose",
  "Chef": "Chef",
  "ChefInfo": "Cook Delicious Meals for Everyone",
  "ChefInfoLong": "(<#8cffff>Crewmates</color>):\n<size=80%>Cook meals that help your allies — and hurt your enemies.\n_____________________________________\nDifficulty: ★★☆☆☆\n\n[Skills]\n・<b><color=#8cffff>Meal Delivery</color></b>\nCompleting tasks creates a meal delivered to a nearby player. Crewmates receive a random boost (speed, vision, or shield). Impostors and neutral killers receive a rotten meal — they must vent or kill within the time limit or become frozen and blind.\n\n<i>The secret ingredient is chaos.</i></size>",
  "Chef.ET.NearestPlayer": "Nearest Player",
  "Chef.ET.RandomPlayer": "Random Player",
  "Chef.EventTarget": "Effect Applies to",
  "Chef.RottenTime": "Time to Spit Out Rotten Food",
  "Chef.SpitOutTime": "Frozen & Blind Time",
  "ChefBoost.Shield": "a shield",
  "ChefBoost.Speed": "increased speed",
  "ChefBoost.TP": "a visit to this player",
  "ChefBoost.TPToVent": "a visit to this vent",
  "ChefBoost.Vision": "increased vision",
  "ChefBoostSuffix": "<#00ffa5>You have </color>{0}<#00ffa5> for </color><b>{1}</b>s",
