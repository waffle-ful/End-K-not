  "BedWars.ReviveTimeOption": "Revive Time",
  "Bedwars.Rooms": "Teams are located in the following rooms:",
  "Bedwars.Shop.ItemShop": "ITEM SHOP",
  "Bedwars.Shop.ItemShopSuffix.CategorySelection": "<#00ffa5><u>{0}</u></color>\\n<size=80%>{1}</size>\\n\\n<size=80%>Select the category that has the item you want to buy.</size>\\n<size=70%>Use the Vanish button to cycle through the categories.\\nPet to enter the category.</size>",
  "Bedwars.Shop.ItemShopSuffix.ItemSelection": "<u>{0}</u> {1}\\n<size=80%>{2}</size>\\n<u>Cost:</u> {3}\\n\\n<size=80%>Select the item you want to buy.</size>\\n<size=70%>Use the Vanish button to cycle through the items.\\nPet to buy the selected item.</size>",
